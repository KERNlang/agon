{
  "schemaVersion": 3,
  "id": "aider",
  "displayName": "Aider (AI Pair Programming)",
  "binary": "aider",
  "searchPaths": [
    "${HOME}/.local/bin",
    "${HOME}/.pyenv/shims",
    "/usr/local/bin",
    "/opt/homebrew/bin"
  ],
  "versionCmd": ["--version"],
  "isLocal": false,
  "tier": "builtin",
  "installHint": "pip install aider-chat",
  "timeout": 300,

  "exec": {
    "args": ["--yes", "--no-git", "--message", "{prompt}"]
  },
  "agent": {
    "args": ["--yes", "--auto-commits", "--message", "{prompt}"]
  },

  "model": {
    "configKey": "aider_model",
    "flag": "--model"
  },

  "test": { "args": ["--version"] }
}
