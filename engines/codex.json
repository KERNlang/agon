{
  "schemaVersion": 3,
  "id": "codex",
  "displayName": "Codex (OpenAI)",
  "binary": "codex",
  "searchPaths": [
    "${HOME}/.local/bin",
    "${HOME}/.npm-global/bin",
    "/usr/local/bin"
  ],
  "versionCmd": ["--version"],
  "isLocal": false,
  "tier": "builtin",
  "installHint": "npm install -g @openai/codex",
  "timeout": 120,

  "exec": {
    "args": ["exec", "{prompt}"]
  },
  "review": {
    "args": ["review", "{prompt}"]
  },
  "agent": {
    "args": ["exec", "--dangerously-bypass-approvals-and-sandbox", "--skip-git-repo-check", "{prompt}"]
  },

  "model": {
    "configKey": "codex_model",
    "flag": "--model",
    "default": "gpt-5.3-codex"
  },

  "api": {
    "baseUrl": "https://api.openai.com/v1",
    "apiKeyEnv": "OPENAI_API_KEY",
    "model": "gpt-5.3-codex",
    "maxTokens": 4096
  },

  "env": {
    "OPENAI_API_KEY": { "required": false }
  },

  "companion": {
    "protocol": "jsonrpc",
    "serverCmd": ["app-server"],
    "sandbox": "danger-full-access",
    "features": {
      "threadResume": true,
      "nativeReview": true,
      "structuredOutput": true
    }
  },

  "test": { "args": ["--version"] },

  "cliModels": {
    "default": "gpt-5.3-codex",
    "list": [
      { "id": "gpt-5.3-codex", "name": "GPT-5.3 Codex" },
      { "id": "gpt-5.4", "name": "GPT-5.4" },
      { "id": "gpt-5.3-codex-spark", "name": "GPT-5.3 Codex Spark" }
    ]
  },

  "isolationHints": {
    "configEnv": "CODEX_HOME",
    "personalPaths": ["~/.codex"],
    "authFiles": ["auth.json"],
    "authMarker": "auth.json",
    "loginArgs": ["login"],
    "setupHint": "Clean codex dispatch needs codex signed in (so ~/.codex/auth.json exists). Run `agon login codex` or `codex login`.",
    "supportsProjectMcp": true
  }
}
