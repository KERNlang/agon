{
  "schemaVersion": 3,
  "id": "codex",
  "displayName": "Codex (OpenAI)",
  "binary": "codex",
  "searchPaths": [
    "${HOME}/.local/bin",
    "${HOME}/.npm-global/bin",
    "/usr/local/bin"
  ],
  "versionCmd": ["--version"],
  "isLocal": false,
  "tier": "builtin",
  "installHint": "npm install -g @openai/codex",
  "timeout": 120,

  "exec": {
    "args": ["exec", "{prompt}"]
  },
  "review": {
    "args": ["review", "{prompt}"]
  },
  "agent": {
    "args": ["exec", "--full-auto", "{prompt}"]
  },

  "model": {
    "configKey": "codex_model",
    "flag": "--model",
    "default": "gpt-5.3-codex"
  },

  "api": {
    "baseUrl": "https://api.openai.com/v1",
    "apiKeyEnv": "OPENAI_API_KEY",
    "model": "gpt-5.3-codex",
    "maxTokens": 4096
  },

  "env": {
    "OPENAI_API_KEY": { "required": false }
  },

  "companion": {
    "protocol": "jsonrpc",
    "serverCmd": ["app-server"],
    "sandbox": "danger-full-access",
    "features": {
      "threadResume": true,
      "nativeReview": true,
      "structuredOutput": true
    }
  },

  "test": { "args": ["--version"] },

  "cliModels": {
    "default": "gpt-5.3-codex",
    "list": [
      { "id": "gpt-5.3-codex", "name": "GPT-5.3 Codex" },
      { "id": "o3", "name": "o3" },
      { "id": "o4-mini", "name": "o4-mini" }
    ]
  }
}
