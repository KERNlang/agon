{
  "schemaVersion": 3,
  "id": "codex",
  "displayName": "Codex (OpenAI)",
  "binary": "codex",
  "searchPaths": [
    "${HOME}/.local/bin",
    "${HOME}/.npm-global/bin",
    "/usr/local/bin"
  ],
  "versionCmd": ["--version"],
  "isLocal": false,
  "tier": "builtin",
  "installHint": "npm install -g @openai/codex",
  "timeout": 120,

  "exec": {
    "args": ["exec", "{prompt}"]
  },
  "review": {
    "args": ["exec", "review", "{prompt}"]
  },
  "agent": {
    "args": ["exec", "--full-auto", "{prompt}"]
  },

  "model": {
    "configKey": "codex_model",
    "flag": "-c",
    "default": null
  },

  "api": {
    "baseUrl": "https://api.openai.com/v1",
    "apiKeyEnv": "OPENAI_API_KEY",
    "model": "o3-mini",
    "maxTokens": 4096
  },

  "env": {
    "OPENAI_API_KEY": { "required": false }
  },

  "companion": {
    "protocol": "jsonrpc",
    "serverCmd": ["app-server"],
    "features": {
      "threadResume": true,
      "nativeReview": true,
      "structuredOutput": true
    }
  },

  "test": { "args": ["--version"] }
}
