{
  "schemaVersion": 3,
  "id": "gemini",
  "displayName": "Gemini (Google)",
  "binary": "gemini",
  "searchPaths": [
    "${HOME}/.local/bin",
    "${HOME}/.npm-global/bin",
    "/usr/local/bin"
  ],
  "versionCmd": ["--version"],
  "isLocal": false,
  "tier": "builtin",
  "installHint": "npm install -g @anthropic-ai/gemini-cli",
  "timeout": 120,

  "exec": {
    "args": ["-p", "{prompt}", "--approval-mode", "yolo"]
  },
  "review": {
    "args": ["-p", "{prompt}", "--approval-mode", "plan"]
  },
  "agent": {
    "args": ["-p", "{prompt}", "--approval-mode", "yolo"]
  },

  "model": {
    "configKey": "gemini_model",
    "flag": "--model"
  },

  "api": {
    "baseUrl": "https://generativelanguage.googleapis.com/v1beta/openai",
    "apiKeyEnv": "GOOGLE_API_KEY",
    "model": "gemini-2.5-flash",
    "maxTokens": 8192
  },

  "env": {
    "GOOGLE_API_KEY": { "required": false }
  },

  "companion": {
    "protocol": "acp",
    "serverCmd": ["--acp"],
    "features": {
      "threadResume": true,
      "nativeReview": false,
      "structuredOutput": true
    }
  },

  "test": { "args": ["--version"] },

  "capabilities": ["vision"],
  "imageFlag": "--image"
}
