// Example: drive the pty-backed Claude TUI from a .kern source file.
//
// This file is NOT compiled by the normal `npm run kern:compile` because
// kern_engines/ is a polyglot helper directory, not a kern-source package.
// To compile it manually:
//
//     KERN_BIN=/abs/path/to/kern kern compile \
//       kern_engines/examples/use-claude-cli.kern \
//       --target=node --out kern_engines/examples/generated/
//
// Two import styles are shown. The TS path works today. The pypi path is
// aspirational — KERN does not yet support the `extern-pypi:` scheme.

// ── working today: import the TS twin ────────────────────────────────────
import from="@agon/kern-engines/cli/claude.js" names="ClaudeCliSession,ClaudeSessionError" types=true
import from="@agon/kern-engines/cli/claude.js" names="ClaudeCliSession" runtime=true

// KERN-GAP: imports — no `extern-pypi:` scheme. We want to write
//     import from="extern-pypi:kern_engines.cli.claude" names="ClaudeCliSession"
// and have the compiler emit either a Python target directly or a TS bridge
// that spawns `python3 -m kern_engines.cli.claude` and proxies stdin/stdout.
// Today, the only realistic path is the TS twin above; the Python twin in
// kern_engines/cli/claude.py has to be invoked from outside .kern, e.g.
// from a Python entrypoint or a TS shell-out helper.

interface name=AskOptions
  field name=prompt type=string
  field name=timeoutMs type=number optional=true

fn name=askClaudeOnce params="opts:AskOptions" returns="Promise<string>" async=true
  doc "One-shot helper: spawn a pty-backed Claude session, ask once, close. For multi-turn workflows prefer holding the session and calling .ask() repeatedly."
  handler <<<
    const session = await ClaudeCliSession.spawn();
    try {
      return await session.ask(opts.prompt, opts.timeoutMs ?? 60_000);
    } finally {
      await session.close();
    }
  >>>

fn name=demoConversation returns="Promise<string[]>" async=true
  doc "Walk through a short Claude conversation. Demonstrates session reuse — the same pty child handles all three turns, so context carries between them just like a human typing into the TUI."
  handler <<<
    const session = await ClaudeCliSession.spawn();
    const turns: string[] = [];
    try {
      turns.push(await session.ask("In one sentence, what does pty.fork() do?"));
      turns.push(await session.ask("And what role does pyte play in screen scraping it?"));
      turns.push(await session.ask("Summarise your two prior answers in 10 words."));
      return turns;
    } finally {
      await session.close();
    }
  >>>
