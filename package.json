{
  "name": "agon-ai",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/core",
    "packages/forge",
    "packages/adapter-cli",
    "packages/cli",
    "packages/mcp"
  ],
  "scripts": {
    "kern:compile": "npm run kern:compile -w packages/core && npm run kern:compile -w packages/forge && npm run kern:compile -w packages/adapter-cli && npm run kern:compile -w packages/cli && npm run kern:compile -w packages/mcp",
    "build": "tsc -b --force",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@kernlang/cli": "file:../kern-lang/packages/cli",
    "zod": "^4.3.6"
  }
}
