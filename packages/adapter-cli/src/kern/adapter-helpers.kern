import from="@kernlang/agon-core" names="EngineDefinition,EngineMode,EngineModeConfig,ImageAttachment,EngineIsolationPlan" types=true
import from="@kernlang/agon-core" names="EngineNotFoundError,loadConfig,engineHealth,classifyDispatchFailure,resolveIsolationMode,planEngineIsolation,agonPath"
import from="node:fs" names="statSync,mkdirSync,existsSync,copyFileSync,chmodSync,unlinkSync"
import from="node:path" names="join,dirname,basename"
import from="node:os" names="homedir"

fn name=recordDispatchHealth params="engineId:string, result:{exitCode?:number,stderr?:string,timedOut?:boolean}" returns=void
  doc "Centralized engine-health recording for any dispatch return point. exitCode 0 + not timed out → mark ok (clears prior quarantine). Otherwise classify and quarantine only on auth-failed/unreachable — timeouts and generic failures stay in rotation since they may be transient."
  handler lang="kern"
    let name=exitCode value="result.exitCode ?? 0"
    if cond="exitCode === 0 && !result.timedOut"
      do value="engineHealth.mark(engineId, 'ok', '')"
      return
    let name=status value="classifyDispatchFailure({ stderr: result.stderr, exitCode, timedOut: result.timedOut })"
    if cond="status === 'auth-failed' || status === 'unreachable'"
      do value="engineHealth.mark(engineId, status, (result.stderr || '').split('\\n')[0])"

fn name=stampDispatchDepth params="env?:Record<string,string>" returns="Record<string,string>" export=false
  doc "Merge the recursion-guard depth marker onto a dispatch env. Applied at EVERY computeEngineIsolation return (inherit / clean-dir fallback / isolate) so a dispatched engine is always marked. The spawn merges the result over process.env, so inherit mode still inherits the full environment — just plus AGON_DISPATCH_DEPTH. A child that tries to run agon sees depth>0 and the entrypoint guard refuses (no process fan-out)."
  handler <<<
    const depth = (parseInt(process.env.AGON_DISPATCH_DEPTH ?? '0', 10) || 0) + 1;
    return Object.assign({}, env ?? {}, { AGON_DISPATCH_DEPTH: String(depth) });
  >>>

fn name=computeEngineIsolation params="engine:EngineDefinition, opts:{isolation?:string, cwd?:string}" returns="{env?:Record<string,string>, argsExtra:string[], plan:EngineIsolationPlan}"
  doc "Resolve + materialise workspace-pure isolation for ONE dispatch. Mode = per-dispatch option > AGON_ENGINE_ISOLATION env > config.engineIsolation > default workspace-pure. For an engine with a configEnv hint, points it at a STABLE clean per-engine config dir (~/.agon/pure/<id>, bounded on disk) seeded with ONLY the engine's auth file(s) — so the user's ~/.claude personal layer (global CLAUDE.md, plugins, hooks, user MCP) is dropped while dispatch stays AUTHENTICATED. If the clean dir / auth copy can't be set up, FALL BACK to inherit (return no env) rather than risk a broken-auth dispatch. Returns env OVERRIDES (the spawn merges them onto process.env) + extra CLI args. API-only / inherit / hint-less engines return no env and [] (already pure / opted out)."
  handler <<<
    const cfg = loadConfig(opts.cwd) as { engineIsolation?: string };
    const mode = resolveIsolationMode({
      option: opts.isolation,
      env: process.env.AGON_ENGINE_ISOLATION,
      config: cfg.engineIsolation,
    });
    const hints = engine.isolationHints;
    const inherit: { env?: Record<string, string>; argsExtra: string[]; plan: EngineIsolationPlan } = {
      env: stampDispatchDepth(undefined),
      argsExtra: [],
      plan: { isolate: false, mode, engineId: engine.id, setEnv: {}, argsExtra: [], strippedPersonal: false },
    };
    if (mode === 'inherit' || !hints?.configEnv) {
      // inherit, or API/flag-only engine — let planEngineIsolation decide argsExtra (no config dir to seed).
      const plan = planEngineIsolation(engine, mode, { cleanConfigDir: '' });
      return { env: stampDispatchDepth(plan.isolate && Object.keys(plan.setEnv).length > 0 ? plan.setEnv : undefined), argsExtra: plan.argsExtra, plan };
    }
    const cleanConfigDir = agonPath('pure', engine.id);
    try {
      mkdirSync(cleanConfigDir, { recursive: true, mode: 0o700 });
      try { chmodSync(cleanConfigDir, 0o700); } catch { /* best effort */ } // holds credentials (mode above narrows the creation window)
      // Seed FILE-based credentials (codex auth.json) from the engine's real
      // config home — personal config (CLAUDE.md/plugins/hooks/MCP) is NOT
      // copied. claude is KEYCHAIN-based: authFiles is empty (no copyable
      // credential), and the clean dir is authenticated by a one-time
      // `claude /login` instead (see isolationHints.setupHint).
      const realHome = process.env[hints.configEnv] || (hints.personalPaths?.[0] ?? '').replace(/^~(?=$|\/)/, homedir());
      for (const rel of hints.authFiles ?? []) {
        const src = join(realHome, rel);
        const dst = join(cleanConfigDir, rel);
        if (realHome && existsSync(src)) {
          mkdirSync(dirname(dst), { recursive: true });
          copyFileSync(src, dst);
          try { chmodSync(dst, 0o600); } catch { /* best effort */ } // owner-only credential
        } else if (existsSync(dst)) {
          // Source credential is gone (engine logged out / signed out) — drop the
          // stale copy so the authMarker check below reflects reality and we fall
          // back to inherit instead of dispatching with dead credentials.
          try { unlinkSync(dst); } catch { /* best effort */ }
        }
      }
    } catch {
      // Could not set up the clean dir / copy auth — do NOT risk an unauthenticated
      // or broken dispatch; fall back to inheriting the real config for this call.
      return inherit;
    }
    // Detection gate: isolate ONLY when the clean dir is actually authenticated
    // (its authMarker exists on disk) — for claude that means a one-time
    // `agon login claude` was done, for codex that the auth.json seed landed.
    // Absent ⇒ planEngineIsolation falls back to inherit (never breaks a
    // dispatch), carrying the setupHint. basename() keeps the lookup inside the
    // clean dir even if a marker were misconfigured with path separators; an
    // empty/whitespace marker is treated as "no marker" (assume authed) rather
    // than silently passing the gate via JS falsiness. (A stale marker from a
    // logged-out dir is a known false-positive: the dispatch then fails fast and
    // recordDispatchHealth quarantines on auth-failed — acceptable vs. spawning
    // an auth-status probe on every dispatch.)
    const marker = hints.authMarker?.trim();
    const authenticated = marker ? existsSync(join(cleanConfigDir, basename(marker))) : true;
    const plan = planEngineIsolation(engine, mode, { cleanConfigDir, authenticated });
    return { env: stampDispatchDepth(plan.isolate && Object.keys(plan.setEnv).length > 0 ? plan.setEnv : undefined), argsExtra: plan.argsExtra, plan };
  >>>

fn name=resolveArgs params="template:string[], vars:Record<string,string>" returns="string[]"
  handler lang="kern"
    return value="template.map((arg) => arg.replace(/\\{(\\w+)\\}/g, (_: string, key: string) => vars[key] ?? ''))"

fn name=resolveModel params="engine:EngineDefinition,cwd?:string" returns="string|null"
  handler <<<
    const modelConfig = engine.model;
    if (!modelConfig) return null;

    if (modelConfig.configKey) {
      const envVal = process.env[modelConfig.configKey.toUpperCase()];
      if (envVal) return envVal;
    }

    const configured = (loadConfig(cwd) as any).engineModels?.[engine.id];
    if (configured) return configured;

    return modelConfig.default ?? null;
  >>>

fn name=resolveEffort params="engine:EngineDefinition,cwd?:string" returns="string|null"
  doc "Resolve the reasoning-effort level for an engine: configured engineEfforts[id] override, else the effort block's default, else null. Only meaningful for engines with an effort block (claude/codex); agy bakes effort into its model tiers."
  handler <<<
    const effortConfig = engine.effort;
    if (!effortConfig) return null;
    const configured = (loadConfig(cwd) as any).engineEfforts?.[engine.id];
    if (configured && effortConfig.levels.includes(configured)) return configured;
    return effortConfig.default ?? null;
  >>>

fn name=resolveClaudePtyExtraArgs params="engine:EngineDefinition, cwd?:string" returns="string[]" export=true
  doc "Launch flags (model + reasoning effort) to forward to the claude pty exec so the interactive subscription path honors an agon /models pick, exactly like the --print fallback. Returns [] when nothing is explicitly configured → defers to claude's own config (resilient if a probe/flag changes)."
  handler <<<
    const out: string[] = [];
    const model = resolveModel(engine, cwd);
    if (model && engine.model?.flag) out.push(engine.model.flag, model);
    const effort = resolveEffort(engine, cwd);
    if (effort && engine.effort) {
      if (engine.effort.flag) out.push(engine.effort.flag, effort);
      else if (engine.effort.configKey) out.push('-c', `${engine.effort.configKey}=${effort}`);
    }
    return out;
  >>>

fn name=formatFileSize params="bytes:number" returns="string" export=false
  handler lang="kern"
    if cond="bytes < 1024"
      return value="`${bytes}B`"
    if cond="bytes < 1024 * 1024"
      return value="`${(bytes / 1024).toFixed(1)}KB`"
    return value="`${(bytes / (1024 * 1024)).toFixed(1)}MB`"

fn name=buildCommand params="engine:EngineDefinition, mode:EngineMode, prompt:string, cwd:string, timeout:number, binaryPath:string, images?:ImageAttachment[]" returns="{command:string, args:string[]}"
  handler <<<
    const modeConfig = mode === 'agent' ? engine.agent
      : mode === 'exec' ? engine.exec
      : engine.review;

    if (!modeConfig) {
      throw new EngineNotFoundError(
        engine.id,
        `Engine "${engine.id}" does not support mode "${mode}"`,
      );
    }

    const model = resolveModel(engine, cwd);

    let effectivePrompt = prompt;
    const hasImages = images && images.length > 0;
    const hasVision = hasImages && engine.capabilities?.includes('vision') && engine.imageFlag;

    // Non-vision engines: prepend image info as text
    if (hasImages && !hasVision) {
      const labels = images.map((img) => {
        try {
          const size = statSync(img.path).size;
          return `[Image: ${img.path} (${formatFileSize(size)})]`;
        } catch {
          return `[Image: ${img.path}]`;
        }
      });
      effectivePrompt = labels.join('\n') + '\n\nPlease read and analyze the image(s) above.\n\n' + prompt;
    }

    // agy (Antigravity) print mode is agentic by default: left to itself it writes
    // the answer to artifact FILES, asks clarifying questions, and runs many tool
    // rounds — which blows past the timeout and returns prose the caller can't parse.
    // For non-agent dispatch (exec/review → ask/brainstorm/tribunal/review) force a
    // single-pass, inline, plain-text answer. Agent mode is left agentic on purpose.
    if (engine.id === 'agy' && mode !== 'agent') {
      effectivePrompt =
        'OUTPUT RULES (important): Reply with your COMPLETE final answer as plain text in THIS response only. ' +
        'Do NOT create, write, edit, or reference any files or artifacts. ' +
        'Do NOT ask clarifying questions — make reasonable assumptions and proceed. ' +
        'Do NOT use slash commands or start an interactive session. ' +
        'Do all the work in a single pass and output the final result directly as text now.\n\n' +
        effectivePrompt;
    }

    const vars: Record<string, string> = {
      prompt: effectivePrompt,
      // Never let a {cwd} placeholder resolve to '' — engines that template it
      // (opencode's --dir) would get a broken empty flag. A dispatch always has
      // a real cwd; fall back to process.cwd() only as a last resort.
      cwd: cwd && cwd.trim() ? cwd : process.cwd(),
      timeout: String(timeout),
      model: model ?? '',
    };

    const args = resolveArgs(modeConfig.args, vars);

    if (model && engine.model?.flag) {
      const promptIdx = args.indexOf(effectivePrompt);
      if (promptIdx > 0 && ['-p', '--prompt'].includes(args[promptIdx - 1])) {
        args.splice(promptIdx - 1, 0, engine.model.flag, model);
      } else if (promptIdx >= 0) {
        args.splice(promptIdx, 0, engine.model.flag, model);
      } else {
        args.unshift(engine.model.flag, model);
      }
    }

    // Reasoning effort: claude → [--effort, level]; codex → [-c, key=level].
    // Inserted just before the prompt so it sits with the other leading flags.
    const effort = resolveEffort(engine, cwd);
    if (effort && engine.effort) {
      const effortArgs = engine.effort.flag
        ? [engine.effort.flag, effort]
        : engine.effort.configKey
          ? ['-c', `${engine.effort.configKey}=${effort}`]
          : [];
      if (effortArgs.length > 0) {
        const pIdx = args.indexOf(effectivePrompt);
        const at = pIdx >= 0 ? pIdx : args.length;
        args.splice(at, 0, ...effortArgs);
      }
    }

    // Vision engines: inject image flags before prompt
    if (hasVision) {
      const promptIdx = args.indexOf(effectivePrompt);
      const insertAt = promptIdx >= 0 ? promptIdx : args.length;
      const imageArgs: string[] = [];
      for (const img of images) {
        imageArgs.push(engine.imageFlag!, img.path);
      }
      args.splice(insertAt, 0, ...imageArgs);
    }

    return { command: binaryPath, args };
  >>>

fn name=supportsAgentMode params="engine:EngineDefinition" returns=boolean expr={{ return !!engine.agent; }}

fn name=resolveAgentArgs params="engine:EngineDefinition, permissionLevel:'full'|'plan'|'read-only'" returns="EngineModeConfig|null"
  handler <<<
    if (permissionLevel === 'read-only') return null;
    if (!engine.agent) return null;
    if (permissionLevel === 'full') return engine.agent;
    // plan mode: swap vendor-specific flags. agy has no --permission-mode (it
    // silently ignores unknown flags), so its only real restriction is --sandbox;
    // mapping the bypass flag to a Claude-only flag would leave agy unrestricted.
    const planArgs = engine.agent.args.map((arg: string) => {
      if (arg === '--dangerously-skip-permissions') return engine.id === 'agy' ? '--sandbox' : '--permission-mode=plan';
      if (arg === '--dangerously-bypass-approvals-and-sandbox') return '--sandbox=workspace-write';
      if (arg === 'yolo') return 'plan';
      return arg;
    });
    return { args: planArgs };
  >>>

fn name=stripStreamJson params="stdout:string" returns=string
  doc "Extract text content from Claude stream-json NDJSON output. Returns plain text with system/hook messages removed."
  handler <<<
    const lines = stdout.split('\n');
    const textParts: string[] = [];

    for (const line of lines) {
      const trimmed = line.trim();
      if (!trimmed) continue;
      try {
        const msg = JSON.parse(trimmed);
        // assistant message → extract text blocks
        if (msg.type === 'assistant' && msg.message?.content) {
          for (const block of msg.message.content) {
            if (block.type === 'text' && block.text) textParts.push(block.text);
          }
        }
        // result → extract result text
        else if (msg.type === 'result' && msg.result && !msg.is_error) {
          textParts.push(typeof msg.result === 'string' ? msg.result : JSON.stringify(msg.result));
        }
        // system, hook, etc. → skip
      } catch {
        // Not JSON — raw text from non-Claude engines, keep as-is
        textParts.push(trimmed);
      }
    }

    return textParts.join('\n');
  >>>

fn name=usesStreamJson params="engine:EngineDefinition" returns=boolean
  doc "Check if engine exec mode outputs stream-json NDJSON."
  handler lang="kern"
    let name=args value="engine.exec?.args ?? []"
    return value="args.includes('stream-json') || args.some((a: string) => a === '--output-format' && args[args.indexOf(a) + 1] === 'stream-json')"

fn name=shouldUseCompanionForAgent params="engine:EngineDefinition" returns=boolean export=true
  doc "Only Codex-style JSON-RPC app-server is reliable for one-shot forge agent dispatch. Claude stream-json and Gemini ACP are reliable as persistent Cesar sessions, but the one-shot companion wrapper can hang or return empty, so forge should use their direct non-interactive CLI agent commands."
  handler lang="kern"
    return value="engine.companion?.protocol === 'jsonrpc'"

fn name=checkEnvVars params="engine:EngineDefinition" returns="string|null"
  handler <<<
    if (!engine.env) return null;
    for (const [envVar, config] of Object.entries(engine.env)) {
      if (config.required && !process.env[envVar]) {
        return `Missing required environment variable: ${envVar}`;
      }
    }
    return null;
  >>>

fn name=shouldUseClaudePty params="engine:EngineDefinition" returns=boolean
  doc "Drive `claude` via the pty subscription path by default. Opt out with AGON_CLAUDE_PRINT=1 (uses `claude -p`, currently free under subscription, but Anthropic is changing this in June — keep as fallback only)."
  handler lang="kern"
    if cond="engine.id !== 'claude'"
      return value="false"
    let name=optOut value="process.env.AGON_CLAUDE_PRINT"
    if cond="optOut === '1' || optOut === 'true'"
      return value="false"
    return value="true"

fn name=composeClaudePtyPrompt params="prompt:string, systemPrompt?:string" returns="string"
  doc "When a caller passed a systemPrompt, prepend it to the prompt with the same [System Instructions]/[User Message] framing the legacy non-flag CLI path uses. Claude's TUI has no --system-prompt equivalent we can apply through stdin, so this is the honest way to keep forge/tribunal/brainstorm system instructions intact on the pty path."
  handler <<<
    if (!systemPrompt) return prompt;
    return `[System Instructions]\n${systemPrompt}\n\n[User Message]\n${prompt}`;
  >>>

fn name=runClaudePtyDispatch params="prompt:string, timeoutSec:number, signal?:AbortSignal, mode?:'exec'|'agent', cwd?:string, systemPrompt?:string, env?:Record<string,string>, extraArgv?:string[]" returns="Promise<{exitCode:number,stdout:string,stderr:string,durationMs:number,timedOut:boolean,unavailable?:boolean}>" async=true
  doc "Drive interactive `claude` under a pty so the subscription billing path is used. Lazy-imports @kernlang/agon-engines — runs a python3 daemon (kern_engines.cli.daemon) over stdio JSON-RPC, no native node deps. cwd is plumbed through so worktree dispatches land in the right repo; systemPrompt is prepended to the prompt; extraArgv (model/effort launch flags) is forwarded to the engine exec. Never throws — returns unavailable:true on any unexpected failure so kern callers can fall through to legacy paths with a simple !result.unavailable check."
  handler <<<
    const start = Date.now();
    try {
      let mod: any;
      try {
        mod = await import('@kernlang/agon-engines/cli/claude.js' as any);
      } catch (e) {
        return {
          exitCode: 1,
          stdout: '',
          stderr: `pty path unavailable: ${e instanceof Error ? e.message : String(e)}`,
          durationMs: Date.now() - start,
          timedOut: false,
          unavailable: true,
        };
      }

      let session: any;
      try {
        session = await mod.ClaudeCliSession.spawn({
          mode: mode ?? 'exec',
          cwd: cwd,
          env: env,
          extraArgv: extraArgv,
        });
      } catch (e) {
        return {
          exitCode: 1,
          stdout: '',
          stderr: `pty path spawn failed: ${e instanceof Error ? e.message : String(e)}`,
          durationMs: Date.now() - start,
          timedOut: false,
          unavailable: true,
        };
      }

      const onAbort = () => { session.close().catch(() => undefined); };
      if (signal) {
        if (signal.aborted) {
          await session.close().catch(() => undefined);
          return { exitCode: 130, stdout: '', stderr: 'aborted', durationMs: Date.now() - start, timedOut: false };
        }
        signal.addEventListener('abort', onAbort, { once: true });
      }

      try {
        const composed = composeClaudePtyPrompt(prompt, systemPrompt);
        const text = await session.ask(composed, timeoutSec * 1000);
        return {
          exitCode: 0,
          stdout: text,
          stderr: '',
          durationMs: Date.now() - start,
          timedOut: false,
        };
      } catch (e: any) {
        const isTimeout = e?.kind === 'timeout' || e?.name === 'ClaudeSessionTimeout';
        return {
          exitCode: isTimeout ? 124 : 1,
          stdout: '',
          stderr: e instanceof Error ? e.message : String(e),
          durationMs: Date.now() - start,
          timedOut: isTimeout,
        };
      } finally {
        if (signal) signal.removeEventListener('abort', onAbort);
        await session.close().catch(() => undefined);
      }
    } catch (e: any) {
      // Last-ditch: any unforeseen error becomes unavailable so the KERN
      // caller's `!result.unavailable` fall-through still works.
      return {
        exitCode: 1,
        stdout: '',
        stderr: `pty path internal error: ${e instanceof Error ? e.message : String(e)}`,
        durationMs: Date.now() - start,
        timedOut: false,
        unavailable: true,
      };
    }
  >>>

fn name=runClaudePtyStreamDispatch params="prompt:string, timeoutSec:number, signal?:AbortSignal, mode?:'exec'|'agent', cwd?:string, systemPrompt?:string, env?:Record<string,string>, extraArgv?:string[]" returns="AsyncGenerator<string, {exitCode:number,stdout:string,stderr:string,durationMs:number,timedOut:boolean,unavailable?:boolean}, void>" async=true stream=true
  doc "Streaming variant of runClaudePtyDispatch — yields response deltas as they arrive, returns the final DispatchResult. extraArgv (model/effort launch flags) is forwarded to the engine exec. Never throws — any unforeseen error returns unavailable:true via the generator's return value, so kern callers can fall through to legacy paths."
  handler <<<
    const start = Date.now();
    let session: any;
    try {
      let mod: any;
      try {
        mod = await import('@kernlang/agon-engines/cli/claude.js' as any);
      } catch (e) {
        return {
          exitCode: 1,
          stdout: '',
          stderr: `pty path unavailable: ${e instanceof Error ? e.message : String(e)}`,
          durationMs: Date.now() - start,
          timedOut: false,
          unavailable: true,
        };
      }

      try {
        session = await mod.ClaudeCliSession.spawn({
          mode: mode ?? 'exec',
          cwd: cwd,
          env: env,
          extraArgv: extraArgv,
        });
      } catch (e) {
        return {
          exitCode: 1,
          stdout: '',
          stderr: `pty path spawn failed: ${e instanceof Error ? e.message : String(e)}`,
          durationMs: Date.now() - start,
          timedOut: false,
          unavailable: true,
        };
      }

      const onAbort = () => { session.close().catch(() => undefined); };
      if (signal) {
        if (signal.aborted) {
          await session.close().catch(() => undefined);
          return { exitCode: 130, stdout: '', stderr: 'aborted', durationMs: Date.now() - start, timedOut: false };
        }
        signal.addEventListener('abort', onAbort, { once: true });
      }

      const collected: string[] = [];
      try {
        const composed = composeClaudePtyPrompt(prompt, systemPrompt);
        const gen = session.askStream(composed, timeoutSec * 1000);
        while (true) {
          const next = await gen.next();
          if (next.done) {
            const text = typeof next.value === 'string' && next.value
              ? next.value
              : collected.join('');
            return {
              exitCode: 0,
              stdout: text,
              stderr: '',
              durationMs: Date.now() - start,
              timedOut: false,
            };
          }
          collected.push(next.value);
          yield next.value;
        }
      } catch (e: any) {
        const isTimeout = e?.kind === 'timeout' || e?.name === 'ClaudeSessionTimeout';
        return {
          exitCode: isTimeout ? 124 : 1,
          stdout: collected.join(''),
          stderr: e instanceof Error ? e.message : String(e),
          durationMs: Date.now() - start,
          timedOut: isTimeout,
        };
      } finally {
        if (signal) signal.removeEventListener('abort', onAbort);
        await session.close().catch(() => undefined);
      }
    } catch (e: any) {
      // Outer guard for anything the inner blocks miss.
      try { if (session) await session.close(); } catch { /* ignore */ }
      return {
        exitCode: 1,
        stdout: '',
        stderr: `pty path internal error: ${e instanceof Error ? e.message : String(e)}`,
        durationMs: Date.now() - start,
        timedOut: false,
        unavailable: true,
      };
    }
  >>>
