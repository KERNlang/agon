{
  "name": "@agon/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "agon": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prebuild": "npm run kern:compile",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "kern:compile": "node ../../scripts/run-kern-compile.mjs src/kern/ src/generated/ --target=auto --recursive"
  },
  "dependencies": {
    "@agon/kern-engines": "^0.1.0",
    "@agon/dedup": "^0.1.0",
    "@ai-sdk/anthropic": "^3.0.67",
    "@ai-sdk/openai-compatible": "^2.0.40",
    "@kernlang/protocol": "~3.5.6",
    "@kernlang/terminal": "~3.5.6",
    "ai": "^6.0.149",
    "citty": "^0.1.6",
    "ink": "^7.0.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "pidusage": "^4.0.1",
    "react": "^19.2.0"
  },
  "devDependencies": {
    "@types/pidusage": "^2.0.5",
    "@types/react": "^19.2.0"
  }
}
