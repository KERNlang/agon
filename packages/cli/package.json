{
  "name": "@agon/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "agon": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "npm run kern:compile",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "kern:compile": "node ../../scripts/run-kern-compile.mjs src/kern/ src/generated/ --target=auto --recursive"
  },
  "dependencies": {
    "@agon/adapter-cli": "*",
    "@agon/core": "*",
    "@agon/forge": "*",
    "@kernlang/terminal": "~3.2.3",
    "citty": "^0.1.6",
    "ink": "^5.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0"
  }
}
