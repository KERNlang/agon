{
  "name": "@kernlang/agon",
  "version": "0.1.1",
  "type": "module",
  "description": "The competitive multi-AI orchestration CLI. Engines compete in isolated git worktrees on the same task, the best test-passing solution is applied, and Glicko-2 ratings track each model over time. Modes: forge, brainstorm, synthesis, tribunal, council, campfire, think, nero, goal, conquer.",
  "keywords": [
    "ai",
    "cli",
    "llm",
    "orchestration",
    "multi-agent",
    "agent",
    "claude",
    "codex",
    "gemini",
    "code-generation",
    "forge",
    "tribunal",
    "synthesis",
    "council",
    "conquer",
    "agon",
    "kernlang"
  ],
  "homepage": "https://github.com/KERNlang/agon#readme",
  "bugs": {
    "url": "https://github.com/KERNlang/agon/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KERNlang/agon.git",
    "directory": "packages/cli"
  },
  "author": "KERNlang",
  "license": "MIT",
  "bin": {
    "agon": "./dist/index.js"
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prebuild": "npm run kern:compile",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "kern:compile": "node ../../scripts/run-kern-compile.mjs src/kern/ src/generated/ --target=auto --recursive"
  },
  "dependencies": {
    "@kernlang/agon-engines": "^0.1.1",
    "@kernlang/agon-dedup": "^0.1.1",
    "@ai-sdk/anthropic": "^3.0.67",
    "@ai-sdk/openai-compatible": "^2.0.40",
    "@kernlang/protocol": "~3.5.7",
    "@kernlang/terminal": "~3.5.7",
    "ai": "^6.0.149",
    "citty": "^0.1.6",
    "ink": "^7.0.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "pidusage": "^4.0.1",
    "react": "^19.2.0"
  },
  "devDependencies": {
    "@types/pidusage": "^2.0.5",
    "@types/react": "^19.2.0"
  }
}
