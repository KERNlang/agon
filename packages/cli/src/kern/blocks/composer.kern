// ── Composer View — memoized text-input subtree ────────────────────
// Extracted from app.kern so that streaming-driven App re-renders
// (~30x/sec via throttle=33 streamingText) don't reach the TextInput.
// React.memo's shallow-equal rejects the re-render entirely because none
// of these props depend on streamingText / liveSpinner / liveProgress /
// cesarConfidence — the composer subtree stays still while Cesar streams.
//
// Keep this screen narrow: only props that legitimately change between
// keystrokes/mode toggles. If you add a streaming-derived prop here, the
// memo will start firing on every chunk and the lag returns.

import from="react" default="React"
import from="ink" names="Box,Text"
import from="../../generated/blocks/prompt-input.js" names="PromptTextInput"
import from="../../generated/blocks/controls.js" names="SlashPicker,AtFilePicker"
import from="../signals/icons.js" names="icons"
import from="../../ghost-text.js" names="getGhostCompletion"
import from="./markdown.js" names="truncateCodeLine"

// Plain keys the main composer must DEFER (not insert) while the update banner
// is showing, so `u`/`l`/`x` trigger the banner action instead of typing into
// the box. Module-level so the reference is stable and PromptTextInput's
// React.memo never re-renders just because we passed a fresh array.
const name=UPDATE_BANNER_KEYS type="string[]" value={{ ['u', 'l', 'x'] }}

screen name=ComposerView target=ink memo=true
  prop name=mode type="'chat'|'campfire'|'brainstorm'|'tribunal'"
  prop name=replState type=string
  prop name=planModeQueued type=boolean
  prop name=autoModeQueued type=boolean
  prop name=activePlanState type="string|null"
  prop name=slashPickerOpen type=boolean
  prop name=atPickerOpen type=boolean
  prop name=atPickerFiles type="string[]"
  prop name=atPickerPrefix type=string
  prop name=atPickerQuery type=string
  prop name=onAtSelect type="(path:string) => void"
  prop name=onAtCancel type="(typed:string) => void"
  prop name=inputValue type=string
  prop name=handleInputChange type="(value:string) => void"
  prop name=handlePasteInput type="(raw:string) => string"
  prop name=handleSubmit type="(value:string) => void"
  prop name=allSlashCommands type="any[]"
  prop name=availableEngines type="string[]"
  prop name=onSlashSelect type="(cmd:string) => void"
  prop name=onSlashCancel type="() => void"
  prop name=questionState type=any
  prop name=questionAnswer type=string
  prop name=selectedChoiceIndex type=number
  prop name=questionOtherActive type=boolean
  prop name=onQuestionAnswerChange type="(value:string) => void"
  prop name=onQuestionAnswerSubmit type="(value:string) => void"
  prop name=onCtrlShortcut type="(shortcut:string) => void"
  prop name=updateBannerActive type=boolean
  prop name=termWidth type=number
  prop name=termHeight type=number
  render
    handler <<<
      const placeholder = replState === 'idle'
        ? (mode === 'chat'
            ? ''
            : mode === 'campfire'
              ? 'What should we think about?'
              : mode === 'brainstorm'
                ? 'What question for the engines?'
                : 'What should they debate?')
        : '';
      const ghost = getGhostCompletion(inputValue, allSlashCommands, availableEngines);
      const promptWidth = Math.max(12, termWidth - (mode === 'chat' ? 10 : 22));
      const promptMaxLines = Math.max(3, Math.min(8, Math.floor(termHeight / 4)));
      const choiceList = Array.isArray(questionState?.choices)
        ? questionState.choices as {key:string,label:string,color?:string}[]
        : [];
      const questionPrompt = typeof questionState?.prompt === 'string'
        ? questionState.prompt.trim()
        : questionState?.prompt;
      const isPermissionQuestion = questionState?.kind === 'permission';
      const permissionTool = typeof questionState?.tool === 'string'
        ? questionState.tool
        : 'Command';
      const permissionCommand = typeof questionState?.command === 'string'
        ? questionState.command
        : '';
      const permissionDescription = typeof questionState?.description === 'string'
        ? questionState.description.trim()
        : '';
      const permissionReason = typeof questionState?.reason === 'string'
        ? questionState.reason.trim()
        : '';
      const permissionLinesAll = permissionCommand ? permissionCommand.split('\n') : [];
      const permissionLineWidth = Math.max(24, termWidth - 24);
      const permissionPreview = permissionLinesAll[0]
        ? truncateCodeLine(permissionLinesAll[0], permissionLineWidth)
        : '';
      const permissionHasMoreLines = permissionLinesAll.length > 1;
      const permissionNeedsDetail = permissionHasMoreLines || permissionCommand.length > permissionLineWidth;
      const permissionSummary = permissionReason || permissionDescription;
      // File-mutating tools (AgonEdit/AgonWrite/Edit/Write) carry a unified diff
      // computed at approval time. Render it with the same shape/idiom as the
      // post-execution cesar recap (engine.kern diffPreview.files): per-file
      // header (path, +N/-M), colored +/- lines, truncation marker. When the
      // file is binary/too large the helper returns a fallbackNote instead and
      // we keep the truncated command preview.
      const permissionDiffFiles = Array.isArray(questionState?.diffPreview?.files)
        ? questionState.diffPreview.files as any[]
        : [];
      const permissionFallbackNote = typeof questionState?.fallbackNote === 'string'
        ? questionState.fallbackNote.trim()
        : '';
      const permissionHasDiff = permissionDiffFiles.length > 0;
      const questionAccent = choiceList.length > 0 ? '#60a5fa' : '#d1d5db';
      // Claude-Code-style select: a cursor (selectedChoiceIndex) highlights one
      // row; arrows move it, Enter confirms. Clamp defensively in case the menu
      // changed under a stale index.
      const selIdx = Math.min(Math.max(0, selectedChoiceIndex ?? 0), Math.max(0, choiceList.length - 1));
      const renderChoiceRow = (c: any, i: number, accent: string) => {
        const active = i === selIdx;
        // Structured-ask options ([ASK] marker) carry a one-line trade-off
        // description; render it dim under the label so the menu reads like a
        // Claude-Code AskUserQuestion. Plain choices (no description) keep the
        // original single-row shape.
        const desc = typeof c.description === 'string' ? c.description.trim() : '';
        return (
          <Box key={`choice-${i}`} flexDirection="column">
            <Text>
              <Text color={active ? (c.color ?? accent) : '#6b7280'} bold={active}>{active ? '❯ ' : '  '}{i + 1}{'. '}{c.label}</Text>
            </Text>
            {desc ? (
              <Text dimColor>{'     '}{truncateCodeLine(desc, Math.max(24, termWidth - 12))}</Text>
            ) : null}
          </Box>
        );
      };
      return (
        <>
          {slashPickerOpen && <SlashPicker commands={allSlashCommands} onSelect={onSlashSelect} onCancel={onSlashCancel} />}
          {atPickerOpen && <AtFilePicker files={atPickerFiles} prefix={atPickerPrefix} initialQuery={atPickerQuery} onSelect={onAtSelect} onCancel={onAtCancel} />}
          {!questionState && (
            <Box borderStyle={mode === 'chat' ? 'round' : 'single'} borderColor={mode === 'chat' ? '#585858' : 'gray'} borderLeft={mode !== 'chat'} borderRight={mode !== 'chat'} borderTop borderBottom paddingX={1} width="100%">
              {mode !== 'chat' && (<Text><Text color={mode === 'campfire' ? '#f97316' : mode === 'brainstorm' ? '#22d3ee' : '#a78bfa'} bold>{mode === 'campfire' ? icons().campfire : mode === 'brainstorm' ? icons().brainstorm : icons().tribunal}{' '}{mode}</Text><Text dimColor>{' \u2502 '}</Text></Text>)}
              <Text color={mode === 'chat' ? (planModeQueued || autoModeQueued || activePlanState === 'planning' ? '#c084fc' : '#585858') : '#fbbf24'}>{mode === 'chat' ? (planModeQueued ? '\u25c8 ' : autoModeQueued ? '\u25b6 ' : '> ') : icons().prompt + ' '}</Text>
              <Box flexGrow={1}>
                {slashPickerOpen ? (
                  <Text dimColor>{inputValue || '/'}</Text>
                ) : atPickerOpen ? (
                  <Text dimColor>{atPickerPrefix}{'@'}</Text>
                ) : (
                  <PromptTextInput
                    value={inputValue}
                    onChange={handleInputChange}
                    onPaste={handlePasteInput}
                    onSubmit={handleSubmit}
                    onCtrlShortcut={onCtrlShortcut}
                    reservedPlainKeys={updateBannerActive ? UPDATE_BANNER_KEYS : undefined}
                    placeholder={placeholder}
                    focus={true}
                    showCursor={true}
                    highlightPastedText={true}
                    ghostText={ghost ?? undefined}
                    width={promptWidth}
                    maxVisibleLines={promptMaxLines} />
                )}
              </Box>
            </Box>
          )}
          {questionState && (
            isPermissionQuestion ? (
              <Box flexDirection="column" width="100%" marginTop={1}>
                <Box borderStyle="round" borderColor="#fbbf24" paddingX={1} flexDirection="column" width="100%">
                  <Text bold color="#fbbf24">{icons().warning}{' '}{permissionTool}{' approval required'}</Text>
                  <Box flexDirection="column" paddingLeft={1}>
                    {choiceList.map((c: any, i: number) => {
                      const active = i === selIdx;
                      // The active "tell Cesar instead" row becomes an inline editor.
                      if (questionOtherActive && active && c.key === '__other') {
                        return (
                          <Box key={`perm-${i}`}>
                            <Text color="#fbbf24" bold>{'❯ '}{i + 1}{'. '}{c.label}{': '}</Text>
                            <Box flexGrow={1}>
                              <PromptTextInput
                                value={questionAnswer}
                                onChange={onQuestionAnswerChange}
                                onPaste={undefined}
                                onSubmit={onQuestionAnswerSubmit}
                                onCtrlShortcut={onCtrlShortcut}
                                reservedPlainKeys={undefined}
                                placeholder="type your instruction, Enter to send"
                                focus={true}
                                showCursor={true}
                                highlightPastedText={true}
                                ghostText={undefined}
                                width={Math.max(12, termWidth - 24)}
                                maxVisibleLines={Math.max(2, Math.min(4, promptMaxLines))} />
                            </Box>
                          </Box>
                        );
                      }
                      return renderChoiceRow(c, i, '#fbbf24');
                    })}
                  </Box>
                  {permissionHasDiff ? (
                    permissionDiffFiles.slice(0, 4).map((file: any, index: number) => (
                      <Box key={`perm-diff-${index}`} flexDirection="column">
                        <Text>
                          <Text color="#22d3ee">{'  Δ '}{file.relPath ?? file.path}</Text>
                          {file.status === 'created' ? <Text color="#4ade80">{' (new file)'}</Text> : null}
                          <Text dimColor>{' +'}{Number(file.additions ?? 0)}{' -'}{Number(file.deletions ?? 0)}</Text>
                        </Text>
                        {(Array.isArray(file.lines) ? file.lines : []).map((line: string, lineIndex: number) => (
                          <Text key={`perm-diff-line-${index}-${lineIndex}`} color={line.startsWith('+') ? '#4ade80' : line.startsWith('-') ? '#ef4444' : '#fbbf24'} dimColor={line.startsWith('@@')}>
                            {'    '}{truncateCodeLine(line, Math.max(24, termWidth - 10))}
                          </Text>
                        ))}
                        {Number(file.omitted ?? 0) > 0 ? <Text dimColor>{'    … +'}{Number(file.omitted)}{' more lines'}</Text> : null}
                      </Box>
                    ))
                  ) : permissionPreview ? (
                    <Text dimColor>{'  $ '}{permissionPreview}{permissionHasMoreLines ? ' …' : ''}{permissionFallbackNote ? ` · ${permissionFallbackNote}` : ''}</Text>
                  ) : questionPrompt ? (
                    <Text dimColor>{'  '}{questionPrompt}</Text>
                  ) : null}
                  {permissionSummary ? <Text dimColor>{'  '}{truncateCodeLine(permissionSummary, Math.max(24, termWidth - 10))}</Text> : null}
                  <Text dimColor>{questionOtherActive ? '  Esc returns to options' : '  press a number, or ↑↓ + Enter · Esc denies'}</Text>
                </Box>
              </Box>
            ) : (
              <Box flexDirection="column" width="100%" marginTop={1}>
                <Box borderStyle="round" borderColor={choiceList.length > 0 ? questionAccent : '#585858'} paddingX={1} flexDirection="column" width="100%">
                  <Text bold color={questionAccent}>{choiceList.length > 0 ? '? ' : ' '}{questionPrompt}</Text>
                  {choiceList.length > 0 ? (
                    <Box flexDirection="column" paddingLeft={1}>
                      {choiceList.map((c: any, i: number) => {
                        const active = i === selIdx;
                        // The active "Other" row becomes an inline text field.
                        if (questionOtherActive && active && c.key === '__other') {
                          return (
                            <Box key={`choice-${i}`}>
                              <Text color="#60a5fa" bold>{'❯ '}{i + 1}{'. '}{c.label}{': '}</Text>
                              <Box flexGrow={1}>
                                <PromptTextInput
                                  value={questionAnswer}
                                  onChange={onQuestionAnswerChange}
                                  onPaste={undefined}
                                  onSubmit={onQuestionAnswerSubmit}
                                  onCtrlShortcut={onCtrlShortcut}
                                  reservedPlainKeys={undefined}
                                  placeholder="type your answer, Enter to send"
                                  focus={true}
                                  showCursor={true}
                                  highlightPastedText={true}
                                  ghostText={undefined}
                                  width={Math.max(12, termWidth - 24)}
                                  maxVisibleLines={Math.max(2, Math.min(4, promptMaxLines))} />
                              </Box>
                            </Box>
                          );
                        }
                        return renderChoiceRow(c, i, questionAccent);
                      })}
                      <Text dimColor>{questionOtherActive ? '  Esc returns to options' : '  press a number, or ↑↓ + Enter · Esc cancel'}</Text>
                    </Box>
                  ) : (
                    <Box paddingLeft={1} width="100%">
                      <PromptTextInput
                        value={questionAnswer}
                        onChange={onQuestionAnswerChange}
                        onPaste={undefined}
                        onSubmit={onQuestionAnswerSubmit}
                        onCtrlShortcut={onCtrlShortcut}
                        reservedPlainKeys={undefined}
                        placeholder=""
                        focus={true}
                        showCursor={true}
                        highlightPastedText={true}
                        ghostText={undefined}
                        width={Math.max(12, termWidth - 10)}
                        maxVisibleLines={Math.max(2, Math.min(4, promptMaxLines))} />
                    </Box>
                  )}
                </Box>
              </Box>
            )
          )}
        </>
      );
    >>>
