import from="../lib/kern-host.js" names="hostEcmaRegex"

fn name=parseToolInputPayload params="input:string" returns=any
  handler lang="kern"
    let name=rawInput value="String(input ?? '')"
    let name=parsed type="Record<string, unknown>" kind=let value="{}"
    try
      if cond="rawInput.trim().startsWith('{')"
        assign target="parsed" value="JSON.parse(rawInput)"
      catch name=e
        assign target="parsed" value="{}"
    return value="{ rawInput, parsed }"

fn name=extractPatchText params="rawInput:string, parsed:any" returns=string
  handler lang="kern"
    let name=values value="[ parsed?.patch, parsed?.content, parsed?.diff, parsed?.input, ].filter((value: unknown): value is string => typeof value === 'string' && value.trim().length > 0)"
    let name=fromParsed value="values.find((value: string) => value.includes('*** Begin Patch') || value.includes('diff --git') || value.split('\\n').some((line: string) => line.startsWith('@@')))"
    if cond="fromParsed"
      return value="fromParsed"
    if cond="rawInput.includes('*** Begin Patch') || rawInput.includes('diff --git') || rawInput.split('\\n').some((line: string) => line.startsWith('@@'))"
      return value="rawInput"
    return value="values[0] ?? ''"

fn name=parsePatchPreview params="rawInput:string, parsed:any" returns="{ files:string[]; lines:string[]; additions:number; deletions:number }"
  handler <<<
    const patchText = extractPatchText(rawInput, parsed);
    const files: string[] = [];
    const lines: string[] = [];
    let additions = 0;
    let deletions = 0;
    const addFile = (filePath: string) => {
      const clean = filePath.trim().replace(/^["']|["']$/g, '');
      if (clean && !files.includes(clean)) files.push(clean);
    };

    for (const line of patchText.split('\n')) {
      const customFile = line.match(/^\*\*\* (?:Update|Add|Delete) File: (.+)$/);
      if (customFile) {
        addFile(customFile[1]);
        continue;
      }
      const diffFile = line.match(/^diff --git a\/(.+?) b\/(.+)$/);
      if (diffFile) {
        addFile(diffFile[2]);
        continue;
      }
      if (line.startsWith('+++ b/')) {
        addFile(line.slice('+++ b/'.length));
        continue;
      }
      if (line.startsWith('--- a/')) {
        addFile(line.slice('--- a/'.length));
        continue;
      }
      if (line.startsWith('@@')) {
        lines.push(line);
        continue;
      }
      if (line.startsWith('+') && !line.startsWith('+++')) {
        additions += 1;
        lines.push(line);
        continue;
      }
      if (line.startsWith('-') && !line.startsWith('---')) {
        deletions += 1;
        lines.push(line);
      }
    }

    return { files, lines, additions, deletions };
  >>>

fn name=formatDuration params="ms:number" returns=string export=true
  doc "Claude Code-style compact wall-clock duration for tool-call result lines. <1s → milliseconds ('420ms'), ≥1s → one-decimal seconds ('1.4s'), ≥~60s → minutes+whole seconds ('1m 12s'). The seconds branch cuts off at 59_950ms (not 60_000) so values that would round to '60.0s' instead roll to '1m 0s'. Negative/NaN inputs clamp to '0ms'. Used both per-tool (durationMs suffix) and in the ToolCallGroup aggregate so both render identically."
  handler <<<
    if (!Number.isFinite(ms) || ms < 0) return '0ms';
    if (ms < 1000) return `${Math.round(ms)}ms`;
    // Boundary: 59_950–59_999ms rounds to "60.0s" via toFixed(1); roll those into
    // the minutes branch so they render "1m 0s" instead.
    if (ms < 59_950) return `${(ms / 1000).toFixed(1)}s`;
    const totalSeconds = Math.round(ms / 1000);
    const minutes = Math.floor(totalSeconds / 60);
    const seconds = totalSeconds % 60;
    return `${minutes}m ${seconds}s`;
  >>>

fn name=extractSummary params="text:string, maxLen:number" returns=string
  handler lang="kern"
    let name=s kind=let value="text.replace(hostEcmaRegex('<think>[\\\\s\\\\S]*?<\\\\/think>\\\\s*', 'gi'), '')"
    assign target="s" value="s.replace(hostEcmaRegex('^#+\\\\s+.+\\\\n', 'gm'), '')"
    assign target="s" value="s.replace(hostEcmaRegex('^\\\\s*[-*]\\\\s+', 'gm'), '')"
    assign target="s" value="s.replace(/\\*\\*/g, '')"
    assign target="s" value="s.trim()"
    let name=firstSentence value="s.match(/^[^.!?\\n]{10,}[.!?]/)"
    let name=summary value="firstSentence ? firstSentence.full : s.slice(0, maxLen)"
    return value="summary.length > maxLen ? summary.slice(0, maxLen - 1) + '\\u2026' : summary"

fn name=stripReasoning params="text:string" returns=string export=true
  doc "Remove reasoning-scaffolding blocks (<think>/<thinking>/<reasoning>) that reasoning models (MiniMax, DeepSeek, Qwen) emit before their real answer and sometimes leak into persisted output. Strips CLOSED blocks only — the common leak case — using a backreference so the open and close tags must match. Engine-agnostic: apply wherever raw engine output is persisted or parsed so scaffolding never reaches users or a structured-findings parser."
  handler <<<
    return text.replace(/<(think|thinking|reasoning)>[\s\S]*?<\/\1>\s*/gi, '').trim();
  >>>

fn name=stripTuiChrome params="text:string" returns=string export=true
  doc "Strip claude TUI thinking-animation chrome that leaks into pty-captured output. The animation redraws on one line, so ANSI-stripping flattens its frames into a glyph/label/counter soup ('·✢✳✶✻✽…This one needs a moment…Working through it…95%…Review …'). Spinner glyph frames and the input-bar prompt char (❯) are NEVER legitimate content, so they're always removed. The …-terminated spinner labels (claude invents endless ones — 'Cogitating…', 'Untangling some thoughts…' — so enumerating them is hopeless) and the leading token/elapsed counter residue are removed ONLY when glyph frames were present, i.e. proof this is TUI chrome. That glyph-gate means API engines (kimi/zai — no TUI) never have real content touched."
  handler <<<
    const hadChrome = /[·✢✳✶✻✽⎿]/.test(text);
    let s = text.replace(/[·✢✳✴✵✶✷✸✹✺✻✼✽✾⎿]/g, '').replace(/❯/g, '');
    if (hadChrome) {
      s = s.replace(/[A-Z][^\n…]{0,40}…/g, '');
      s = s.replace(/^[\s\d%]+/, '');
    }
    return s.replace(/[ \t]{2,}/g, ' ').replace(/\n{3,}/g, '\n\n').trim();
  >>>
