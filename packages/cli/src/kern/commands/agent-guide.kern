// `agon agent-guide` — print a compact overview of how to call agon.
//
// The universal mechanism: any external engine (Codex, agy, Claude,
// OpenCode, anything with a shell) runs this once and immediately knows how
// to drive agon — no MCP, no always-on token cost. The per-CLI slash-command
// shims written by `agon install-agent-prompts` just point back here.

import from="citty" names="defineCommand"
import from="./agent-guide-text.js" names="agentGuideMarkdown,modeDocsMarkdown"

const name=agentGuideCommand type=any
  handler <<<
    defineCommand({
      meta: {
        name: 'agent-guide',
        description: 'Print how to call agon — a compact overview for any external engine (Codex, Antigravity, Claude, OpenCode)',
      },
      args: {
        json: {
          type: 'boolean',
          description: 'Emit the mode list as JSON instead of markdown.',
        },
        docs: {
          type: 'boolean',
          description: 'Emit the docs-corpus page (docs/modes.md content) — same guide with a generated-file banner, for RAG indexing.',
        },
      },
      run({ args }) {
        if (args.docs) {
          // modeDocsMarkdown is newline-terminated by construction — write verbatim
          // so `agon agent-guide --docs > docs/modes.md` matches the sync test exactly.
          process.stdout.write(modeDocsMarkdown());
          return;
        }
        if (args.json) {
          process.stdout.write(JSON.stringify({
            modes: [
              { name: 'forge', cmd: 'agon forge "<task>" -t "<test cmd>"', use: 'multiple valid approaches + a runnable test', setup: 'the -t test IS the spec: it must FAIL a plausibly-wrong impl and be RED-at-base. Red-team it with `agon nero` before launching.' },
              { name: 'synthesis', cmd: 'agon synthesis "<prompt>" [-s <swaps>] [-j <judge>]', use: 'one polished result blending the best ideas; no clean pass/fail test' },
              { name: 'brainstorm', cmd: 'agon brainstorm "<question>"', use: 'cheap second opinion / ideas' },
              { name: 'tribunal', cmd: 'agon tribunal "<question>" --mode adversarial', use: 'decisions with real tradeoffs' },
              { name: 'council', cmd: 'agon council "<decision>" [--roles "..."] [--chairman <id>]', use: 'high-stakes decision: ALL engines take distinct roles (Contrarian=top critic, Red-Team, First-Principles, ...), the top-rated engine chairs and returns ONE verdict with confidence + a kill-switch' },
              { name: 'campfire', cmd: 'agon campfire "<topic>"', use: 'open exploration, no winner' },
              { name: 'think', cmd: 'agon think "<problem>" --strategy reflexion [--steps N --branches N]', use: 'sequential thinking — decompose a problem (optionally branch) and surface open questions before acting' },
              { name: 'nero', cmd: 'agon nero "<decision>" --reasoning "<why>"', use: 'adversarial self-challenge — the top-rated critic attacks YOUR decision and returns a verdict. Use this instead of an internal evil-twin/devils-advocate pass' },
              { name: 'research', cmd: 'agon research "<question>" [--count N] [--engine <id>]', use: 'keyless web-grounded, CITED research — Agon discovers sources (npm/GitHub/MDN/IETF/Stack Overflow/Wikipedia, no API key), an engine drafts an answer grounded only in them, and Agon re-fetches and VERIFIES every citation. Use to look up a library/repo/spec/Q&A/fact with sources you can trust' },
              { name: 'chrome', cmd: 'agon call chrome "<task>" [--auto-approve] [--engine <id>]  (direct: agon chrome "<task>")', use: "drive the USER's own browser for research / checking a page design — reuses a running agon (serve/REPL) the side panel is attached to, else embeds a transient bridge for the run. Read-only page tools (navigate/read/screenshot) need no approval; --auto-approve lets a non-interactive caller perform page-changing actions (click/type). Requires the Agon browser extension with its side panel open" },
              { name: 'review', cmd: 'agon review uncommitted', use: 'multi-engine code review' },
              { name: 'goal', cmd: 'agon goal "<intent>" --queue <dir|.jsonl> --gate "<test cmd>"', use: 'autonomously drive a task queue to completion (build->review->fix->commit per task); long-running', setup: 'each task verify + --gate IS the spec: --dryRun, gate green at base, each slice RED-at-base for the right reason. Add --oracle-gate=warn|strict to have the panel try to GAME each verify before forging (strict refuses to launch if any verify is gameable) — the built-in oracle red-team.' },
              { name: 'conquer', cmd: 'agon conquer "<task>" --gate "<test cmd>"', use: 'supervised-autonomous BUILD of an OPEN-ENDED task: Cesar drives a pluggable builder CLI (codex/claude/agy) unattended; on a fork the builder asks and Cesar convenes the cheapest consult (nero/tribunal/brainstorm/council); on done a layered oracle runs and it STOPS at a human merge gate (never auto-merges). The open-ended sibling to goal — use it when you cannot write a clean discriminating oracle up front.', setup: 'the --gate command IS the done-oracle floor (L0). Runs in cwd; --push needs a clean tree at start.' },
            ],
            flags: ['--engines claude,codex,agy', '--timeout <sec>'],
            machineReadable: 'agon call <mode> "<input>" [flags] --jsonl',
            results: { lastDir: 'agon last', summary: 'cat "$(agon last)/summary.json"', status: 'agon last --status' },
            rooms: {
              about: 'Shared multi-party chat rooms — coordinate with other live CLIs/sessions over one persistent transcript (human-mediated: post when prompted).',
              join: 'agon room join <room> --as <callsign> --engine <codex|claude|agy>',
              post: 'agon room post <room> --as <callsign> -m "<message>"  (use @callsign to mention; positional message also works)',
              read: 'agon room read <room> [--since <seq>] [--json]',
              unread: 'agon room read <room> --unread --as <callsign> [--json] — only what you have not seen, then advances your read cursor (--peek to not advance). Run at the START of every turn so you never work a stale board.',
              tail: 'agon room tail <room> [--json]',
              who: 'agon room who <room> [--json] — presence + per-member unread/mention counts + the resource lock table',
              lock: 'agon room lock <room> -r <resource> --as <callsign> [--ttl <min>] — claim a file/branch/task before working it; --steal takes over an EXPIRED lock (audited, @mentions the stale holder)',
              release: 'agon room release <room> -r <resource> --as <callsign> — always release when done (posting with an expired lock warns you)',
              leave: 'agon room leave <room> --as <callsign>',
              auto: 'agon room auto <room> --as <callsign> --engine <id> [--open-floor] [--max-turns N] [--until-human] [--dry-run] — autonomous reply loop, safe by default (mention-only, ≤3 turns/10min, turn-lease, ping-pong halt)',
            },
          }, null, 2) + '\n');
          return;
        }
        process.stdout.write(agentGuideMarkdown() + '\n');
      },
    })
  >>>
