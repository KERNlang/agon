import from="citty" names="defineCommand"
import from="@kernlang/agon-core" names="EngineRegistry,ensureAgonHome,loadConfig,createRunDir,writeRunStatus,printRunSummary"
import from="@kernlang/agon-core" names="RunStatus,RunStatusEngine" types=true
import from="../lib/engines-dir.js" names="resolveBuiltinEnginesDir"
import from="@kernlang/agon-adapter-cli" names="createCliAdapter"
import from="../blocks/output-format.js" names="header,info,bold,dim"
import from="../handlers/engine-filter.js" names="filterDefaultOrchestrationEngines"

doc "Disambiguate the two optional positionals of `agon ask`. One positional => it IS the prompt and the engine defaults to the first active engine. Two positionals => the first is the engine id, the second (plus any unconsumed words) is the prompt. Returns error='no-prompt' when nothing to ask, 'no-engine' when no default engine is available. Pure + registry-free so it is unit-testable; the caller resolves engineId to a concrete engine."
fn name=resolveAskInputs export=true params="rawEngine:string|undefined, rawPrompt:string|undefined, extras:string[], activeEngines:string[]" returns="{ engineId: string; prompt: string; error: 'no-prompt' | 'no-engine' | null }"
  handler <<<
    const extra = (extras || []).filter(Boolean).join(' ').trim();
    if (rawPrompt === undefined || rawPrompt === null) {
      // Single positional: treat it as the prompt against the default engine.
      const prompt = [rawEngine ?? '', extra].filter(Boolean).join(' ').trim();
      const engineId = activeEngines[0] ?? '';
      if (!prompt) return { engineId, prompt: '', error: 'no-prompt' };
      if (!engineId) return { engineId: '', prompt, error: 'no-engine' };
      return { engineId, prompt, error: null };
    }
    // Two positionals: first is the engine, the rest is the prompt.
    const engineId = (rawEngine ?? '').trim();
    const prompt = [rawPrompt, extra].filter(Boolean).join(' ').trim();
    if (!prompt) return { engineId, prompt: '', error: 'no-prompt' };
    if (!engineId) return { engineId: '', prompt, error: 'no-engine' };
    return { engineId, prompt, error: null };
  >>>

const name=askCommand type=any
  handler <<<
    defineCommand({
      meta: {
        name: 'ask',
        description: 'Ask one engine a single question — fast raw answer, no competition. `agon ask codex "..."`, or `agon ask "..."` for the default engine.',
      },
      args: {
        engine: {
          type: 'positional',
          description: 'Engine id (codex, agy, claude, ...). Omit to use the default (first active) engine.',
          required: false,
        },
        prompt: {
          type: 'positional',
          description: 'The question. With one positional it IS the prompt; with two, the first is the engine.',
          required: false,
        },
        timeout: {
          type: 'string',
          description: 'Timeout in seconds',
          default: '120',
        },
        system: {
          type: 'string',
          description: 'Optional system prompt prepended to the call.',
        },
        quiet: {
          type: 'boolean',
          description: 'Print ONLY the engine answer on stdout (pipe-friendly) — no header, no run summary.',
        },
        label: {
          type: 'string',
          description: 'Human-readable suffix baked into the run dir name.',
        },
      },
      async run({ args }) {
        ensureAgonHome();
        const config = loadConfig(process.cwd());

        const registry = new EngineRegistry();
        registry.load(resolveBuiltinEnginesDir());
        const adapter = createCliAdapter(registry);

        // citty stows positionals beyond the named ones in `_`; fold them into the
        // prompt so an unquoted multi-word question still works.
        const extras = Array.isArray((args as any)._) ? (args as any)._.map(String) : [];
        const active = filterDefaultOrchestrationEngines(registry.activeIds(config as any));
        const resolved = resolveAskInputs(args.engine as any, args.prompt as any, extras, active);

        const quiet = !!args.quiet;
        if (resolved.error === 'no-prompt') {
          console.error('Provide a prompt. Usage: agon ask [engine] "your question"');
          process.exitCode = 1;
          return;
        }
        if (resolved.error === 'no-engine') {
          console.error('No active engines. Run `agon engine list` or `agon engine add <id>`.');
          process.exitCode = 1;
          return;
        }

        // Resolve to a concrete engine — throws EngineNotFoundError with an install hint.
        const engine = registry.get(resolved.engineId);
        const timeoutSec = parseInt(args.timeout, 10);

        const startedAt = new Date().toISOString();
        const { path: outputDir } = createRunDir({ mode: 'ask', label: args.label, announce: false });

        if (!quiet) {
          header(`Ask ${bold(engine.id)}`);
          info(resolved.prompt.length > 120 ? resolved.prompt.slice(0, 120) + '...' : resolved.prompt);
          console.log('');
        }

        const result = await adapter.dispatch({
          engine,
          prompt: resolved.prompt,
          cwd: process.cwd(),
          mode: 'exec',
          timeout: timeoutSec,
          outputDir,
          systemPrompt: args.system,
        });

        const answer = (result.stdout || '').trim();
        const ok = result.exitCode === 0 && !result.timedOut && answer.length > 0;

        const engineStatus: RunStatusEngine = {
          id: engine.id,
          status: ok ? 'ok' : result.timedOut ? 'timeout' : 'error',
          exitCode: result.exitCode,
          durationMs: result.durationMs,
          detail: result.timedOut ? `timed out after ${timeoutSec}s` : `exit=${result.exitCode}`,
        };
        const status: RunStatus = {
          mode: 'ask',
          label: args.label,
          startedAt,
          endedAt: new Date().toISOString(),
          engines: [engineStatus],
          summary: ok ? `${engine.id} answered` : `${engine.id} failed (${engineStatus.status})`,
          ok,
          requested: [engine.id],
          timeoutSec,
        };
        writeRunStatus(outputDir, status);

        if (!ok) {
          console.error(result.timedOut
            ? `${engine.id} timed out after ${timeoutSec}s`
            : `${engine.id} exited ${result.exitCode} with no answer`);
          if (result.stderr && result.stderr.trim()) {
            console.error(result.stderr.trim().slice(0, 500));
          }
          process.exitCode = 1;
          return;
        }

        // The answer. In quiet mode this is the ONLY thing on stdout (pipe-friendly).
        console.log(answer);

        if (!quiet) {
          console.log('');
          info(dim(`Saved: ${outputDir}`));
          printRunSummary(status);
        }
      },
    })
  >>>
