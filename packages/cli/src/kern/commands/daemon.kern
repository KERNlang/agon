// ── agon daemon — the long-lived session host (agond) ─────────────────────────
//
// Client/server split, Milestone 3 — the daemon itself, and the program's first
// real proof: a long-lived agon process that OWNS a session, keeps running when
// the launching terminal/TUI dies, and whose session a client (`agon attach
// --self <id>`) can reattach to.
//
//   agon daemon start [--foreground]   start the daemon (default: detached)
//   agon daemon status                 is it alive? + its session + attach hint
//   agon daemon stop                   ask it to exit cleanly (fallback SIGTERM)
//   agon daemon run --foreground       (internal) the actual server loop
//
// HOW SURVIVAL WORKS
//   `start` (default) re-spawns THIS binary as `daemon run --foreground` with
//   detached:true + stdio:'ignore' + unref(), so the child has its own process
//   group, no controlling terminal, and is not kept alive by — nor keeps alive —
//   the launcher. The launcher prints the session id and exits; the daemon lives
//   on. A pidfile + heartbeat + unix socket let a later client find and drive it.
//
// THE HEADLESS TURN (reused plumbing, not rebuilt)
//   A {type:'prompt'} request runs ONE single-engine turn via the SAME path
//   `agon ask` uses: adapter.dispatch({ engine: cesarEngine, mode:'exec', ... }).
//   Full Cesar orchestration is coupled to the Ink REPL's HandlerContext (chat
//   session, tool registry, approval callbacks) and is deliberately OUT of M3
//   scope — a configured-cesarEngine ask-style turn is the accepted M3 scope.
//   Every step of the turn is appended to the session ledger as an OutputEvent
//   (user-message → engine-block / error), so `agon attach --self <id>` replays
//   and FOLLOWS it live over the exact M1/M2 seam.
//
// SCOPE: no leases/approvals/multi-client; one turn at a time (busy otherwise);
// no client changes (attach already follows ledgers — that IS the read client).

import from="citty" names="defineCommand"
import from="node:fs" names="mkdirSync,writeFileSync,readFileSync,existsSync,rmSync,utimesSync,statSync,chmodSync"
import from="node:path" names="join,dirname,resolve"
import from="node:net" names="createServer,connect"
import from="node:net" names="Socket,Server" types=true
import from="node:child_process" names="spawn"
import from="@kernlang/agon-core" names="ensureAgonHome,loadConfig,agonPath,EngineRegistry,JobService,eventLogAppend,eventLogFlush,eventLogLatestSeq"
import from="@kernlang/agon-core" names="encodeDaemonRequest,encodeDaemonResponse,parseDaemonRequest,parseDaemonResponse,splitFrames"
import from="@kernlang/agon-core" names="DaemonRequest,DaemonResponse" types=true
import from="../lib/engines-dir.js" names="resolveBuiltinEnginesDir"
import from="../jobs/daemon-job-router.js" names="handleDaemonJobRequest,isDaemonJobRequest"
import from="../jobs/workflow-job.js" names="daemonJobConfig,resolveDaemonWorkflowJob"
import from="@kernlang/agon-adapter-cli" names="createCliAdapter"
import from="../blocks/output-format.js" names="header,info,success,warn,bold,dim,green,cyan,yellow,red"

// ── Daemon-home paths (resolved at call time so AGON_HOME overrides apply) ────

fn name=daemonDir returns="string" export=true expr={{ return agonPath('daemon'); }}
  doc "The $AGON_HOME/daemon/ directory that holds the pidfile, heartbeat, and socket. Resolved at call time (not a frozen const) so a test that sets AGON_HOME after module load points the daemon at its temp home."

fn name=pidFilePath returns="string" export=true expr={{ return join(daemonDir(), 'agond.pid'); }}
  doc "Path to the daemon pidfile ($AGON_HOME/daemon/agond.pid). Holds JSON { pid, sessionId, startedAt } so `status`/`stop` can find the process AND name its session without opening the socket."

fn name=heartbeatPath returns="string" export=true expr={{ return join(daemonDir(), 'heartbeat'); }}
  doc "Path to the heartbeat file ($AGON_HOME/daemon/heartbeat). The server touches its mtime every HEARTBEAT_MS; `status` reads the mtime age to decide liveness even if the socket is wedged."

fn name=socketPath returns="string" export=true expr={{ return join(daemonDir(), 'agond.sock'); }}
  doc "Path to the unix domain socket the daemon listens on ($AGON_HOME/daemon/agond.sock). Newline-JSON protocol (see daemon-protocol.kern). Cleaned on clean exit; a stale file from a crash is probed-then-removed on the next start/stop."

// ── Constants ─────────────────────────────────────────────────────────────

const name=HEARTBEAT_MS type=number value=2000 export=true
  doc "How often the running daemon touches the heartbeat file's mtime. 2s, matching the spec; the timer is unref'd so it never keeps the process alive past its real work."

const name=HEARTBEAT_STALE_MS type=number value=5000 export=true
  doc "A daemon whose heartbeat mtime is older than this is considered DEAD by `status` even if its pid still kill(0)-checks (e.g. hung). 5s = > 2 missed beats."

const name=PING_TIMEOUT_MS type=number value=1500 export=true
  doc "How long a client waits for a {type:'pong'} (or any reply) before declaring the socket unreachable. Bounds `status`/`stop`/stale-probe so a wedged socket never hangs the CLI."

// ── pidfile read/write ──────────────────────────────────────────────────────

interface name=DaemonPidInfo export=true
  doc "Contents of the pidfile: the daemon's OS pid, the session id it owns, and when it started (ISO). Read by status/stop; written once by the server loop on boot."
  field name=pid type=number
  field name=sessionId type=string
  field name=startedAt type=string

fn name=readPidFile returns="DaemonPidInfo | null" export=true
  doc "Parse the pidfile into { pid, sessionId, startedAt }, or null when it is absent/unreadable/malformed. Never throws — a corrupt pidfile reads as 'no daemon' so stale-takeover can clean it."
  handler <<<
    try {
      const raw = readFileSync(pidFilePath(), 'utf-8');
      const obj = JSON.parse(raw) as Partial<DaemonPidInfo>;
      if (typeof obj?.pid !== 'number' || !Number.isFinite(obj.pid)) return null;
      return {
        pid: obj.pid,
        sessionId: typeof obj.sessionId === 'string' ? obj.sessionId : '',
        startedAt: typeof obj.startedAt === 'string' ? obj.startedAt : '',
      };
    } catch {
      return null;
    }
  >>>

fn name=writePidFile params="info:DaemonPidInfo" returns="void" export=true
  doc "Write the pidfile atomically-ish (mkdir the daemon dir first, then writeFileSync — single small write is effectively atomic on POSIX). Best-effort: a write failure is logged, not thrown, so the daemon still runs (status degrades to socket-ping only)."
  handler <<<
    try {
      mkdirSync(daemonDir(), { recursive: true });
      writeFileSync(pidFilePath(), JSON.stringify(info, null, 2) + '\n');
    } catch (err) {
      console.warn(`[agond] could not write pidfile: ${err instanceof Error ? err.message : String(err)}`);
    }
  >>>

// ── Liveness probes ─────────────────────────────────────────────────────────

fn name=isProcessAlive params="pid:number" returns="boolean" export=true
  doc "True if a process with this pid exists and is signalable by us (kill(pid, 0) does not actually send a signal — it only checks existence/permission). EPERM means the process EXISTS but we can't signal it → still alive. ESRCH means it's gone. A non-finite/<=0 pid is dead."
  handler <<<
    if (!Number.isFinite(pid) || pid <= 0) return false;
    try {
      process.kill(pid, 0);
      return true;
    } catch (err) {
      // EPERM: the process exists but is owned by another user — alive.
      // ESRCH: no such process — dead.
      return (err as NodeJS.ErrnoException)?.code === 'EPERM';
    }
  >>>

fn name=heartbeatAgeMs returns="number" export=true
  doc "Milliseconds since the heartbeat file was last touched, or Infinity when it's absent/unreadable (treated as maximally stale). `status` compares this against HEARTBEAT_STALE_MS to catch a hung daemon whose pid still exists."
  handler <<<
    try {
      const st = statSync(heartbeatPath());
      return Date.now() - st.mtimeMs;
    } catch {
      return Infinity;
    }
  >>>

// ── Socket client — send one request, await one reply (or timeout) ───────────

fn name=sendDaemonRequest params="req:DaemonRequest, timeoutMs?:number" returns="Promise<DaemonResponse | null>" async=true export=true
  doc "Connect to the daemon socket, send ONE request, and resolve with the FIRST reply frame (or null if the socket is unreachable / no reply within timeoutMs). Pure transport: encodes via the protocol module, accumulates bytes with splitFrames, parses the first complete line. Used by status (ping), stop (shutdown), the stale-socket probe, and tests. Never throws — a refused/absent socket resolves null so callers branch on 'no live daemon'."
  handler <<<
    const timeout = typeof timeoutMs === 'number' && timeoutMs > 0 ? timeoutMs : PING_TIMEOUT_MS;
    return await new Promise<DaemonResponse | null>((resolve) => {
      let settled = false;
      let buffer = '';
      const finish = (val: DaemonResponse | null): void => {
        if (settled) return;
        settled = true;
        clearTimeout(timer);
        try { sock.destroy(); } catch { /* best-effort */ }
        resolve(val);
      };
      const timer = setTimeout(() => finish(null), timeout);
      if (typeof (timer as any).unref === 'function') (timer as any).unref();
      const sock: Socket = connect(socketPath(), () => {
        try { sock.write(encodeDaemonRequest(req)); } catch { finish(null); }
      });
      sock.setEncoding('utf-8');
      sock.on('data', (chunk: string) => {
        buffer += chunk;
        const { lines, rest } = splitFrames(buffer);
        buffer = rest;
        for (const line of lines) {
          const parsed = parseDaemonResponse(line);
          if (parsed) { finish(parsed); return; }
        }
      });
      sock.on('error', () => finish(null));
      sock.on('close', () => finish(null));
    });
  >>>

// ── Stale-takeover — is there a LIVE daemon, and clean up a dead one ──────────

interface name=DaemonLiveness export=true
  doc "What a start/status check learned about the current daemon. `live` true ⇒ a process is up AND answering; refuse to start over it. `hung` true ⇒ the pidfile pid is ALIVE but its socket does not answer (half-dead / mid-boot) — start must ALSO refuse here (NOT spawn a second daemon over a running pid), and tell the user to `stop` it. `staleCleaned` true ⇒ we found a dead pidfile/socket and removed it, so a fresh start is safe."
  field name=live type=boolean
  field name=hung type=boolean optional=true
  field name=pid type=number optional=true
  field name=sessionId type=string optional=true
  field name=staleCleaned type=boolean

fn name=probeDaemon returns="Promise<DaemonLiveness>" async=true export=true
  doc "Decide whether a live daemon owns this AGON_HOME. A daemon is LIVE only if its pidfile pid is process-alive AND a ping over the socket returns pong. If the pid is ALIVE but the socket does not answer, the daemon is HUNG (half-dead / mid-boot) — we report hung:true and DO NOT remove its pidfile or spawn over it (the spec's 'refuse when ALIVE'); only `stop` may tear a hung daemon down. If the pid is DEAD (crash), the leftover pidfile/socket are STALE — remove them and report staleCleaned so a caller can start fresh. A socket file with no listener pings null → stale → removed. This is the stale-takeover gate the spec requires."
  handler <<<
    const info = readPidFile();
    // No pidfile: maybe a leftover socket from a crash that never wrote one.
    if (!info) {
      if (existsSync(socketPath())) {
        const pong = await sendDaemonRequest({ type: 'ping' });
        if (pong && pong.type === 'pong') {
          return { live: true, sessionId: pong.sessionId, staleCleaned: false };
        }
        // Socket file with no live listener — stale, remove it.
        try { rmSync(socketPath(), { force: true }); } catch { /* best-effort */ }
        return { live: false, staleCleaned: true };
      }
      return { live: false, staleCleaned: false };
    }
    // Pidfile present: pid must be alive AND the socket must answer.
    const alive = isProcessAlive(info.pid);
    if (alive) {
      const pong = await sendDaemonRequest({ type: 'ping' });
      if (pong && pong.type === 'pong') {
        return { live: true, pid: info.pid, sessionId: pong.sessionId || info.sessionId, staleCleaned: false };
      }
      // Pid alive but socket dead — the daemon is HUNG (half-dead, or still
      // booting before listen()). We must NOT spawn a second daemon over a
      // running pid (review #1 blocking): leave its pidfile + socket untouched
      // and report hung so start refuses and points the user at `stop`. (A real
      // hang is rare; a transient mid-boot probe self-resolves on the next call.)
      return { live: false, hung: true, pid: info.pid, sessionId: info.sessionId, staleCleaned: false };
    }
    // Pid is dead — fully stale. Clean both pidfile and socket.
    try { rmSync(pidFilePath(), { force: true }); } catch { /* best-effort */ }
    try { if (existsSync(socketPath())) rmSync(socketPath(), { force: true }); } catch { /* best-effort */ }
    return { live: false, pid: info.pid, sessionId: info.sessionId, staleCleaned: true };
  >>>

// ── The headless turn — one single-engine ask, teed into the ledger ──────────

fn name=runHeadlessTurn params="sessionId:string, text:string, registry:EngineRegistry, cwd:string" returns="Promise<number>" async=true export=true
  doc "Run ONE headless single-engine turn for a prompt and append every step to the session ledger, returning the highest seq written (for the ack). The reused plumbing: a user-message event, then a single dispatch of the configured cesarEngine in 'exec' mode (the SAME call `agon ask` makes), then an engine-block (or error) event. AGON_DAEMON_ECHO=1 is a documented TEST SEAM — instead of dispatching a real engine (heavy/non-deterministic for an automated survival test) it echoes the prompt straight into the ledger as an engine-block, so the test can assert the event landed without a live engine. The ledger writes are flushed synchronously before returning so the ack's seq is durable and an attach client sees the turn immediately."
  handler <<<
    // 1) Record the user's prompt as a ledger event (mirrors the REPL tee shape).
    eventLogAppend(sessionId, { type: 'user-message', content: text }, { kind: 'daemon' });

    // TEST SEAM: AGON_DAEMON_ECHO=1 short-circuits the real engine dispatch.
    // The survival test sets this so it never depends on an installed engine —
    // the turn echoes the prompt into the ledger as an engine-block and acks.
    if (process.env.AGON_DAEMON_ECHO === '1') {
      const seq = eventLogAppend(
        sessionId,
        { type: 'engine-block', engineId: 'echo', content: `echo: ${text}` },
        { kind: 'daemon' },
      );
      eventLogFlush(sessionId);
      return seq;
    }

    // 2) Resolve the configured Cesar engine (the single engine that answers a
    //    headless turn). Fall back to forgeFixedStarter / 'claude' like the rest
    //    of the codebase. A missing/unknown engine becomes an error event, not a
    //    crash — the daemon must survive a bad turn.
    const config = loadConfig(cwd) as { cesarEngine?: string; forgeFixedStarter?: string };
    const engineId = config.cesarEngine || config.forgeFixedStarter || 'claude';
    let lastSeq = eventLogLatestSeq(sessionId);
    try {
      const engine = registry.get(engineId);
      const adapter = createCliAdapter(registry);
      const result = await adapter.dispatch({
        engine,
        prompt: text,
        cwd,
        mode: 'exec',
        timeout: 120,
        // The dispatch writes a per-engine output file under here; the run dir
        // doubles as scratch. The ledger — not this file — is the daemon's
        // durable transcript, so a throwaway dir under the daemon home is fine.
        outputDir: join(daemonDir(), 'turns'),
      });
      const answer = (result.stdout || '').trim();
      if (result.exitCode === 0 && !result.timedOut && answer.length > 0) {
        lastSeq = eventLogAppend(
          sessionId,
          { type: 'engine-block', engineId, content: answer },
          { kind: 'daemon' },
        );
      } else {
        lastSeq = eventLogAppend(
          sessionId,
          { type: 'error', message: result.timedOut ? `${engineId} timed out` : `${engineId} produced no answer (exit ${result.exitCode})` },
          { kind: 'daemon' },
        );
      }
    } catch (err) {
      lastSeq = eventLogAppend(
        sessionId,
        { type: 'error', message: `turn failed: ${err instanceof Error ? err.message : String(err)}` },
        { kind: 'daemon' },
      );
    }
    eventLogFlush(sessionId);
    return lastSeq;
  >>>

// ── The server loop — owns the session, heartbeats, serves the socket ────────

fn name=runDaemonServer returns="Promise<void>" async=true export=true
  doc "The actual daemon: create a session id (daemon-<ts>), seed its ledger meta, write the pidfile, start the unref'd heartbeat, and listen on the unix socket. Serves the newline-JSON protocol: {prompt} → run one headless turn (busy if one is already running) → ack(seq); {ping} → pong(sessionId, uptime); {shutdown} → bye then clean exit. On exit (shutdown / SIGTERM / SIGINT) it flushes the ledger, closes the server, and removes the socket + pidfile. Returns a promise that resolves only when the daemon shuts down — the foreground/detached child awaits it to stay alive."
  handler <<<
    ensureAgonHome();
    mkdirSync(daemonDir(), { recursive: true });
    try { chmodSync(daemonDir(), 0o700); }
    catch (err) { throw new Error(`Cannot secure daemon directory: ${err instanceof Error ? err.message : String(err)}`); }

    const startedAtMs = Date.now();
    const sessionId = `daemon-${startedAtMs}`;
    const cwd = process.cwd();
    const jobConfig = daemonJobConfig(cwd);
    const jobs = new JobService({
      eventLimit: jobConfig.jobEventLimit,
      retentionLimit: jobConfig.jobRetentionLimit,
      maxConcurrency: jobConfig.jobMaxConcurrency,
    });
    const jobResolver = { resolve: resolveDaemonWorkflowJob };

    const registry = new EngineRegistry();
    registry.load(resolveBuiltinEnginesDir());

    // Seed the session ledger with a meta + boot event so `agon attach --self`
    // sees a non-empty session immediately, and meta.kind === 'daemon'.
    eventLogAppend(sessionId, { type: 'info', message: `agond session started (pid ${process.pid})` }, { kind: 'daemon' });
    eventLogFlush(sessionId);

    writePidFile({ pid: process.pid, sessionId, startedAt: new Date(startedAtMs).toISOString() });

    // Heartbeat — touch the file's mtime every HEARTBEAT_MS. Create it first.
    try { writeFileSync(heartbeatPath(), ''); } catch { /* best-effort */ }
    const heartbeat = setInterval(() => {
      try { utimesSync(heartbeatPath(), new Date(), new Date()); }
      catch { try { writeFileSync(heartbeatPath(), ''); } catch { /* best-effort */ } }
    }, HEARTBEAT_MS);
    if (typeof (heartbeat as any).unref === 'function') (heartbeat as any).unref();

    // One turn at a time — a prompt arriving mid-turn gets {busy}. The check +
    // set both run in handleRequest's SYNCHRONOUS prologue (before the first
    // await), so even two prompt frames in one data chunk are mutually exclusive:
    // the second sees busy === true. (No await sits between the check and the set.)
    const turnState = { busy: false };

    // Track accepted client sockets so cleanup() can destroy them — an open
    // connection would otherwise keep the event loop alive after server.close(),
    // leaving an orphaned daemon (review: sockets-keep-process-alive).
    const openSockets = new Set<Socket>();

    return await new Promise<void>((resolve, reject) => {
      let shuttingDown = false;
      let cleanupPromise: Promise<void> | null = null;
      const cleanup = (failure?: Error): Promise<void> => {
        if (cleanupPromise) return cleanupPromise;
        shuttingDown = true;
        cleanupPromise = (async () => {
          jobs.cancelAll('daemon shutting down');
          const drained = await jobs.waitForIdle(jobConfig.jobShutdownTimeoutMs);
          if (!drained) console.warn(`[agond] job drain exceeded ${jobConfig.jobShutdownTimeoutMs}ms; completing shutdown`);
          try { clearInterval(heartbeat); } catch { /* best-effort */ }
          process.off('SIGTERM', onSignal);
          process.off('SIGINT', onSignal);
          try { eventLogFlush(sessionId); } catch { /* best-effort */ }
          try { server.close(); } catch { /* best-effort */ }
          for (const s of openSockets) { try { s.destroy(); } catch { /* best-effort */ } }
          openSockets.clear();
          try { rmSync(socketPath(), { force: true }); } catch { /* best-effort */ }
          try { rmSync(pidFilePath(), { force: true }); } catch { /* best-effort */ }
          if (failure) reject(failure); else resolve();
        })();
        return cleanupPromise;
      };

      const reply = (sock: Socket, msg: DaemonResponse): void => {
        try { sock.write(encodeDaemonResponse(msg)); } catch { /* peer gone */ }
      };

      const handleRequest = async (sock: Socket, req: DaemonRequest): Promise<void> => {
        if (isDaemonJobRequest(req)) {
          try {
            const response = handleDaemonJobRequest(req, jobs, jobResolver);
            if (response) reply(sock, response);
          } catch (err) {
            reply(sock, { type: 'error', message: err instanceof Error ? err.message : String(err) });
          }
          return;
        }
        switch (req.type) {
          case 'ping':
            reply(sock, { type: 'pong', sessionId, uptime: Date.now() - startedAtMs, capabilities: ['jobs-v1'] });
            return;
          case 'shutdown':
            reply(sock, { type: 'bye' });
            // Give the bye a tick to flush to the socket before we tear down.
            setTimeout(() => { void cleanup(); }, 10);
            return;
          case 'prompt': {
            if (turnState.busy) { reply(sock, { type: 'busy' }); return; }
            turnState.busy = true;
            try {
              const seq = await runHeadlessTurn(sessionId, req.text, registry, cwd);
              reply(sock, { type: 'ack', seq });
            } catch (err) {
              reply(sock, { type: 'error', message: err instanceof Error ? err.message : String(err) });
            } finally {
              turnState.busy = false;
            }
            return;
          }
          case 'error':
            reply(sock, { type: 'error', message: req.message });
            return;
          default:
            reply(sock, { type: 'error', message: 'unhandled request' });
        }
      };

      // A client must never grow the daemon's memory unbounded by streaming
      // bytes with no newline. The configured frame bound drops the connection.

      const server: Server = createServer((sock: Socket) => {
        sock.setEncoding('utf-8');
        openSockets.add(sock);
        let buffer = '';
        sock.on('data', (chunk: string) => {
          buffer += chunk;
          if (Buffer.byteLength(buffer, 'utf8') > jobConfig.daemonFrameMaxBytes) {
            // Oversized un-framed input — refuse and hang up rather than grow.
            try { sock.write(encodeDaemonResponse({ type: 'error', message: 'frame too large' })); } catch { /* best-effort */ }
            try { sock.destroy(); } catch { /* best-effort */ }
            return;
          }
          const { lines, rest } = splitFrames(buffer);
          buffer = rest;
          for (const line of lines) {
            const req = parseDaemonRequest(line);
            // .catch() so a rejection inside the async handler can never become
            // an unhandledRejection that crashes the daemon (review: void-promise).
            if (req) void handleRequest(sock, req).catch((err) => {
              try { reply(sock, { type: 'error', message: err instanceof Error ? err.message : String(err) }); } catch { /* best-effort */ }
            });
          }
        });
        sock.on('error', () => { /* a client hangup is not the daemon's problem */ });
        sock.on('close', () => { openSockets.delete(sock); });
      });

      server.on('error', (err: NodeJS.ErrnoException) => {
        // EADDRINUSE: the socket path exists. The caller (start) already
        // stale-probed; if we still hit it the file is racing — log and exit so
        // we don't run a daemon with no socket. cleanup() removes our own files.
        console.warn(`[agond] socket server error: ${err.message}`);
        void cleanup(err);
      });

      // Clean shutdown on the usual signals so a `kill` (stop's SIGTERM fallback)
      // still removes the socket + pidfile.
      const onSignal = (): void => { void cleanup(); };
      process.on('SIGTERM', onSignal);
      process.on('SIGINT', onSignal);

      try {
        server.listen(socketPath(), () => {
          // Jobs can mutate a workspace, so a socket permission failure is fatal.
          try { chmodSync(socketPath(), 0o600); }
          catch (err) {
            console.warn(`[agond] cannot secure socket: ${err instanceof Error ? err.message : String(err)}`);
            void cleanup(new Error(`Cannot secure daemon socket: ${err instanceof Error ? err.message : String(err)}`));
          }
        });
      } catch (err) {
        console.warn(`[agond] listen failed: ${err instanceof Error ? err.message : String(err)}`);
        void cleanup(err instanceof Error ? err : new Error(String(err)));
      }
    });
  >>>

// ── start — spawn the detached daemon (or run the loop in --foreground) ──────

fn name=startDaemon params="foreground:boolean" returns="Promise<void>" async=true export=true
  doc "Start the daemon. In --foreground (also the internal `daemon run` mode) this RUNS the server loop in THIS process (awaits runDaemonServer, never returns until shutdown). Otherwise it RE-SPAWNS this binary as `daemon run --foreground` with detached:true + stdio:'ignore' + unref(), so the child outlives this launcher and the terminal — then prints the session id + attach hint and returns. Refuses to start over a LIVE daemon (prints status); cleans a STALE pidfile/socket first (stale-takeover)."
  handler <<<
    ensureAgonHome();
    mkdirSync(daemonDir(), { recursive: true });

    if (foreground) {
      // We ARE the daemon. Run the server loop until shutdown.
      await runDaemonServer();
      return;
    }

    // Stale-takeover gate: refuse over a live OR hung daemon, clean a dead one.
    const probe = await probeDaemon();
    if (probe.live) {
      warn('A daemon is already running.');
      info(dim(`  pid ${probe.pid ?? '?'} · session ${probe.sessionId ?? '?'}`));
      info(dim('  Stop it with `agon daemon stop`, or attach with ' + (probe.sessionId ? `\`agon attach --self ${probe.sessionId}\`` : '`agon attach --self`')));
      return;
    }
    if (probe.hung) {
      // A pid is ALIVE but its socket doesn't answer (hung or still booting).
      // Refuse rather than spawn a SECOND daemon over a running pid (review #1
      // blocking): two daemons would race the same pidfile/heartbeat/socket.
      warn('A daemon process is alive but not answering its socket.');
      info(dim(`  pid ${probe.pid ?? '?'} · session ${probe.sessionId ?? '?'}`));
      info(dim('  If it is wedged, `agon daemon stop` will terminate it; then start again.'));
      return;
    }
    if (probe.staleCleaned) {
      info(dim('Cleaned up a stale daemon (pidfile/socket) before starting.'));
    }

    // Re-spawn THIS binary as the detached daemon. process.argv[1] is the CLI
    // entry (dist/index.js); execPath is the node binary. detached + stdio
    // 'ignore' + unref() = the child has its own session leader and is not tied
    // to our stdio or lifetime.
    const entry = process.argv[1] ? resolve(process.argv[1]) : '';
    if (!entry) throw new Error('Cannot start daemon: CLI entry path is unavailable');
    const child = spawn(process.execPath, [entry, 'daemon', 'run', '--foreground'], {
      detached: true,
      stdio: 'ignore',
      // Carry AGON_HOME explicitly so a test's temp home reaches the child even
      // if the inherited env somehow lost it; harmless in production.
      env: { ...process.env },
    });
    // Surface a spawn failure (bad execPath / ENOENT) instead of silently
    // swallowing it — otherwise the poll below just times out into a misleading
    // "has not reported a session yet" (review: no child error handler).
    const spawnErr: { msg: string | null } = { msg: null };
    child.on('error', (err: Error) => { spawnErr.msg = err.message; });
    child.unref();

    // Wait briefly for the daemon to write its pidfile so we can print the real
    // session id. Poll a few times rather than a fixed sleep so a fast daemon
    // prints instantly and a slow one still resolves.
    let info0: DaemonPidInfo | null = null;
    for (let i = 0; i < 40; i += 1) {
      if (spawnErr.msg) break;
      info0 = readPidFile();
      if (info0 && isProcessAlive(info0.pid)) break;
    await new Promise<void>((r) => { setTimeout(r, 50); });
    }

    if (spawnErr.msg) {
      // The child process couldn't be spawned at all (e.g. bad entry path).
      console.error(red(`Failed to start daemon: ${spawnErr.msg}`));
      return;
    }
    if (info0 && info0.sessionId) {
      success('agond started.');
      info(`  ${bold('session')}  ${cyan(info0.sessionId)}  ${dim(`(pid ${info0.pid})`)}`);
      info(`  ${bold('attach')}   ${dim(`agon attach --self ${info0.sessionId}`)}`);
      info(`  ${bold('stop')}     ${dim('agon daemon stop')}`);
    } else {
      // The pidfile never appeared — the child may have failed to boot. Don't
      // claim success; point at status for diagnosis.
      warn('Started a detached daemon but it has not reported a session yet.');
      info(dim('  Check `agon daemon status` in a moment.'));
    }
  >>>

// ── status — pidfile + alive + heartbeat freshness + socket ping ─────────────

fn name=daemonStatus returns="Promise<void>" async=true export=true
  doc "Report whether a daemon is running for this AGON_HOME and how healthy it is, across THREE independent signals: the pidfile pid (kill -0 alive?), the heartbeat mtime freshness (< HEARTBEAT_STALE_MS?), and a live socket ping (pong?). Prints the owned session id + an attach hint when up. Does NOT clean stale files — it's read-only diagnosis (start/stop own the cleanup)."
  handler <<<
    ensureAgonHome();
    const info = readPidFile();
    header('agond status');
    if (!info) {
      if (existsSync(socketPath())) {
        const pong = await sendDaemonRequest({ type: 'ping' });
        if (pong && pong.type === 'pong') {
          success('running (socket only — no pidfile)');
          info0(`  session ${cyan(pong.sessionId)} · uptime ${formatUptime(pong.uptime)}`);
          return;
        }
      }
      info0(dim('not running.'));
      info0(dim('  Start it with `agon daemon start`.'));
      return;
    }

    const alive = isProcessAlive(info.pid);
    const hbAge = heartbeatAgeMs();
    const hbFresh = hbAge < HEARTBEAT_STALE_MS;
    const pong = await sendDaemonRequest({ type: 'ping' });
    const answering = !!(pong && pong.type === 'pong');

    const line = (label: string, ok: boolean, detail: string): void => {
      info0(`  ${ok ? green('●') : red('○')} ${bold(label.padEnd(10))} ${ok ? green(detail) : yellow(detail)}`);
    };
    line('process', alive, alive ? `pid ${info.pid} alive` : `pid ${info.pid} dead`);
    line('heartbeat', hbFresh, hbFresh ? `${Math.round(hbAge)}ms ago` : (Number.isFinite(hbAge) ? `stale (${Math.round(hbAge)}ms)` : 'absent'));
    line('socket', answering, answering ? 'answering' : 'no reply');

    if (alive && answering) {
      const sid = (pong && pong.type === 'pong' && pong.sessionId) ? pong.sessionId : info.sessionId;
      const up = (pong && pong.type === 'pong') ? formatUptime(pong.uptime) : '?';
      console.log('');
      success(`running · session ${cyan(sid)} · uptime ${up}`);
      info0(dim(`  attach with \`agon attach --self ${sid}\``));
    } else {
      console.log('');
      warn('not healthy — start may stale-clean and restart it.');
    }
  >>>

// Local alias to dodge a name clash between the imported `info` printer and the
// `info` variable used above for the pidfile struct.
fn name=info0 params="text:string" returns="void" export=false expr={{ info(text); }}
  doc "Thin alias for the output-format `info` printer, used inside daemonStatus where a local variable named `info` (the pidfile struct) shadows the imported function."

fn name=formatUptime params="ms:number" returns="string" export=true
  doc "Render a millisecond uptime as a coarse human string (e.g. '42s', '3m', '2h 5m'). Used by status/pong reporting. Defensive: a non-finite/negative input renders '?'."
  handler <<<
    if (!Number.isFinite(ms) || ms < 0) return '?';
    const s = Math.floor(ms / 1000);
    if (s < 60) return `${s}s`;
    const m = Math.floor(s / 60);
    if (m < 60) return `${m}m ${s % 60}s`;
    const h = Math.floor(m / 60);
    return `${h}h ${m % 60}m`;
  >>>

// ── stop — shutdown over the socket, fallback SIGTERM, then cleanup ──────────

fn name=stopDaemon returns="Promise<void>" async=true export=true
  doc "Stop the daemon. First try a graceful {shutdown} over the socket (the daemon replies {bye} and self-cleans its socket + pidfile). If the socket is unreachable but a pid is alive, fall back to SIGTERM via the pidfile. Then poll until the pid is gone, and finally sweep any leftover socket/pidfile so a crash that left files behind doesn't block the next start. Idempotent: 'stop' with nothing running just reports so."
  handler <<<
    ensureAgonHome();
    const info = readPidFile();
    const sockExists = existsSync(socketPath());
    if (!info && !sockExists) {
      info0(dim('No daemon running.'));
      return;
    }

    // 1) Graceful shutdown over the socket.
    let acked = false;
    if (sockExists) {
      const bye = await sendDaemonRequest({ type: 'shutdown' });
      acked = !!(bye && bye.type === 'bye');
    }

    // 2) Fallback SIGTERM if the socket didn't ack but a pid is alive.
    if (!acked && info && isProcessAlive(info.pid)) {
      try { process.kill(info.pid, 'SIGTERM'); } catch { /* already gone */ }
    }

    // 3) Wait for the pid to actually exit (bounded), so cleanup doesn't race a
    //    daemon mid-teardown.
    if (info) {
      for (let i = 0; i < 40; i += 1) {
        if (!isProcessAlive(info.pid)) break;
        await new Promise<void>((r) => { const t = setTimeout(r, 50); if (typeof (t as any).unref === 'function') (t as any).unref(); });
      }
    }

    // 4) Sweep leftover files (the daemon self-cleans on a graceful exit, but a
    //    SIGKILL'd or crashed one won't — make `stop` idempotent + leave a clean
    //    slate for the next start).
    try { if (existsSync(socketPath())) rmSync(socketPath(), { force: true }); } catch { /* best-effort */ }
    try { if (existsSync(pidFilePath())) rmSync(pidFilePath(), { force: true }); } catch { /* best-effort */ }

    success(acked ? 'agond stopped (graceful shutdown).' : 'agond stopped (signaled / swept).');
  >>>

// ── Command ───────────────────────────────────────────────────────────────

const name=daemonCommand type=any
  handler <<<
    defineCommand({
      meta: {
        name: 'daemon',
        description: 'Run a long-lived agon session host (agond) you can attach to (client/server split M3): start | stop | status',
      },
      args: {
        action: {
          type: 'positional',
          description: 'start | stop | status | run (run is the internal foreground loop the detached child uses)',
          required: false,
        },
        foreground: {
          type: 'boolean',
          description: 'Run the server loop in THIS process instead of detaching (used by `daemon run` internally; also for debugging)',
          default: false,
        },
      },
      async run({ args }: { args: { action?: string; foreground?: boolean } }) {
        ensureAgonHome();
        const action = (typeof args.action === 'string' ? args.action : 'status').trim().toLowerCase();
        switch (action) {
          case 'start':
            await startDaemon(!!args.foreground);
            return;
          case 'run':
            // Internal: the detached child invokes `daemon run --foreground`.
            // Always runs the loop in-process regardless of the flag value so a
            // stray `daemon run` (without --foreground) still hosts rather than
            // recursively spawning.
            await runDaemonServer();
            return;
          case 'stop':
            await stopDaemon();
            return;
          case 'status':
          case '':
            await daemonStatus();
            return;
          default:
            warn(`Unknown action "${action}". Use: start | stop | status`);
        }
      },
    })
  >>>
