import from="citty" names="defineCommand"
import from="node:path" names="join"
import from="node:fs" names="mkdirSync"
import from="@agon/core" names="EngineRegistry,ensureAgonHome,loadConfig,RUNS_DIR"
import from="../lib/engines-dir.js" names="resolveBuiltinEnginesDir"
import from="@agon/adapter-cli" names="createCliAdapter"
import from="@agon/forge" names="runForge"
import from="../blocks/output-format.js" names="header,success,fail,warn,info,table,green,red,yellow,bold,cyan"
import from="../signals/icons.js" names="icons"

const name=forgeCommand type=any
  handler <<<
    defineCommand({
      meta: {
        name: 'forge',
        description: 'Run competitive forge — engines race to implement a task',
      },
      args: {
        task: {
          type: 'positional',
          description: 'Task description',
          required: true,
        },
        test: {
          type: 'string',
          alias: 't',
          description: 'Fitness test command',
          required: true,
        },
        cwd: {
          type: 'string',
          description: 'Working directory',
          default: process.cwd(),
        },
        starter: {
          type: 'string',
          alias: 's',
          description: 'Override starter engine',
        },
        engines: {
          type: 'string',
          alias: 'e',
          description: 'Comma-separated engine list',
        },
        timeout: {
          type: 'string',
          description: 'Engine timeout in seconds',
        },
        mode: {
          type: 'string',
          description: 'Forge mode: implement, improve, or validate',
          default: 'implement',
        },
        requireDiff: {
          type: 'string',
          description: 'Require a candidate diff (true/false). Defaults true for implement, false for improve/validate.',
        },
        baselineMayPass: {
          type: 'boolean',
          description: 'Allow a passing baseline without treating fitness as discriminating.',
          default: false,
        },
        acceptReviewOutput: {
          type: 'string',
          description: 'Accept useful no-diff review output as a validation result (true/false).',
        },
        dryRun: {
          type: 'boolean',
          description: 'Show what would happen without executing',
          default: false,
        },
      },
      async run({ args }) {
        ensureAgonHome();
        const config = loadConfig(args.cwd);

        const registry = new EngineRegistry();
        registry.load(resolveBuiltinEnginesDir());

        const adapter = createCliAdapter(registry);

        const available = registry.activeIds(config as any);
        if (available.length === 0) {
          fail('No engines found. Install at least one AI CLI tool.');
          info('Supported: claude, codex, gemini');
          process.exit(1);
        }

        const forgeDir = join(RUNS_DIR, `forge-${Date.now()}`);
        mkdirSync(forgeDir, { recursive: true });

        const engines = args.engines?.split(',').map((s: string) => s.trim());
        const displayEngines = engines && engines.length > 0 ? engines : available;
        const parseOptionalBoolean = (value: unknown): boolean | undefined => {
          if (value == null || value === '') return undefined;
          if (typeof value === 'boolean') return value;
          const text = String(value).trim().toLowerCase();
          if (['true', '1', 'yes', 'y', 'on'].includes(text)) return true;
          if (['false', '0', 'no', 'n', 'off'].includes(text)) return false;
          return undefined;
        };
        const requestedMode = String(args.mode ?? 'implement').toLowerCase();
        const mode = requestedMode === 'improve' || requestedMode === 'validate' ? requestedMode : 'implement';
        const requireDiff = parseOptionalBoolean(args.requireDiff);
        const acceptReviewOutput = parseOptionalBoolean(args.acceptReviewOutput);

        header(`Forge: ${args.task}`);
        info(`Engines: ${displayEngines.join(', ')}`);
        info(`Fitness: ${args.test}`);
        info(`Mode: ${mode}`);

        if (args.dryRun) {
          warn('Dry-run mode — no engines will be dispatched');
        }

        const manifest = await runForge(
          {
            task: args.task,
            fitnessCmd: args.test,
            cwd: args.cwd,
            forgeDir,
            timeout: args.timeout ? parseInt(args.timeout, 10) : undefined,
            mode,
            requireDiff,
            baselineMayPass: args.baselineMayPass,
            acceptReviewOutput,
            starter: args.starter,
            engines,
            dryRun: args.dryRun,
          },
          registry,
          adapter,
          (event: any) => {
            switch (event.type) {
              case 'baseline:start':
                info('Running baseline preflight...');
                break;
              case 'baseline:done':
                if (event.data?.passes) {
                  warn('Baseline passes — fitness may be non-discriminating. Add a failing regression test, use --mode validate, or set --require-diff=false.');
                }
                break;
              case 'stage1:dispatch':
                info(`Stage 1: dispatching ${bold(event.engineId ?? 'starter')}...`);
                break;
              case 'stage1:accepted':
                success(`Stage 1 auto-accepted: ${event.engineId} (score: ${event.data?.score})`);
                break;
              case 'stage2:dispatch':
                info(`Stage 2: dispatching ${bold(event.engineId ?? 'challenger')}...`);
                break;
              case 'engine:failed':
                warn(`Engine failed: ${bold(String(event.engineId ?? event.data?.engineId ?? 'unknown'))} (${event.data?.phase ?? 'dispatch'})`);
                break;
              case 'winner:determined':
                if (event.data?.winner) {
                  success(`Winner: ${bold(String(event.data.winner))} (score: ${event.data.bestScore})`);
                  if (event.data.closeCall) {
                    warn('Close call — triggering synthesis');
                  }
                } else {
                  fail('No engine passed the fitness test');
                }
                break;
              case 'forge:no-candidate-diff':
                if (Number(event.data?.toolLoopLimit ?? 0) > 0) {
                  warn(`No candidate diff: ${event.data.toolLoopLimit}/${event.data.count} engine(s) hit the tool-loop limit before producing a patch.`);
                } else {
                  warn(`No candidate diff from ${event.data?.count ?? 0} engine(s).`);
                }
                break;
              case 'synthesis:done':
                if (event.data?.wins) {
                  success(`Synthesis improved score: ${event.data.originalScore} → ${event.data.score}`);
                } else if (event.data?.error) {
                  warn(`Synthesis kept ${event.data.keptWinner ?? 'winner'} — ${event.data.error}`);
                } else if (event.data?.reason) {
                  warn(`Synthesis kept ${event.data.keptWinner ?? 'winner'} — ${event.data.reason}`);
                } else {
                  info('Synthesis completed without improving the winner');
                }
                break;
              case 'forge:done':
                break;
            }
          },
        );

        // Summary
        console.log('');
        header('Results');

        const rows = Object.entries(manifest.results).map(([id, r]: [string, any]) => [
          id === manifest.winner ? green(`${icons().winner} ${id}`) : id,
          r.pass ? green(r.status ?? 'PASS') : red(r.status ?? 'FAIL'),
          String(r.score),
          String(r.diffLines),
          String(r.filesChanged),
          `${r.durationSec}s`,
        ]);

        table(['Engine', 'Status', 'Score', 'Diff', 'Files', 'Time'], rows);

        console.log('');
        if (manifest.winner) {
          success(`Winner: ${bold(manifest.winner)}`);
          info(`Patch: ${manifest.patches[manifest.winner]}`);
        } else if (manifest.noDiffSummary) {
          const summary = manifest.noDiffSummary as any;
          if (summary.toolLoopLimit > 0) {
            fail(`No candidate diff — ${summary.toolLoopLimit}/${summary.count} engine(s) hit the tool-loop limit.`);
          } else {
            warn(`No candidate diff — baseline passed and engines produced no patch.`);
          }
          info('Try: add a failing regression fitness command, use --mode validate, or set --require-diff=false.');
        } else {
          fail('No winner — all engines failed');
        }
        info(`Manifest: ${forgeDir}/manifest.json`);
      },
    })
  >>>
