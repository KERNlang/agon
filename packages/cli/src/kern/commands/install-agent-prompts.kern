// `agon install-agent-prompts` — wire agon into other CLIs as a cheap /agon
// slash command, instead of an always-on MCP server.
//
// Drops a thin per-CLI shim into each detected CLI's prompt/command dir:
//   Codex       -> ~/.codex/prompts/agon.md
//   Gemini CLI  -> ~/.gemini/commands/agon.toml
//   Claude Code -> ~/.claude/commands/agon.md
// Each shim just tells the engine to run `agon agent-guide` and drive agon
// from its normal shell. Nothing is loaded into context until /agon is typed.

import from="citty" names="defineCommand"
import from="./agent-guide-text.js" names="agonShim"
import from="node:fs" names="existsSync,mkdirSync,writeFileSync"
import from="node:os" names="homedir"
import from="node:path" names="join,dirname"

const name=installAgentPromptsCommand type=any
  handler <<<
    defineCommand({
      meta: {
        name: 'install-agent-prompts',
        description: 'Install a lightweight /agon slash command into other CLIs (Codex, Gemini, Claude Code) — no MCP, no always-on tokens',
      },
      args: {
        cli: {
          type: 'string',
          description: 'Comma list to target: codex,gemini,claude. Default: every CLI whose config dir exists.',
        },
        force: {
          type: 'boolean',
          description: 'Overwrite an existing agon shim.',
        },
        dry: {
          type: 'boolean',
          description: 'Show what would be written without writing anything.',
        },
      },
      run({ args }) {
        const home = homedir();
        type Target = { id: string; label: string; baseDir: string; file: string; format: string };
        const targets: Target[] = [
          { id: 'codex', label: 'Codex', baseDir: join(home, '.codex'), file: join(home, '.codex', 'prompts', 'agon.md'), format: 'codex' },
          { id: 'gemini', label: 'Gemini CLI', baseDir: join(home, '.gemini'), file: join(home, '.gemini', 'commands', 'agon.toml'), format: 'gemini' },
          { id: 'claude', label: 'Claude Code', baseDir: join(home, '.claude'), file: join(home, '.claude', 'commands', 'agon.md'), format: 'claude' },
        ];

        const requested = String(args.cli ?? '')
          .split(',')
          .map((s) => s.trim().toLowerCase())
          .filter(Boolean);
        const dryRun = !!args.dry;
        const force = !!args.force;

        // Warn (do not silently drop) on unknown --cli ids, so typos surface.
        const knownIds = targets.map((t) => t.id);
        const unknown = requested.filter((id) => !knownIds.includes(id));
        if (unknown.length > 0) {
          process.stderr.write(`agon install-agent-prompts: ignoring unknown CLI "${unknown.join(', ')}" (known: ${knownIds.join(', ')})\n`);
        }

        const chosen = targets.filter((t) =>
          requested.length > 0 ? requested.includes(t.id) : existsSync(t.baseDir),
        );

        if (chosen.length === 0) {
          if (requested.length > 0) {
            process.stderr.write(`agon install-agent-prompts: no known CLI matched "${requested.join(', ')}" (known: ${knownIds.join(', ')})\n`);
          } else {
            process.stderr.write('agon install-agent-prompts: no CLI config dirs found (~/.codex, ~/.gemini, ~/.claude). Pass --cli codex,gemini,claude to force.\n');
          }
          process.exitCode = 1;
          return;
        }

        const fmt = (action: string, label: string, detail: string) =>
          `${action.padEnd(15)} ${(label + ':').padEnd(12)} ${detail}`;

        let hadError = false;
        const lines: string[] = [];
        for (const t of chosen) {
          const exists = existsSync(t.file);
          if (exists && !force) {
            lines.push(fmt('skip', t.label, `${t.file} (exists — use --force to overwrite)`));
            continue;
          }
          if (dryRun) {
            lines.push(fmt(exists ? 'would overwrite' : 'would write', t.label, t.file));
            continue;
          }
          try {
            mkdirSync(dirname(t.file), { recursive: true });
            writeFileSync(t.file, agonShim(t.format));
            lines.push(fmt(exists ? 'updated' : 'wrote', t.label, t.file));
          } catch (err) {
            hadError = true;
            lines.push(fmt('error', t.label, err instanceof Error ? err.message : String(err)));
          }
        }

        process.stdout.write(lines.join('\n') + '\n');
        if (hadError) {
          process.stderr.write('\nSome shims failed to install (see the "error" lines above).\n');
          process.exitCode = 1;
        } else if (!dryRun) {
          process.stdout.write('\nDone. In each CLI, type /agon — it runs `agon agent-guide`, then orchestrates. No MCP; nothing is loaded until you invoke it.\n');
        }
      },
    })
  >>>
