import from="citty" names="defineCommand"
import from="node:child_process" names="spawnSync"
import from="node:fs" names="mkdirSync,existsSync,chmodSync"
import from="node:path" names="join,basename"
import from="@kernlang/agon-core" names="EngineRegistry,agonPath"
import from="../lib/engines-dir.js" names="resolveBuiltinEnginesDir"
import from="@kernlang/agon-core" names="EngineDefinition" types=true
import from="../blocks/output-format.js" names="header,info,success,fail,warn,dim,bold,cyan"

interface name=EngineLoginPlan export=true
  doc "The decided plan for `agon login <engine>` — what clean config dir to point the engine at and which login subcommand to run. PURE so it can be unit-tested without spawning a CLI."
  field name=ok type=boolean
  field name=engineId type=string
  field name=reason type="'no-config-dir'|'no-login-command'" optional=true
    doc "Why login isn't applicable. no-config-dir: API-only engine (authenticates via API key, not a CLI config dir). no-login-command: has a config dir but no loginArgs to drive non-interactively."
  field name=configEnv type=string optional=true
  field name=cleanConfigDir type=string optional=true
  field name=loginArgs type="string[]" optional=true
  field name=authMarker type=string optional=true

fn name=planEngineLogin params="engine:EngineDefinition, cleanConfigDir:string" returns=EngineLoginPlan export=true
  doc "Decide how to log ONE engine into its clean workspace-pure config dir. Only engines with a configEnv isolation hint have an isolated dir to authenticate (API-only engines like kimi/minimax/zai use API keys — `agon provider`). An engine with a configEnv but no loginArgs can't be driven from here. Otherwise return the clean dir + the engine's login subcommand for the caller to spawn with configEnv pointed at it."
  handler <<<
    const hints = engine.isolationHints;
    if (!hints?.configEnv) {
      return { ok: false, engineId: engine.id, reason: 'no-config-dir' };
    }
    if (!hints.loginArgs || hints.loginArgs.length === 0) {
      return { ok: false, engineId: engine.id, reason: 'no-login-command', configEnv: hints.configEnv, cleanConfigDir };
    }
    return {
      ok: true,
      engineId: engine.id,
      configEnv: hints.configEnv,
      cleanConfigDir,
      loginArgs: [...hints.loginArgs],
      authMarker: hints.authMarker,
    };
  >>>

const name=loginCommand type="any"
  handler <<<
    defineCommand({
      meta: {
        name: 'login',
        description: "Log an engine's CLI into its clean workspace-pure config dir so dispatches stay authenticated without inheriting your personal Claude Code setup",
      },
      args: {
        engine: {
          type: 'positional',
          description: 'Engine to log in (e.g. claude, codex)',
          required: true,
        },
        force: {
          type: 'boolean',
          description: 'Re-run the login flow even if the clean dir already looks authenticated',
          default: false,
        },
      },
      async run({ args }: { args: { engine: string; force?: boolean } }) {
        const registry = new EngineRegistry();
        registry.load(resolveBuiltinEnginesDir());

        const id = registry.resolveId(String(args.engine).trim());
        let engine;
        try {
          engine = registry.get(id);
        } catch {
          fail(`Unknown engine: ${args.engine}`);
          info('Run `agon engine list` to see available engines.');
          process.exit(1);
          return;
        }

        const cleanConfigDir = agonPath('pure', engine.id);
        const plan = planEngineLogin(engine, cleanConfigDir);

        if (!plan.ok) {
          if (plan.reason === 'no-config-dir') {
            info(`${bold(engine.id)} doesn't use an isolated CLI config dir — it authenticates via API key.`);
            info(`Set its key with ${cyan('agon provider')} (or the engine's *_API_KEY env var). Nothing to log in here.`);
            process.exit(0);
          } else {
            fail(`${bold(engine.id)} has a clean config dir but no login command configured (isolationHints.loginArgs).`);
            process.exit(1);
          }
          return;
        }

        const binary = registry.findBinary(engine);
        if (!binary) {
          fail(`${engine.id} CLI not found on PATH.`);
          if (engine.installHint) info(`Install: ${engine.installHint}`);
          process.exit(1);
          return;
        }

        const marker = plan.authMarker?.trim();
        const markerPath = marker ? join(plan.cleanConfigDir!, basename(marker)) : '';
        const alreadyAuthed = !!markerPath && existsSync(markerPath);
        if (alreadyAuthed && !args.force) {
          success(`${engine.id} is already logged in for clean dispatch — workspace-pure isolation is active.`);
          info(`Re-run with ${cyan(`agon login ${engine.id} --force`)} to sign in again.`);
          return;
        }

        // Materialise the clean dir (owner-only) and point the engine's config
        // env at it, then hand the terminal to the engine's own login flow.
        mkdirSync(plan.cleanConfigDir!, { recursive: true, mode: 0o700 });
        try { chmodSync(plan.cleanConfigDir!, 0o700); } catch { warn(`Could not restrict permissions on ${plan.cleanConfigDir} — credentials there may be readable by other users.`); }

        header(`Login: ${engine.displayName ?? engine.id}`);
        info('Signing in to a clean config dir so agon dispatches stay authenticated');
        info(`  ${dim(`${plan.configEnv}=${plan.cleanConfigDir}`)}`);
        console.log('');

        const env = { ...process.env, [plan.configEnv!]: plan.cleanConfigDir! };
        const res = spawnSync(binary, plan.loginArgs!, { stdio: 'inherit', env });

        console.log('');
        // spawnSync sets res.error (and leaves status null) when the process
        // can't even start — surface that instead of a vague "exit null".
        if (res.error) {
          fail(`${engine.id} login failed to start: ${res.error.message}`);
          process.exit(1);
          return;
        }
        const authedNow = markerPath ? existsSync(markerPath) : res.status === 0;
        if (authedNow) {
          success(`${engine.id} is logged in for clean dispatch — workspace-pure isolation is now active.`);
        } else if (res.status === 0) {
          warn(`${engine.id} login finished but the auth marker (${marker}) wasn't found in the clean dir.`);
          info(`Dispatches fall back to your normal config until it appears. Re-run ${cyan(`agon login ${engine.id}`)} if needed.`);
        } else {
          const code = res.status !== null ? String(res.status) : 'signal';
          fail(`${engine.id} login did not complete (exit ${code}).`);
          process.exit(res.status ?? 1);
        }
      },
    })
  >>>
