// ── agon room — multi-party shared chat over the room ledger ──
// Phase-1 MVP: human-mediated. Any CLI (codex, claude, agy, agon) joins a named
// room and they read/post a shared persistent transcript. No auto, MCP, daemon.

import from="citty" names="defineCommand"
import from="node:path" names="basename"
import from="@kernlang/agon-core" names="ensureAgonHome,createRoom,listRooms,roomExists,closeRoom,isRoomClosed,appendEvent,readEvents,parseMentions,slugifyRoomId,recordPresence,removePresence,listPresence"
import from="@kernlang/agon-core" names="RoomActor,RoomEvent,PresenceEntry" types=true
import from="../blocks/output-format.js" names="header,info,success,fail,table,bold,green,red,dim"

fn name=actorFromArgs params="args:any" returns="RoomActor"
  doc "Build the room actor from CLI flags. callsign comes from --as (or --engine); cli/engine from --engine."
  handler <<<
    const engine = (args.engine as string | undefined) || undefined;
    const callsign = String((args.as as string) || engine || 'me').toLowerCase();
    const cli = engine || 'cli';
    const humanOwner = process.env.USER || process.env.USERNAME || 'local';
    return {
      actorId: `${cli}:${callsign}`,
      callsign,
      kind: 'external-cli',
      engineId: engine,
      cli,
      humanOwner,
    };
  >>>

fn name=renderEvent params="ev:RoomEvent" returns="string"
  doc "One transcript line. Posts show the body; join/leave/close render as system lines."
  handler <<<
    const t = new Date(ev.createdAt);
    const hh = String(t.getHours()).padStart(2, '0');
    const mm = String(t.getMinutes()).padStart(2, '0');
    const stamp = dim(`${hh}:${mm}`);
    const seq = dim(`#${ev.seq}`);
    const who = bold(green(ev.actor.callsign));
    if (ev.kind === 'post') {
      return `${seq} ${stamp} ${who}: ${ev.body}`;
    }
    if (ev.kind === 'join') return `${seq} ${stamp} ${dim('* ' + ev.actor.callsign + ' joined')}`;
    if (ev.kind === 'leave' || ev.kind === 'room-closed') return `${seq} ${stamp} ${dim('* ' + ev.actor.callsign + ' left')}`;
    return `${seq} ${stamp} ${dim('* ' + ev.kind + ' by ' + ev.actor.callsign)}`;
  >>>

const name=roomCommand type="any"
  handler <<<
    defineCommand({
      meta: {
        name: 'room',
        description: 'Shared multi-party chat room any CLI can join',
      },
      args: {
        action: {
          type: 'positional',
          description: 'create | join | post | read | tail | who | leave | close | list',
          required: true,
        },
        room: {
          type: 'positional',
          description: 'Room name or id',
          required: false,
        },
        as: { type: 'string', description: 'Your callsign in the room (e.g. claude, codex)' },
        text: { type: 'string', alias: 'm', description: 'Message text (post)' },
        name: { type: 'string', alias: 'n', description: 'Room name (create)' },
        engine: { type: 'string', description: 'Engine/CLI id: codex | claude | agy | agon' },
        since: { type: 'string', description: 'Only events after this seq (read/tail)', default: '0' },
        limit: { type: 'string', description: 'Max events to show (read)', default: '50' },
      },
      async run({ args }) {
        ensureAgonHome();
        const action = String(args.action);

        if (action === 'list') {
          const rooms = listRooms();
          if (rooms.length === 0) { info('No rooms yet. Create one: agon room create --name <name>'); return; }
          header('Rooms');
          table(['Room', 'Name', 'Created', 'Status'], rooms.map((r) => [
            bold(r.roomId), r.name, new Date(r.createdAt).toLocaleString(), r.closed ? red('closed') : green('open'),
          ]));
          return;
        }

        const roomName = String((args.room as string) || (args.name as string) || '');
        if (!roomName) { fail(`Usage: agon room ${action} <room> ...`); return; }
        const roomId = slugifyRoomId(roomName);
        const actor = actorFromArgs(args);
        const repoHint = basename(process.cwd());
        const since = Math.max(0, parseInt(String(args.since ?? '0'), 10) || 0);
        const limit = Math.max(0, parseInt(String(args.limit ?? '50'), 10) || 0);

        switch (action) {
          case 'create': {
            const meta = createRoom(roomName);
            success(`Room ${bold(meta.roomId)} ready.`);
            info(dim(`Join it:  agon room join ${meta.roomId} --as <callsign>`));
            return;
          }
          case 'join': {
            if (roomExists(roomId) && isRoomClosed(roomId)) { fail(`Room "${roomId}" is closed.`); return; }
            createRoom(roomName); // idempotent — create on first join
            recordPresence(roomId, actor, 0, false);
            appendEvent(roomId, { kind: 'join', actor, body: '', mentions: [], replyTo: null, repoHint });
            success(`${actor.callsign} joined ${bold(roomId)}.`);
            info(dim(`Post:  agon room post ${roomId} --as ${actor.callsign} -m "hello"`));
            info(dim(`Watch: agon room tail ${roomId}`));
            return;
          }
          case 'post': {
            if (!roomExists(roomId)) { fail(`No room "${roomId}". Create/join it first.`); return; }
            if (isRoomClosed(roomId)) { fail(`Room "${roomId}" is closed.`); return; }
            const text = String(args.text ?? '');
            if (!text.trim()) { fail('Nothing to post. Use -m "your message".'); return; }
            const ev = appendEvent(roomId, { kind: 'post', actor, body: text, mentions: parseMentions(text), replyTo: null, repoHint });
            recordPresence(roomId, actor, ev.seq, false);
            success(`#${ev.seq} posted to ${bold(roomId)}${ev.mentions.length ? dim(' · @' + ev.mentions.join(' @')) : ''}`);
            return;
          }
          case 'read': {
            if (!roomExists(roomId)) { fail(`No room "${roomId}".`); return; }
            const events = readEvents(roomId, since, limit);
            header(`Room ${roomId}`);
            if (events.length === 0) { info(dim('(no messages yet)')); return; }
            for (const ev of events) console.log(renderEvent(ev));
            return;
          }
          case 'tail': {
            if (!roomExists(roomId)) { fail(`No room "${roomId}".`); return; }
            header(`Room ${roomId} ${dim('(tailing — Ctrl+C to leave)')}`);
            let lastSeq = since;
            for (const ev of readEvents(roomId, since, 50)) { console.log(renderEvent(ev)); lastSeq = Math.max(lastSeq, ev.seq); }
            // Keep the interval REF'd — it is the only handle holding the event
            // loop open; the awaited promise below never settles (so the command
            // runs until Ctrl+C), and an unsettled promise is not a libuv handle.
            setInterval(() => {
              const news = readEvents(roomId, lastSeq, 0);
              for (const ev of news) { console.log(renderEvent(ev)); lastSeq = Math.max(lastSeq, ev.seq); }
            }, 1000);
            await new Promise<void>(() => { /* run until SIGINT */ });
            return;
          }
          case 'who': {
            if (!roomExists(roomId)) { fail(`No room "${roomId}".`); return; }
            const present: PresenceEntry[] = listPresence(roomId);
            if (present.length === 0) { info(dim('Nobody here yet.')); return; }
            header(`Who's in ${roomId}`);
            table(['Callsign', 'Status', 'CLI', 'Last seen'], present.map((p) => [
              bold(p.callsign),
              p.status === 'here' ? green('here') : p.status === 'stale' ? dim('stale') : red('left'),
              p.cli,
              new Date(p.lastSeenAt).toLocaleTimeString(),
            ]));
            return;
          }
          case 'leave': {
            if (!roomExists(roomId)) { fail(`No room "${roomId}".`); return; }
            appendEvent(roomId, { kind: 'leave', actor, body: '', mentions: [], replyTo: null, repoHint });
            removePresence(roomId, actor.callsign);
            success(`${actor.callsign} left ${bold(roomId)}.`);
            return;
          }
          case 'close': {
            if (!roomExists(roomId)) { fail(`No room "${roomId}".`); return; }
            appendEvent(roomId, { kind: 'room-closed', actor, body: '', mentions: [], replyTo: null, repoHint });
            closeRoom(roomId);
            success(`Room ${bold(roomId)} closed.`);
            return;
          }
          default:
            fail(`Unknown action "${action}". Use: create | join | post | read | tail | who | leave | close | list`);
        }
      },
    })
  >>>
