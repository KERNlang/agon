import from="@kernlang/agon-core" names="EngineRegistry,EngineAdapter,Plan,AgonConfig,ChatSession,PersistentSession,CesarMemory,EventBus,ToolRegistry,DiscoveredGate" types=true
import from="../cesar/telemetry.js" names="EngineVitals" types=true
import from="../cesar/task-execution-lease.js" names="TaskExecutionLease" types=true

interface name=EngineProgress
  field name=id type=string
  field name=status type=string
  field name=elapsed type=number
  field name=done type=boolean
  field name=failed type=boolean
  field name=score type=string optional=true
  field name=isAgent type=boolean optional=true

union name=OutputEvent discriminant=type
  variant name=text
    field name=content type=string
  variant name=engine-block
    field name=engineId type=string
    field name=color type=number
    field name=content type=string
    doc "Honest fallback label: the engine that ACTUALLY produced this content when it differs from the attributed engineId (silent acting-Cesar swap, when the configured engine was unavailable). Rendered as a dim '(acting: X)' suffix after the header."
    field name=actingNote type=string optional=true
    doc "Narration-fold metadata. foldedSteps = count of research play-by-play sentences collapsed out of `content` (the visible text); when > 0 the renderer shows a compact '▸ N reasoning steps folded · /raw' placeholder. Unset for engines that emit no narration (clean answers pay zero tax). The untouched raw text is NOT carried per-event (it would accumulate unbounded over a long session) — it lives in narration-fold.kern's bounded ring, which /raw replays."
    field name=foldedSteps type=number optional=true
  variant name=streaming-chunk
    field name=engineId type=string
    field name=chunk type=string
  variant name=streaming-preview
    doc "A SPECULATIVE live-draft frame (from a PTY 'preview' chunk). REPLACES the engine's live-pane content with the draft and marks the entry draft=true. It is NEVER committed to the transcript: streaming-end drops a still-draft entry, and the first authoritative streaming-chunk overwrites the draft. The renderer shows it dimmed with a 'draft preview' hint. content carries the full sanitized draft so far."
    field name=engineId type=string
    field name=content type=string
  variant name=thinking-chunk
    field name=engineId type=string
    field name=chunk type=string
  variant name=streaming-end
    field name=engineId type=string
  variant name=spinner-start
    field name=message type=string
    field name=color type=number optional=true
  variant name=spinner-stop
    field name=message type=string optional=true
  variant name=spinner-update
    field name=message type=string
  variant name=progress-update
    field name=engines type="EngineProgress[]"
  variant name=progress-clear
  variant name=separator
  variant name=header
    field name=title type=string
  variant name=success
    field name=message type=string
  variant name=error
    field name=message type=string
  variant name=warning
    field name=message type=string
    field name=transient type=boolean optional=true
  variant name=info
    field name=message type=string
  variant name=plan
    field name=plan type=Plan
  variant name=plan-list
    field name=plans type="Plan[]"
  variant name=plan-proposal
    field name=plan type=any
    field name=markdown type=string
    field name=planFilePath type=string optional=true
    doc "When committed=true the proposal is a historical scrollback record (demoted from the live pane after the user responded), so the approval prompt is suppressed."
    field name=committed type=boolean optional=true
  variant name=plan-execution
    field name=plan type=any
  variant name=plan-cancelled
    doc "Fired when the user rejects a plan-proposal at the approval prompt. Clears the live-pane proposal slot; does not add a scrollback block."
    field name=plan type=any
  variant name=plan-dismiss
    doc "Fired from handleSubmit when the user responds to a pinned plan proposal. Demotes the pinned proposal from the live pane into scrollback history (Claude-style) so the next turn's output is the bottom-most content. No-op when nothing is pinned."
  variant name=todos-set
    doc "Replace the rolling todo list shown above the composer. Pass an empty array to hide it; pass a non-empty array to declare 'here's what I'm about to do'."
    field name=todos type="any[]"
  variant name=todos-update
    doc "Patch a single todo's state. Used by the plan-executor on step transitions and by any handler that wants to mark a declared todo running/done/failed."
    field name=id type=string
    field name=state type=string
    field name=note type=string optional=true
  variant name=todos-clear
    doc "Wipe the rolling todo list. With scope:'live' only live-sourced items are dropped (plan items survive); omit scope to wipe everything."
    field name=scope type="'live'" optional=true
  variant name=scoreboard
    field name=title type=string
    field name=winner type=string optional=true
    field name=engineIds type="string[]"
    field name=metrics type="{ label: string; values: string[] }[]"
  variant name=table
    field name=headers type="string[]"
    field name=rows type="string[][]"
  variant name=clear
  variant name=kern-draft
    field name=engineId type=string
    field name=content type=string
    field name=critique type=string optional=true
  variant name=debate-round
    field name=round type=number
    field name=engineId type=string
    field name=position type=string
    field name=argument type=string
  variant name=verdict
    field name=summary type=string
  variant name=question
    field name=prompt type=string
    field name=resolve type="(answer: string) => void"
  variant name=permission-ask
    field name=tool type=string
    field name=command type=string
    field name=description type=string optional=true
    field name=reason type=string
    field name=diffPreview type="{ files: Array<{ path: string; relPath: string; status: string; additions: number; deletions: number; lines: string[]; omitted: number }>; totalFiles: number }" optional=true
    field name=fallbackNote type=string optional=true
    field name=resolve type="(approved: boolean) => void"
  variant name=patch-review
    field name=winnerId type=string
    field name=patchPath type=string
    field name=patchContent type=string
  variant name=tool-call
    field name=engineId type=string
    field name=tool type=string
    field name=input type=string
    field name=status type="'running'|'done'|'error'"
    field name=toolCallId type=string optional=true
    field name=terminalReason type="'succeeded'|'failed'|'skipped_policy'|'denied'|'cancelled'|'unknown'" optional=true
    field name=output type=string optional=true
    doc "Wall-clock duration of the tool call (running→done/error), set by the brain dispatcher. Rendered as a dim suffix on the result line (e.g. '→ 12 lines · 1.4s'). Absent for instant signal/MCP completions that had no preceding 'running' event."
    field name=durationMs type=number optional=true
  variant name=tool-call-group
    doc "A compacted group of consecutive tool-call blocks, committed to Static as a single summary row a-la Claude Code. Built by output.kern's pending buffer on non-tool events or /clear."
    field name=blocks type="any[]"
  variant name=tool-stream-start
    field name=streamId type=string
    field name=engineId type=string
    field name=tool type=string
    field name=input type=string
  variant name=tool-stream-chunk
    field name=streamId type=string
    field name=chunk type=string
  variant name=tool-stream-end
    field name=streamId type=string
    field name=status type="'done'|'error'"
    field name=output type=string optional=true
    field name=engineId type=string optional=true
    field name=tool type=string optional=true
    field name=input type=string optional=true
    field name=toolCallId type=string optional=true
    field name=terminalReason type="'succeeded'|'failed'|'skipped_policy'|'denied'|'cancelled'|'unknown'" optional=true
    doc "Wall-clock duration of the streamed tool call, measured by executeToolCall in the eager path. Passed through to the synthetic tool-call block in output.kern so the renderer shows the '· 1.4s' suffix for streaming tools too."
    field name=durationMs type=number optional=true
  variant name=user-message
    field name=content type=string
  variant name=response-meta
    field name=engineId type=string
    field name=elapsed type=number
    field name=inputTokens type=number optional=true
    field name=outputTokens type=number optional=true
    field name=cost type=number optional=true
  variant name=confidence-update
    field name=value type="number|null"
  variant name=context-usage
    field name=pct type=number
    field name=used type=number
    field name=limit type=number
    field name=compacted type=number optional=true
    field name=cached type=number optional=true
    field name=source type="'api'|'projected'|'estimate'" optional=true
      doc "Exactness of `used`: 'api' = real token usage from the last API response; 'projected' = real anchor plus a small estimated delta; 'estimate' = chars-based estimate only."
  variant name=cesar-recap
    field name=engineId type=string
    field name=mode type=string
    field name=outcome type=string
    field name=durationMs type=number
    field name=confidence type="number|null" optional=true
    field name=confidenceReasoning type=string optional=true
    field name=toolCount type=number
    field name=failedTools type=number optional=true
    doc "True only when the TURN genuinely failed (engine did not respond) — drives the ⚠ headline. Never set from intermediate tool exit codes."
    field name=failed type=boolean optional=true
    doc "Failed tools that did NOT become a red ✗ line (recovered retries, plumbing non-zero exits, non-command tool errors). Rendered as the dim '· N non-fatal' suffix."
    field name=nonFatalCount type=number optional=true
    doc "Unrecovered CONSEQUENTIAL command failures, promoted to bright red ✗ lines under the headline (capped at 3; the rest counted by failureOverflow)."
    field name=failureLines type="Array<{ action: string; command: string; reason: string }>" optional=true
    field name=failureOverflow type=number optional=true
    field name=changeSummary type="{ created: number; edited: number; read: number }" optional=true
    field name=verification type="Array<{ label: string; ok: boolean }>" optional=true
    field name=toolSummary type="string[]"
    field name=commands type="Array<{ label: string; command: string; status: string }>"
    field name=files type="Array<{ path: string; relPath: string; status: string; touchCount: number }>"
    doc "The turn's final live-todo checklist progress (N/M done), or null when the turn declared no live checklist. Rendered as a 'todos: N/M done' line."
    field name=todos type="{ done: number; total: number } | null" optional=true
    field name=checkpoints type="Array<{ id: string; label: string }>" optional=true
    field name=diffPreview type="{ files: Array<{ path: string; relPath: string; status: string; additions: number; deletions: number; lines: string[]; omitted: number }>; totalFiles: number }" optional=true
    field name=warnings type="string[]"
  variant name=cesar-preamble
    doc "One short intent line ([INTENT] marker, RULE 7c) shown as a distinct dim block at the START of a Cesar turn, before any tool work. Parsed + stripped from the visible answer like [TODOS]; absent marker = no block."
    field name=engineId type=string optional=true
    field name=intent type=string
  variant name=file-changes
    field name=files type="{ path: string; status: 'modified'|'created'|'deleted'; additions: number; deletions: number }[]"
  variant name=dashboard
    field name=available type="string[]"
    field name=enabled type="string[]"
    field name=defaultEngine type=string
    field name=eloTop type="{ id: string; rating: number }" optional=true
    field name=totalForges type=number
    field name=workspace type="{ name: string; path: string; isKern?: boolean }" optional=true
    field name=runCount type=number
  variant name=agent-step-end
    field name=engineId type=string
    field name=turnIndex type=number
    field name=outcome type="'completed'|'cancelled'|'failed'"
    field name=toolCalls type=number
    field name=tokensUsed type=number
    field name=stopReason type=string
  variant name=agent-turn-summary
    field name=engineId type=string
    field name=turnsUsed type=number
    field name=turnsRemaining type=number
    field name=cumulativeTokens type=number
    field name=cumulativeToolCalls type=number
    field name=elapsedMs type=number
  variant name=agent-budget-warning
    field name=engineId type=string
    field name=kind type="'turns'|'tokens'|'duration'"
    field name=used type=number
    field name=limit type=number
    field name=remaining type=number
  variant name=agent-step-start
    field name=engineId type=string
    field name=turnIndex type=number
    field name=userPrompt type=string
    field name=maxTurns type=number
    field name=maxDurationMs type=number
    field name=maxTokens type="number|null" optional=true
    field name=teamId type=string optional=true
  variant name=agent-team-start
    field name=teamId type=string
    field name=engineIds type="string[]"
    field name=task type=string
    field name=taskKind type="'edit'|'investigate'"
  variant name=engine-switch
    doc "Emitted when the active engine changes — either Cesar re-routes, team synthesis selects a winner, or Phase B auto-upgrades solo→team. Enables the UI to show a subtle attribution badge."
    field name=from type=string optional=true
    field name=to type=string
    field name=reason type="'auto-fanout'|'cesar-route'|'team-member'|'synthesis'|'fallback'"
    field name=confidence type=number optional=true
  variant name=shadow-active
    doc "Emitted once when shadow mode starts — a secondary engine is racing in a background worktree. Lets the UI show a subtle 'shadow running' indicator without cluttering the foreground stream."
    field name=shadowEngineId type=string
    field name=foregroundEngineId type=string
  variant name=agent-routing
    doc "Emitted when Cesar decides between solo and team mode before dispatch. Gives the user visibility into the routing decision."
    field name=mode type="'solo'|'team'"
    field name=engines type="string[]"
    field name=reason type=string
  variant name=agent-team-complete
    field name=teamId type=string
    field name=winner type="string|null"
    field name=synthesizedPatch type="string|null" optional=true
    field name=synthesizedAnalysis type="string|null" optional=true
    field name=memberOutcomes type="Array<{engineId:string,outcome:string,diffLines:number,passedFitness:boolean}>"
    field name=teamCostUsd type=number
    field name=teamDurationMs type=number
    field name=synthesisRan type=boolean optional=true
    field name=synthesisChanged type=boolean optional=true
    field name=synthesisCostUsd type=number optional=true
    field name=synthesisFitnessRegressed type=boolean optional=true

interface name=PendingDelegation
  field name=action type=string
  field name=task type=string optional=true
  field name=reasoning type=string
  field name=scope type="'slice'|'full'" optional=true
  field name=fitnessCmd type=string optional=true
  field name=hardened type=boolean
  field name=tribunalMode type=string optional=true
  field name=team type=boolean
  field name=target type=string optional=true
  field name=engineId type=string optional=true
  field name=engines type="string[]" optional=true
  field name=taskKind type="'edit'|'investigate'" optional=true
  field name=maxTurns type=number optional=true
  field name=queue type=string optional=true
  field name=gate type=string optional=true
  field name=builder type=string optional=true
  field name=push type=boolean optional=true
  field name=pr type=boolean optional=true
  field name=maxHours type=number optional=true
  field name=budget type=number optional=true
  field name=cesarEngineId type=string optional=true
  field name=cesarBackend type=string optional=true
  field name=hasNativeTools type=boolean optional=true
  field name=toolCount type=number optional=true
  field name=toolEventCount type=number optional=true
  field name=toolCallTurns type=number optional=true
  field name=toolsUsed type="string[]" optional=true
  field name=nativeToolCalls type=number optional=true
  field name=mcpToolCalls type=number optional=true
  field name=xmlToolCalls type=number optional=true
  field name=narratedToolStalls type=number optional=true
  field name=autoToolExecutions type=number optional=true
  field name=confidenceToolUsed type=boolean optional=true
  field name=createdAt type=number

type name=CesarLiveMode values="self|self-nero|delegate|forge|forge-slice|team-forge|brainstorm|team-brainstorm|campfire|tribunal|team-tribunal|pipeline|goal|conquer|review|agent|team-agent|plan"

interface name=CesarTurnOutcome
  field name=turnId type=string optional=true
  field name=terminalState type="'completed'|'failed'|'cancelled'|'timed_out'|'superseded'" optional=true
  field name=mode type=CesarLiveMode optional=true
  field name=delegated type=boolean
  field name=responded type=boolean
  field name=action type=string optional=true
  field name=task type=string optional=true
  field name=reasoning type=string optional=true
  field name=decisionReason type=string optional=true
  field name=scope type="'slice'|'full'" optional=true
  field name=fitnessCmd type=string optional=true
  field name=hardened type=boolean optional=true
  field name=tribunalMode type=string optional=true
  field name=team type=boolean optional=true
  field name=target type=string optional=true
  field name=engineId type=string optional=true
  field name=engines type="string[]" optional=true
  field name=taskKind type="'edit'|'investigate'" optional=true
  field name=maxTurns type=number optional=true
  field name=queue type=string optional=true
  field name=gate type=string optional=true
  field name=builder type=string optional=true
  field name=push type=boolean optional=true
  field name=pr type=boolean optional=true
  field name=maxHours type=number optional=true
  field name=budget type=number optional=true
  field name=deterministicFailure type=boolean optional=true
  field name=awaitingUserInput type=boolean optional=true
  field name=cesarEngineId type=string optional=true
  field name=cesarBackend type=string optional=true
  field name=hasNativeTools type=boolean optional=true
  field name=toolCount type=number optional=true
  field name=toolEventCount type=number optional=true
  field name=toolCallTurns type=number optional=true
  field name=toolsUsed type="string[]" optional=true
  field name=nativeToolCalls type=number optional=true
  field name=mcpToolCalls type=number optional=true
  field name=xmlToolCalls type=number optional=true
  field name=narratedToolStalls type=number optional=true
  field name=autoToolExecutions type=number optional=true
  field name=confidenceToolUsed type=boolean optional=true
  field name=liveTodosEmitted type=boolean optional=true

interface name=CesarState
  field name=busy type=boolean
  field name=busySince type="number | null"
  field name=queue type="{ input: string; dispatch: any; images?: any[] } | null"
  field name=abortSignal type="AbortSignal | null" optional=true
  field name=toolRegistry type="ToolRegistry | null"
  field name=hasNativeTools type=boolean
  field name=lastDispatch type="((event: any) => void) | null"
  field name=pendingDelegation type="PendingDelegation | null"
  field name=reportedConfidence type="number | undefined"
  field name=reportedConfidenceReasoning type="string | undefined"
  field name=confidenceSatisfied type=boolean
  field name=blockedOnConfidence type="{ name:string; args:Record<string,unknown> } | null"
  field name=confidenceBlockCount type=number optional=true
  field name=searchToolCount type=number optional=true
  field name=searchNudged type=boolean optional=true
  field name=budgetWarned type=boolean optional=true
  field name=quickNeroRequested type=boolean optional=true
  field name=autoNero type=boolean
  field name=advisorPending type=boolean
  field name=mcpFingerprint type="string | undefined"
  field name=kernContextSpine type="string | undefined" optional=true doc="Compiler-derived project call/use map prepared once for each fresh Cesar session."
  field name=mcpSignalPath type="string | undefined" optional=true
  field name=planDispatch type="((event: any) => void) | null"
  field name=proposedPlan type="any | undefined"
  field name=lastEscalation type="string | null"
  field name=turnId type="string | undefined" optional=true
  field name=sessionMcpServers type="Array<{name:string, type?:string, url?:string, command?:string, args?:string[]}>"
  field name=autoModeQueued type=boolean optional=true
  field name=harnessProfile type="'legacy'|'agentic' | undefined" optional=true doc="Controller profile used to create the current persistent Cesar session; changing it forces a clean session rebuild with history replay."
  field name=taskExecutionLease type="TaskExecutionLease | undefined" optional=true doc="Turn-scoped AUTO authority shared by native, companion, XML, and MCP execution adapters."
  field name=discoveredGate type="DiscoveredGate | undefined" optional=true doc="The verification gate discovered for the current turn's cwd (command + loose matchers). command==='' means gateAbsent."
  field name=gateWaived type=boolean optional=true doc="Session-sticky: when true, the verify-before-done gate nudge is suppressed for the rest of the session. Set on /nogate, on a user skip-signal after a nudge, or when no gate could be discovered (gateAbsent)."
  field name=gateNudgedClaim type="string | undefined" optional=true doc="Signature of the most recent done-claim that already received a gate nudge — guards one nudge per distinct claim so a repeated/identical 'done' doesn't re-nudge, while a NEW done-claim (different signature) can."

interface name=HandlerContext
  field name=registry type=EngineRegistry
  field name=adapter type=EngineAdapter
  field name=activeEngines type="() => string[]"
  field name=inputEpoch type=number optional=true
  field name=config type=AgonConfig
  field name=chatSession type=ChatSession
  field name=currentPlan type="Plan | null"
  field name=setCurrentPlan type="(plan: Plan | null) => void"
  field name=setActiveAbort type="(abort: AbortController | null) => void"
  field name=askQuestion type="(prompt: string) => Promise<string>"
  field name=cesarSession type="PersistentSession | null"
  field name=setCesarSession type="(session: PersistentSession | null) => void"
  field name=explorationMode type=boolean
  field name=setExplorationMode type="(mode: boolean) => void"
  field name=neroMode type=boolean
  field name=setNeroMode type="(mode: boolean) => void"
  field name=cesarMemory type=CesarMemory
  field name=activePlan type="any | null" optional=true
  field name=setActivePlan type="((plan: any) => void) | undefined" optional=true
  field name=extensionPromptFragments type="string[]" optional=true
  field name=eventBus type="EventBus | undefined" optional=true
  field name=cesar type="CesarState | undefined" optional=true
  field name=cesarRuntimeHost type="any | undefined" optional=true doc="App-owned stable control-plane host shared by every fresh HandlerContext for this chat ledger."
  field name=lastReviewResult type="{ engineId: string; target: string; label: string; diff: string; reviewOutput: string; timestamp: number } | undefined" optional=true
  field name=sessionMcpServers type="Array<Record<string,unknown>>" optional=true
  field name=setSessionMcpServers type="((servers: Array<Record<string,unknown>>) => void) | undefined" optional=true
  field name=autoModeQueued type=boolean optional=true
  field name=delegatedContinuationDepth type=number optional=true doc="Depth guard for delegated-result synthesis. Typed on the shared context so continuations do not need unsafe casts."
  field name=telemetryVitals type="Map<string, EngineVitals> | undefined" optional=true
  field name=telemetrySnapshot type="(() => Map<string, EngineVitals>) | undefined" optional=true doc="Live read of the telemetry poller's current vitals map. telemetryVitals (React state) is repaint-deduped and may lag by a signature bucket while the /status dashboard is closed; on-demand consumers (the /status text snapshot) should prefer this getter."
  field name=recentFallbacks type="{from:string,to:string,reason:string,at:number}[] | undefined" optional=true
