// ── App Input Handlers ───────────────────────────────────────────────
// Pure functions for input processing — no React, no JSX.

import from="./ghost-text.js" names="getGhostCompletion"
import from="../../input-utils.js" names="stripBracketedPasteMarkers"
import from="@kernlang/agon-core" names="collectSourceFiles"

fn name=cleanInputValue params="value:string" returns=string expr={{ return stripBracketedPasteMarkers(value); }}
  doc "Strip bracketed paste escapes from input while preserving pasted content."

fn name=cleanSubmitValue params="value:string" returns=string expr={{ return stripBracketedPasteMarkers(value).trim(); }}
  doc "Strip paste escapes and trim for submission."

fn name=findInputChange params="previous:string, next:string" returns="{start:number, removed:string, inserted:string}"
  doc "Find the single contiguous edit between two input values."
  handler <<<
    let start = 0;
    while (start < previous.length && start < next.length && previous[start] === next[start]) {
      start++;
    }

    let previousEnd = previous.length;
    let nextEnd = next.length;
    while (previousEnd > start && nextEnd > start && previous[previousEnd - 1] === next[nextEnd - 1]) {
      previousEnd--;
      nextEnd--;
    }

    return {
      start,
      removed: previous.slice(start, previousEnd),
      inserted: next.slice(start, nextEnd),
    };
  >>>

fn name=navigateHistory params="direction:'up'|'down', currentIndex:number, history:string[]" returns="{index:number, value:string}"
  doc "Navigate input history up/down."
  handler lang="kern"
    if cond="direction === 'up' && history.length > 0"
      let name=newIndex value="currentIndex === -1 ? history.length - 1 : Math.max(0, currentIndex - 1)"
      return value="{ index: newIndex, value: history[newIndex] }"
    if cond="direction === 'down' && currentIndex >= 0"
      let name=newIndex value="currentIndex + 1"
      if cond="newIndex >= history.length"
        return value="{ index: -1, value: '' }"
      return value="{ index: newIndex, value: history[newIndex] }"
    return value="{ index: currentIndex, value: '' }"

fn name=appendInputHistory params="history:string[], input:string, maxEntries?:number" returns="string[]"
  doc "Append a submitted composer command with duplicate pruning and a bounded history length."
  handler lang="kern"
    let name=max value="Math.max(1, Math.floor(maxEntries ?? 200))"
    let name=entry value="String(input ?? '').trim()"
    if cond="!entry"
      return value="history.slice(-max)"
    let name=deduped value="history.filter((item: string) => item !== entry)"
    return value="[...deduped, entry].slice(-max)"

fn name=parseAutoModeCommand params="input:string" returns="'on'|'off'|'toggle'|'status'|null"
  doc "Parse first-class /auto controls. /auto <task> intentionally returns null so normal autonomous task routing still works."
  handler lang="kern"
    let name=trimmed value="String(input ?? '').trim().toLowerCase()"
    let name=match value="trimmed.match(/^\\/(?:auto|autonomous)(?:\\s+(on|off|toggle|status))?$/)"
    if cond="!match"
      return value="null"
    return value="(match.groups[0] as 'on' | 'off' | 'toggle' | 'status' | null | undefined) ?? 'toggle'"

fn name=hasBtwSideChannelTarget params="opts:{replState:string,activePlanState?:string|null,runningJobCount?:number}" returns=boolean export=true
  doc "True when /btw should run as a side-channel instead of falling through to normal command dispatch."
  handler lang="kern"
    if cond="opts.replState !== 'idle'"
      return value="true"
    if cond="(opts.runningJobCount ?? 0) > 0"
      return value="true"
    let name=planState value="String(opts.activePlanState ?? '')"
    return value="['planning', 'awaiting_approval', 'running', 'paused'].includes(planState)"

interface name=EscapeDecision
  field name=action type="'close-slash'|'close-engine-picker'|'cancel-question'|'interrupt'|'clear-input'|'noop'"

fn name=resolveEscapeAction params="opts:{replState:string,inputValue:string,slashPickerOpen:boolean,enginePickerOpen:boolean,questionOpen:boolean}" returns="EscapeDecision"
  doc "Resolve Esc behavior without destructive transcript clearing."
  handler lang="kern"
    if cond="opts.slashPickerOpen"
      return value="{ action: 'close-slash' }"
    if cond="opts.enginePickerOpen"
      return value="{ action: 'close-engine-picker' }"
    if cond="opts.questionOpen"
      return value="{ action: 'cancel-question' }"
    if cond="opts.replState !== 'idle'"
      return value="{ action: 'interrupt' }"
    if cond="opts.inputValue"
      return value="{ action: 'clear-input' }"
    return value="{ action: 'noop' }"

fn name=tryGhostComplete params="inputValue:string, commands:any[], engineIds:string[]" returns="string|null" expr={{ return getGhostCompletion(inputValue, commands, engineIds); }}
  doc "Get ghost text completion for current input."

fn name=getSlashMatches params="filter:string, commands:any[]" returns="any[]"
  doc "Rank slash-command matches so prefix hits stay on top while substring hits remain reachable."
  handler <<<
    const normalizedFilter = filter.trim().toLowerCase();
    return commands
      .map((c: any) => {
        const name = c.cmd.toLowerCase().replace(/^\//, '');
        const startsWith = normalizedFilter ? name.startsWith(normalizedFilter) : true;
        const includes = normalizedFilter ? name.includes(normalizedFilter) : true;
        const rank = !normalizedFilter ? 0 : startsWith ? 0 : includes ? 1 : 2;
        const { rank: _rank, ...command } = { ...c, rank };
        return { command, rank };
      })
      .filter((entry: any) => entry.rank < 2)
      .sort((a: any, b: any) => a.rank - b.rank || a.command.cmd.localeCompare(b.command.cmd))
      .map((entry: any) => entry.command);
  >>>

fn name=movePickerCursor params="direction:'up'|'down', currentIndex:number, itemCount:number" returns=number
  doc "Move a picker cursor with wrap-around."
  handler lang="kern"
    if cond="itemCount <= 0"
      return value="0"
    if cond="direction === 'up'"
      return value="currentIndex <= 0 ? itemCount - 1 : currentIndex - 1"
    return value="currentIndex >= itemCount - 1 ? 0 : currentIndex + 1"

fn name=shouldQueuePlanModeOnTab params="opts:{replState:string,inputValue:string,activePlanState?:string|null}" returns=boolean
  doc "Only queue plan mode from Tab when the composer is idle and empty."
  handler lang="kern"
    if cond="opts.replState !== 'idle'"
      return value="false"
    if cond="opts.inputValue.trim()"
      return value="false"
    if cond="opts.activePlanState && ['planning', 'awaiting_approval', 'running', 'paused'].includes(opts.activePlanState)"
      return value="false"
    return value="true"

// ── @-file mentions ─────────────────────────────────────────────────
// Claude-Code-style "@" in the composer opens a fuzzy file picker; on submit,
// each @path that resolves to a real file is read into the turn context so the
// engine sees its content without the user pasting it. The picker reuses the
// codebase map's file walk (collectSourceFiles) as the file source.
//
// Mention syntax rule (email-safe): a mention is "@" at the START of the input
// or immediately after WHITESPACE, followed by one or more non-whitespace path
// chars. So "@src/foo.ts", "@README.md", "@Makefile" are mentions; "user@host"
// and "dev@company.com" are NOT (the "@" is preceded by a word char). The path
// itself stops at the first whitespace, but a trailing "@" boundary punctuation
// (comma / period / semicolon / closing bracket) is trimmed so "see @a.ts." or
// "@a.ts," mention "a.ts", not "a.ts." / "a.ts,".

// Path chars that may end a mention as sentence/clause punctuation and should be
// stripped from the captured path (not part of the filename in normal prose):
//   , . ; : ! ? ) ] } ' "
// NOTE: built by joining single-char literals so the kern attribute-escaper can
// never fold a stray backslash / mangled quote into the set (the prior
// double-quoted attribute form emitted a literal "\\" and broken quotes, so a
// trailing backslash was wrongly stripped). A backslash is NOT trailing prose
// punctuation and must stay out of this set.
const name=MENTION_TRAILING_PUNCT type="string" value={{ [',', '.', ';', ':', '!', '?', ')', ']', '}', "'", '"'].join('') }}

fn name=stripMentionTrailingPunct params="path:string" returns=string export=true
  doc "Trim sentence/clause punctuation from the end of a captured @-mention path so trailing prose punctuation isn't read as part of the filename."
  handler <<<
    let end = path.length;
    while (end > 0 && MENTION_TRAILING_PUNCT.includes(path[end - 1])) end--;
    return path.slice(0, end);
  >>>

fn name=extractFileMentions params="text:string" returns="string[]" export=true
  doc "Extract @-mentioned relative paths from submitted composer text. A mention is '@<path>' where '@' is at string start or follows whitespace (so user@host emails are NOT matched). Trailing prose punctuation is trimmed. Returns de-duplicated paths in first-seen order; never includes the leading '@'."
  handler <<<
    const out: string[] = [];
    const seen = new Set<string>();
    // (^|\s)@ ensures the @ is a fresh token, not the @ inside an email.
    const re = /(^|\s)@([^\s]+)/g;
    let m: RegExpExecArray | null;
    while ((m = re.exec(text)) !== null) {
      const raw = stripMentionTrailingPunct(m[2]);
      if (!raw) continue;
      // Reject mentions that smell like an email local-part artifact (a bare "@"
      // already excluded above) or that contain another "@" — paths don't.
      if (raw.includes('@')) continue;
      if (seen.has(raw)) continue;
      seen.add(raw);
      out.push(raw);
    }
    return out;
  >>>

fn name=parseActiveAtMention params="value:string" returns="{ query: string } | null" export=true
  doc "Given the current composer value, return the active trailing @-mention fragment the picker should filter on, or null if the caret (assumed end-of-input) is not inside a mention. Active means: the last '@' in the value is a valid mention boundary (start or after whitespace) AND no whitespace follows it. The query is the text typed after that '@' (may be empty right after typing '@')."
  handler <<<
    const at = value.lastIndexOf('@');
    if (at < 0) return null;
    // Boundary check: '@' must start the value or follow whitespace.
    if (at > 0 && !/\s/.test(value[at - 1])) return null;
    const after = value.slice(at + 1);
    // A space after the '@' means the mention is finished — picker closes.
    if (/\s/.test(after)) return null;
    return { query: after };
  >>>

fn name=fuzzyFileScore params="query:string, candidate:string" returns="number" export=true
  doc "Subsequence fuzzy score of query against a candidate path (case-insensitive). Returns -1 when query is not a subsequence. Higher is better: contiguous runs, basename hits, and matches near a path segment boundary score higher; earlier matches score higher. Empty query scores all candidates 0 (caller keeps source order)."
  handler <<<
    if (!query) return 0;
    const q = query.toLowerCase();
    const c = candidate.toLowerCase();
    // Fast path: contiguous substring — strongly preferred, basename hit best.
    const subIdx = c.indexOf(q);
    let score = 0;
    let qi = 0;
    let prevMatch = -2;
    let lastSep = -1;
    for (let ci = 0; ci < c.length && qi < q.length; ci++) {
      const ch = c[ci];
      if (ch === '/' ) lastSep = ci;
      if (ch === q[qi]) {
        // Contiguous run bonus.
        if (ci === prevMatch + 1) score += 5; else score += 1;
        // Segment-boundary bonus: matching the first char of a path segment.
        if (ci === 0 || ci === lastSep + 1) score += 3;
        // Earlier matches preferred.
        score += Math.max(0, 4 - Math.floor(ci / 8));
        prevMatch = ci;
        qi++;
      }
    }
    if (qi < q.length) return -1;
    if (subIdx >= 0) score += 8;
    // Basename hit: the contiguous substring sits in the final path segment.
    const slash = c.lastIndexOf('/');
    if (subIdx > slash) score += 6;
    return score;
  >>>

fn name=rankFileMatches params="query:string, files:string[], limit?:number" returns="string[]" export=true
  doc "Rank project file paths against a fuzzy query (subsequence). Non-matches are dropped; ties break on shorter path then lexicographic. Empty query returns the first `limit` files in source order. Capped at `limit` (default 50)."
  handler <<<
    const cap = Math.max(1, Math.floor(limit ?? 50));
    if (!query.trim()) return files.slice(0, cap);
    const scored: { path: string; score: number }[] = [];
    for (const f of files) {
      const s = fuzzyFileScore(query, f);
      if (s >= 0) scored.push({ path: f, score: s });
    }
    scored.sort((a, b) =>
      b.score - a.score ||
      a.path.length - b.path.length ||
      (a.path < b.path ? -1 : a.path > b.path ? 1 : 0)
    );
    return scored.slice(0, cap).map((e) => e.path);
  >>>

fn name=safeCollectSourceFiles params="cwd:string" returns="string[]" export=true
  doc "collectSourceFiles wrapped so a bad cwd / fs error never throws into the keystroke path — returns [] instead. Used to lazily populate the @-file picker on first '@'."
  handler <<<
    try {
      return collectSourceFiles(cwd);
    } catch {
      return [];
    }
  >>>
