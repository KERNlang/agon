// ── Agent progress surface ─────────────────────────────────────────
// Phase 4 of agent-mode: the live view of an autonomous agent turn.
// Driven by OutputEvents (agent-step-start, agent-step-end,
// agent-turn-summary, agent-budget-warning, tool-call) that the
// runAgentMode handler in handlers/agent.kern dispatches.
//
// This file is a pure render surface — Phase 5 will wire it into the
// app shell by subscribing to OutputEvents and passing the current
// snapshot as props.
//
// Note: Kern 3.2.3 correctly emits Ink imports for this hookless surface.
// The explicit React import is kept for clarity and consistency with other
// Ink surfaces, not as a compiler workaround.

import from="react" default="React"
import from="ink" names="Box,Text"
import from="../blocks/output-format.js" names="ENGINE_COLORS"
import from="@kernlang/agon-core" names="AgentPhase" types=true

// ── Helpers ────────────────────────────────────────────────────────

fn name=phaseGlyph params="phase:string" returns=string export=false
  doc "Map an AgentPhase kind to a single-char status glyph."
  handler <<<
    if (phase === 'running') return '\u25cf'; // ●
    if (phase === 'awaiting_approval') return '\u25c6'; // ◆
    if (phase === 'completed') return '\u2713'; // ✓
    if (phase === 'failed') return '\u2717'; // ✗
    if (phase === 'cancelled') return '\u25ce'; // ◎
    return '\u00b7'; // ·
  >>>

fn name=phaseColor params="phase:string" returns=string export=false
  doc "Terminal color for a phase glyph."
  handler lang="kern"
    if cond="phase === 'running'"
      return value="'#fbbf24'"
    if cond="phase === 'awaiting_approval'"
      return value="'#60a5fa'"
    if cond="phase === 'completed'"
      return value="'#22c55e'"
    if cond="phase === 'failed'"
      return value="'#ef4444'"
    if cond="phase === 'cancelled'"
      return value="'#9ca3af'"
    return value="'#6b7280'"

fn name=progressBar params="pct:number,width:number" returns=string export=false
  doc "Unicode block-bar string. pct in [0,1], width is cell count."
  handler lang="kern"
    let name=p value="Math.max(0, Math.min(1, pct))"
    let name=filled value="Math.round(p * width)"
    let name=empty value="width - filled"
    return value="'█'.repeat(filled) + '░'.repeat(empty)"

fn name=formatElapsed params="ms:number" returns=string export=false
  doc "Human-readable elapsed time (e.g. '42s', '3m12s', '1h04m')."
  handler lang="kern"
    let name=secs value="Math.floor(ms / 1000)"
    if cond="secs < 60"
      fmt return=true template="${secs}s"
    let name=mins value="Math.floor(secs / 60)"
    let name=rem value="secs % 60"
    if cond="mins < 60"
      fmt return=true template="${mins}m${rem.toString().padStart(2, '0')}s"
    let name=hours value="Math.floor(mins / 60)"
    let name=mrem value="mins % 60"
    fmt return=true template="${hours}h${mrem.toString().padStart(2, '0')}m"

fn name=formatTokens params="tokens:number" returns=string export=false
  doc "Render token count as 1.2k, 45k, 1.4M."
  handler lang="kern"
    if cond="tokens < 1000"
      return value="`${tokens} tok`"
    if cond="tokens < 1_000_000"
      return value="`${(tokens / 1000).toFixed(1)}k tok`"
    return value="`${(tokens / 1_000_000).toFixed(2)}M tok`"

// ── Screen: AgentProgressView ──────────────────────────────────────

screen name=AgentProgressView target=ink memo=true
  prop name=engineId type=string
  prop name=turnIndex type=number
  prop name=phase type="'idle'|'running'|'awaiting_approval'|'completed'|'failed'|'cancelled'"
  prop name=userPrompt type=string optional=true
  prop name=toolCalls type=number
  prop name=lastTool type=string optional=true
  prop name=lastToolStatus type="'running'|'ok'|'error'|'rejected'" optional=true
  prop name=tokensUsed type=number
  prop name=elapsedMs type=number
  prop name=turnsRemaining type=number
  prop name=maxTurns type=number
  prop name=tokensRemaining type="number|null" optional=true
  prop name=maxTokens type="number|null" optional=true
  prop name=error type=string optional=true
  render
    handler <<<
      const glyph = phaseGlyph(phase);
      const pColor = phaseColor(phase);
      const engineColor = '#' + (ENGINE_COLORS[engineId] ? ENGINE_COLORS[engineId].toString(16).padStart(6, '0') : '60a5fa');

      // Turn budget bar
      const turnsUsed = maxTurns - turnsRemaining;
      const turnPct = maxTurns > 0 ? turnsUsed / maxTurns : 0;
      const turnBar = progressBar(turnPct, 10);
      const turnBarColor = turnPct > 0.8 ? '#ef4444' : turnPct > 0.6 ? '#fbbf24' : '#4ade80';

      // Token budget bar (only when maxTokens is set)
      let tokBar: string | null = null;
      let tokBarColor = '#4ade80';
      let tokPctLabel = '';
      if (maxTokens && maxTokens > 0 && tokensRemaining != null) {
        const tokUsed = maxTokens - tokensRemaining;
        const tokPct = tokUsed / maxTokens;
        tokBar = progressBar(tokPct, 10);
        tokBarColor = tokPct > 0.8 ? '#ef4444' : tokPct > 0.6 ? '#fbbf24' : '#4ade80';
        tokPctLabel = ` ${Math.round(tokPct * 100)}%`;
      }

      const lastToolDisplay = lastTool ? (lastTool.length > 42 ? lastTool.slice(0, 39) + '...' : lastTool) : null;
      const toolColor = lastToolStatus === 'error' ? '#ef4444'
                      : lastToolStatus === 'rejected' ? '#f97316'
                      : lastToolStatus === 'ok' ? '#22c55e'
                      : '#fbbf24';

      return (
        <Box flexDirection="column" paddingLeft={1}>
          {/* Header line: engine, turn index, phase */}
          <Box>
            <Text dimColor>{'\u256d\u2500 '}</Text>
            <Text bold color={engineColor}>{engineId}</Text>
            <Text dimColor>{' \u00b7 turn '}</Text>
            <Text>{String(turnIndex + 1)}</Text>
            <Text dimColor>{'/'}</Text>
            <Text>{String(maxTurns)}</Text>
            <Text dimColor>{' \u00b7 '}</Text>
            <Text color={pColor}>{glyph}</Text>
            <Text color={pColor}>{' ' + phase}</Text>
          </Box>

          {/* User prompt (truncated) */}
          {userPrompt ? (
            <Box>
              <Text dimColor>{'\u2502 '}</Text>
              <Text dimColor>{userPrompt.length > 60 ? userPrompt.slice(0, 57) + '...' : userPrompt}</Text>
            </Box>
          ) : null}

          {/* Stats line: tool count, tokens, elapsed */}
          <Box>
            <Text dimColor>{'\u2502 '}</Text>
            <Text>{toolCalls > 0 ? `${toolCalls} tool${toolCalls === 1 ? '' : 's'}` : 'no tools yet'}</Text>
            <Text dimColor>{' \u00b7 '}</Text>
            <Text>{formatTokens(tokensUsed)}</Text>
            <Text dimColor>{' \u00b7 '}</Text>
            <Text>{formatElapsed(elapsedMs)}</Text>
          </Box>

          {/* Current/last tool */}
          {lastToolDisplay ? (
            <Box>
              <Text dimColor>{'\u2502 '}</Text>
              <Text dimColor>{'\u2514\u2500 '}</Text>
              <Text color={toolColor}>{lastToolDisplay}</Text>
            </Box>
          ) : null}

          {/* Turn budget bar */}
          <Box>
            <Text dimColor>{'\u2502 '}</Text>
            <Text dimColor>{'turns   '}</Text>
            <Text color={turnBarColor}>{turnBar}</Text>
            <Text dimColor>{` ${turnsUsed}/${maxTurns}`}</Text>
          </Box>

          {/* Token budget bar (conditional) */}
          {tokBar ? (
            <Box>
              <Text dimColor>{'\u2502 '}</Text>
              <Text dimColor>{'tokens  '}</Text>
              <Text color={tokBarColor}>{tokBar}</Text>
              <Text dimColor>{tokPctLabel}</Text>
            </Box>
          ) : null}

          {/* Error line when failed */}
          {error && (phase === 'failed' || phase === 'cancelled') ? (
            <Box>
              <Text dimColor>{'\u2502 '}</Text>
              <Text color="#ef4444">{error.length > 70 ? error.slice(0, 67) + '...' : error}</Text>
            </Box>
          ) : null}

          <Text dimColor>{'\u2570\u2500'}</Text>
        </Box>
      );
    >>>
