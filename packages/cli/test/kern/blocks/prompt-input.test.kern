test name="Prompt input block" target="../../../src/kern/blocks/prompt-input.kern"
  it name="prompt input stays valid KERN"
    expect no=schemaViolations
    expect no=semanticViolations
    expect no=codegenErrors

  it name="wrapPromptText wraps by fixed terminal width"
    expect fn=wrapPromptText args={{["abcd", 2]}} equals={{["ab", "cd"]}}
    expect fn=wrapPromptText args={{["a\nbc", 2]}} equals={{["a", "bc"]}}
    expect fn=wrapPromptText args={{["abc", 0]}} equals={{["a", "b", "c"]}}
    expect fn=wrapPromptText args={{["abcdefgh", 4]}} equals={{["abcd", "efgh"]}}
    expect fn=wrapPromptText args={{["ab\ncdef", 3]}} equals={{["ab", "cde", "f"]}}

  it name="cursor and viewport helpers keep stable boundaries"
    expect fn=locatePromptCursor args={{["abcd", 2, 2]}} equals={{ { line: 1, column: 0, synthetic: false } }}
    expect fn=locatePromptCursor args={{["abcde", 4, 4]}} equals={{ { line: 1, column: 0, synthetic: false } }}
    expect fn=locatePromptCursor args={{["ab\ncd", 4, 2]}} equals={{ { line: 0, column: 2, synthetic: true } }}
    expect fn=selectPromptViewport args={{[10, 7, 4]}} equals={{ { start: 6, end: 10, hiddenAbove: 6, hiddenBelow: 0 } }}
    expect fn=selectPromptViewport args={{[8, 5, 3]}} equals={{ { start: 4, end: 7, hiddenAbove: 4, hiddenBelow: 1 } }}
    expect fn=selectPromptViewport args={{[2, 1, 4]}} equals={{ { start: 0, end: 2, hiddenAbove: 0, hiddenBelow: 0 } }}

  it name="terminal escape noise stays out of prompt state"
    expect node=fn name=isMouseReportInput prop=returns is=boolean
    expect node=fn name=stripMouseReportInput prop=returns is=string

  it name="prompt echo adoption avoids stale buffered values"
    expect fn=shouldAdoptPromptValue args={{["", "remote"]}} equals=true
    expect fn=shouldAdoptPromptValue args={{["hello", "hello"]}} equals=true
    expect fn=shouldAdoptPromptValue args={{["hel", "hello"]}} equals=false
    expect fn=shouldAdoptPromptValue args={{["hello", null]}} equals=true
    expect fn=shouldAdoptPromptValue args={{["a", "ab"]}} equals=false
    expect fn=shouldAdoptPromptValue args={{["abc", "abcd"]}} equals=false
    expect fn=shouldAdoptPromptValue args={{["/history", "ab"]}} equals=true

  it name="shortcut delegation remains explicit"
    expect node=fn name=isDelegatedCtrlShortcut prop=returns is=boolean
    expect node=fn name=isDelegatedCtrlShortcut prop=export is=true

  it name="reserved plain keys defer only when empty, plain, and exact-case"
    # lowercase u/l/x on an empty composer defer to the global banner handler
    expect fn=shouldDeferReservedPlainKey args={{["u", false, false, "", ["u", "l", "x"]]}} equals=true
    expect fn=shouldDeferReservedPlainKey args={{["x", false, false, "", ["u", "l", "x"]]}} equals=true
    # uppercase is case-SENSITIVE → types normally (not deferred)
    expect fn=shouldDeferReservedPlainKey args={{["U", false, false, "", ["u", "l", "x"]]}} equals=false
    # non-empty composer → user is typing, insert normally
    expect fn=shouldDeferReservedPlainKey args={{["u", false, false, "hi", ["u", "l", "x"]]}} equals=false
    # no reserved keys (banner hidden) → never defer
    expect fn=shouldDeferReservedPlainKey args={{["u", false, false, "", []]}} equals=false
    # Ctrl / special-key signals → never defer (Ctrl+U is line-kill, etc.)
    expect fn=shouldDeferReservedPlainKey args={{["u", true, false, "", ["u", "l", "x"]]}} equals=false
    expect fn=shouldDeferReservedPlainKey args={{["u", false, true, "", ["u", "l", "x"]]}} equals=false
    # an unrelated plain char → never defer
    expect fn=shouldDeferReservedPlainKey args={{["a", false, false, "", ["u", "l", "x"]]}} equals=false
