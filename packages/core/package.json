{
  "name": "@kernlang/agon-core",
  "version": "0.2.4",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "kern:compile": "node ../../scripts/run-kern-compile.mjs src/kern/ src/generated/ --target=auto --recursive --postcompile=scripts/kern-postcompile.sh",
    "prebuild": "npm run kern:compile",
    "build": "tsup && tsc -b tsconfig.json --force",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@kernlang/agon-dedup": "^0.2.4",
    "@kernlang/agon-engines": "^0.1.2",
    "@kernlang/context": "~4.5.0",
    "@ai-sdk/anthropic": "^3.0.67",
    "@ai-sdk/openai-compatible": "^2.0.40",
    "ai": "^6.0.149"
  },
  "optionalDependencies": {}
}
