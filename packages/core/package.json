{
  "name": "@agon/core",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "kern:compile": "for d in models signals blocks cesar tools api sessions teams; do kern compile src/kern/$d --outdir=src/generated/$d; done && bash scripts/kern-postcompile.sh",
    "prebuild": "npm run kern:compile",
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.67",
    "@ai-sdk/openai-compatible": "^2.0.40",
    "ai": "^6.0.149",
    "kern-lang": "file:../../../kern-lang/packages/cli"
  }
}
