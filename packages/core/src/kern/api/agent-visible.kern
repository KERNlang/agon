import from="../tools/tool-parser.js" names="parseToolCalls"

fn name=safeAgentVisibleText params="text:string|null|undefined" returns=string export=true
  doc "Extract visible API-agent prose without ever forwarding complete, truncated, or provider-specific tool markup."
  handler <<<
    const raw = String(text ?? '').trim();
    if (!raw) return '';
    const parsed = parseToolCalls(raw);
    if (parsed.hasToolCalls) {
      return [parsed.textBefore, parsed.textAfter].filter(Boolean).join('\n\n').trim();
    }
    // The shared parser needs a complete call. Provider streams may end in a
    // partial wrapper, so reject every known tool-tag prefix fail-closed.
    if (/<\/?(?:tool|function|invoke|antml|minimax:)/i.test(raw)) return '';
    return raw;
  >>>
