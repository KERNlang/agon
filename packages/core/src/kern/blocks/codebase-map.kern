// Codebase Map / "Project Atlas" — a compact, cheap-to-build index of WHERE
// code lives, injected into Cesar's per-turn context so it stops re-grepping to
// locate things. Built from a filesystem walk + regex symbol extraction (no
// compiler pass). Two-layer cache: an in-process memo per cwd (session-level)
// backed by a disk cache at ~/.agon/cache/codebase-map/<key>.json, invalidated
// when git HEAD or a lockfile changes — plus a TTL backstop so uncommitted
// working-tree edits can't serve a stale brief forever. See
// [[project-cesar-harness-rework]].
import from="node:fs" names="readFileSync,readdirSync,statSync,lstatSync,writeFileSync,mkdirSync,existsSync,rmSync"
import from="node:path" names="join,relative"
import from="node:crypto" names="createHash"
import from="../signals/config.js" names="agonPath"
import from="./git.js" names="headSha"

// Directories that never carry useful "where things live" signal for the brief.
const name=MAP_IGNORE_DIRS type="Set<string>" value={{ new Set(['node_modules', '.git', 'dist', 'dist-tsc', '.next', '.cache', '.turbo', '__pycache__', '.venv', 'venv', 'coverage', '.kern-gaps', '.agon', '.claude', 'worktrees', 'build', 'out', '.idea', '.vscode']) }}

// Source extensions we index. Order matters only for display grouping.
const name=MAP_SOURCE_EXT type="string[]" value={{ ['.kern', '.ts', '.tsx', '.py', '.js', '.jsx'] }}

// Caps so a large repo can't blow build time or the token budget.
const name=MAP_MAX_FILES_WALKED type=number value={{ 6000 }}
const name=MAP_MAX_FILES_READ type=number value={{ 600 }}
const name=MAP_MAX_FILE_BYTES type=number value={{ 262144 }}

// In-process memo (L1): keyed by cwd, holds the brief + the signature it was
// built for, and is backed by the disk cache (L2). Storing the signature lets a
// warm memo hit re-validate against the CURRENT signature, so a mid-session
// commit / branch-switch / lockfile change refreshes the brief instead of
// serving a stale one for the whole process. The Map binding is const; its
// contents mutate.
const name=MAP_MEMO type="Map<string,{sig:string,brief:string}>" value={{ new Map() }}

// Lockfiles whose mtime is folded into the cache signature so the disk cache
// invalidates when dependencies change. First match wins.
const name=MAP_LOCKFILES type="string[]" value={{ ['package-lock.json', 'pnpm-lock.yaml', 'yarn.lock', 'bun.lockb'] }}

// TTL backstop so uncommitted working-tree edits (which move neither git HEAD
// nor a lockfile) can't serve a stale disk cache forever. 6h.
const name=MAP_CACHE_TTL_MS type=number value={{ 6 * 60 * 60 * 1000 }}

fn name=mapSourceExt params="path:string" returns="string|null" export=false
  doc "Return the indexed source extension of a path, or null if it is not an indexed source file."
  handler <<<
    const dot = path.lastIndexOf('.');
    if (dot < 0) return null;
    const ext = path.slice(dot);
    return MAP_SOURCE_EXT.includes(ext) ? ext : null;
  >>>

fn name=collectSourceFiles params="root:string" returns="string[]" export=true
  doc "Walk the tree from root (excluding noise dirs) and return repo-relative paths of indexed source files. Capped at MAP_MAX_FILES_WALKED for safety on huge trees."
  handler <<<
    const out: string[] = [];
    const stack: string[] = [root];
    while (stack.length > 0 && out.length < MAP_MAX_FILES_WALKED) {
      const dir = stack.pop()!;
      let entries: string[];
      try { entries = readdirSync(dir); } catch { continue; }
      for (const entry of entries) {
        if (entry.startsWith('.DS_')) continue;
        const full = join(dir, entry);
        // lstat (not stat) so we DON'T follow symlinks: a directory symlink can
        // form a cycle (infinite walk — the file cap only bounds files FOUND,
        // not dirs visited) or point outside the repo. Skip symlinks entirely.
        let st: ReturnType<typeof lstatSync>;
        try { st = lstatSync(full); } catch { continue; }
        if (st.isSymbolicLink()) continue;
        if (st.isDirectory()) {
          if (!MAP_IGNORE_DIRS.has(entry)) stack.push(full);
          continue;
        }
        if (mapSourceExt(entry)) out.push(relative(root, full));
        if (out.length >= MAP_MAX_FILES_WALKED) break;
      }
    }
    out.sort();
    return out;
  >>>

fn name=extractSymbols params="relPath:string, content:string" returns="string[]" export=true
  doc "Regex-extract top-level declared/exported symbols from a source file. Cheap and language-aware (KERN node decls, TS/JS exports, Python def/class). Returns a de-duplicated, capped list of names — enough to answer 'where does X live', not a full AST."
  handler <<<
    const ext = mapSourceExt(relPath);
    const names: string[] = [];
    const push = (n: string | undefined) => { if (n && !names.includes(n)) names.push(n); };
    if (ext === '.kern') {
      // KERN declarations: `fn name=X`, `service name=X`, `union name=X`,
      // `interface name=X`, `const name=X`, `screen name=X`, `machine name=X`,
      // `event name=X`, `type name=X`.
      const re = /\b(?:fn|service|union|interface|const|screen|machine|event|type)\s+name=([A-Za-z0-9_$]+)/g;
      let m: RegExpExecArray | null;
      while ((m = re.exec(content)) !== null) push(m[1]);
    } else if (ext === '.py') {
      const re = /^\s*(?:async\s+)?(?:def|class)\s+([A-Za-z0-9_]+)/gm;
      let m: RegExpExecArray | null;
      while ((m = re.exec(content)) !== null) push(m[1]);
    } else {
      // TS/TSX/JS/JSX: exported value/type declarations.
      const re = /^\s*export\s+(?:default\s+)?(?:async\s+)?(?:function|const|let|var|class|interface|type|enum)\s+([A-Za-z0-9_$]+)/gm;
      let m: RegExpExecArray | null;
      while ((m = re.exec(content)) !== null) push(m[1]);
    }
    return names.slice(0, 12);
  >>>

fn name=topLevelGroup params="relPath:string" returns=string export=false
  doc "Group key for a repo-relative path: 'packages/<name>' for a monorepo package, else the first path segment, else '(root)'."
  handler <<<
    const parts = relPath.split('/');
    if (parts[0] === 'packages' && parts.length > 1) return `packages/${parts[1]}`;
    if (parts.length > 1) return parts[0];
    return '(root)';
  >>>

fn name=mapCacheDir returns=string export=false expr={{ return agonPath('cache', 'codebase-map'); }}
  doc "Directory holding per-project codebase-brief disk caches. Honors AGON_HOME."

fn name=mapCacheKey params="cwd:string" returns=string export=false expr={{ return createHash('sha1').update(cwd).digest('hex').slice(0, 16); }}
  doc "Stable short filename key for a project root."

fn name=mapCacheFile params="cwd:string" returns=string export=false expr={{ return join(mapCacheDir(), `${mapCacheKey(cwd)}.json`); }}

fn name=mapCacheSignature params="cwd:string" returns=string export=false
  doc "Cheap invalidation signature: git HEAD SHA + newest lockfile mtime ('nogit'/'0' when absent). Spawns git once per session, behind the L1 memo."
  handler <<<
    let head = 'nogit';
    try { head = headSha(cwd); } catch { /* not a git repo */ }
    let lockMtime = '0';
    for (const lf of MAP_LOCKFILES) {
      try { lockMtime = String(Math.round(statSync(join(cwd, lf)).mtimeMs)); break; }
      catch { /* lockfile absent */ }
    }
    return `${head}:${lockMtime}`;
  >>>

fn name=readMapDiskCache params="cwd:string, sig:string" returns="string|null" export=false
  doc "Return the cached brief if the disk cache exists, matches the signature, and is within TTL; else null. Never throws."
  handler <<<
    try {
      const path = mapCacheFile(cwd);
      if (!existsSync(path)) return null;
      const raw = JSON.parse(readFileSync(path, 'utf-8')) as { sig?: string; brief?: string; builtAt?: number };
      if (raw.sig !== sig) return null;
      if (typeof raw.builtAt === 'number' && Date.now() - raw.builtAt > MAP_CACHE_TTL_MS) return null;
      return typeof raw.brief === 'string' ? raw.brief : null;
    } catch { return null; }
  >>>

fn name=writeMapDiskCache params="cwd:string, sig:string, brief:string" returns=void export=false
  doc "Persist the brief + signature to the disk cache. Best-effort; never throws."
  handler <<<
    try {
      mkdirSync(mapCacheDir(), { recursive: true });
      writeFileSync(mapCacheFile(cwd), JSON.stringify({ sig, brief, builtAt: Date.now() }));
    } catch { /* cache write is best-effort */ }
  >>>

fn name=composeBrief params="cwd:string, cap:number" returns=string export=false
  doc "Build the CODEBASE BRIEF for cwd capped at `cap` chars. Pure (no caching) — the cacheable core of buildCodebaseMap."
  handler <<<
    const files = collectSourceFiles(cwd);
    if (files.length === 0) return '';

    // Identify generated files + .kern sources so we can note the mirror once,
    // and exclude generated .ts from the per-file symbol listing (it duplicates
    // the .kern source the user should edit instead).
    const generatedCount = files.filter((f: string) => f.includes('/generated/')).length;
    const kernCount = files.filter((f: string) => f.endsWith('.kern')).length;

    // Group files by package/top-level dir. Within a group, prefer .kern + hand
    // TS over generated mirrors for the symbol listing.
    const groups = new Map<string, string[]>();
    for (const f of files) {
      const g = topLevelGroup(f);
      const arr = groups.get(g) ?? [];
      arr.push(f);
      groups.set(g, arr);
    }

    let filesRead = 0;
    const lines: string[] = [];
    // Track the running length incrementally instead of re-joining `lines` on
    // every iteration (that was O(n²) over up to MAP_MAX_FILES_READ files). The
    // +1 per line counts the joining newline; it over-counts the budget by one
    // line, which is harmless for the cap/per-group comparisons (deltas stay
    // exact) — the final slice below bounds the real string length.
    let totalLen = 0;
    const addLine = (s: string) => { lines.push(s); totalLen += s.length + 1; };
    addLine('## CODEBASE BRIEF (where things live — prefer this over searching)');
    if (kernCount > 0 && generatedCount > 0) {
      addLine(`KERN project: ${kernCount} .kern sources compile to generated/ TS mirrors — EDIT THE .kern, not generated/.`);
    }

    const groupNames = Array.from(groups.keys()).sort();
    // Breadth before depth: give each group a fair slice of the budget so a huge
    // package (e.g. packages/cli) can't consume the whole brief and starve the
    // others. Small groups under-spend their slice, leaving global slack; the
    // hard `cap` below still bounds the total. Clamp to `cap` so a tiny custom
    // cap (< 300) can't hand one group more than the whole budget.
    const perGroupBudget = Math.min(cap, Math.max(300, Math.floor(cap / Math.max(1, groupNames.length))));
    for (const g of groupNames) {
      if (totalLen > cap) break;
      const groupFiles = (groups.get(g) ?? []).filter((f: string) => !f.includes('/generated/'));
      if (groupFiles.length === 0) continue;
      // Surface .kern sources first: they're the editable truth, whereas the
      // hand-TS files are mostly thin re-export facades. Without this, plain
      // alphabetical order shows facades (src/blocks, src/commands) and cuts off
      // the src/kern/* sources before the per-group budget reaches them.
      groupFiles.sort((a: string, b: string) => {
        const ak = a.endsWith('.kern') ? 0 : 1;
        const bk = b.endsWith('.kern') ? 0 : 1;
        if (ak !== bk) return ak - bk;
        return a < b ? -1 : a > b ? 1 : 0;
      });
      const groupStart = totalLen;
      addLine(`\n### ${g} (${groupFiles.length} files)`);
      // List up to 12 files per group with their top symbols, stopping early once
      // this group has used its fair share (but always showing at least one).
      let shown = 0;
      for (const f of groupFiles.slice(0, 12)) {
        if (totalLen > cap) break;
        if (shown > 0 && totalLen - groupStart > perGroupBudget) break;
        let syms: string[] = [];
        if (filesRead < MAP_MAX_FILES_READ) {
          try {
            const st = statSync(join(cwd, f));
            if (st.size <= MAP_MAX_FILE_BYTES) {
              syms = extractSymbols(f, readFileSync(join(cwd, f), 'utf-8'));
              filesRead++;
            }
          } catch { /* unreadable — list the path without symbols */ }
        }
        addLine(syms.length > 0 ? `- ${f}: ${syms.join(', ')}` : `- ${f}`);
        shown++;
      }
      const extra = groupFiles.length - shown;
      if (extra > 0) addLine(`  (+${extra} more files in ${g})`);
    }

    let brief = lines.join('\n');
    if (brief.length > cap) brief = brief.slice(0, cap) + '\n... (brief truncated)';
    return brief;
  >>>

fn name=buildCodebaseMap params="cwd:string, maxChars?:number" returns=string export=true
  doc "Build the compact CODEBASE BRIEF for cwd: a where-things-live index grouped by package/dir, listing source files with their top symbols and noting .kern->generated mirroring. Cheap (fs walk + regex). Two-layer cached: an in-process memo (session) backed by a disk cache invalidated on git HEAD / lockfile change (default cap only); a custom maxChars bypasses both caches. Returns '' if nothing indexable. Cap defaults to ~3500 chars."
  handler <<<
    // A custom cap is a one-off (e.g. tests) — compose fresh, bypass both caches.
    if (maxChars !== undefined) return composeBrief(cwd, Math.max(1, maxChars));
    // Compute the signature first and validate BOTH cache layers against it, so a
    // warm memo can't serve a brief from a stale HEAD/lockfile (the L1 memo used
    // to return on a cwd hit before checking the signature — three reviewers
    // flagged that it contradicted the stated git-HEAD invalidation).
    const sig = mapCacheSignature(cwd);
    const cached = MAP_MEMO.get(cwd);
    if (cached !== undefined && cached.sig === sig) return cached.brief;
    const fromDisk = readMapDiskCache(cwd, sig);
    if (fromDisk !== null) { MAP_MEMO.set(cwd, { sig, brief: fromDisk }); return fromDisk; }
    const brief = composeBrief(cwd, 3500);
    writeMapDiskCache(cwd, sig, brief);
    MAP_MEMO.set(cwd, { sig, brief });
    return brief;
  >>>

fn name=clearCodebaseMapCache params="cwd?:string" returns=void export=true
  doc "Drop the codebase atlas caches — both the in-process memo and the disk cache — for one cwd, or all. git HEAD / lockfile changes invalidate the disk cache automatically; call this to force a rebuild."
  handler <<<
    if (cwd) {
      MAP_MEMO.delete(cwd);
      try { rmSync(mapCacheFile(cwd), { force: true }); } catch { /* best-effort */ }
    } else {
      MAP_MEMO.clear();
      try { rmSync(mapCacheDir(), { recursive: true, force: true }); } catch { /* best-effort */ }
    }
  >>>
