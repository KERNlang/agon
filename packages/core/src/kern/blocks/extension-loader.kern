// ── Extension Loader: discovery, loading, registration ──────────────
// Discovers extensions from ~/.agon/extensions/ and .agon/extensions/,
// validates manifests, and wires contributions into registries.

import from="node:path" names="join,resolve"
import from="node:fs" names="readdirSync,readFileSync,existsSync,statSync"
import from="node:os" names="homedir"
import from="../models/extension-manifest.js" names="validateManifest"
import from="../models/extension-manifest.js" names="ExtensionManifest,LoadedExtension,CommandContribution" types=true
import from="../signals/command-registry.js" names="CommandRegistry"
import from="../signals/command-registry.js" names="CommandHandler" types=true
import from="../signals/engine-registry.js" names="EngineRegistry"
import from="./host-runtime.js" names="hostLog,hostNowMs,hostWarn"
import from="./skill-loader.js" names="Skill" types=true
import from="../signals/event-bus.js" names="EventBus"

fn name=discoverExtensionDirs params="cwd:string" returns="{ dir: string; source: 'user' | 'repo' }[]"
  doc "Scan ~/.agon/extensions/ and <cwd>/.agon/extensions/ for extension directories."
  handler <<<
    const results: { dir: string; source: 'user' | 'repo' }[] = [];

    // User-level extensions
    const override = process.env.AGON_HOME?.trim();
    const home = override ? resolve(override) : join(homedir(), '.agon');
    const userDir = join(home, 'extensions');
    if (existsSync(userDir)) {
      try {
        const entries = readdirSync(userDir, { withFileTypes: true });
        for (const entry of entries) {
          if (entry.isDirectory()) {
            const manifestPath = join(userDir, entry.name, 'manifest.json');
            if (existsSync(manifestPath)) {
              results.push({ dir: join(userDir, entry.name), source: 'user' });
            }
          }
        }
      } catch { /* permission denied or missing dir — skip extensions */ }
    }

    // Repo-level extensions
    const repoDir = join(cwd, '.agon', 'extensions');
    if (existsSync(repoDir)) {
      try {
        const entries = readdirSync(repoDir, { withFileTypes: true });
        for (const entry of entries) {
          if (entry.isDirectory()) {
            const manifestPath = join(repoDir, entry.name, 'manifest.json');
            if (existsSync(manifestPath)) {
              results.push({ dir: join(repoDir, entry.name), source: 'repo' });
            }
          }
        }
      } catch { /* permission denied or missing dir — skip extensions */ }
    }

    return results;
  >>>

fn name=loadExtensionManifest params="dir:string, source:'builtin'|'user'|'repo'" returns="LoadedExtension | null"
  doc "Read and validate a manifest.json from an extension directory."
  handler lang="kern"
    let name=manifestPath value="join(dir, 'manifest.json')"
    try
      let name=raw value="JSON.parse(readFileSync(manifestPath, 'utf-8'))"
      let name=result value="validateManifest(raw, manifestPath)"
      if cond="!result.ok || !result.data"
        do value="hostWarn(`[agon] skipping extension ${dir}: ${result.error}`)"
        return value="null"
      return value="{ manifest: result.data, dir, source, loadedAt: hostNowMs() }"
      catch name=err
        do value="hostWarn(`[agon] failed to load extension ${dir}: ${(err as Error).message}`)"
        return value="null"

fn name=loadExtensions params="cwd:string" returns="LoadedExtension[]"
  doc "Discover and load all extensions. Later source wins for duplicate IDs."
  handler <<<
    const dirs = discoverExtensionDirs(cwd);
    const byId = new Map<string, LoadedExtension>();

    for (const { dir, source } of dirs) {
      const ext = loadExtensionManifest(dir, source);
      if (ext) {
        if (byId.has(ext.manifest.id)) {
          console.warn(`[agon] extension '${ext.manifest.id}' from ${source} overrides earlier definition`);
        }
        byId.set(ext.manifest.id, ext);
      }
    }

    return Array.from(byId.values());
  >>>

fn name=registerExtensionCommands async=true params="ext:LoadedExtension, commandRegistry:CommandRegistry" returns="Promise<string[]>"
  doc "Dynamically import command handlers from an extension and register them."
  handler <<<
    const registered: string[] = [];
    const commands = ext.manifest.contributes?.commands;
    if (!commands || commands.length === 0) return registered;

    for (const cmd of commands) {
      try {
        const handlerPath = resolve(ext.dir, cmd.handler);
        const mod = await import(handlerPath);

        if (typeof mod.execute !== 'function') {
          console.warn(`[agon] extension '${ext.manifest.id}' command '${cmd.name}': handler missing execute() export`);
          continue;
        }

        const handler: CommandHandler = {
          definition: {
            name: cmd.name,
            description: cmd.description || '',
            category: cmd.category || 'extension',
            aliases: cmd.aliases,
            source: ext.manifest.id,
          },
          parseArgs: typeof mod.parseArgs === 'function'
            ? mod.parseArgs
            : (rest: string) => ({ input: rest }),
          execute: mod.execute,
        };

        commandRegistry.register(handler);
        registered.push(cmd.name);
      } catch (err) {
        console.warn(`[agon] extension '${ext.manifest.id}' command '${cmd.name}': failed to load handler: ${(err as Error).message}`);
        const errorExt = ext as { errors?: string[] };
        if (!errorExt.errors) errorExt.errors = [];
        errorExt.errors.push(`command ${cmd.name}: ${(err as Error).message}`);
      }
    }

    return registered;
  >>>

fn name=registerExtensionEngines params="ext:LoadedExtension, engineRegistry:EngineRegistry" returns="string[]"
  doc "Load engine JSON definitions from an extension and register them."
  handler lang="kern"
    let name=registered type="string[]" value="[]"
    let name=enginePaths value="ext.manifest.contributes?.engines"
    if cond="!enginePaths || enginePaths.length === 0"
      return value="registered"
    each name=enginePath in="enginePaths"
      try
        let name=fullPath value="resolve(ext.dir, enginePath)"
        let name=raw value="JSON.parse(readFileSync(fullPath, 'utf-8'))"
        if cond="raw.id"
          do value="engineRegistry.register(raw)"
          do value="registered.push(raw.id)"
        catch name=err
          do value="hostWarn(`[agon] extension '${ext.manifest.id}' engine '${enginePath}': ${(err as Error).message}`)"
    return value="registered"

fn name=registerExtensionSkills params="ext:LoadedExtension" returns="Skill[]"
  doc "Convert skill contributions to Skill objects. Supports both inline prompts and handler-based skills."
  handler <<<
    const skills: Skill[] = [];
    const skillContribs = ext.manifest.contributes?.skills;
    if (!skillContribs || skillContribs.length === 0) return skills;

    for (const sc of skillContribs) {
      const skill: Skill = {
        name: sc.name || sc.trigger.replace(/^\//, ''),
        trigger: sc.trigger.startsWith('/') ? sc.trigger : '/' + sc.trigger,
        description: sc.description || '',
        prompt: sc.prompt || '',
        source: resolve(ext.dir, 'manifest.json'),
        tools: sc.tools,
      };

      if (sc.handler) {
        try {
          const handlerPath = resolve(ext.dir, sc.handler);
          // Dynamic import is async but registerExtensionSkills is sync.
          // Store the path — the handler will be loaded lazily on first invocation.
          (skill as any)._handlerPath = handlerPath;
          skill.handler = async (args: string, ctx: any) => {
            // Lazy-load the handler module on first call
            const mod = await import(handlerPath);
            if (typeof mod.execute !== 'function') {
              ctx.dispatch({ type: 'warning', message: `Skill handler '${sc.trigger}' missing execute() export` });
              return { handled: false };
            }
            return mod.execute(args, ctx);
          };
        } catch (err) {
          console.warn(`[agon] extension '${ext.manifest.id}' skill '${sc.trigger}': failed to set up handler: ${(err as Error).message}`);
        }
      }

      skills.push(skill);
    }

    return skills;
  >>>

fn name=registerExtensionHooks async=true params="ext:LoadedExtension, eventBus:EventBus" returns="Promise<string[]>"
  doc "Dynamically import hook handlers from an extension and register them on the event bus."
  handler <<<
    const registered: string[] = [];
    const hookContribs = ext.manifest.contributes?.hooks;
    if (!hookContribs || hookContribs.length === 0) return registered;

    for (const hook of hookContribs) {
      try {
        const handlerPath = resolve(ext.dir, hook.handler);
        const mod = await import(handlerPath);
        if (typeof mod.handler !== 'function' && typeof mod.default !== 'function') {
          console.warn(`[agon] extension '${ext.manifest.id}' hook '${hook.event}': handler missing handler() or default() export`);
          continue;
        }
        const fn = mod.handler ?? mod.default;
        eventBus.on(hook.event, fn, hook.priority ?? 100, ext.manifest.id);
        registered.push(hook.event);
      } catch (err) {
        console.warn(`[agon] extension '${ext.manifest.id}' hook '${hook.event}': ${(err as Error).message}`);
      }
    }

    return registered;
  >>>

fn name=initExtensions async=true params="cwd:string, commandRegistry:CommandRegistry, engineRegistry:EngineRegistry, eventBus?:EventBus" returns="Promise<{ extensions: LoadedExtension[]; skills: Skill[]; systemPromptFragments: string[] }>"
  doc "Main entry point — discover, load, and wire all extensions. Called once at app startup."
  handler lang="kern"
    let name=extensions value="loadExtensions(cwd)"
    let name=allSkills type="Skill[]" value="[]"
    let name=allFragments type="string[]" value="[]"
    each name=ext in="extensions"
      comment raw="// Commands"
      let name=cmds value="await registerExtensionCommands(ext, commandRegistry)"
      if cond="cmds.length > 0"
        do value="hostLog(`[agon] extension '${ext.manifest.id}': registered commands: ${cmds.join(', ')}`)"
      comment raw="// Engines"
      let name=engines value="registerExtensionEngines(ext, engineRegistry)"
      if cond="engines.length > 0"
        do value="hostLog(`[agon] extension '${ext.manifest.id}': registered engines: ${engines.join(', ')}`)"
      comment raw="// Skills"
      let name=skills value="registerExtensionSkills(ext)"
      do value="allSkills.push(...skills)"
      comment raw="// Hooks"
      if cond="eventBus"
        let name=hooks value="await registerExtensionHooks(ext, eventBus)"
        if cond="hooks.length > 0"
          do value="hostLog(`[agon] extension '${ext.manifest.id}': registered hooks: ${hooks.join(', ')}`)"
      comment raw="// System prompt fragments"
      if cond="ext.manifest.contributes?.systemPromptFragments"
        do value="allFragments.push(...ext.manifest.contributes.systemPromptFragments)"
    if cond="extensions.length > 0"
      do value="hostLog(`[agon] loaded ${extensions.length} extension(s)`)"
    return value="{ extensions, skills: allSkills.slice(), systemPromptFragments: allFragments.slice() }"

fn name=buildExtensionContext params="cb:any, source:string" returns="Record<string, unknown>"
  doc "Build a sandboxed context object for extension command handlers."
  handler <<<
    return {
      dispatch: cb.dispatch,
      askQuestion: cb.askQuestion,
      config: cb.ctx?.config,
      registry: cb.ctx?.registry,
      adapter: cb.ctx?.adapter,
      source,
      cwd: process.cwd(),
    };
  >>>
