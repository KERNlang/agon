import from="node:fs" names="existsSync,readFileSync,statSync"
import from="node:path" names="resolve,basename,extname"
import from="node:os" names="homedir"
import from="node:url" names="fileURLToPath"
import from="../models/types.js" names="ImageAttachment" types=true

const name=IMAGE_EXTENSIONS type="Set<string>" value={{ new Set(['.png', '.jpg', '.jpeg', '.gif', '.webp', '.svg', '.bmp']) }}

const name=MIME_MAP type="Record<string,string>" value={{ ({ '.png': 'image/png', '.jpg': 'image/jpeg', '.jpeg': 'image/jpeg', '.gif': 'image/gif', '.webp': 'image/webp', '.svg': 'image/svg+xml', '.bmp': 'image/bmp' }) }}

const name=IMG_CMD_REGEX type=RegExp value={{ /^\/img\s+(.+)$/i }}

comment raw="// Dispatch caps for API-engine vision. base64 is sent inline per request, so we"
comment raw="// bound count + per-image bytes to keep a single drop from blowing the context window."
const name=MAX_DISPATCH_IMAGE_BYTES type=number value={{ 5 * 1024 * 1024 }}
const name=MAX_DISPATCH_IMAGES type=number value={{ 4 }}
comment raw="// MIME types every major OpenAI-compatible vision endpoint accepts (animated GIF"
comment raw="// is sent as a still by most providers). SVG is excluded — vision models can't raster it."
const name=DISPATCH_VISION_MIME type="Set<string>" value={{ new Set(['image/png', 'image/jpeg', 'image/webp', 'image/gif']) }}

fn name=isImagePath params="filePath:string" returns="boolean"
  handler lang="kern"
    let name=ext value="extname(filePath).toLowerCase()"
    return value="IMAGE_EXTENSIONS.has(ext)"

fn name=mimeFromExt params="filePath:string" returns="string"
  handler lang="kern"
    let name=ext value="extname(filePath).toLowerCase()"
    return value="MIME_MAP[ext] ?? 'application/octet-stream'"

fn name=resolveImagePath params="rawPath:string, cwd:string" returns="string|null"
  handler <<<
    let resolved: string;
    if (rawPath.startsWith('~/')) {
      resolved = resolve(homedir(), rawPath.slice(2));
    } else if (rawPath.startsWith('/')) {
      resolved = resolve(rawPath);
    } else {
      resolved = resolve(cwd, rawPath);
    }
    return existsSync(resolved) ? resolved : null;
  >>>

fn name=buildImageAttachment params="rawPath:string, cwd:string" returns="ImageAttachment|null"
  handler lang="kern"
    let name=resolved value="resolveImagePath(rawPath.trim(), cwd)"
    if cond="!resolved"
      return value="null"
    return value="{ path: resolved, filename: basename(resolved), mimeType: mimeFromExt(resolved), }"

fn name=normalizeDroppedPath params="raw:string" returns="string"
  doc "Normalise a path as a terminal emits it on drag-drop: strip one layer of matching quotes, decode a file:// URI (%20 → space), then unescape shell backslash escapes (\\ space → space, \\( → ( …). A plain typed path has no quotes/backslashes so it passes through untouched. macOS Terminal/iTerm drop screenshots — whose default names contain spaces — in one of the escaped/quoted/file:// forms, all of which the bare path detector would otherwise miss."
  handler <<<
    let p = raw.trim();
    const sq = p.startsWith("'") && p.endsWith("'");
    const dq = p.startsWith('"') && p.endsWith('"');
    if (sq || dq) p = p.slice(1, -1);
    // file:// URI → OS path via Node's parser: handles the authority (file:///x,
    // file://localhost/x), %-decoding, and Windows drive letters correctly.
    if (p.startsWith('file://')) {
      try { return fileURLToPath(p).trim(); }
      catch {
        // Malformed URI — fall back to a plain strip + percent-decode.
        p = p.slice('file://'.length);
        try { p = decodeURIComponent(p); } catch { /* keep raw */ }
        return p.trim();
      }
    }
    // Unescape shell-style backslash escapes (\ space, \', \(, \\ …). A URI never
    // reaches here; a plain typed path has none so it passes through untouched.
    p = p.replace(/\\(.)/g, '$1');
    return p.trim();
  >>>

fn name=extractImagesFromInput params="input:string, cwd:string" returns="{text:string, images:ImageAttachment[]}"
  doc "Pull image paths out of composer input. Handles the four shapes a terminal produces on drag-drop — plain, backslash-escaped spaces, single/double-quoted, and file:// URIs — plus an explicit /img <path> command. Detected paths are normalised + stripped from the returned text so they aren't duplicated into the prompt; the pixels reach a vision engine via buildCommand's --image flag (non-vision engines get a text fallback)."
  handler <<<
    const images: ImageAttachment[] = [];

    // Explicit /img <path> command (path may itself be quoted / escaped / file://).
    const imgCmdMatch = IMG_CMD_REGEX.exec(input.trim());
    if (imgCmdMatch) {
      const att = buildImageAttachment(normalizeDroppedPath(imgCmdMatch[1]), cwd);
      if (att) images.push(att);
      return { text: '', images };
    }

    // Combined detector. Alternatives, in order:
    //   1. '…ext'           single-quoted (drop of a path containing spaces)
    //   2. "…ext"           double-quoted (drop of a path containing spaces)
    //   3. file://…ext       file URI (some terminals drop this form)
    //   4. /… ~/… ./… ../…   plain OR backslash-escaped-space path
    // Built via new RegExp (not a /literal/) so the embedded ' and " stay clear of
    // KERN's {{ }} expression parsing; \x20 matches an escaped space without putting
    // a literal space in the source.
    const EXT = '(?:png|jpe?g|gif|webp|svg|bmp)';
    const detector = new RegExp(
      "'([^']*\\." + EXT + ")'" +
      '|"([^"]*\\.' + EXT + ')"' +
      "|(file:\\/\\/\\S+?\\." + EXT + ")" +
      "|(?:^|\\s)((?:\\/|~\\/|\\.{1,2}\\/)(?:\\\\\\x20|[^\\s'\"])*\\." + EXT + ")",
      'gi',
    );

    let text = input;
    let match: RegExpExecArray | null;
    const hits: { raw: string; whole: string }[] = [];

    while ((match = detector.exec(input)) !== null) {
      const raw = match[1] ?? match[2] ?? match[3] ?? match[4];
      if (raw) hits.push({ raw, whole: match[0] });
    }

    for (const hit of hits) {
      const att = buildImageAttachment(normalizeDroppedPath(hit.raw), cwd);
      if (att) {
        images.push(att);
        text = text.replace(hit.whole, '');
      }
    }

    // Whole-input fallback: a lone dropped path the structured detector can't
    // disambiguate inside prose — bare unescaped spaces, an escaped apostrophe
    // ("Bob's Shot.png"), or a bare relative filename. When the ENTIRE message
    // normalises to a single existing image file, attach it. existsSync (inside
    // buildImageAttachment) + the image-extension check gate this, so ordinary
    // prose can never false-attach.
    if (images.length === 0) {
      const whole = normalizeDroppedPath(input);
      if (isImagePath(whole)) {
        const att = buildImageAttachment(whole, cwd);
        if (att) {
          images.push(att);
          text = '';
        }
      }
    }

    text = text.replace(/\s{2,}/g, ' ').trim();

    return { text, images };
  >>>

fn name=encodeImagesRaw params="paths:string[], maxBytes?:number, maxImages?:number" returns="{images:Array<{data:string,mediaType:string}>, skipped:string[]}"
  doc "Single source of truth for turn-local image encoding: read each path to base64, enforcing a count cap, a per-image byte cap, a MIME allowlist, and a regular-file check. Rejections land in `skipped` with a human-readable reason. The two formatters below shape this for the AI-SDK (API engines) and Anthropic content blocks (claude stream-json). base64 is for the live request ONLY — never persist it into message history."
  handler <<<
    const lim = maxBytes ?? MAX_DISPATCH_IMAGE_BYTES;
    const cap = maxImages ?? MAX_DISPATCH_IMAGES;
    const images: Array<{data:string,mediaType:string}> = [];
    const skipped: string[] = [];
    const kb = (n: number) => `${Math.round(n / 1024)}KB`;
    for (const p of paths) {
      const name = basename(p);
      if (images.length >= cap) { skipped.push(`${name} (exceeds ${cap}-image limit)`); continue; }
      try {
        if (!existsSync(p)) { skipped.push(`${name} (not found)`); continue; }
        const mediaType = mimeFromExt(p);
        if (!DISPATCH_VISION_MIME.has(mediaType)) { skipped.push(`${name} (unsupported type ${mediaType})`); continue; }
        const st = statSync(p);
        // Reject anything that isn't a plain file — a FIFO/device/socket path would
        // block or mislead the size check; readFileSync on it could hang the turn.
        if (!st.isFile()) { skipped.push(`${name} (not a regular file)`); continue; }
        if (st.size > lim) { skipped.push(`${name} (${kb(st.size)} over ${kb(lim)} limit)`); continue; }
        const data = readFileSync(p).toString('base64');
        images.push({ data, mediaType });
      } catch {
        skipped.push(`${name} (read error)`);
      }
    }
    return { images, skipped };
  >>>

fn name=encodeImagesForDispatch params="paths:string[], maxBytes?:number, maxImages?:number" returns="{parts:Array<{type:'image',image:string,mediaType:string}>, skipped:string[]}"
  doc "AI-SDK ImagePart shape for OpenAI-compatible / Anthropic API engines (used by session-resume → apiStreamDispatchWithHistory). The image field is a full data: URL — explicit + standard, so the SDK never has to guess base64-vs-URL — and mediaType is set redundantly for providers that read it."
  handler <<<
    const { images, skipped } = encodeImagesRaw(paths, maxBytes, maxImages);
    return {
      parts: images.map((i) => ({ type: 'image' as const, image: `data:${i.mediaType};base64,${i.data}`, mediaType: i.mediaType })),
      skipped,
    };
  >>>

