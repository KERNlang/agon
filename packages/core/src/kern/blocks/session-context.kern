import from="./context-scanner.js" names="scanProjectContext"

service name=SessionContext
  doc "Memoized project context — gathered once per session, reused across dispatches. Inspired by Claude Code's immutable context pattern: capture directory structure, git status, project type at startup and cache for the session lifetime."

  field name=cache type="string|null" default="null" private=true
  field name=cachedCwd type="string|null" default="null" private=true
  field name=cachedExtra type="string|null" default="null" private=true
  field name=cachedFormat type="string|null" default="null" private=true
  field name=capturedAt type="number|null" default="null" private=true

  method name=get params="cwd:string, extra?:string, format?:'plain'|'kern'" returns=string
    doc "Returns memoized context. Only recomputes if cwd, extra, or format changes, or if cache is stale (>5 min)."
    handler lang="kern"
      let name=extraVal value="extra ?? null"
      let name=formatVal value="format ?? null"
      let name=stale value="this.capturedAt !== null && (Date.now() - this.capturedAt) > 300000"
      if cond="this.cache !== null && this.cachedCwd === cwd && this.cachedExtra === extraVal && this.cachedFormat === formatVal && !stale"
        return value="this.cache"
      assign target="this.cache" value="scanProjectContext(cwd, extra, format)"
      assign target="this.cachedCwd" value="cwd"
      assign target="this.cachedExtra" value="extraVal"
      assign target="this.cachedFormat" value="formatVal"
      assign target="this.capturedAt" value="Date.now()"
      return value="this.cache"

  method name=invalidate returns=void
    doc "Force re-capture on next get() call."
    handler lang="kern"
      assign target="this.cache" value="null"
      assign target="this.cachedCwd" value="null"
      assign target="this.cachedExtra" value="null"
      assign target="this.cachedFormat" value="null"
      assign target="this.capturedAt" value="null"

  method name=age returns=number
    doc "Milliseconds since context was captured. Returns Infinity if never captured."
    handler lang="kern"
      if cond="this.capturedAt === null"
        return value="Infinity"
      return value="Date.now() - this.capturedAt"

  method name=isStale params="maxAgeMs?:number" returns=boolean
    doc "Returns true if context is older than maxAgeMs (default 5 minutes)."
    handler lang="kern"
      let name=limit value="maxAgeMs ?? 300_000"
      return value="this.age() > limit"

  singleton name=sessionContext
