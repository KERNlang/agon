interface name=ParsedChunk
  field name=type type="'text'|'status'|'result'|'raw'"
  field name=content type=string

service name=StreamParser
  doc "Buffered NDJSON parser that handles partial JSON lines spanning multiple chunks."
  field name=buffer type=string private=true

  constructor
    handler lang="kern"
      assign target="this.buffer" value="''"

  method name=feed params="chunk:string" returns="ParsedChunk[]"
    handler lang="kern"
      assign target="this.buffer" op="+=" value="chunk"
      let name=results type="ParsedChunk[]" value="[]"
      let name=lines value="this.buffer.split('\\n')"
      comment raw="// Keep the last element — it may be an incomplete line"
      assign target="this.buffer" value="lines.pop() ?? ''"
      each name=line in="lines"
        let name=trimmed value="line.trim()"
        if cond="!trimmed"
          continue
        do value="results.push(...this._parseLine(trimmed))"
      return value="results"

  method name=flush returns="ParsedChunk[]"
    handler lang="kern"
      let name=results type="ParsedChunk[]" value="[]"
      let name=remaining value="this.buffer.trim()"
      assign target="this.buffer" value="''"
      if cond="!remaining"
        return value="results"
      do value="results.push(...this._parseLine(remaining))"
      return value="results"

  method name=_parseLine params="line:string" returns="ParsedChunk[]" private=true
    handler lang="kern"
      let name=results type="ParsedChunk[]" value="[]"
      try
        let name=msg value="JSON.parse(line)"
        comment raw="// Claude Code stream-json: assistant message with content blocks"
        if cond="msg.type === 'assistant' && msg.message?.content"
          each name=block in="msg.message.content"
            if cond="block.type === 'text' && block.text"
              do value="results.push({ type: 'text', content: block.text })"
          return value="results"
        comment raw="// Claude Code stream-json: final result"
        if cond="msg.type === 'result'"
          if cond="msg.result"
            do value="results.push({ type: 'result', content: typeof msg.result === 'string' ? msg.result : JSON.stringify(msg.result) })"
          if cond="msg.is_error || msg.error"
            let name=errMsg value="msg.error ?? msg.result ?? 'Unknown error'"
            do value="results.push({ type: 'status', content: typeof errMsg === 'string' ? errMsg : JSON.stringify(errMsg) })"
          return value="results"
        comment raw="// Claude Code stream-json: system status"
        if cond="msg.type === 'system'"
          if cond="msg.message"
            do value="results.push({ type: 'status', content: msg.message })"
          return value="results"
        comment raw="// A genuine stream-json control envelope always carries a string `type`. If this line parsed as JSON but is NOT such an envelope (e.g. an API engine like kimi emitting its findings as a JSON array — or any model whose TEXT output contains a JSON object/array on its own line), it is CONTENT, not protocol. Dropping it silently ate kimi's review findings (the array parsed as JSON, matched no envelope type, and was discarded — the output file written by the adapter looked complete, but the accumulated text lost the block). Preserve it as raw text. We only skip lines that look like an unknown control envelope (string `type` field)."
        if cond="msg && typeof msg === 'object' && typeof msg.type === 'string'"
          return value="results"
        do value="results.push({ type: 'raw', content: line })"
        return value="results"
        catch name=e
          comment raw="// Not JSON: treat as raw text (Codex, Gemini, etc.)."
          do value="results.push({ type: 'raw', content: line })"
          return value="results"

fn name=parseStreamChunk params="chunk:string" returns="ParsedChunk[]"
  doc "Stateless convenience wrapper. For streaming use, prefer StreamParser.feed() + flush()."
  handler lang="kern"
    let name=parser value="new StreamParser()"
    let name=results value="parser.feed(chunk)"
    do value="results.push(...parser.flush())"
    return value="results"
