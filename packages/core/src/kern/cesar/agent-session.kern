// ── AgentSession — budget-enforcing, abort-aware agent invocation ──
// Phase 1 of agent-mode: a stateful wrapper around runApiAgentLoop that
// enforces turn/token/wall-clock budgets across one or more step() calls
// and owns the per-session AbortController so Ctrl+C cancels cleanly.
//
// Scope note: Phase 1 tracks CUMULATIVE stats across steps but does NOT
// persist multi-turn conversation history. That lives in Phase 2's union
// + reducers (see plan.kern as the prior-art pattern we mirror). Each
// step() runs runApiAgentLoop with a fresh prompt; the session enforces
// outer budgets around that inner loop.
//
// Scope note 2: Phase 1 is API-engine only. CLI-binary agent mode lands
// in Phase 3 once the canonical AgentEvent protocol-parser normalization
// exists. Until then, step() requires opts.api to be set.

import from="../api/agent-loop.js" names="runApiAgentLoop"
import from="../api/agent-loop.js" names="ApiAgentOptions,ApiAgentResult" types=true
import from="../api/dispatch.js" names="ApiConfig" types=true
import from="../signals/token-tracker.js" names="estimateTokens,estimateCost"
import from="../models/agent-event.js" names="AgentEvent" types=true
import from="../models/agent-event.js" names="makeAssistantChunk,makeToolCall"
import from="../blocks/semaphore.js" names="Semaphore" types=true
import from="./context-thread.js" names="ContextThread" types=true

// ── Budget definition ─────────────────────────────────────────────

interface name=AgentBudget
  field name=maxTurns type=number
  field name=maxTokens type=number optional=true
  field name=maxDurationMs type=number

// ── Step result shape ─────────────────────────────────────────────

interface name=AgentStepResult
  field name=response type=string
  field name=toolCalls type=number
  field name=innerSteps type=number
  field name=tokensUsed type=number
  field name=costUsd type=number
  field name=stopReason type="'completed'|'budget_exceeded'|'cancelled'|'error'"
  field name=error type=string optional=true

// ── Cumulative session stats ──────────────────────────────────────

interface name=AgentSessionStats
  field name=turnsUsed type=number
  field name=turnsRemaining type=number
  field name=tokensUsed type=number
  field name=tokensRemaining type="number|null"
  field name=totalToolCalls type=number
  field name=totalCostUsd type=number
  field name=elapsedMs type=number
  field name=durationRemainingMs type=number
  field name=state type="'idle'|'running'|'completed'|'cancelled'|'failed'"

// ── Session config ────────────────────────────────────────────────

interface name=AgentSessionConfig
  field name=engineId type=string
  field name=api type=ApiConfig
  field name=cwd type=string
  field name=systemPrompt type=string optional=true
  field name=budget type=AgentBudget
  field name=perStepTimeoutSec type=number optional=true
  field name=maxInnerSteps type=number optional=true
  field name=teamId type=string optional=true
  field name=heavyToolSemaphore type=Semaphore optional=true
  field name=thread type=ContextThread optional=true

// ── Typed budget error ────────────────────────────────────────────

fn name=makeBudgetError params="kind:'turns'|'tokens'|'duration',detail:string" returns=Error export=true
  doc "Create a typed budget-exceeded error. Kind is attached to error.name for structural matching."
  handler <<<
    const err = new Error(`Agent budget exceeded: ${kind} — ${detail}`);
    err.name = `AgentBudget${kind.charAt(0).toUpperCase() + kind.slice(1)}Exceeded`;
    return err;
  >>>

// ── The service ───────────────────────────────────────────────────

service name=AgentSession export=true
  doc "Stateful agent invocation wrapper with budget enforcement and abort. Phase 1: API engines only."

  field name=config type=AgentSessionConfig private=true
  field name=turnsUsed type=number private=true default="0"
  field name=tokensUsed type=number private=true default="0"
  field name=totalToolCalls type=number private=true default="0"
  field name=totalCostUsd type=number private=true default="0"
  field name=startedAt type=number private=true default="0"
  field name=state type="'idle'|'running'|'completed'|'cancelled'|'failed'" private=true default="'idle'"
  field name=abortController type=AbortController private=true

  constructor params="config:AgentSessionConfig"
    handler <<<
      this.config = config;
      this.turnsUsed = 0;
      this.tokensUsed = 0;
      this.totalToolCalls = 0;
      this.totalCostUsd = 0;
      this.startedAt = Date.now();
      this.state = 'idle';
      this.abortController = new AbortController();
    >>>

  method name=step params="prompt:string,opts?:{onEvent?:(event:AgentEvent)=>void}" returns="Promise<AgentStepResult>" async=true
    doc "Run one agent turn. Enforces budgets before + after the inner runApiAgentLoop call. On cancel, returns a stopReason='cancelled' result rather than throwing. Optional opts.onEvent receives canonical AgentEvents in real time — assistant_chunk for streaming text, tool_call events for each tool invocation."
    handler <<<
      // ── Pre-step budget check ─────────────────────────────────
      if (this.state === 'cancelled') {
        return {
          response: '',
          toolCalls: 0,
          innerSteps: 0,
          tokensUsed: 0,
          costUsd: 0,
          stopReason: 'cancelled',
          error: 'Session was cancelled',
        };
      }
      if (this.state === 'completed' || this.state === 'failed') {
        return {
          response: '',
          toolCalls: 0,
          innerSteps: 0,
          tokensUsed: 0,
          costUsd: 0,
          stopReason: 'error',
          error: `Session is in terminal state: ${this.state}`,
        };
      }

      const budget = this.config.budget;

      if (this.turnsUsed >= budget.maxTurns) {
        this.state = 'failed';
        return {
          response: '',
          toolCalls: 0,
          innerSteps: 0,
          tokensUsed: 0,
          costUsd: 0,
          stopReason: 'budget_exceeded',
          error: `Turn budget exceeded: ${this.turnsUsed}/${budget.maxTurns}`,
        };
      }

      if (budget.maxTokens != null && this.tokensUsed >= budget.maxTokens) {
        this.state = 'failed';
        return {
          response: '',
          toolCalls: 0,
          innerSteps: 0,
          tokensUsed: 0,
          costUsd: 0,
          stopReason: 'budget_exceeded',
          error: `Token budget exceeded: ${this.tokensUsed}/${budget.maxTokens}`,
        };
      }

      const elapsed = Date.now() - this.startedAt;
      if (elapsed >= budget.maxDurationMs) {
        this.state = 'failed';
        return {
          response: '',
          toolCalls: 0,
          innerSteps: 0,
          tokensUsed: 0,
          costUsd: 0,
          stopReason: 'budget_exceeded',
          error: `Duration budget exceeded: ${elapsed}ms/${budget.maxDurationMs}ms`,
        };
      }

      // ── Refuse to start a step we can't finish in budget ─────
      // runApiAgentLoop has a hardcoded 30s floor (agent-loop.kern:143).
      // If we started a step with <30s remaining, we'd let that floor
      // silently override our duration budget. Instead, fail fast.
      const remainingMs = budget.maxDurationMs - elapsed;
      const MIN_STEP_MS = 30_000;
      if (remainingMs < MIN_STEP_MS) {
        this.state = 'failed';
        return {
          response: '',
          toolCalls: 0,
          innerSteps: 0,
          tokensUsed: 0,
          costUsd: 0,
          stopReason: 'budget_exceeded',
          error: `Duration budget too small to start step: ${remainingMs}ms remaining, ${MIN_STEP_MS}ms minimum`,
        };
      }

      // ── Run the inner loop ────────────────────────────────────
      this.state = 'running';
      const perStepSec = this.config.perStepTimeoutSec ?? Math.floor(remainingMs / 1000);
      const timeoutSec = Math.min(perStepSec, Math.floor(remainingMs / 1000));

      // Phase 1: Token usage is ESTIMATED (source='estimated' in TokenTracker terms).
      // Phase 3 will wire real SDK usage once dispatch.kern:390-402 capturedParts
      // are normalized through the canonical AgentEvent surface.
      const promptTokens = estimateTokens(prompt);

      const onEvent = opts?.onEvent;
      const thread = this.config.thread;

      // ── ContextThread integration ─────────────────────────────────
      // Pre-load: give this engine the full session history up to its
      // context budget. All major engines (Codex, Claude, Gemini,
      // OpenCode+GLM) now ship with 1M token context windows. We budget
      // 700k for history — leaving 300k for the task, tool calls, and
      // response within the current step. This means the engine sees
      // COMPLETE prior forge results, brainstorm decisions, agent tool
      // call outcomes, and user decisions — not a compressed stub.
      // If a specific engine has a smaller window, messagesFor() will
      // compact further via TOKEN_BUDGET_SAFETY_FACTOR; we don't cap
      // here because the engine registry doesn't yet expose window size.
      const engineTokenBudget = 700_000;
      const historyMessages = thread
        ? thread.messagesFor(this.config.engineId, engineTokenBudget)
        : undefined;

      // Post-emit: each entry produced during the inner loop feeds back
      // into the shared thread so the next step (or a different engine)
      // picks it up automatically.
      const onHistoryEntry = thread
        ? (entry: Record<string,unknown>) => { thread.appendLoopEntry(entry, this.config.engineId); }
        : undefined;

      const innerOpts: ApiAgentOptions = {
        api: this.config.api,
        prompt,
        systemPrompt: this.config.systemPrompt,
        cwd: this.config.cwd,
        timeout: timeoutSec,
        signal: this.abortController.signal,
        maxSteps: this.config.maxInnerSteps,
        onChunk: onEvent ? (text: string) => onEvent(makeAssistantChunk(this.config.engineId, text)) : undefined,
        onToolCall: onEvent ? (name: string, args: Record<string,unknown>) => onEvent(makeToolCall(this.config.engineId, name, 'running', { input: args })) : undefined,
        // RT-26 fix (Gemini): thread the team-shared semaphore through to the
        // inner loop's tool execution. Solo /agent runs leave this undefined
        // → no semaphore overhead. Team runs share ONE Semaphore instance
        // across all members so heavy tools (npm test, tsc, cargo build) are
        // serialized across the team.
        heavyToolSemaphore: this.config.heavyToolSemaphore,
        historyMessages: historyMessages as Array<Record<string,unknown>> | undefined,
        onHistoryEntry,
      };

      let result: ApiAgentResult;
      try {
        result = await runApiAgentLoop(innerOpts);
      } catch (err: any) {
        // Distinguish abort from other errors
        if (this.abortController.signal.aborted || err?.name === 'AbortError') {
          this.state = 'cancelled';
          return {
            response: '',
            toolCalls: 0,
            innerSteps: 0,
            tokensUsed: promptTokens,
            costUsd: 0,
            stopReason: 'cancelled',
            error: 'Aborted by caller',
          };
        }
        this.state = 'failed';
        return {
          response: '',
          toolCalls: 0,
          innerSteps: 0,
          tokensUsed: promptTokens,
          costUsd: 0,
          stopReason: 'error',
          error: err?.message ?? String(err),
        };
      }

      // If abort fired mid-stream, runApiAgentLoop may have returned a partial
      // response without throwing. Detect that here.
      if (this.abortController.signal.aborted) {
        this.state = 'cancelled';
        const partialResponseTokens = estimateTokens(result.response ?? '');
        const partialTotal = promptTokens + partialResponseTokens;
        this.turnsUsed += 1;
        this.tokensUsed += partialTotal;
        this.totalToolCalls += result.toolCalls;
        this.totalCostUsd += estimateCost(this.config.engineId, partialTotal, this.config.api.model);
        return {
          response: result.response,
          toolCalls: result.toolCalls,
          innerSteps: result.steps,
          tokensUsed: partialTotal,
          costUsd: estimateCost(this.config.engineId, partialTotal, this.config.api.model),
          stopReason: 'cancelled',
        };
      }

      // ── Accumulate stats ──────────────────────────────────────
      const responseTokens = estimateTokens(result.response);
      const stepTokens = promptTokens + responseTokens;
      const stepCost = estimateCost(this.config.engineId, stepTokens, this.config.api.model);

      this.turnsUsed += 1;
      this.tokensUsed += stepTokens;
      this.totalToolCalls += result.toolCalls;
      this.totalCostUsd += stepCost;

      // ── Post-step budget enforcement (tokens + duration only) ─
      // Turns are a discrete cap that the pre-check already enforces (N steps
      // are allowed when maxTurns=N; the (N+1)-th is refused). But TOKENS and
      // DURATION can overrun mid-step — the inner loop already ran and used
      // real resources we can't undo. When runAgentMode calls step() only once
      // per /agent invocation, the pre-check on the next call will never fire,
      // so maxTokens / maxDurationMs become advisory unless we also check
      // AFTER accumulation. The step's work is preserved in `response`; we
      // transition state to 'failed' so any future step() calls are blocked,
      // and return stopReason='budget_exceeded' so the caller knows what
      // happened. (Fix for Codex review P1 on agent-session.kern:248-250.)
      const postElapsed = Date.now() - this.startedAt;
      let overrunReason: string | null = null;
      if (budget.maxTokens != null && this.tokensUsed > budget.maxTokens) {
        overrunReason = `Token budget overrun: ${this.tokensUsed}/${budget.maxTokens} (step added ${stepTokens})`;
      } else if (postElapsed > budget.maxDurationMs) {
        overrunReason = `Duration budget overrun: ${postElapsed}ms/${budget.maxDurationMs}ms`;
      }

      if (overrunReason) {
        this.state = 'failed';
        return {
          response: result.response,
          toolCalls: result.toolCalls,
          innerSteps: result.steps,
          tokensUsed: stepTokens,
          costUsd: stepCost,
          stopReason: 'budget_exceeded',
          error: overrunReason,
        };
      }

      // RT-16 fix: state guard against cancel-vs-complete race. If cancel()
      // landed during step execution (microtask interleaving) it set state to
      // 'cancelled' and aborted the controller. Without this guard, the final
      // 'idle' write would silently overwrite that, and the session would
      // appear successful — its diff would even be eligible to win a team
      // round and land a patch from a session the user explicitly killed.
      // The cancel() method is the source of truth: if it ran, it wins.
      // Cast to string to defeat TS narrowing — TS doesn't know that cancel()
      // can mutate this.state from a parallel microtask context.
      // ── Flush ContextThread ───────────────────────────────────────
      // The onHistoryEntry callback already appended entries in-memory
      // during the step. Now mark this engine as caught up and persist.
      // We do this regardless of stopReason so partial work from a
      // cancelled or budget-exceeded step is still recorded for the
      // next run. (Full synchronous flush on abort is a Phase A.5 item.)
      if (thread) {
        try {
          thread.markSeen(this.config.engineId);
          await thread.save();
        } catch (err) {
          // Non-fatal — thread persistence failure must never kill the
          // agent step itself.
          console.warn(`[agon] context-thread: failed to flush after step: ${err instanceof Error ? err.message : String(err)}`);
        }
      }

      const stateAsString = this.state as string;
      if (stateAsString === 'cancelled' || stateAsString === 'failed') {
        return {
          response: result.response,
          toolCalls: result.toolCalls,
          innerSteps: result.steps,
          tokensUsed: stepTokens,
          costUsd: stepCost,
          stopReason: stateAsString === 'cancelled' ? 'cancelled' : 'error',
        };
      }
      this.state = 'idle';
      return {
        response: result.response,
        toolCalls: result.toolCalls,
        innerSteps: result.steps,
        tokensUsed: stepTokens,
        costUsd: stepCost,
        stopReason: 'completed',
      };
    >>>

  method name=cancel returns=void
    doc "Abort any in-flight step() and mark the session cancelled. Idempotent. Phase A.5: synchronously flushes the ContextThread before aborting so partial work from the cancelled step is not silently lost on process exit."
    handler <<<
      if (this.state === 'completed' || this.state === 'failed') return;
      this.state = 'cancelled';
      // Flush thread BEFORE aborting so onHistoryEntry entries appended
      // during the in-flight step make it to disk. The abort signal fires
      // after this flush, which is the correct order: save what we have,
      // THEN signal cancellation to the inner loop.
      if (this.config.thread) {
        try {
          this.config.thread.markSeen(this.config.engineId);
          // Use saveSync() — cancel() may be called from a sync abort handler
          // where we can't await. saveSync() skips the lock but persists.
          this.config.thread.saveSync();
        } catch { /* never let flush failure block abort */ }
      }
      if (!this.abortController.signal.aborted) {
        this.abortController.abort();
      }
    >>>

  method name=complete returns=void
    doc "Mark the session as successfully completed. Caller decides when the agent has finished its work."
    handler <<<
      if (this.state === 'cancelled' || this.state === 'failed') return;
      this.state = 'completed';
    >>>

  method name=getStats returns=AgentSessionStats
    handler <<<
      const budget = this.config.budget;
      const elapsed = Date.now() - this.startedAt;
      return {
        turnsUsed: this.turnsUsed,
        turnsRemaining: Math.max(0, budget.maxTurns - this.turnsUsed),
        tokensUsed: this.tokensUsed,
        tokensRemaining: budget.maxTokens != null ? Math.max(0, budget.maxTokens - this.tokensUsed) : null,
        totalToolCalls: this.totalToolCalls,
        totalCostUsd: this.totalCostUsd,
        elapsedMs: elapsed,
        durationRemainingMs: Math.max(0, budget.maxDurationMs - elapsed),
        state: this.state,
      };
    >>>

  method name=getSignal returns=AbortSignal
    doc "Expose the session's abort signal so callers can pass it to nested operations."
    handler <<<
      return this.abortController.signal;
    >>>
