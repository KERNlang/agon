// ── Plan step validation — sanitize LLM-proposed steps at the boundary ──
// Cesar occasionally emits malformed step objects (no `type`/`description`,
// or a non-array `steps` container entirely). Those are unexecutable —
// `plan-executor` returns "No executor for type: undefined" — and worse, they
// corrupt the plan markdown ("### Step 4: undefined") and crash
// PlanExecutionView at `s.description.slice()`. This validates the
// LLM-controlled shape once, where the cost estimate is also applied, and
// reports how many steps were dropped so the caller can surface it.

import from="./plan.js" names="CesarPlanStep" types=true
import from="./plan.js" names="CESAR_STEP_TYPES"
import from="./plan-cost-estimator.js" names="planCostEstimator"

const name=VALID_STEP_TYPES type="Set<string>" value={{ new Set<string>(CESAR_STEP_TYPES) }}

fn name=sanitizePlanSteps params="rawSteps:any" returns="{ steps: CesarPlanStep[]; dropped: number }" export=true
  doc "Validate LLM-proposed plan steps. Drops any entry whose `type` isn't a real CesarStepType (unexecutable noise), coerces `description` to a non-empty string, applies the cost estimate (the only source of truth for cost), and sanitizes the step id before it hits filesystem joins. Returns the surviving steps plus the count of dropped entries."
  handler <<<
    // Sanitize LLM-controlled step ids before they hit filesystem joins.
    // Anything outside [a-z0-9_-]{1,64} is replaced with a safe fallback.
    const SAFE_ID = /^[a-z0-9_-]{1,64}$/;
    const sanitizeId = (raw: any, fallback: string): string => {
      if (typeof raw === 'string' && SAFE_ID.test(raw)) return raw;
      return fallback;
    };

    // The container shape is LLM-controlled too: a truthy non-array (object,
    // string, number) would throw on `.filter`. Normalize to an array first.
    const input: any[] = Array.isArray(rawSteps) ? rawSteps : [];

    const steps: CesarPlanStep[] = input
      .filter((s: any) => s && VALID_STEP_TYPES.has(s.type))
      .map((s: any, i: number) => {
        // Estimator is the only source of truth for cost — Cesar cannot lie
        // about cost to slip past the auto-approve ceiling. `i` is the
        // post-filter index, which is fine for a unique fallback id.
        const est = planCostEstimator.estimate(s.type, s.engines ?? []);
        return {
          id: sanitizeId(s.id, `step-${i}-${Math.random().toString(36).slice(2, 8)}`),
          type: s.type,
          description: typeof s.description === 'string' && s.description.trim().length > 0 ? s.description : '(no description)',
          engines: s.engines,
          engine: s.engine,
          fitnessCmd: s.fitnessCmd,
          tribunalMode: s.tribunalMode,
          parallel: s.parallel ?? false,
          dependsOn: s.dependsOn,
          exports: typeof s.exports === 'string' ? [s.exports] : s.exports,
          imports: typeof s.imports === 'string' ? [s.imports] : s.imports,
          estimatedTokens: est.tokens,
          estimatedCostUsd: est.costUsd,
          rationale: s.rationale,
          verifyCmd: s.verifyCmd,
        };
      });

    const dropped = input.length - steps.length;
    return { steps, dropped };
  >>>
