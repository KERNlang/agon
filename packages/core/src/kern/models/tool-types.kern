// ── Tool System Types ────────────────────────────────────────────────
// Modeled after Claude Code's tool architecture, adapted for KERN.

interface name=ToolInput
  field name=type type=string

interface name=ToolResult
  field name=ok type=boolean
  field name=content type=string
  field name=error type=string optional=true
  field name=metadata type="Record<string,unknown>" optional=true

interface name=PermissionDecision
  field name=behavior type="'allow'|'ask'|'deny'"
  field name=message type=string optional=true
  field name=reason type=string optional=true

interface name=ToolContext
  field name=cwd type=string
  field name=readFileState type="Map<string, FileState>"
  field name=abortSignal type=AbortSignal optional=true
  field name=permissionMode type="'auto'|'smart'|'ask'|'deny-all'" optional=true
  field name=explorationMode type=boolean optional=true
  field name=allowedCommands type="string[]" optional=true
  field name=toolPermissions type="Record<string,'allow'|'ask'|'deny'>" optional=true
  field name=onProgress type="((message: string) => void)" optional=true
  field name=readOnlyMode type=boolean optional=true
  field name=virtualFs type="any" optional=true
  field name=sessionAllowList type="string[]" optional=true
  field name=source type="'user'|'orchestrator'" optional=true

interface name=FileState
  field name=content type=string
  field name=timestamp type=number
  field name=offset type="number|undefined"
  field name=limit type="number|undefined"
  field name=isPartialView type=boolean optional=true

interface name=ToolDefinition
  field name=name type=string
  field name=description type=string
  field name=inputSchema type="Record<string,unknown>"
  field name=maxResultSizeChars type=number
  field name=isReadOnly type=boolean
  field name=isConcurrencySafe type=boolean
  field name=isDestructive type=boolean optional=true

interface name=ToolHandler
  field name=definition type=ToolDefinition
  field name=validate type="(input: Record<string,unknown>, ctx: ToolContext) => string|null"
  field name=checkPermission type="(input: Record<string,unknown>, ctx: ToolContext) => PermissionDecision"
  field name=execute type="(input: Record<string,unknown>, ctx: ToolContext) => Promise<ToolResult>"

interface name=ToolCall
  field name=id type=string
  field name=name type=string
  field name=input type="Record<string,unknown>"

interface name=ToolCallResult
  field name=toolCallId type=string
  field name=toolName type=string
  field name=result type=ToolResult
  field name=durationMs type=number
