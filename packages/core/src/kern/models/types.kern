type name=EngineMode values="exec|review|agent"
type name=TaskClass values="algorithm|refactor|bugfix|test|docs|feature|other"

interface name=EngineModeConfig
  field name=args type="string[]"
  field name=stdin type=boolean optional=true

interface name=ImageAttachment
  field name=path type=string
  field name=filename type=string
  field name=mimeType type=string

interface name=EngineModelConfig
  field name=configKey type=string optional=true
  field name=flag type=string optional=true
  field name=default type="string|null" optional=true

interface name=EngineEffortConfig
  doc "Reasoning-effort selection for a CLI engine. Applied at dispatch as either a flag ([flag, level], e.g. claude --effort high) or a -c config override (['-c', `${configKey}=${level}`], e.g. codex -c model_reasoning_effort=high). agy bakes effort into its model tiers (Flash High/Medium/Low) so it needs no effort block."
  field name=flag type=string optional=true
  field name=configKey type=string optional=true
  field name=levels type="string[]"
  field name=default type=string optional=true

interface name=EngineEnvVar
  field name=required type=boolean optional=true
  field name=default type=string optional=true

interface name=CompanionConfig
  field name=protocol type="'jsonrpc'|'acp'|'structured-cli'|'stream-json'"
  field name=serverCmd type="string[]"
  field name=sandbox type="'read-only'|'workspace-write'|'danger-full-access'" optional=true
  field name=cwdArg type=string optional=true doc="Flag the companion server uses to set its working directory (e.g. opencode's '--cwd'). When set, companionDispatch appends [cwdArg, opts.cwd] to serverCmd so the server is PINNED to the worktree. Required for servers (opencode) that ignore the spawn cwd / attach to a shared server in the launch repo — relying on the spawn cwd alone leaked writes into the parent repo."
  field name=features type="{threadResume?:boolean, nativeReview?:boolean, structuredOutput?:boolean}" optional=true

interface name=CliModelEntry
  field name=id type=string
  field name=name type=string optional=true

interface name=EngineCliModelConfig
  field name=default type=string optional=true
  field name=list type="CliModelEntry[]" optional=true
  field name=dynamicListCmd type="string[]" optional=true

interface name=SessionBudget
  doc "Proactive context-window management metadata for an engine's Cesar brain session. Engines WITHOUT this object get NO budget behavior — the pre-turn gate is inert (zero regression risk). Thresholds are fractions of the EFFECTIVE window (contextWindow minus reserveTokens). See token-estimator.kern / session-budget.kern."
  field name=contextWindow type=number
    doc "Total model context window in tokens (input+history+output). The single source of truth the gate sizes against; an engine.api.contextWindow may also exist for the API compaction path but this is the brain-session budget."
  field name=reserveTokens type=number optional=true
    doc "Headroom (output + tool overhead) to subtract from contextWindow before applying thresholds. Defaults to max(15% of window, 8000) when omitted."
  field name=warnAt type=number optional=true
    doc "Fraction (0..1) of the effective window at which to emit ONE quiet info nudge per session. Default 0.70."
  field name=compactAt type=number optional=true
    doc "Fraction (0..1) at which to auto-trigger compaction. Default 0.82."
  field name=hardStopAt type=number optional=true
    doc "Fraction (0..1) at which to BLOCK the turn with a clear error (compaction did not bring usage down enough). Default 0.92."
  field name=estimator type="'chars-per-token'|'message-history'" optional=true
    doc "How to estimate tokens. 'chars-per-token' = sum content chars / charsPerToken (cheap, default). 'message-history' = same divisor but iterates structured messages incl tool-call args. Both are conservative over-counts (compaction fires a touch early)."
  field name=charsPerToken type=number optional=true
    doc "Average chars per token for the estimator's division. Default 3.9 (code/JSON-heavy agent history tokenizes denser than prose; a higher divisor under-counts and risks overflow, so the default is conservative-low)."

interface name=EngineDefinition
  field name=schemaVersion type="1|2|3"
  field name=id type=string
  field name=displayName type=string
  field name=binary type=string optional=true
  field name=searchPaths type="string[]" optional=true
  field name=versionCmd type="string[]" optional=true
  field name=isLocal type=boolean
  field name=tier type="'builtin'|'user'"
  field name=installHint type=string optional=true
  field name=timeout type=number
  field name=exec type=EngineModeConfig optional=true
  field name=review type=EngineModeConfig optional=true
  field name=model type=EngineModelConfig optional=true
  field name=effort type=EngineEffortConfig optional=true
  field name=env type="Record<string,EngineEnvVar>" optional=true
  field name=test type="{args:string[]}" optional=true
  field name=modes type="EngineMode[]" optional=true
  field name=modelConfigKey type=string optional=true
  field name=adapterType type=string optional=true
  field name=family type=string optional=true
    doc "Model family for rating lineage (e.g. 'opus', 'kimi'). Lets a new version inherit a sibling's Glicko rating at cold-start."
  field name=derivedFrom type=string optional=true
    doc "Engine id this version supersedes (e.g. opus-4.8 derivedFrom opus-4.7). At cold-start the new engine inherits the predecessor's Glicko mu with inflated uncertainty. See seedSuccessorRating."
  field name=capabilities type="string[]" optional=true
  field name=guards type="'strict'|'invariants'|'shadow'" optional=true
    doc "Guard-pipeline mode for this engine's API Cesar brain (P1+P2). 'strict' (default when absent) = the existing inline guards run byte-identically to today. 'invariants' = the new GuardPipeline runs and blocks/nudges/escalates for real (grounded-write batch gate, info-gain stall ladder, evidence final-text check, confidence-gate escalation, post-edit DiagnosticRunner). 'shadow' = the pipeline EVALUATES and emits telemetry but every block/nudge/escalate is downgraded to allow. Resolved via resolveGuardMode (user ~/.agon/config.json guardModes override > this field > 'strict')."
  field name=imageFlag type=string optional=true
  field name=systemPromptFlag type=string optional=true
  field name=agent type=EngineModeConfig optional=true
  field name=api type="{baseUrl:string, apiKeyEnv:string, model:string, maxTokens?:number, contextWindow?:number, format?:'openai'|'anthropic', firstChunkTimeoutMs?:number, idleTimeoutMs?:number, firstChunkRetryCount?:number, firstChunkRetryBackoffMs?:number}" optional=true
  field name=companion type=CompanionConfig optional=true
  field name=sessionBudget type=SessionBudget optional=true
    doc "Proactive context-window budget for this engine's Cesar brain session. When present, the pre-turn gate estimates session tokens and warns/auto-compacts/hard-stops before the window overflows. When ABSENT the gate is inert (feature opt-in per engine — zero regression for engines lacking it)."
  field name=cliModels type=EngineCliModelConfig optional=true
  field name=isolationHints type="{configEnv?:string, strictMcpArgs?:string[], personalPaths?:string[], authFiles?:string[], authMarker?:string, setupHint?:string, loginArgs?:string[], supportsProjectMcp?:boolean}" optional=true
    doc "Workspace-pure isolation knobs. configEnv = env var that repoints the engine's config dir to a clean throwaway (e.g. CLAUDE_CONFIG_DIR, CODEX_HOME), dropping the user's global config/plugins/hooks/MCP. AUTH has two models: file-based engines (codex) list authFiles — credential files (relative to the real config home, personalPaths[0]) copied into the clean dir so dispatch stays logged in (codex 'auth.json'); keychain-based engines (claude on macOS) have NO copyable credential (the token is in the OS keychain, keyed to the DEFAULT config dir) so authFiles is empty and the clean dir gets its own one-time login via `agon login claude`. authMarker = the file whose presence in the clean dir means it IS authenticated (codex 'auth.json' — the seeded file; claude '.claude.json' — written by login); isolation is gated on it, falling back to inherit (never breaking a dispatch) when absent. setupHint = the one-time instruction to surface when the clean dir isn't authenticated. loginArgs = the engine CLI subcommand `agon login <id>` runs (with configEnv pointed at the clean dir) to authenticate it (claude ['auth','login'], codex ['login']). strictMcpArgs = CLI flags forcing no/limited MCP (claude '--strict-mcp-config'). personalPaths[0] = the engine's real config home. supportsProjectMcp = engine reads .mcp.json from cwd. ABSENT on API-only engines (kimi/minimax/zai): no local process, already pure."

interface name=DispatchOptions
  field name=engine type=EngineDefinition
  field name=prompt type=string
  field name=cwd type=string
  field name=mode type=EngineMode
  field name=timeout type=number
  field name=outputDir type=string
  field name=maxTokens type=number optional=true
    doc "Per-call output-token cap. Overrides engine.api.maxTokens for THIS dispatch only — lets each mode size output independently (review caps low for speed; forge can raise; Cesar uses the engine default) without mutating the shared engine config. Ignored by CLI/companion engines; applies to the API path."
  field name=signal type=AbortSignal optional=true
  field name=images type="ImageAttachment[]" optional=true
  field name=systemPrompt type=string optional=true
  field name=tools type="Array<{type:string,function:{name:string,description:string,parameters:Record<string,unknown>}}>" optional=true
    doc "Native function-calling tool specs (OpenAI-function shape). When present AND the dispatch resolves to the API path (binary-less engine + usable key), the adapter sends them to the model's native tool API and returns any structured call in DispatchResult.parts. IGNORED on the CLI/companion paths — those engines use the in-prompt text-marker protocol. Lets the browser brain's ReAct loop get reliable native tool calls from API-only coding-plan engines that otherwise forget to emit the text marker (narrate-and-stop)."
  field name=messages type="Array<{role:string,content:any,tool_calls?:any[],tool_call_id?:string}>" optional=true
    doc "Full conversation history (OpenAI wire format) for the NATIVE API+tools path. When present, the adapter dispatches this structured assistant/tool thread (prepending the project-context system prompt) instead of the flat `prompt`, so the model sees a real tool conversation it can prompt-cache. IGNORED on the CLI/companion paths (they use `prompt`) and when no tools are sent. The browser brain reconstructs it from its step log each turn (Phase 2)."
  field name=onApproval type="(tool:string, command:string, reason?:string) => Promise<boolean|string>" optional=true
  field name=permissionMode type="'auto'|'smart'|'ask'|'deny-all'" optional=true
  field name=allowedCommands type="string[]" optional=true
  field name=toolPermissions type="Record<string,'allow'|'ask'|'deny'>" optional=true
  field name=onSpawn type="(pid:number)=>void" optional=true
  field name=onTodos type="((todos: Array<{id:string,text:string,state:string,kind?:string,note?:string}>) => void)" optional=true
    doc "Forwarded to the API agent loop's ToolContext.onTodos so a TodoWrite tool call surfaces the rolling task list. Handlers with a UI dispatch (build, pipeline) pass a callback that emits a todos-set OutputEvent to render the todo-rail. Only fires on the runApiAgentLoop path (API-only engines); native CLI engines use their own todo UI."
  field name=isolation type="'workspace-pure'|'inherit'" optional=true
    doc "Per-dispatch isolation override. When unset, the adapter resolves it from the AGON_ENGINE_ISOLATION env var, then config.engineIsolation, then the default (workspace-pure). workspace-pure = strip the user's personal/global engine config (plugins/hooks/global CLAUDE.md/MCP) via a clean per-engine config dir (auth preserved) but KEEP the project's repo CLAUDE.md/.mcp.json; inherit = inherit everything (legacy)."

interface name=DispatchResult
  field name=exitCode type=number
  field name=stdout type=string
  field name=stderr type=string
  field name=durationMs type=number
  field name=timedOut type=boolean
  field name=engineFault type=boolean optional=true
    doc "True when the execution transport/engine failed, as distinct from a caller cancellation, policy denial, or ordinary nonzero task result."
  field name=pid type="number|null" optional=true
  field name=usage type="{promptTokens:number,completionTokens:number,totalTokens:number,cachedInputTokens?:number,source:'sdk'|'cli-reported'|'estimated'}" optional=true
    doc "promptTokens (AI SDK inputTokens) already INCLUDES cache read+write tokens, so promptTokens+completionTokens = the request's exact context occupancy. cachedInputTokens = the cache-read share, for display/cost."
  field name=parts type="Array<{kind:'text',text:string}|{kind:'reasoning',text:string}|{kind:'tool_call',toolName:string,toolCallId:string,args:Record<string,unknown>}>" optional=true
  doc "Structured parts captured at stream time. Enables compaction to fold over typed data instead of parsing strings."
  field name=finishReason type=string optional=true
    doc "AI SDK finishReason ('stop'|'length'|'content-filter'|'tool-calls'|'error'|'other'|'unknown') captured from the fullStream 'finish' part on API dispatches. 'length' with empty stdout = the model exhausted its output-token budget (typically all spent on reasoning) — callers use it to name that failure instead of misreporting a generic empty response. Absent on CLI/pty dispatch paths."

interface name=AgentDispatchResult extends=DispatchResult
  field name=diff type=string
  field name=diffLines type=number
  field name=filesChanged type=number

interface name=EngineAdapter
  field name=dispatch type="(options:DispatchOptions)=>Promise<DispatchResult>"
  field name=dispatchStream type="(options:DispatchOptions)=>AsyncGenerator<string, DispatchResult, void>" optional=true
  field name=dispatchAgent type="(options:DispatchOptions)=>Promise<AgentDispatchResult>" optional=true
  field name=dispatchAgentStream type="(options:DispatchOptions)=>AsyncGenerator<string, AgentDispatchResult, void>" optional=true
  field name=isAvailable type="(engine:EngineDefinition)=>Promise<boolean>"
  field name=getVersion type="(engine:EngineDefinition)=>Promise<string|null>"

interface name=FitnessResult
  field name=pass type=boolean
  field name=diffLines type=number
  field name=filesChanged type=number
  field name=durationSec type=number
  field name=lintWarnings type=number
  field name=styleScore type=number
  field name=compositeScore type=number
  field name=syntaxErrors type=number optional=true
  field name=syntaxInvalidFiles type="string[]" optional=true

interface name=ScoreWeights
  field name=pass type=number
  field name=quality type=number
  field name=diff type=number
  field name=files type=number
  field name=duration type=number

interface name=ScoreComponents
  field name=passScore type=number
  field name=qualityScore type=number
  field name=diffScore type=number
  field name=filesScore type=number
  field name=durationScore type=number
  field name=composite type=number

interface name=GlickoRating
  field name=mu type=number
  field name=phi type=number
  field name=sigma type=number
  field name=wins type=number
  field name=losses type=number
  field name=lastActive type=string

interface name=EngineMeta
  field name=firstSeen type=string
  field name=lastActive type=string
  field name=matchCount type=number
  field name=derivedFrom type="string|null"
  field name=versions type="string[]"

interface name=RatingRecord
  field name=global type="Record<string,GlickoRating>"
  field name=byMode type="{forge:Record<string,GlickoRating>,brainstorm:Record<string,GlickoRating>,tribunal:Record<string,GlickoRating>,critique:Record<string,GlickoRating>}"
  field name=byTaskClass type="Record<string,Record<string,GlickoRating>>"
  field name=engineMeta type="Record<string,EngineMeta>"
  field name=lastUpdated type=string

config name=AgonConfig
  field name=debug type=boolean default=false
  field name=timeout type=number default=360
  field name=forgeTimeout type=number default=1800
  field name=forgeDispatchTimeout type=number default=480
    doc "Per-engine dispatch timeout in seconds for stage1/stage2 forge dispatches. Used when an engine definition does not set its own timeout. Replaces the previous behavior of flooring every engine to forgeTimeout (1800s), which let one slow/hung engine hold the whole run hostage for 30 min."
  field name=forgeAutoAcceptScore type=number default=88
  field name=forgeClearWinnerSpread type=number default=8
  field name=forgeEnableSynthesis type=boolean default=false
  field name=forgeMaxCritiques type=number default=3
  field name=forgeStarterStrategy type="'fixed'|'rotate'" default="'fixed'"
  field name=forgeFixedStarter type=string default=claude
  field name=reviewDefaultEngine type=string default=""
    doc "Legacy preference used by explicitly singular/internal Review selection. Standard `agon review`, `/review`, and Review() use the full active panel and do not narrow to this value; callers must pass engine/engines explicitly to narrow."
  field name=goalReviewEngines type="string[]" default="[]"
    doc "Default review panel for `agon goal` when --reviewEngines is omitted. Empty = smart default (every active engine except local ones like ollama). Pin an explicit roster, e.g. ['claude','codex','agy'], to control cost/noise of the per-task review gate."
  field name=forgeRequireBaselineCheck type=boolean default=true
  field name=engineActivationMode type="'auto'|'explicit'" default=auto
    doc "'auto' keeps every available engine active. 'explicit' only activates engines listed in forgeEnabledEngines; set by /use or the engine picker."
  field name=forgeEnabledEngines type="string[]" default="['claude','codex','agy']"
  field name=forgeFitnessTimeout type=number default=120
  field name=forgeSynthesisTimeout type=number default=300
  field name=forgeEarlyFinalizeEnabled type=boolean default=true
    doc "When true, forge stage2 auto-finalizes once M engines pass with score >= forgeEarlyFinalizeMinScore, aborting any remaining in-flight engines. Prevents waiting on slow stragglers when quorum is already reached."
  field name=forgeEarlyFinalizePassingCount type=number default=3
    doc "Quorum size (M): number of passing engines (each with score >= forgeEarlyFinalizeMinScore) required to trigger auto-finalize. Overridable per-invocation via --early-finalize-count."
  field name=forgeEarlyFinalizeMinScore type=number default=70
    doc "Minimum score an engine must achieve to count toward the early-finalize quorum."
  field name=forgeHealthCheckEnabled type=boolean default=true
    doc "When true, forge pings each engine with a tiny prompt before dispatch and skips engines that don't respond cleanly. Costs ~timeout × max(parallel-engine-spawn-time) per forge run; saves up to forgeDispatchTimeout per dead engine."
  field name=forgeHealthCheckTimeoutSec type=number default=20
    doc "Per-engine health-check timeout in seconds. CLI agents can take several seconds to warm up, so keep this above the common cold-start range. An engine that doesn't return non-empty stdout within this window is treated as unhealthy for THIS run only."
  field name=forgeHealthCheckApiTimeoutSec type=number default=45
    doc "Health-check timeout for API/network-backed engines (no local CLI binary, e.g. kimi/zai/minimax). These add network round-trips + provider cold-start on top of the CLI warm-up, so they get a longer probe window than forgeHealthCheckTimeoutSec. Used as a floor — if the CLI timeout is already higher it wins."
  field name=forgeMaxParallelApi type=number default=2
    doc "Max number of API/network-backed engines probed (and otherwise burst-dispatched) at once. Local CLI engines stay fully parallel. Capping the API fan-out stops a big roster's API engines from all cold-starting against rate-limited providers simultaneously and losing the whole batch to a thundering-herd timeout. Set to 0 or a high number to effectively disable the cap."
  field name=forgeJudgeEngine type=string default=""
    doc "Default 'judge' engine for forge: excluded from the competing roster and used to review the winning patch after a forge run (Codex-as-judge workflow — competitors race, the judge independently audits the winner for bugs the fitness spec missed). Empty = no judge unless --judge is passed. The CLI --judge flag overrides this."
  field name=reviewMaxTokens type=number default=0
    doc "Output-token cap for REVIEW-mode dispatches. 0 (default) is automatic: use at least 8192 and never cap an API engine below its configured api.maxTokens, because reasoning models can consume most of the budget before emitting visible review text. A positive value is an explicit per-review override. Applied per-call via DispatchOptions.maxTokens, so it does NOT affect Cesar or Forge."
  field name=reviewFileContext type=boolean default=true
    doc "Repo grounding: include the full current content of the changed source files in the review prompt so reviewers verify findings against real code instead of guessing from diff hunks (kills the 'X is unhandled / unimported' false alarms). Bounded hard (per-file + total caps; generated/dist/min files skipped). Set false to minimize prompt size / time-to-first-token at the cost of more false alarms."
  field name=ratingsEnabled type=boolean default=true
  field name=contextSummary type=boolean default=true
  field name=sessionContinuity type=boolean default=false
    doc "Opt-in automatic cross-session memory. When false, new Agon processes start with clean engine context; explicit /chats resume and in-process chat history still work."
  field name=onboarded type=boolean default=false
  field name=projectContext type=string default=""
  field name=contextFormat type="'plain'|'kern'" default=plain
  field name=approvalLevel type="'plan'|'task'|'write'|'none'" default=plan
  field name=agentTimeout type=number default=600
  field name=agentPermissionLevel type="'full'|'plan'|'read-only'" default=full
  field name=jobEventLimit type=number default=256
    doc "Maximum replayable events retained per autonomous job. Older events are evicted while sequence cursors remain monotonic."
  field name=jobRetentionLimit type=number default=100
    doc "Maximum fully-settled terminal autonomous jobs retained in memory by a JobService instance."
  field name=jobMaxConcurrency type=number default=4
    doc "Maximum autonomous job executors active at once. Cancelled executors retain their slot until their promise settles."
  field name=jobLabelMaxChars type=number default=120
    doc "Maximum characters retained in an autonomous job display label. Full input remains in the executor closure only while the job is active."
  field name=jobOutputChunkChars type=number default=16000
    doc "Maximum characters stored in one stdout/stderr autonomous job event. Large process chunks are split before replay retention."
  field name=jobCancelGraceMs type=number default=2000
    doc "Grace period between SIGTERM and SIGKILL when cancelling a daemon workflow process tree."
  field name=jobShutdownTimeoutMs type=number default=10000
    doc "Maximum time a daemon or HTTP host waits for cancelled autonomous executors to settle before completing shutdown."
  field name=daemonFrameMaxBytes type=number default=1048576
    doc "Maximum buffered newline-JSON daemon request frame size before the client connection is rejected."
  field name=gauntletEnabled type=boolean default=false
  field name=gauntletMaxBreakers type=number default=3
  field name=gauntletRepairTimeout type=number default=300
  field name=corpusReplayLimit type=number default=5
  field name=skillSynthesisThreshold type=number default=3
  field name=cesarEnabled type=boolean default=true
  field name=cesarScoutCount type=number default=2
  field name=cesarScoutTimeout type=number default=18
  field name=cesarDirectThreshold type=number default=85
  field name=cesarDisagreementSpread type=number default=20
  field name=cesarCodeFastPathChars type=number default=180
  field name=cesarAutoPipeline type=boolean default=false
  field name=cesarPipelineThreshold type=number default=93
  field name=cesarEngine type=string default=claude
  field name=cesarBackend type="'cli'|'api'|'auto'" default=auto
  field name=claudeBackend type="'print'|'pty'" default=print
    doc "How the `claude` CLI brain dispatches (chat / forge / orchestration / Cesar — NOT the /model live probe, which always uses the TUI). 'print' (default) = `claude --print` (-p): Anthropic no longer meters -p under the subscription and it's far more reliable than scraping the interactive TUI. 'pty' = the interactive kern-engines subscription-TUI brain. The AGON_CLAUDE_PTY env var (1/true → pty, 0/false → print) overrides this setting per-run. Read everywhere via claudeBrainUsesPty(). Set it with `agon config claudeBackend pty|print`."
  field name=cesarActingFallback type="'ask'|'auto'|'off'" default=auto
    doc "Controls whether Agon may switch to another engine as acting Cesar when the configured Cesar engine returns no response. 'auto'=swap silently and attribute output as Cesar (no chrome — the user perceives a single Cesar persona), 'ask'=prompt and show recovery messages, 'off'=never switch engines."
  field name=cesarMcpEnabled type=boolean default=false
  field name=cesarMcpConfigPath type=string default=""
  field name=cesarAutoApproveMode type="'off'|'safe-only'|'cost-bounded'|'always'" default="'safe-only'"
    doc "Autonomous plan approval policy. 'off'=always prompt, 'safe-only'=only non-mutating plans, 'cost-bounded'=plans under cesarAutoApproveMaxCostUsd, 'always'=any plan with autoApprove=true."
  field name=cesarAutoApproveMaxCostUsd type=number optional=true
    doc "When cesarAutoApproveMode is 'cost-bounded' or 'always', the maximum estimated USD cost (including 2× review cycle estimate for mutating plans) that can be auto-approved without user confirmation."
  field name=cesarAutoMode type=boolean default=false
    doc "When true, plain chat turns run with Cesar autonomous mode enabled by default until the user disables it."
  field name=cesarAutoHarnessProfile type="'legacy'|'agentic'" default=agentic
    doc "AUTO harness implementation. 'agentic' gives Cesar task ownership, structural continuation, normal budgets, and tool-layer safety. 'legacy' is the instant rollback and preserves the prior prompt/guard behavior. Non-AUTO turns always use legacy semantics."
  field name=cesarAgenticContinuationLimit type=number default=12
    doc "Safety ceiling for agentic AUTO continuation cycles. Progress is checkpointed with an explicit terminal reason at the ceiling; the old legacy controller remains capped at five."
  field name=cesarImportantTaskPattern type=string optional=true
    doc "Optional task-risk regex override used by the legacy AUTO approval profile. Agentic AUTO does not prompt merely because a task is important."
  field name=cesarDangerousTaskPattern type=string optional=true
    doc "Optional dangerous-boundary regex override shared by both AUTO harness profiles."
  field name=cesarAutoModePrompted type=boolean default=false
    doc "Tracks whether the CLI has asked the first-run question for enabling default Cesar autonomous mode."
  field name=resumePausedPlanOnStartup type=boolean default=false
    doc "When true, the CLI prompts to resume the freshest paused/running plan on startup. Default false — most users prefer to ask Cesar explicitly when they want to pick a plan back up. Set to true via `agon config set resumePausedPlanOnStartup true` to restore the auto-prompt."
  field name=cesarSelfTurnAutoApprove type=boolean default=true
    doc "When true, Cesar may auto-approve small Edit/Write operations during its own live turn if the target file is already known, inside the workspace, not sensitive, not stale, and under the diff token threshold."
  field name=cesarSelfTurnAutoApproveMaxDiffTokens type=number default=1200
    doc "Maximum estimated changed-token count for Cesar self-turn Edit/Write auto-approval."
  field name=cesarApprovalLedger type=boolean default=true
    doc "When true, write compact JSONL permission-decision records for Cesar tool approvals, prompts, and blocks."
  field name=cesarToolTimeline type=boolean default=true
    doc "When true, write compact JSONL per-turn tool timeline records for Cesar tool calls, results, and summaries."
  field name=protectedPushBranches type="string[]" optional=true
    doc "Branches unattended pushes (conquer --push) refuse to land on. Default when absent OR empty: main, master (an empty list never disables the guard). Case-insensitive exact match. KERN-GAP: codegen — optional array fields are emitted as [] into DEFAULT_AGON_CONFIG and as required (non-?) TS fields, so consumers must treat [] as 'unset'."
  field name=cesarStreamingXmlTools type=boolean default=true
    doc "When true, interrupt text streaming as soon as a complete XML tool call is parsed so XML fallback tools can execute live instead of waiting for the whole response."
  field name=campfireObserverStrategy type="'lead-first'|'all-respond'" default=lead-first
  field name=hooks type="Record<string,Array<{command:string,engines?:string[],matcher?:string,timeout?:number}>>" optional=true
    doc "Shell hook commands keyed by event. Dispatch-lifecycle events (pre_dispatch, post_forge, …) use {command, engines?, timeout?}. CC-parity tool-call events `preToolUse`/`postToolUse` use {matcher?, command, timeout?}: a pre-hook gets {tool_name, tool_input} on stdin and may BLOCK with exit 2 (stderr = refusal); a post-hook gets {tool_name, tool_input, tool_response} and never blocks. All hooks are fail-safe (timeout/spawn-failure/other-exit → proceed)."
  field name=permissionMode type="'auto'|'smart'|'ask'|'deny-all'" default=smart
  field name=allowedCommands type="string[]" optional=true
  field name=toolPermissions type="Record<string,'allow'|'ask'|'deny'>" optional=true
  field name=permissions type="{allow?:string[],deny?:string[]}" optional=true
    doc "Claude-Code-parity allow/deny rule strings honored by the approval gate. Rules look like `Bash(npm test:*)`, `Bash(git diff:*)`, `Edit`, `Write`, `Read`. `deny` ALWAYS wins over `allow`: a deny rule refuses without prompting, an allow rule auto-approves the matching ask, everything else falls through to the normal ask flow. Project scope lives in .agon.json (committable); personal overrides in .agon.local.json (gitignored). Malformed rules are ignored with a one-time warning, never block."
  field name=hiddenEngines type="string[]" optional=true
    doc "SOFT denylist (verb: /engines hide). Excluded from automatic rosters, rankings, batch selection and health-preflight candidates, but an explicit -e/--engines request for a hidden engine is still HONORED (with a warning). Use for engines you usually don't want but occasionally A/B-test."
  field name=removedEngines type="string[]" optional=true
    doc "HARD denylist (verb: /engines remove). Excluded from EVERY roster including explicit -e/--engines — a removed engine cannot run in any agon session, even when an external CLI forwards it via `agon call ... --engines`. Requesting one is a pre-run error, never a silent drop. Restore with /models add <id> or /engines restore <id>."
  field name=engineModels type="Record<string,string>" optional=true
  field name=engineEfforts type="Record<string,string>" optional=true doc="Per-engine reasoning-effort override (engineId → level), set when the user explicitly picks an effort in agon. Absent = defer to the CLI's own config (no --effort / -c forced)."
  field name=engineIsolation type="'workspace-pure'|'inherit'" default="'workspace-pure'"
    doc "How much of the user's personal tooling a dispatched engine inherits. 'workspace-pure' (default) strips the personal/global layer (global CLAUDE.md, Claude Code plugins/hooks, user MCP servers) via a clean per-engine config dir (auth preserved), but KEEPS the repo's project CLAUDE.md/.mcp.json so engines still see task-relevant rules. 'inherit' is the legacy behavior — inherit everything (your full ~/.claude). A competitive arena should be clean of private user augmentation, not ignorant of the repo it operates on. Override per dispatch with --pure/--impure/--isolation or AGON_ENGINE_ISOLATION."
  field name=isolationMigrationNotified type=boolean default=false
    doc "Internal: set true once the one-time 'engines now run workspace-pure by default' migration notice has been shown, so it isn't repeated."
  field name=terminalMode type="'auto'|'native'|'fullscreen'" default=auto
    doc "Terminal scroll behavior. 'auto' (default) uses fullscreen on a capable interactive terminal while preserving native scrollback in Zellij, dumb/non-TTY terminals, CI, or when AGON_NO_ALT_SCREEN is set. Explicit 'native' and 'fullscreen' always win."
  field name=uiMotion type="'full'|'reduced'|'off'" default=reduced
    doc "TUI repaint cadence. 'full' keeps responsive one-second activity clocks and higher-rate streaming, 'reduced' (default) uses coarse clocks and bounded stream frames for a steadier terminal, and 'off' disables cosmetic timers while preserving low-rate live output."
  field name=statusLine type=string default=""
    doc "Configurable one-line status (engine/model · context % · git branch) in the Cesar TUI. '' (default/absent) = off / keep existing status chrome only. 'default' = render the standard line. Any other value is treated as a format string with {engine}, {model}, {context}, {branch}, {cwd} placeholders (unknown placeholders pass through literally; a missing value renders empty). Custom shell-command status lines (à la Claude Code's `statusLine.command`) are NOT supported yet — placeholders only."
  field name=iconTheme type="'roman'|'classic'" default=roman
  field name=narrationFold type="'off'|'safe'|'aggressive'" default=safe
    doc "Engine-agnostic narration folding. Collapses verbose research play-by-play (e.g. a black-box --print agent's 'I will read X… let me check Y…' transcript) into a compact '▸ N reasoning steps folded · /raw' placeholder, keeping the answer visible. 'safe' (default) folds only contiguous runs of >=2 narration sentences and never the answer tail; 'aggressive' folds single narration lines too; 'off' disables. Fold-not-delete — /raw reprints the untouched original."
  field name=autoReviewAfterForge type=boolean default=true
    doc "Auto-run review on forge winner's patch before presenting to user. Data: 79% bug catch rate."
  field name=autoReviewAfterImpl type=boolean default=true
    doc "Auto-run review after Cesar implements code (Edit/Write). Catches bugs before user sees 'done'."
  field name=buddyTimeout type=number default=420
    doc "Timeout for AI buddy dispatches (brainstorm/tribunal/forge). Codex needs 420s minimum."
  field name=speculativeThresholdUsd type=number default=0.50
    doc "Max estimated USD cost for a single plan step below which speculation (scout+parallel agents) is skipped. Tasks cheaper than this go solo."
  field name=speculativeEloSpreadThreshold type=number default=15
    doc "Min ELO spread between top two engines for a task class. Below this, engines are too close to call — speculation is worthwhile. Above it, the leader is clear enough to skip speculation."
  field name=neroExplorationRate type=number default=0.2
    doc "ε for Nero's ε-greedy critic selection. With this probability the critic is drawn uniformly from the #2/#3-ranked eligible critics instead of the top-rated one, so challengers keep getting critique matches to contest the #1 spot (breaks the rich-get-richer loop where the top critic plays every match and nobody else can catch up). 0 = always exploit the top pick; clamped to [0,1]. Forced --engine picks and pools with fewer than 2 eligible critics are never explored."
  field name=ratingsPurgeKeepEngines type="string[]" default="[]"
    doc "Extra engine ids `agon ratings purge-unknown` must NEVER remove, even when they no longer correspond to a registered engine definition — e.g. legacy real engines (gemini before the agy rename) or old drifted version-suffixed ids (kimi-for-coding-k2p6) whose match history you want to keep. Unioned with the command's --keep flag."
  field name=autoCredit type=boolean default=true
    doc "When true, append 'Co-authored-by: Agon AI <agon@local>' to commits where Agon generated the commit message. Set to false to disable."
  field name=commitCoAuthor type=string default="agon (KERN) <292465531+KERN-Agon@users.noreply.github.com>"
    doc "Co-Authored-By identity for commits agon creates — and the SINGLE opt-out switch for agon's whole attribution block (mirrors Claude Code's includeCoAuthoredBy): when set (the default), agon-made commits end with a '⚔️ Forged by [Agon](…)' paragraph + this Co-Authored-By trailer, and agon-written PR bodies end with the same Forged-by line (rendered with the AGON logo image). Set to \"\" to disable ALL of it (machine-wide in ~/.agon/config.json or per-project in .agon.json). The default email is the KERN-Agon GitHub account's noreply address, so GitHub renders agon as a real co-author avatar + contributor; override with your own bot account's <id>+<login>@users.noreply.github.com to credit a different account."
  field name=browserExtensionIds type="string[]" optional=true
    doc "Extra Chrome extension ids (or full chrome-extension://<id> origins) `agon ext install` / `agon browser-host install` allow ALONGSIDE the baked dev id — e.g. the Chrome Web Store id once the extension is published, so the store build pairs without a code change. Each entry is either a bare 32-char a-p id or a full chrome-extension:// origin; a malformed entry is skipped with a warning, never a crash. AGON_EXTENSION_IDS (comma-separated) is the env-var equivalent, unioned with this list."


interface name=ScoutBid
  field name=engineId type=string
  field name=confidence type=number
  field name=approach type=string
  field name=steps type="string[]"
  field name=keyFiles type="string[]"
  field name=risk type="'low'|'medium'|'high'"
  field name=needsCompetition type=boolean

interface name=RoutingDecision
  field name=action type="'chat'|'build'|'pipeline'|'campfire'|'forge'|'brainstorm'|'tribunal'|'agent'|'team-agent'"
  field name=leadEngine type=string
  field name=confidence type=number
  field name=reasoning type=string
  field name=seedPlan type=string optional=true
  field name=observerEngines type="string[]"
  field name=forgeEngines type="string[]" optional=true
  field name=bids type="ScoutBid[]"

interface name=CampfireMessage
  field name=engineId type=string
  field name=content type=string
  field name=isLead type=boolean

interface name=ForgeOptions
  field name=task type=string
  field name=fitnessCmd type=string
  field name=cwd type=string
  field name=forgeDir type=string
  field name=mode type="'implement'|'improve'|'validate'" optional=true
  field name=requireDiff type=boolean optional=true
  field name=baselineMayPass type=boolean optional=true
  field name=acceptReviewOutput type=boolean optional=true
  field name=context type=string optional=true
  field name=seedPlan type=string optional=true
  field name=timeout type=number optional=true
  field name=fitnessTimeout type=number optional=true
  field name=starter type=string optional=true
  field name=engines type="string[]" optional=true
  field name=dryRun type=boolean optional=true
  field name=hardened type=boolean optional=true
  field name=signal type=AbortSignal optional=true
  field name=earlyFinalizeCount type=number optional=true
    doc "Per-invocation override of config.forgeEarlyFinalizePassingCount — minimum passing engines required to trigger stage2 auto-finalize. Set by --early-finalize-count on the CLI."
  field name=healthCheckEnabled type=boolean optional=true
    doc "Per-invocation override of config.forgeHealthCheckEnabled. Set false (or --no-health-check) to skip the pre-flight health probe for this run."
  field name=healthCheckTimeoutSec type=number optional=true
    doc "Per-invocation override of config.forgeHealthCheckTimeoutSec."
  field name=synthesize type="'always'|'close-call'|'never'" optional=true
    doc "When synthesis runs. 'close-call' (default) keeps the historical gate (only on a close call); 'always' synthesizes whenever 2+ engines pass; 'never' disables it. goal passes 'always'."
  field name=synthEngine type=string optional=true
    doc "Engine that performs the synthesis/refine pass. Defaults to the winner engine (forge's historical behavior). goal passes the judge; interactive forge passes Cesar."

interface name=EngineResult
  field name=engineId type=string
  field name=pass type=boolean
  field name=score type=number
  field name=status type=string optional=true
  field name=fitnessPassed type=boolean optional=true
  field name=engineCompleted type=boolean optional=true
  field name=reason type=string optional=true
  field name=diffLines type=number
  field name=filesChanged type=number
  field name=durationSec type=number
  field name=lintWarnings type=number
  field name=styleScore type=number
  field name=patchPath type=string optional=true
  field name=worktreePath type=string optional=true
  field name=fitnessLogPath type=string optional=true
  field name=dispatchStdout type=string optional=true
  field name=syntaxErrors type=number optional=true
  field name=syntaxInvalidFiles type="string[]" optional=true

interface name=SkippedEngine
  field name=engineId type=string
  field name=status type=string
  field name=reason type=string optional=true

interface name=DispatchMetric
  field name=engineId type=string
  field name=phase type="'stage1'|'stage1-fallback'|'stage2-scout'|'stage2-scout-fallback'|'stage2-follower'|'stage2-fallback'|'synthesis'|'gauntlet'"
  field name=dispatchDurationMs type=number
  field name=fitnessDurationMs type=number optional=true
  field name=totalDurationMs type=number
  field name=pass type=boolean optional=true
  field name=score type=number optional=true
  field name=timedOut type=boolean optional=true
  field name=error type=string optional=true
  field name=tokens type="{prompt:number, response:number, costUsd:number}" optional=true

interface name=ForgeManifest
  field name=forgeId type=string
  field name=forgeDir type=string
  field name=task type=string
  field name=fitnessCmd type=string
  field name=timestamp type=string
  field name=engines type="string[]"
  field name=skippedEngines type="SkippedEngine[]" optional=true
  field name=results type="Record<string,EngineResult>"
  field name=patches type="Record<string,string>"
  field name=winner type="string|null"
  field name=closeCall type=boolean
  field name=stage1Accepted type=boolean
  field name=baselinePasses type=boolean
  field name=mode type="'implement'|'improve'|'validate'" optional=true
  field name=requireDiff type=boolean optional=true
  field name=acceptReviewOutput type=boolean optional=true
  field name=status type=string optional=true
  field name=noDiffSummary type="{status:string,count:number,toolLoopLimit:number,usefulReports:number}" optional=true
  field name=alreadySatisfied type=boolean optional=true
  field name=singleSurvivor type=boolean optional=true
  field name=error type=string optional=true
  field name=starter type=string
  field name=enginesDispatched type=number
  field name=dispatchLog type="DispatchMetric[]" optional=true
  field name=resultBundlePath type=string optional=true
  field name=cleanupCommand type=string optional=true
  field name=synthesis type="{pass:boolean,score:number,wins:boolean,patchPath:string,originalWinnerScore:number,reason?:string}" optional=true
  field name=gauntlet type=GauntletResult optional=true

interface name=ConvergenceEntry
  field name=file type=string
  field name=fn type=string
  field name=from type=string
  field name=reason type=string

interface name=ForgeJudgment
  field name=winner type=string
  field name=strengths type="{ engineId: string; category: string; reason: string }[]"
  field name=convergencePlan type="ConvergenceEntry[]"
  field name=summary type=string
  field name=shouldConverge type=boolean

event name=ForgeEvent
  type name="baseline:start"
  type name="baseline:done" data="{ passes: boolean }"
  type name="stage1:start"
  type name="stage1:dispatch" data="{ engineId: string }"
  type name="stage1:score" data="{ engineId: string, score?: number, pass?: boolean, worktreePath?: string }"
  type name="stage1:accepted" data="{ engineId: string, score: number }"
  type name="stage2:start"
  type name="stage2:dispatch" data="{ engineId: string }"
  type name="stage2:score" data="{ engineId: string, score?: number, pass?: boolean, worktreePath?: string }"
  type name="stage2:done"
  type name="engine:failed" data="{ engineId: string, phase: string, error: string }"
  type name="engine:worktree" data="{ engineId: string, worktreePath: string, phase: string }"
  type name="winner:determined" data="{ winner: string, bestScore: number }"
  type name="forge:no-candidate-diff" data="{ status: string, count: number, toolLoopLimit: number, usefulReports: number }"
  type name="synthesis:start"
  type name="synthesis:critique" data="{ engineId: string }"
  type name="synthesis:refine"
  type name="synthesis:score" data="{ score: number }"
  type name="synthesis:done"
  type name="elo:update"
  type name="gauntlet:start"
  type name="gauntlet:breaker-dispatch" data="{ engineId: string }"
  type name="gauntlet:breaker-done" data="{ engineId: string, validated: boolean }"
  type name="gauntlet:attack-landed" data="{ engineId: string, failureMessage: string }"
  type name="gauntlet:repair-start"
  type name="gauntlet:repair-done" data="{ pass: boolean, score: number }"
  type name="gauntlet:corpus-save" data="{ count: number }"
  type name="gauntlet:done" data="{ attacksLanded: number, repairPass: boolean }"
  type name="forge:done"
  type name="forge:engine-skipped" data="{ engineId: string, status: string, reason?: string }"
  type name="forge:already-satisfied" data="{ baselinePasses: boolean }"
  type name="forge:single-survivor" data="{ engineId: string, score: number, totalEngines: number, failedCount: number }"
  type name="forge:no-engines-available" data="{ enabled: string[], skipped: string[] }"
  type name="forge:fatal" data="{ phase: string, error: string }"
  type name="forge:auto-finalize" data="{ passingCount: number, targetCount: number, minScore: number }"
  type name="forge:health-check-start" data="{ engineIds: string[], timeoutSec: number }"
  type name="forge:health-check-done" data="{ healthy: string[], unhealthy: any[], totalMs: number }"

interface name=BrainstormBid
  field name=engineId type=string
  field name=confidence type=number
  field name=reasoning type=string
  field name=approach type=string
  field name=score type=number optional=true

interface name=BrainstormGroup
  field name=members type="string[]"
  field name=representative type=string
  field name=similarity type=number

interface name=BrainstormDedupStatus
  field name=status type="'not-needed' | 'applied' | 'unavailable' | 'failed' | 'timed-out'"
  field name=detail type=string optional=true

interface name=BrainstormSynthesisStatus
  field name=status type="'completed' | 'fallback'"
  field name=detail type=string optional=true

// One panel-health record per multi-engine run: how many seats were requested,
// how many actually responded (after the one auto-retry), and the banner every
// surface MUST print when notes exist — a silent 3/6 committee is the failure.
interface name=PanelHealth
  field name=requested type=number
  field name=responded type=number
  field name=degraded type=boolean
  field name=notes type="string[]"
  field name=banner type="string | null"

interface name=BrainstormResult
  field name=question type=string
  field name=bids type="BrainstormBid[]"
  field name=winner type=string
  field name=response type=string
  field name=groups type="BrainstormGroup[]" optional=true
  field name=dedup type=BrainstormDedupStatus optional=true
  field name=synthesis type=BrainstormSynthesisStatus optional=true
  field name=panelHealth type=PanelHealth optional=true

interface name=BreakerArtifact
  field name=engineId type=string
  field name=testScript type=string
  field name=testPath type=string
  field name=failureMessage type=string
  field name=deterministic type=boolean
  field name=validated type=boolean

interface name=GauntletResult
  field name=winnerId type=string
  field name=breakerArtifacts type="BreakerArtifact[]"
  field name=attacksLanded type=number
  field name=repairAttempted type=boolean
  field name=repairPass type=boolean
  field name=preRepairScore type=number
  field name=postRepairScore type=number
  field name=finalWinnerId type=string
  field name=patchPath type=string optional=true

interface name=CorpusEntry
  field name=forgeId type=string
  field name=taskClass type=TaskClass
  field name=artifact type=BreakerArtifact
  field name=timestamp type=string
  field name=replayCount type=number
  field name=pattern type=string optional=true

interface name=GapPattern
  field name=pattern type=string
  field name=taskClass type=TaskClass
  field name=frequency type=number
  field name=firstSeen type=string
  field name=lastSeen type=string
  field name=skillProposed type=boolean
  field name=skillPath type=string optional=true

interface name=Critique
  field name=file type=string
  field name=lines type=string
  field name=problem type=string
  field name=minimalFix type=string

const name=DEFAULT_CONFIG type="Required<AgonConfig>" value=DEFAULT_AGON_CONFIG
