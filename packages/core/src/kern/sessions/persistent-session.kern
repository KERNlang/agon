import from="../models/types.js" names="EngineDefinition" types=true
import from="../diagnostics/diagnostic-runner.js" names="DiagnosticDeps" types=true
import from="./session-companion.js" names="createCompanionSession"
import from="./session-acp.js" names="createAcpSession"
import from="./session-streamjson.js" names="createStreamJsonSession"
import from="./session-resume.js" names="createResumeSession"
import from="./session-pty.js" names="createPtySession"
import from="./claude-backend.js" names="claudeBrainUsesPty"

interface name=SessionChunk
  doc "A streamed unit from a PersistentSession.send() turn. 'text' is the authoritative answer; 'preview' is a SPECULATIVE, best-effort live draft (currently emitted only by the PTY brain while it waits for the DeliverAnswer channel). A 'preview' chunk may ONLY update the live/dynamic streaming pane — it must NEVER be committed to the transcript or accumulated into the final answer. Every consumer that does not understand 'preview' must ignore it (all current consumers accumulate only 'text' and break on 'done'/'error', so a new 'preview' falls through harmlessly)."
  field name=type type="'text'|'preview'|'status'|'tool_call'|'error'|'done'"
  field name=content type=string
  field name=metadata type="Record<string,unknown>" optional=true

interface name=SessionSendOptions
  field name=message type=string
  field name=images type="string[]" optional=true
  field name=signal type=AbortSignal optional=true
  field name=systemPrompt type=string optional=true
  field name=toolLoopBaseBudget type=number optional=true
  field name=toolLoopMaxBudget type=number optional=true

interface name=PersistentSessionConfig
  field name=engine type=EngineDefinition
  field name=binaryPath type=string
  field name=cwd type=string
  field name=systemPrompt type=string optional=true
  field name=onApproval type="(tool: string, command: string) => Promise<boolean|string>" optional=true
  field name=nativeTools type="Array<{type:string,function:{name:string,description:string,parameters:Record<string,unknown>}}>" optional=true
  field name=onToolCall type="(name: string, args: Record<string,unknown>, callId: string) => Promise<string>" optional=true
  field name=onTurnEnd type="(learnings: {filesRead:string[], filesModified:string[], decisions:string[], discoveries:string[], toolsUsed:string[]}) => void" optional=true
  field name=mcpServers type="Array<Record<string,unknown>>" optional=true
  field name=sessionContinuity type=boolean optional=true
  field name=toolLoopBaseBudget type=number optional=true
  field name=toolLoopMaxBudget type=number optional=true
  field name=answerChannelPath type=string optional=true
  field name=claudePtyLaunchArgs type="string[]" optional=true
  field name=diagnosticDeps type=DiagnosticDeps optional=true
    doc "Injection seam for the per-session DiagnosticRunner (invariants/shadow modes). Threaded as `new DiagnosticRunner(engineId, config.diagnosticDeps)` so tests inject a fake spawnFn (no real tsc) + a now-clock; production leaves it unset (real spawnWithTimeout / saveToolResultToDisk)."

interface name=PersistentSession
  field name=alive type=boolean
  field name=sessionId type="string|null"
  field name=engineId type=string
  field name=pid type="number|null" optional=true
  field name=start type="() => Promise<void>"
  field name=send type="(opts: SessionSendOptions) => AsyncGenerator<SessionChunk, void, void>"
  field name=close type="() => void"
  field name=getMessageHistory type="() => Array<{role:string,content:any,tool_calls?:any[],tool_call_id?:string}>"
  field name=getContextUsage type="() => {tokens:number, limit:number, softLimit:number, source:'api'|'projected'|'estimate', cachedInputTokens:number}" optional=true
    doc "API sessions only. Real-usage-anchored context occupancy: tokens = last dispatch's real prompt+completion tokens plus an estimate of messages appended since; limit = the engine's context window; softLimit = the compaction trigger line (limit minus reserve). source marks exactness: 'api' (exact), 'projected' (real anchor + estimated delta), 'estimate' (no anchor yet)."
  field name=compact type="() => Promise<{ok:boolean, method:'llm'|'regex'|'none'|'deferred', beforeTokens:number, afterTokens:number, limit:number}>" optional=true
    doc "API sessions only. In-place Claude-style compaction: summarize older messages (LLM first, deterministic regex fallback), keep a boundary-safe verbatim tail, CONTINUE the same session. Coalesces concurrent calls; defers ('deferred') while a send() is in flight. Policy-owned by the Cesar budget gate and /compact."
  field name=getTurnUsage type="() => {promptTokens:number, completionTokens:number, totalTokens:number, source:'sdk', model?:string} | null" optional=true
    doc "API sessions only. DRAINS the real billed token usage accumulated since the last drain (summed across dispatch steps — each step bills its own full input; resets on read so each token is recorded exactly once). null when nothing real accrued. Callers record cost from this instead of estimating from text length."
  field name=getReadPaths type="() => string[] | undefined" optional=true
    doc "API sessions only. Serialized snapshot of the per-session ReadPathRegistry (the P1+P2 grounded-write read set), or undefined when the pipeline is off (strict → the registry is never allocated). saveConversation persists this at a cross-engine handoff so the next engine restores the grounded-read knowledge directly (the replayed history's tool_calls are flattened to text by stripEngineArtifacts and cannot be re-derived)."

fn name=createPersistentSession params="config:PersistentSessionConfig" returns="PersistentSession"
  doc "Factory: picks the right session implementation based on engine config."
  handler lang="kern"
    let name=engine value="config.engine"
    comment raw="// API path: engine has API config and no binary path provided → use stateless resume session"
    if cond="engine.api && !config.binaryPath"
      return value="createResumeSession(config)"
    comment raw="// Claude: `claude --print` (stream-json) brain by DEFAULT — Anthropic no longer meters -p under"
    comment raw="// the subscription, and -p is far more reliable than the TUI scrape. Opt INTO the PTY subscription"
    comment raw="// brain with AGON_CLAUDE_PTY=1 (claudeBrainUsesPty — the single switch all claude gates read)."
    if cond="(engine.companion?.protocol === 'stream-json' || engine.id === 'claude' || engine.binary === 'claude') && config.binaryPath"
      comment raw="// Only CLAUDE consults claudeBrainUsesPty — createPtySession drives the claude TUI specifically."
      comment raw="// A non-claude stream-json companion engine routes to the --print stream-json session, never the"
      comment raw="// claude PTY, so it is not coupled to claude's AGON_CLAUDE_PTY / claudeBackend setting."
      let name=isClaude value="engine.id === 'claude' || engine.binary === 'claude'"
      if cond="isClaude && claudeBrainUsesPty(config.cwd)"
        return value="createPtySession(config)"
      return value="createStreamJsonSession(config)"
    comment raw="// Engines with ACP protocol (OpenCode, Gemini)"
    if cond="engine.companion && engine.companion.protocol === 'acp'"
      return value="createAcpSession(config)"
    comment raw="// Engines with JSONRPC companion (Codex)"
    if cond="engine.companion && engine.companion.protocol === 'jsonrpc'"
      return value="createCompanionSession(config)"
    comment raw="// Fallback: resume-based (spawn per turn with --resume/--continue)"
    return value="createResumeSession(config)"
