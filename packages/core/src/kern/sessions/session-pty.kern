import from="node:fs" names="existsSync,readFileSync,rmSync"
import from="./persistent-session.js" names="PersistentSessionConfig,PersistentSession,SessionChunk,SessionSendOptions" types=true

fn name=createPtySession params="config:PersistentSessionConfig" returns="PersistentSession"
  doc "Persistent interactive Claude brain over the kern-engines PTY subscription daemon (@kernlang/agon-engines), NOT `claude --print`. Honors the hard rule that the claude brain bills via the subscription TUI. Cesar orchestration is preserved by injecting the agon-orchestration MCP server (config.mcpServers → --mcp-config + --strict-mcp-config) with native writes disabled (--disallowedTools) and only Read/Grep/Glob + mcp__agon-orchestration allowed. The engine's FINAL answer is read from the DeliverAnswer answer-channel file (config.answerChannelPath) — authoritative and reliable — instead of scraping the TUI text (which is flaky for short tool-answers: the ⏺ marker collides with spinner glyphs and short answers fuse with status chrome on one row). The scraped extract is kept only as a fallback when the engine didn't call DeliverAnswer."
  handler <<<
    let claudeSession: any = null;
    let alive = false;
    let firstTurn = true;
    let turnActive = false;
    // The PTY pump for the PRIOR turn, still settling in the background after we
    // early-returned its channel answer. The next send() awaits it so the daemon
    // (which forbids concurrent asks) is free — this overlaps with the user
    // reading the last answer + typing, so it's almost always already done.
    let pendingDrain: Promise<void> | null = null;

    // 15-min per-turn ceiling. A turn is short in practice: orchestration tools
    // (Forge/Tribunal) SIGNAL Cesar and return "stop" immediately; AgonBash runs
    // in the MCP server (bounded by its own timeout). The ceiling only guards a
    // wedged TUI.
    const TURN_TIMEOUT_MS = 15 * 60 * 1000;

    function buildExtraArgv(): string[] {
      const args: string[] = [];
      // Inject the Agon-configured MCP servers (incl. agon-orchestration) the same
      // way the --print path does, then lock to ONLY these (--strict-mcp-config).
      if (config.mcpServers && config.mcpServers.length > 0) {
        const mcpConfig = JSON.stringify({
          mcpServers: Object.fromEntries(
            config.mcpServers.map((s: any) => [s.name ?? s.command ?? 'mcp', s]),
          ),
        });
        args.push('--mcp-config', mcpConfig, '--strict-mcp-config');
      }
      // Defense in depth: disallow native writes (claude must route through
      // AgonBash/AgonEdit/AgonWrite) AND only allow read tools + the agon server.
      // --disallowedTools wins over --allowedTools, so writes are off regardless
      // of how the default config's --allowedTools merges with this one.
      args.push('--disallowedTools', 'Bash Edit Write MultiEdit NotebookEdit');
      args.push('--allowedTools', 'Read Grep Glob mcp__agon-orchestration');
      // Optional per-session launch flags (model/effort), forwarded by the caller.
      if (config.claudePtyLaunchArgs && config.claudePtyLaunchArgs.length > 0) {
        args.push(...config.claudePtyLaunchArgs);
      }
      return args;
    }

    function readAnswer(): string | null {
      const p = config.answerChannelPath;
      if (!p) return null;
      try {
        if (!existsSync(p)) return null;
        const parsed = JSON.parse(readFileSync(p, 'utf-8'));
        const t = (parsed as any)?.text;
        return typeof t === 'string' ? t : null;
      } catch { return null; }
    }
    function clearAnswer(): void {
      const p = config.answerChannelPath;
      if (!p) return;
      try { rmSync(p, { force: true }); } catch { /* best-effort */ }
    }

    const session: PersistentSession = {
      get alive() { return alive; },
      sessionId: null,
      engineId: config.engine.id,
      get pid() { return null; },

      async start() {
        if (alive) return;
        const mod: any = await import('@kernlang/agon-engines/cli/claude.js');
        claudeSession = await mod.ClaudeCliSession.spawn({
          mode: 'agent',
          cwd: config.cwd,
          extraArgv: buildExtraArgv(),
          daemonTimeoutMs: 60_000,
        });
        alive = true;
        firstTurn = true;
      },

      async *send(opts: SessionSendOptions) {
        if (turnActive) { yield { type: 'error' as const, content: 'claude PTY session busy (concurrent turn rejected)' }; return; }
        turnActive = true;
        try {
          // Free the daemon: a prior turn whose answer we already returned may
          // still be settling its PTY pump in the background. Wait it out (this
          // overlaps with the user's read+type time, so it's usually instant).
          if (pendingDrain) { try { await pendingDrain; } catch { /* ignore */ } pendingDrain = null; }

          if (!alive || !claudeSession) {
            try { await session.start(); }
            catch (e) { yield { type: 'error' as const, content: `claude PTY session not alive: ${e instanceof Error ? e.message : String(e)}` }; return; }
          }
          if (opts.signal?.aborted) { yield { type: 'done' as const, content: 'cancelled' }; return; }

          clearAnswer();
          // Claude's TUI has no --system-prompt; prepend it on the first turn only
          // (the persistent session retains it in conversation context thereafter).
          const sys = firstTurn ? (opts.systemPrompt ?? config.systemPrompt) : undefined;
          firstTurn = false;
          const composed = sys
            ? `[System Instructions]\n${sys}\n\n[User Message]\n${opts.message}`
            : opts.message;

          let aborted = false;
          const onAbort = () => {
            aborted = true;
            try { claudeSession?.close?.(); } catch { /* ignore */ }
            claudeSession = null; alive = false;
          };
          opts.signal?.addEventListener('abort', onAbort, { once: true });

          // Driver: pump the PTY turn to completion (idle-settle). It runs to the
          // end even after we early-return the channel answer, so the daemon's
          // single-flight lock clears for the next turn. It NEVER rejects — the
          // scraped extract / error are captured for the fallback path. Tracked
          // in pendingDrain from creation so it can't orphan the daemon.
          let scrapedFinal = '';
          let driverError: unknown = null;
          const it = claudeSession.askStream(composed, TURN_TIMEOUT_MS);
          const driver: Promise<void> = (async () => {
            try {
              let res = await it.next();
              while (!res.done) { res = await it.next(); }
              scrapedFinal = typeof res.value === 'string' ? res.value : '';
            } catch (e) { driverError = e; }
          })();
          pendingDrain = driver;
          let driverDone = false;
          void driver.then(() => { driverDone = true; });

          // Race: the DeliverAnswer channel file appearing (normal turn — return
          // the instant Claude delivers, skipping the idle-settle wait) vs the
          // driver completing (orchestration STOP turn with no answer, or error).
          await new Promise<void>((resolve) => {
            const tick = setInterval(() => {
              if (driverDone || readAnswer() !== null) { clearInterval(tick); resolve(); }
            }, 100);
            void driver.finally(() => { clearInterval(tick); resolve(); });
          });

          opts.signal?.removeEventListener('abort', onAbort);

          if (aborted) {
            // pendingDrain already === driver; the closed pump unwinds off the hot path.
            yield { type: 'done' as const, content: 'cancelled' }; return;
          }

          // Authoritative answer via the DeliverAnswer channel — return NOW; the
          // PTY finishes settling in the background (next send() awaits it).
          const answer = readAnswer();
          if (answer !== null && answer.length > 0) {
            yield { type: 'text' as const, content: answer };
            yield { type: 'done' as const, content: 'end_turn' };
            return;
          }

          // No channel answer — the driver has finished (orchestration STOP turn,
          // or Claude didn't deliver). Surface an error or fall back to scrape.
          await driver;
          pendingDrain = null;
          if (driverError) {
            alive = false; claudeSession = null;
            yield { type: 'error' as const, content: `claude PTY turn failed: ${driverError instanceof Error ? driverError.message : String(driverError)}` };
            return;
          }
          if (scrapedFinal && scrapedFinal.trim()) {
            yield { type: 'text' as const, content: scrapedFinal };
          }
          yield { type: 'done' as const, content: 'end_turn' };
        } finally {
          turnActive = false;
        }
      },

      close() {
        try { claudeSession?.close?.(); } catch { /* ignore */ }
        claudeSession = null;
        alive = false;
      },

      getMessageHistory() {
        // Claude TUI manages its own conversation thread — no local history.
        return [];
      },
    };

    return session;
  >>>
