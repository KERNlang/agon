// ── CLI Models Registry — dynamic provider→models from models.dev + binary discovery ──
// Maps installed CLI engine binaries to their latest model lists from the models.dev API.
// Falls back to a minimal static list if the API is unavailable.

import from="node:child_process" names="execSync"
import from="node:fs" names="readFileSync,writeFileSync,mkdirSync,existsSync,statSync"
import from="node:path" names="join"
import from="node:os" names="homedir"
import from="../utils/paths.js" names="getCacheDir"

interface name=CliModelEntry
  field name=id type=string
  field name=name type=string
  field name=providerId type=string
  field name=providerName type=string
  field name=engineId type=string
  field name=engineBinary type=string
  field name=contextWindow type=number optional=true
  field name=toolCall type=boolean optional=true
  field name=reasoning type=boolean optional=true

interface name=CliProviderGroup
  field name=providerId type=string
  field name=providerName type=string
  field name=engineId type=string
  field name=engineBinary type=string
  field name=installed type=boolean
  field name=version type="string|null"
  field name=models type="CliModelEntry[]"

// ── Engine binary → models.dev provider mapping ──
// This is the only static config needed: which CLI binary maps to which API provider.

const name=ENGINE_PROVIDER_MAP type="Record<string, {providerId:string, engineId:string, engineBinary:string, versionCmd:string[]}>" value={{ ({ anthropic: { providerId: 'anthropic', engineId: 'claude', engineBinary: 'claude', versionCmd: ['--version'] }, openai: { providerId: 'openai', engineId: 'codex', engineBinary: 'codex', versionCmd: ['--version'] }, google: { providerId: 'google', engineId: 'agy', engineBinary: 'agy', versionCmd: ['--version'] }, mistral: { providerId: 'mistral', engineId: 'mistral', engineBinary: 'mistral', versionCmd: ['--version'] }, openrouter: { providerId: 'openrouter', engineId: 'openrouter', engineBinary: 'openrouter', versionCmd: [] } }) }}

// ── Minimal fallback when API is unreachable ──

const name=FALLBACK_MODELS type="Record<string, {id:string, name:string, contextWindow?:number, toolCall?:boolean, reasoning?:boolean}[]>" value={{ ({ anthropic: [ { id: 'claude-sonnet-4-5-20250929', name: 'Claude Sonnet 4.5', contextWindow: 200000, toolCall: true, reasoning: true }, { id: 'claude-haiku-4-5-20251001', name: 'Claude Haiku 4.5', contextWindow: 200000, toolCall: true, reasoning: true } ], openai: [ { id: 'gpt-4o', name: 'GPT-4o', contextWindow: 128000, toolCall: true, reasoning: false }, { id: 'o4-mini', name: 'o4-mini', contextWindow: 200000, toolCall: true, reasoning: true } ], google: [ { id: 'gemini-3.5-flash', name: 'Gemini 3.5 Flash', contextWindow: 1048576, toolCall: true, reasoning: true }, { id: 'gemini-3.1-pro', name: 'Gemini 3.1 Pro', contextWindow: 1048576, toolCall: true, reasoning: true }, { id: 'gemini-3-flash-preview', name: 'Gemini 3 Flash', contextWindow: 1048576, toolCall: true, reasoning: true } ], mistral: [ { id: 'mistral-large-latest', name: 'Mistral Large', contextWindow: 128000, toolCall: true, reasoning: false }, { id: 'codestral-latest', name: 'Codestral', contextWindow: 256000, toolCall: true, reasoning: false } ], openrouter: [ { id: 'auto', name: 'Auto (best for task)', toolCall: true, reasoning: false } ] }) }}

const name=CACHE_TTL_MS type=number value=3600000

// ── Fetch models from models.dev API (shared cache with models-registry) ──

fn name=fetchCliModelsRegistry async=true returns="Promise<Record<string, any> | null>"
  handler <<<
    const cacheDir = getCacheDir();
    const cacheFile = join(cacheDir, 'models-dev.json');
    try {
      if (existsSync(cacheFile)) {
        const stat = statSync(cacheFile);
        const age = Date.now() - stat.mtimeMs;
        if (age < CACHE_TTL_MS) {
          return JSON.parse(readFileSync(cacheFile, 'utf-8'));
        }
      }
    } catch { /* cache read failed, refetch */ }

    try {
      const response = await fetch('https://models.dev/api.json');
      if (!response.ok) {
        // Try stale cache
        if (existsSync(cacheFile)) {
          return JSON.parse(readFileSync(cacheFile, 'utf-8'));
        }
        return null;
      }
      const data = await response.json();
      mkdirSync(cacheDir, { recursive: true });
      writeFileSync(cacheFile, JSON.stringify(data));
      return data;
    } catch {
      // Stale cache fallback
      try {
        if (existsSync(cacheFile)) {
          return JSON.parse(readFileSync(cacheFile, 'utf-8'));
        }
      } catch { /* give up */ }
      return null;
    }
  >>>

fn name=findBinary params="binary:string" returns="string|null" export=true
  handler lang="kern"
    try
      let name=result value="execSync(`which ${binary}`, { encoding: 'utf-8', timeout: 5000, stdio: ['pipe', 'pipe', 'pipe'] }).trim()"
      if cond="result"
        return value="result"
      catch name=e
    let name=home value="homedir()"
    let name=searchPaths value="[ join(home, '.local', 'bin'), join(home, '.npm-global', 'bin'), '/usr/local/bin', ]"
    each name=dir in="searchPaths"
      let name=fullPath value="join(dir, binary)"
      if cond="existsSync(fullPath)"
        return value="fullPath"
    return value="null"

fn name=getBinaryVersion params="binary:string, versionCmd:string[]" returns="string|null" export=true
  handler lang="kern"
    if cond="!versionCmd.length"
      return value="null"
    try
      let name=result value="execSync(`${binary} ${versionCmd.join(' ')}`, { encoding: 'utf-8', timeout: 5000, stdio: ['pipe', 'pipe', 'pipe'] }).trim()"
      return value="result || null"
      catch name=e
        return value="null"

fn name=buildCliModelGroups returns="CliProviderGroup[]" export=true
  doc "Build CLI provider groups synchronously from fallback models. For async version use buildCliModelGroupsAsync."
  handler lang="kern"
    let name=groups type="CliProviderGroup[]" value="[]"
    each pairKey=key pairValue=eng in="ENGINE_PROVIDER_MAP" entries=true
      let name=binaryPath value="findBinary(eng.engineBinary)"
      let name=installed value="binaryPath !== null"
      let name=version value="installed ? getBinaryVersion(eng.engineBinary, eng.versionCmd) : null"
      let name=fallbackModels value="FALLBACK_MODELS[key] ?? []"
      let name=models type="CliModelEntry[]" value="fallbackModels.map((m: any) => Object.assign({}, { id: m.id, name: m.name, providerId: eng.providerId, providerName: key.charAt(0).toUpperCase() + key.slice(1), engineId: eng.engineId, engineBinary: eng.engineBinary, contextWindow: m.contextWindow, toolCall: m.toolCall, reasoning: m.reasoning }))"
      do value="groups.push({ providerId: eng.providerId, providerName: key.charAt(0).toUpperCase() + key.slice(1), engineId: eng.engineId, engineBinary: eng.engineBinary, installed, version, models, })"
    return value="groups"

fn name=buildCliModelGroupsAsync async=true returns="Promise<CliProviderGroup[]>" export=true
  doc "Build CLI provider groups with latest models from models.dev API. Falls back to static list on failure."
  handler lang="kern"
    let name=registry type="Record<string, any> | null" kind=let value="null"
    try
      assign target="registry" value="await fetchCliModelsRegistry()"
      catch name=e
        assign target="registry" value="null"
    let name=groups type="CliProviderGroup[]" value="[]"
    each pairKey=key pairValue=eng in="ENGINE_PROVIDER_MAP" entries=true
      let name=binaryPath value="findBinary(eng.engineBinary)"
      let name=installed value="binaryPath !== null"
      let name=version value="installed ? getBinaryVersion(eng.engineBinary, eng.versionCmd) : null"
      let name=models type="CliModelEntry[]" kind=let value="[]"
      comment raw="// Try to get models from the API registry"
      if cond="registry && registry[eng.providerId]"
        let name=provider value="registry[eng.providerId]"
        let name=providerName value="provider.name ?? (key.charAt(0).toUpperCase() + key.slice(1))"
        let name=apiModels value="provider.models ?? {}"
        assign target="models" value="Object.values(apiModels).map((m: any) => Object.assign({}, { id: m.id, name: m.name, providerId: eng.providerId, providerName, engineId: eng.engineId, engineBinary: eng.engineBinary, contextWindow: m.limit?.context, toolCall: m.tool_call ?? false, reasoning: m.reasoning ?? false }))"
      comment raw="// Fallback to static list"
      if cond="models.length === 0"
        let name=fallbackModels value="FALLBACK_MODELS[key] ?? []"
        assign target="models" value="fallbackModels.map((m: any) => Object.assign({}, { id: m.id, name: m.name, providerId: eng.providerId, providerName: key.charAt(0).toUpperCase() + key.slice(1), engineId: eng.engineId, engineBinary: eng.engineBinary, contextWindow: m.contextWindow, toolCall: m.toolCall, reasoning: m.reasoning }))"
      comment raw="// Determine display name"
      let name=displayName value="registry?.[eng.providerId]?.name ?? (key.charAt(0).toUpperCase() + key.slice(1))"
      do value="groups.push({ providerId: eng.providerId, providerName: displayName, engineId: eng.engineId, engineBinary: eng.engineBinary, installed, version, models, })"
    return value="groups"
