        ],
      },
    })
  >>>

fn name=findBinary params="binary:string" returns="string|null"
  handler <<<
    try {
      const result = execSync(`which ${binary}`, { encoding: 'utf-8', timeout: 5000, stdio: ['pipe', 'pipe', 'pipe'] }).trim();
      if (result) return result;
    } catch { /* not found via which */ }

    const home = homedir();
    const searchPaths = [
      join(home, '.local', 'bin'),
      join(home, '.npm-global', 'bin'),
      '/usr/local/bin',
    ];
    for (const dir of searchPaths) {
      const fullPath = join(dir, binary);
      if (existsSync(fullPath)) return fullPath;
    }
    return null;
  >>>

fn name=getBinaryVersion params="binary:string, versionCmd:string[]" returns="string|null"
  handler <<<
    if (!versionCmd.length) return null;
    try {
      const result = execSync(`${binary} ${versionCmd.join(' ')}`, { encoding: 'utf-8', timeout: 5000, stdio: ['pipe', 'pipe', 'pipe'] }).trim();
      return result || null;
    } catch { return null; }
  >>>
