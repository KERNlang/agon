import from="node:fs" names="readdirSync,readFileSync,existsSync"
import from="node:path" names="join,dirname,resolve"
import from="node:os" names="homedir"
import from="node:child_process" names="execFileSync"
import from="../models/types.js" names="EngineDefinition,EngineMode,AgonConfig" types=true
import from="../models/errors.js" names="EngineNotFoundError"
import from="../../schemas/engine-schema.js" names="validateEngineConfig"

fn name=getAgonEnginesDir returns=string export=false
  handler <<<
    const override = process.env.AGON_HOME?.trim();
    const home = override ? resolve(override) : join(homedir(), '.agon');
    return join(home, 'engines');
  >>>

// One-time log guard so noisy configs don't spam on every load/reload.
const name=_formatNormalizedSet type="Set<string>" value={{ new Set<string>() }}

// Hosts that are *known* to serve only OpenAI-shaped /chat/completions
// despite being declared with format='anthropic' in the wild. A broader
// rewrite (every non-Anthropic host) would regress valid setups like
// Cloudflare AI Gateway, enterprise Anthropic proxies, or Bedrock's
// Anthropic-compatible endpoints, so the list stays narrow — add
// providers only after confirming they truly don't speak /messages.
const name=_OPENAI_COMPAT_ONLY_HOST_SUFFIXES type="string[]" value={{ [ 'api.kimi.com', 'moonshot.cn', 'moonshot.ai', 'api.groq.com', 'together.xyz', 'together.ai', 'api.deepinfra.com', 'openrouter.ai', 'api.deepseek.com', 'api.perplexity.ai' ] }}

fn name=normalizeEngineFormat params="raw:any, fileLabel:string" returns=void export=false
  doc "Narrow normalization: if api.format='anthropic' but the baseUrl host is on the known-OpenAI-compat-only allowlist (Kimi/Moonshot, Groq, Together, DeepInfra, OpenRouter), rewrite to 'openai'. Every other non-Anthropic host is left alone — arbitrary Anthropic-compatible proxies are valid configurations and must not be silently coerced. Skips /coding/ API paths which are specialised endpoints that choose their own wire format. Mutates raw in place; logs once per engine id."
  handler <<<
    const api = raw?.api;
    if (!api || api.format !== 'anthropic' || typeof api.baseUrl !== 'string') return;
    let parsedUrl: URL;
    try { parsedUrl = new URL(api.baseUrl); } catch { return; }
    const host = parsedUrl.host.toLowerCase();
    if (host === 'api.anthropic.com' || host.endsWith('.anthropic.com')) return;
    // Skip specialised /coding/ API paths — these are provider-specific endpoints
    // (e.g. api.kimi.com/coding/v1, api.z.ai/api/coding/paas/v4) that declare their
    // own wire format and should not be force-rewritten based on hostname alone.
    if (parsedUrl.pathname.toLowerCase().includes('/coding/')) return;
    const matched = _OPENAI_COMPAT_ONLY_HOST_SUFFIXES.some((suffix: string) => host === suffix || host.endsWith('.' + suffix));
    if (!matched) return;
    api.format = 'openai';
    const key = typeof raw.id === 'string' ? raw.id : fileLabel;
    if (!_formatNormalizedSet.has(key)) {
      _formatNormalizedSet.add(key);
      console.log(`[agon] engine '${key}': api.format 'anthropic' on known OpenAI-compat host '${host}' normalized to 'openai'.`);
    }
  >>>

service name=EngineRegistry
  field name=engines type="Map<string, EngineDefinition>" default="new Map()" private=true
  field name=binaryCache type="Map<string, string | null>" default="new Map()" private=true

  method name=resolveBuiltinDir params="dir:string" returns=string private=true
    handler <<<
      if (existsSync(dir)) return dir;
      let cursor = dirname(dir);
      for (let i = 0; i < 6; i += 1) {
        const candidate = join(cursor, 'engines');
        if (candidate !== dir && existsSync(candidate)) return candidate;
        const parent = dirname(cursor);
        if (parent === cursor) break;
        cursor = parent;
      }
      return dir;
    >>>

  method name=loadDir params="dir:string, tier:'builtin'|'user'" returns=void private=true
    handler <<<
      if (!existsSync(dir)) {
        console.warn(`[agon] engine directory does not exist: ${dir}`);
        return;
      }
      let files: string[];
      try { files = readdirSync(dir).filter((f: string) => f.endsWith('.json')); }
      catch (err) {
        console.warn(`[agon] failed to read engine directory ${dir}: ${err instanceof Error ? err.message : String(err)}`);
        return;
      }
      for (const file of files) {
        try {
          const raw = JSON.parse(readFileSync(join(dir, file), 'utf-8'));
          normalizeEngineFormat(raw, file);
          const validation = validateEngineConfig(raw, file);
          if (!validation.ok) {
            console.warn(`[agon] ${validation.error}`);
            // Still load the engine with a warning — don't break existing setups
            const def = raw as EngineDefinition;
            def.tier = tier;
            this.engines.set(def.id, def);
            continue;
          }
          const def = validation.data as unknown as EngineDefinition;
          def.tier = tier;
          this.engines.set(def.id, def);
        } catch (err) {
          console.warn(`[agon] failed to load engine definition ${file}: ${err instanceof Error ? err.message : String(err)}`);
        }
      }
    >>>

  method name=load params="builtinDir:string" returns=void
    handler lang="kern"
      do value="this.loadDir(this.resolveBuiltinDir(builtinDir), 'builtin')"
      let name=agonEnginesDir value="getAgonEnginesDir()"
      if cond="existsSync(agonEnginesDir)"
        do value="this.loadDir(agonEnginesDir, 'user')"

  method name=register params="engine:EngineDefinition" returns=void
    handler lang="kern"
      do value="normalizeEngineFormat(engine, engine.id)"
      do value="this.engines.set(engine.id, engine)"

  method name=unregister params="id:string" returns=void
    handler lang="kern"
      do value="this.engines.delete(id)"
      do value="this.binaryCache.delete(id)"

  method name=clearBinaryCache params="id?:string" returns=void
    doc "Clear cached binary lookup results. Used after users install or remove CLIs while Agon is already running so /discover and /engines see the new PATH state."
    handler lang="kern"
      if cond="id"
        do value="this.binaryCache.delete(id)"
        return
      do value="this.binaryCache.clear()"

  method name=resolveId params="id:string" returns=string
    doc "Resolve a possibly-abbreviated engine id to a canonical registered id. An exact id wins. Otherwise, case-insensitively: a unique exact match, then a unique prefix match (kimi -> kimi-for-coding-k2p6), then a unique substring match (zai -> zai-coding-plan-glm-5.1). Ambiguous or no match returns the input unchanged so the caller fails loudly with the original name rather than guessing wrong."
    handler <<<
      if (!id) return id;
      if (this.engines.has(id)) return id;
      const needle = id.trim().toLowerCase();
      if (!needle) return id;
      const ids = Array.from(this.engines.keys());
      const ci = ids.filter((k) => k.toLowerCase() === needle);
      if (ci.length === 1) return ci[0];
      const prefix = ids.filter((k) => k.toLowerCase().startsWith(needle));
      if (prefix.length === 1) return prefix[0];
      const substr = ids.filter((k) => k.toLowerCase().includes(needle));
      if (substr.length === 1) return substr[0];
      return id;
    >>>

  method name=get params="id:string" returns=EngineDefinition
    handler lang="kern"
      let name=engine value="this.engines.get(id)"
      if cond="engine"
        return value="engine"
      let name=resolved value="this.resolveId(id)"
      let name=aliased value="resolved !== id ? this.engines.get(resolved) : undefined"
      if cond="aliased"
        return value="aliased"
      throw value="new EngineNotFoundError(id)"

  method name=list returns="EngineDefinition[]"
    handler lang="kern"
      return value="Array.from(this.engines.values())"

  method name=listIds returns="string[]"
    handler lang="kern"
      return value="Array.from(this.engines.keys())"

  method name=findBinary params="engine:EngineDefinition" returns="string|null"
    handler <<<
      if (!engine.binary) { this.binaryCache.set(engine.id, null); return null; }
      if (this.binaryCache.has(engine.id)) return this.binaryCache.get(engine.id) ?? null;
      const envKey = `${engine.id.toUpperCase()}_PATH`;
      const envPath = process.env[envKey];
      if (envPath && existsSync(envPath)) { this.binaryCache.set(engine.id, envPath); return envPath; }
      try {
        const result = execFileSync('which', [engine.binary], { encoding: 'utf-8', timeout: 5000, stdio: ['pipe', 'pipe', 'pipe'] }).trim();
        if (result) { this.binaryCache.set(engine.id, result); return result; }
      } catch {
        // 'which' not finding a binary is expected — no warning needed
      }
      for (const rawPath of (engine.searchPaths ?? [])) {
        const expanded = rawPath.replace('${HOME}', homedir());
        const fullPath = join(expanded, engine.binary);
        if (existsSync(fullPath)) { this.binaryCache.set(engine.id, fullPath); return fullPath; }
      }
      this.binaryCache.set(engine.id, null);
      return null;
    >>>

  method name=isAvailable params="engine:EngineDefinition" returns=boolean
    handler <<<
      const hasApiKey = !!(engine.api && process.env[engine.api.apiKeyEnv]);
      const hasBinary = !!(engine.binary && this.findBinary(engine) !== null);
      return hasApiKey || hasBinary;
    >>>

  method name=supportsMode params="engine:EngineDefinition, mode:EngineMode" returns=boolean
    handler lang="kern"
      if cond="mode === 'exec' && engine.exec"
        return value="true"
      if cond="mode === 'review' && engine.review"
        return value="true"
      if cond="mode === 'agent' && engine.agent"
        return value="true"
      return value="engine.modes?.includes(mode) ?? false"

  method name=agentCapableIds params="config?:Pick<Required<AgonConfig>,'engineActivationMode'|'forgeEnabledEngines'|'hiddenEngines'>" returns="string[]"
    handler lang="kern"
      return value="this.activeEngines(config) .filter((e: EngineDefinition) => !!e.agent && !!e.binary && this.findBinary(e) !== null) .map((e: EngineDefinition) => e.id)"

  method name=availableEngines returns="EngineDefinition[]"
    handler lang="kern"
      return value="this.list().filter((e: EngineDefinition) => this.isAvailable(e))"

  method name=availableIds returns="string[]"
    handler lang="kern"
      return value="this.availableEngines().map((e: EngineDefinition) => e.id)"

  method name=activeEngines params="config?:Pick<Required<AgonConfig>,'engineActivationMode'|'forgeEnabledEngines'|'hiddenEngines'>" returns="EngineDefinition[]"
    doc "Available engines filtered through user activation settings. hiddenEngines are removed from routing in every mode. In auto mode every non-hidden available engine is active; in explicit mode only non-hidden forgeEnabledEngines are active."
    handler lang="kern"
      let name=hidden value="new Set(config?.hiddenEngines ?? [])"
      let name=available value="this.availableEngines().filter((e: EngineDefinition) => !hidden.has(e.id))"
      if cond="!config || config.engineActivationMode !== 'explicit'"
        return value="available"
      let name=selected value="new Set(config.forgeEnabledEngines ?? [])"
      return value="available.filter((e: EngineDefinition) => selected.has(e.id))"

  method name=activeIds params="config?:Pick<Required<AgonConfig>,'engineActivationMode'|'forgeEnabledEngines'|'hiddenEngines'>" returns="string[]"
    handler lang="kern"
      return value="this.activeEngines(config).map((e: EngineDefinition) => e.id)"

  method name=pickStarter params="available:string[], strategy:'fixed'|'rotate', preferred?:string" returns=string
    handler lang="kern"
      if cond="available.length === 0"
        throw value="new EngineNotFoundError('(any)', 'No engines available')"
      if cond="strategy === 'fixed'"
        if cond="preferred && available.includes(preferred)"
          return value="preferred"
        return value="available[0]"
      return value="available[Math.floor(Date.now() / 1000) % available.length]"

  method name=getFallbackChain params="sourceId:string, taskClass?:string, candidateIds?:string[]" returns="string[]"
    doc "Return ranked candidate engines for fallback from sourceId, excluding source itself. Uses Glicko-2 ratings when available; falls back to available order."
    handler <<<
      const available = (candidateIds ?? this.availableIds()).filter((id: string) => id !== sourceId);
      if (available.length === 0) return [];
      try {
        const { getEngineGlickoRating } = require('../signals/glicko.js');
        const scored = available.map((id: string) => {
          const r = getEngineGlickoRating(id, taskClass);
          return { id, score: r.mu - 2 * r.phi };
        });
        scored.sort((a: any, b: any) => b.score - a.score);
        return scored.map((s: any) => s.id);
      } catch {
        return available;
      }
    >>>

  method name=getFallbackCandidate params="sourceId:string, taskClass?:string, candidateIds?:string[]" returns="string|undefined"
    doc "Top fallback candidate for sourceId, or undefined if none available."
    handler lang="kern"
      let name=chain value="this.getFallbackChain(sourceId, taskClass, candidateIds)"
      return value="chain[0]"
