// ── Engine dispatch isolation ──────────────────────────────────────────
// agon is a competitive multi-AI arena. Inheriting the user's personal
// tooling (~/.claude global CLAUDE.md, Claude Code plugins/hooks, user MCP
// servers) into a dispatched engine makes the competition "Claude + the
// user's private toolchain" vs other engines bare — unfair, costly (every
// MCP tool def is injected context), and full of side effects (the user's
// hooks fire inside a forge worker). So engines run "workspace-pure" by
// default: strip the PERSONAL/global layer (via a clean per-engine config
// dir, seeded with ONLY the auth file so dispatch stays logged in), while the
// repo's project CLAUDE.md/.mcp.json in the cwd are kept (task-relevant,
// symmetric across engines). 'inherit' opts back into the full personal setup.
//
// Two PURE functions here (testable without spawning anything):
//   resolveIsolationMode — option > env > config > default
//   planEngineIsolation  — given an engine + mode, what env/args to apply
// The I/O (clean config dir, auth-file copy, env merge) is hand-wired in the
// adapter (computeEngineIsolation).

import from="../models/types.js" names="EngineDefinition" types=true

const name=ISOLATION_MODES type="readonly string[]" value={{ ['workspace-pure', 'inherit'] as const }}
  doc "The valid isolation modes — used to validate untrusted input (env var / config / flag) before it reaches the planner. ('bare' — strip project context too — is intentionally not shipped: it needs a worktree overlay to physically remove the repo CLAUDE.md, and is only useful for benchmarks.)"

interface name=EngineIsolationPlan export=true
  doc "The decided isolation for ONE engine dispatch — consumed by the adapter to shape the spawn (env overrides + extra CLI args) and by provenance."
  field name=isolate type=boolean
    doc "True when something is actually stripped. False for 'inherit' and for API-only engines (no local config to isolate)."
  field name=mode type="'workspace-pure'|'inherit'"
  field name=engineId type=string
  field name=setEnv type="Record<string,string>"
    doc "Env vars to set on the spawned engine (e.g. {CLAUDE_CONFIG_DIR: <cleanDir>}) — repoints the engine's config dir to a clean throwaway."
  field name=argsExtra type="string[]"
    doc "Extra CLI args to append (e.g. ['--strict-mcp-config'] for claude's --print path)."
  field name=configDir type=string optional=true
    doc "The clean config dir applied via the engine's configEnv, when it has one."
  field name=strippedPersonal type=boolean
    doc "True when the user's personal/global layer was stripped (for the migration notice + provenance)."
  field name=setupHint type=string optional=true
    doc "Set only on the inherit-fallback plan when workspace-pure was requested but the engine's clean config dir isn't authenticated (e.g. claude's keychain login not yet established there). The one-time instruction to surface so the user can enable clean dispatch."

fn name=isValidIsolationMode params="v:unknown" returns="boolean" export=true
  doc "Type-guard for untrusted isolation values (env var, config, CLI flag). Anything not a known mode is rejected so a typo falls through to the next source rather than corrupting dispatch."
  handler <<<
    return typeof v === 'string' && (ISOLATION_MODES as readonly string[]).includes(v);
  >>>

fn name=resolveIsolationMode params="opts:{option?:string, env?:string, config?:string}" returns="'workspace-pure'|'inherit'" export=true
  doc "Resolve the effective isolation mode by precedence: explicit per-dispatch option > AGON_ENGINE_ISOLATION env > config.engineIsolation > default 'workspace-pure'. Each source is validated; an invalid value is skipped (not honored, not fatal) so a typo can never silently disable isolation in an unexpected way."
  handler <<<
    const pick = (v: string | undefined): 'workspace-pure' | 'inherit' | null =>
      isValidIsolationMode(v) ? (v as 'workspace-pure' | 'inherit') : null;
    return pick(opts.option) ?? pick(opts.env) ?? pick(opts.config) ?? 'workspace-pure';
  >>>

fn name=planEngineIsolation params="engine:EngineDefinition, mode:'workspace-pure'|'inherit', opts:{cleanConfigDir:string, authenticated?:boolean}" returns="EngineIsolationPlan" export=true
  doc "Decide what to strip for one engine dispatch. PURE: the caller materialises opts.cleanConfigDir and, for a config-dir engine, sets opts.authenticated = whether that clean dir is actually logged in (the adapter checks the engine's authMarker on disk; defaults true so a caller that omits it keeps the legacy 'assume authed' behavior). 'inherit' isolates nothing. An engine with no isolationHints (API-only: kimi/minimax/zai) is already pure. A configEnv engine that is NOT authenticated in its clean dir CANNOT be isolated without breaking auth — fall back to inherit (never break a dispatch) carrying the engine's setupHint. (claude's login is keychain-based and keyed to the DEFAULT config dir, so a redirected CLAUDE_CONFIG_DIR can't borrow it — the clean dir needs its own one-time `claude /login`; codex is file-based so its seeded auth.json doubles as the marker.) Otherwise apply the engine's configEnv (clean config dir) + strictMcpArgs."
  handler <<<
    const base = { engineId: engine.id, mode };
    const hints = engine.isolationHints;
    if (mode === 'inherit' || !hints) {
      return { ...base, isolate: false, setEnv: {}, argsExtra: [], strippedPersonal: false };
    }
    // A config-dir engine that isn't authenticated in its clean dir can't be
    // isolated without logging it out — inherit instead, and tell the user how
    // to enable clean dispatch. (authenticated defaults true: callers that
    // pre-seed a file credential or skip the check keep isolating.)
    const authenticated = opts.authenticated ?? true;
    if (hints.configEnv && !authenticated) {
      return { ...base, isolate: false, setEnv: {}, argsExtra: [], strippedPersonal: false, setupHint: hints.setupHint };
    }
    const setEnv: Record<string, string> = hints.configEnv ? { [hints.configEnv]: opts.cleanConfigDir } : {};
    const argsExtra: string[] = hints.strictMcpArgs ? [...hints.strictMcpArgs] : [];
    return {
      ...base,
      isolate: true,
      setEnv,
      argsExtra,
      configDir: hints.configEnv ? opts.cleanConfigDir : undefined,
      strippedPersonal: true,
    };
  >>>
