// ── Session Store ─────────────────────────────────────────────────
// Persists API session state to disk so sessions survive process restarts.
// v2: Rich state with compaction summaries, tool cache manifests, and schema migration.
// v2.1: Conversation store — cross-engine continuity so engine switches feel seamless.

import from="node:fs" names="writeFileSync,readFileSync,existsSync,mkdirSync,unlinkSync,readdirSync,statSync,rmdirSync,renameSync"
import from="node:path" names="join,dirname"
import from="node:crypto" names="createHash"
import from="../utils/paths.js" names="runtimeAgonPath"
import from="../models/context-parts.js" names="CompactionSummaryPart,ToolCacheEntry" types=true

const name=SESSION_SCHEMA_VERSION type=number value=2
const name=SESSION_MAX_MESSAGES type=number value=80
const name=SESSION_TTL_MS type=number value=3600000
  doc "60 minutes (was 30 min in v1)"
const name=TOOL_CACHE_MAX_BYTES type=number value=10485760
  doc "10 MB max total disk cache per session"

interface name=SessionStateV2
  field name=schemaVersion type=number
  field name=messageHistory type="Array<{role:string,content:any,tool_calls?:any[],tool_call_id?:string}>"
  field name=compactionSummary type="CompactionSummaryPart|null"
  field name=toolCacheManifest type="ToolCacheEntry[]"
  field name=confidence type="number|null"
  field name=readPaths type="string[]" optional=true
    doc "Canonicalized read-path set serialized from the per-session ReadPathRegistry (P1+P2 guard pipeline). Optional + backward-compatible: an old session file without it restores an empty registry, an old reader ignores it. Lets grounded-write's read-then-edit knowledge survive a process restart like messageHistory does."
  field name=savedAt type=number

fn name=sessionStorePath params="engineId:string" returns="string"
  doc "Session path scoped by engine + workspace to prevent context leaking across repos."
  handler <<<
    const cwdHash = createHash('md5').update(process.cwd()).digest('hex').slice(0, 8);
    return runtimeAgonPath('sessions', `${engineId}-${cwdHash}.json`);
  >>>

fn name=sessionCacheDir params="engineId:string" returns="string"
  doc "Directory for disk-backed tool result cache files."
  handler <<<
    const cwdHash = createHash('md5').update(process.cwd()).digest('hex').slice(0, 8);
    return runtimeAgonPath('sessions', `${engineId}-${cwdHash}-cache`);
  >>>

fn name=saveToolResultToDisk params="engineId:string, toolCallId:string, toolName:string, content:string" returns="ToolCacheEntry|null"
  doc "Write a large tool result to disk cache. Returns manifest entry, or null if write failed."
  handler <<<
    try {
      const cacheDir = sessionCacheDir(engineId);
      mkdirSync(cacheDir, { recursive: true });
      const filePath = join(cacheDir, `${toolCallId}.txt`);
      const tmpFilePath = filePath + '.tmp';
      writeFileSync(tmpFilePath, content, 'utf-8');
      renameSync(tmpFilePath, filePath);
      return {
        toolCallId,
        toolName,
        filePath,
        savedAt: Date.now(),
        byteSize: Buffer.byteLength(content, 'utf-8'),
      };
    } catch (err) {
      console.warn(`[agon] session-cache: failed to write ${toolCallId}: ${err instanceof Error ? err.message : String(err)}`);
      return null;
    }
  >>>

fn name=loadToolResultFromDisk params="engineId:string, toolCallId:string" returns="string|null"
  doc "Read a cached tool result from disk. Returns null if not found."
  handler lang="kern"
    try
      let name=cacheDir value="sessionCacheDir(engineId)"
      let name=filePath value="join(cacheDir, `${toolCallId}.txt`)"
      if cond="!existsSync(filePath)"
        return value="null"
      return value="readFileSync(filePath, 'utf-8')"
      catch name=e
        return value="null"

fn name=pruneToolCache params="engineId:string, keepIds:Set<string>" returns="void"
  doc "Remove cached tool results not in the keep set. Prevents unbounded disk growth."
  handler <<<
    try {
      const cacheDir = sessionCacheDir(engineId);
      if (!existsSync(cacheDir)) return;
      const files = readdirSync(cacheDir);
      for (const f of files) {
        const id = f.replace(/\.txt$/, '');
        if (!keepIds.has(id)) {
          try { unlinkSync(join(cacheDir, f)); } catch { /* already removed */ }
        }
      }
    } catch { /* cache dir doesn't exist or inaccessible */ }
  >>>

fn name=saveSessionState params="engineId:string, state:{ messageHistory: Array<{role:string,content:any,tool_calls?:any[],tool_call_id?:string}>, confidence:number|null, compactionSummary?:CompactionSummaryPart|null, toolCacheManifest?:ToolCacheEntry[], readPaths?:string[] }" returns="void"
  doc "Persist API session state to disk (v2 schema). readPaths (optional) is the serialized ReadPathRegistry set — omitted when the guard pipeline is off (strict), persisted under invariants/shadow so grounded-write knowledge survives a restart."
  handler lang="kern"
    let name=dir value="runtimeAgonPath('sessions')"
    do value="mkdirSync(dir, { recursive: true })"
    let name=path value="sessionStorePath(engineId)"
    comment raw="// Keep last SESSION_MAX_MESSAGES to avoid unbounded growth"
    let name=trimmed value="state.messageHistory.slice(-SESSION_MAX_MESSAGES)"
    let name=data type="SessionStateV2" value="{ schemaVersion: SESSION_SCHEMA_VERSION, messageHistory: trimmed, compactionSummary: state.compactionSummary ?? null, toolCacheManifest: state.toolCacheManifest ?? [], confidence: state.confidence, readPaths: state.readPaths, savedAt: Date.now(), }"
    let name=tmpPath value="path + '.tmp'"
    do value="writeFileSync(tmpPath, JSON.stringify(data), 'utf-8')"
    do value="renameSync(tmpPath, path)"

fn name=loadSessionState params="engineId:string" returns="{ messageHistory: Array<{role:string,content:any,tool_calls?:any[],tool_call_id?:string}>, confidence:number|null, compactionSummary:CompactionSummaryPart|null, toolCacheManifest:ToolCacheEntry[], readPaths:string[], savedAt: number } | null"
  doc "Load persisted API session state from disk. Handles v1→v2 migration transparently. readPaths defaults to [] for any state file (v1, or v2 saved before the field existed) so the registry restore is always safe."
  handler lang="kern"
    let name=path value="sessionStorePath(engineId)"
    if cond="!existsSync(path)"
      return value="null"
    try
      let name=raw value="readFileSync(path, 'utf-8')"
      let name=data value="JSON.parse(raw)"
      comment raw="// TTL: discard state older than SESSION_TTL_MS."
      if cond="data.savedAt && Date.now() - data.savedAt > SESSION_TTL_MS"
        return value="null"
      if cond="!Array.isArray(data.messageHistory)"
        return value="null"
      comment raw="// v1 migration: old format has no schemaVersion."
      if cond="!data.schemaVersion || data.schemaVersion < 2"
        return value="{ messageHistory: data.messageHistory, confidence: data.confidence ?? null, compactionSummary: null, toolCacheManifest: [], readPaths: [], savedAt: data.savedAt ?? 0, }"
      return value="{ messageHistory: data.messageHistory, confidence: data.confidence ?? null, compactionSummary: data.compactionSummary ?? null, toolCacheManifest: data.toolCacheManifest ?? [], readPaths: Array.isArray(data.readPaths) ? data.readPaths : [], savedAt: data.savedAt ?? 0, }"
      catch name=e
        return value="null"

fn name=clearSessionState params="engineId:string" returns="void"
  doc "Delete persisted session state and its cache directory."
  handler <<<
    const path = sessionStorePath(engineId);
    try { if (existsSync(path)) unlinkSync(path); } catch { /* already removed */ }
    // Clean up cache dir too
    try {
      const cacheDir = sessionCacheDir(engineId);
      if (existsSync(cacheDir)) {
        const files = readdirSync(cacheDir);
        for (const f of files) { try { unlinkSync(join(cacheDir, f)); } catch { /* skip */ } }
        rmdirSync(cacheDir);
      }
    } catch { /* cache dir cleanup is best-effort */ }
  >>>

// ── Conversation Store ──────────────────────────────────────────
// Cross-engine conversation continuity. Keyed by workspace (not engine)
// so that engine switches carry the conversation forward seamlessly.

const name=CONVERSATION_SCHEMA_VERSION type=number value=1

interface name=ConversationState
  field name=schemaVersion type=number
  field name=messageHistory type="Array<{role:string,content:any,tool_calls?:any[],tool_call_id?:string}>"
  field name=savedAt type=number
  field name=sourceEngine type="string|null"
  field name=readPaths type="string[]" optional=true
    doc "Serialized ReadPathRegistry set from the SOURCE engine at handoff (P1+P2 guard pipeline). Optional + backward-compatible: omitted when the source ran strict (registry null) so the strict disk shape is byte-identical, and an old conversation file without it loads fine. The cross-engine restore in session-resume restores the registry from this directly — stripEngineArtifacts flattens tool_calls to text on save, so deriving read paths by scanning the replayed history is impossible; this field carries the ground truth across the handoff."

fn name=conversationStorePath params="" returns="string"
  doc "Conversation path scoped by workspace only — shared across all engines."
  handler <<<
    const cwdHash = createHash('md5').update(process.cwd()).digest('hex').slice(0, 8);
    return runtimeAgonPath('sessions', `conversation-${cwdHash}.json`);
  >>>

fn name=stripEngineArtifacts params="messages:Array<{role:string,content:any,tool_calls?:any[],tool_call_id?:string}>" returns="Array<{role:string,content:any,tool_calls?:any[],tool_call_id?:string}>"
  doc "Strip engine-specific artifacts (tool call IDs, internal markers) for clean replay into a different engine."
  handler <<<
    const stringifyContent = (content: any): any => {
      if (typeof content === 'string') return content;
      if (Array.isArray(content)) return content;
      try {
        return content == null ? '' : JSON.stringify(content);
      } catch {
        return String(content ?? '');
      }
    };

    const toolNameById = new Map<string, string>();
    for (const msg of messages as any[]) {
      if (msg?.role !== 'assistant' || !Array.isArray(msg.tool_calls)) continue;
      for (const tc of msg.tool_calls) {
        const id = typeof tc?.id === 'string' ? tc.id : '';
        const name = tc?.function?.name ?? tc?.name;
        if (id && typeof name === 'string' && name.trim()) toolNameById.set(id, name.trim());
      }
    }

    return messages.map((msg: any) => {
      const role = msg?.role === 'assistant' || msg?.role === 'system' || msg?.role === 'user'
        ? msg.role
        : 'user';
      const clean: any = { role };

      if (msg?.role === 'tool') {
        const id = typeof msg.tool_call_id === 'string' ? msg.tool_call_id : '';
        const toolName = toolNameById.get(id) ?? 'tool';
        const content = stringifyContent(msg.content);
        clean.content = Array.isArray(content)
          ? content
          : `[Tool result from previous ${toolName} call]\n${content}`;
      } else if (msg?.role === 'assistant' && Array.isArray(msg.tool_calls) && msg.tool_calls.length > 0) {
        const toolNames = msg.tool_calls
          .map((tc: any) => tc?.function?.name ?? tc?.name ?? '')
          .filter(Boolean);
        const marker = toolNames.length > 0
          ? `[Tool calls omitted during engine handoff: ${toolNames.join(', ')}]`
          : '[Tool calls omitted during engine handoff]';
        const content = typeof msg.content === 'string' ? msg.content.trim() : '';
        clean.content = content ? `${content}\n${marker}` : marker;
      } else if (typeof msg?.content === 'string') {
        clean.content = msg.content;
      } else if (Array.isArray(msg?.content)) {
        // Multimodal content blocks: keep as-is.
        clean.content = msg.content;
      } else {
        clean.content = stringifyContent(msg?.content);
      }
      return clean;
    });
  >>>

fn name=saveConversation params="messages:Array<{role:string,content:any,tool_calls?:any[],tool_call_id?:string}>, sourceEngineId:string|null, readPaths?:string[]" returns="void"
  doc "Save conversation history to the workspace-scoped conversation store. Called before engine switch. readPaths (optional) is the SOURCE engine's serialized ReadPathRegistry set — undefined when the source ran strict (so the persisted shape is byte-identical to before this field existed); the cross-engine restore in session-resume restores the registry from it (stripEngineArtifacts flattens tool_calls to text, so the read paths cannot be re-derived from the replayed history)."
  handler lang="kern"
    let name=dir value="runtimeAgonPath('sessions')"
    do value="mkdirSync(dir, { recursive: true })"
    let name=path value="conversationStorePath()"
    comment raw="// Only keep last SESSION_MAX_MESSAGES to avoid unbounded growth"
    let name=trimmed value="messages.slice(-SESSION_MAX_MESSAGES)"
    let name=clean value="stripEngineArtifacts(trimmed)"
    comment raw="// readPaths is set only when defined: JSON.stringify drops an undefined"
    comment raw="// field, so a strict-source save (readPaths === undefined) writes the SAME"
    comment raw="// JSON shape as before this field existed."
    let name=data type="ConversationState" value="{ schemaVersion: CONVERSATION_SCHEMA_VERSION, messageHistory: clean, savedAt: Date.now(), sourceEngine: sourceEngineId, readPaths, }"
    let name=tmpPath value="path + '.tmp'"
    do value="writeFileSync(tmpPath, JSON.stringify(data), 'utf-8')"
    do value="renameSync(tmpPath, path)"

fn name=loadConversation params="" returns="{ messageHistory: Array<{role:string,content:any,tool_calls?:any[],tool_call_id?:string}>, sourceEngine: string|null, savedAt: number, readPaths: string[] } | null"
  doc "Load conversation history from the workspace-scoped store. Used when booting a new engine after a switch. readPaths is the SOURCE engine's serialized ReadPathRegistry set (already canonical), or [] for an old conversation file written before the field existed — the cross-engine restore uses it to ground the new engine's grounded-write check directly (the replayed history's tool_calls were flattened to text by stripEngineArtifacts, so they cannot be re-derived)."
  handler lang="kern"
    let name=path value="conversationStorePath()"
    if cond="!existsSync(path)"
      return value="null"
    try
      let name=raw value="readFileSync(path, 'utf-8')"
      let name=data value="JSON.parse(raw)"
      comment raw="// TTL: discard conversations older than SESSION_TTL_MS."
      if cond="data.savedAt && Date.now() - data.savedAt > SESSION_TTL_MS"
        return value="null"
      if cond="!Array.isArray(data.messageHistory)"
        return value="null"
      return value="{ messageHistory: stripEngineArtifacts(data.messageHistory), sourceEngine: data.sourceEngine ?? null, savedAt: data.savedAt ?? 0, readPaths: Array.isArray(data.readPaths) ? data.readPaths : [], }"
      catch name=e
        return value="null"

fn name=clearConversation params="" returns="void"
  doc "Delete the workspace-scoped conversation store."
  handler <<<
    const path = conversationStorePath();
    try { if (existsSync(path)) unlinkSync(path); } catch { /* already removed */ }
  >>>
