// ── Tool Registry + Executor ─────────────────────────────────────────
// Registers tools, dispatches tool_use calls, manages execution pipeline.

import from="../models/tool-types.js" names="ToolDefinition,ToolCall,ToolCallResult,ToolResult,ToolContext,PermissionDecision,ToolHandler" types=true
import from="../tools/tool-hooks.js" names="runPreToolUseHooks,runPostToolUseHooks,hasToolHooks"

// ── Permission-denial marker ──────────────────────────────────────────
// Canonical, typed denial marker — BOTH the message produced when the user
// declines a tool-call permission ask (executeToolCall deny path) AND the
// prefix on rule/deny-all denials from the inline tool gates. Callers that
// wrap tool errors with a retry nudge (the CLI native tool loop) MUST exempt
// errors carrying this string: a permission denial is terminal, not a
// malformed-input retry. Exported so producers and detectors stay in
// lock-step instead of coupling on a hardcoded substring. (Merged from the
// behavior + rails branches, which introduced it independently.)
const name=PERMISSION_DENIED_MESSAGE type=string value={{ 'User denied permission' }} export=true

service name=ToolRegistry singleton=true
  field name=tools type="Map<string, ToolHandler>"

  constructor
    handler lang="kern"
      assign target="this.tools" value="new Map()"

  method name=register params="handler:ToolHandler" returns=void
    handler lang="kern"
      do value="this.tools.set(handler.definition.name, handler)"

  method name=get params="name:string" returns="ToolHandler|undefined"
    handler lang="kern"
      return value="this.tools.get(name) ?? this.tools.get(name.charAt(0).toUpperCase() + name.slice(1)) ?? [...this.tools.values()].find(h => h.definition.name.toLowerCase() === name.toLowerCase())"

  method name=list returns="ToolDefinition[]"
    handler lang="kern"
      return value="Array.from(this.tools.values()).map(h => h.definition)"

  method name=has params="name:string" returns=boolean
    handler lang="kern"
      if cond="this.tools.has(name) || this.tools.has(name.charAt(0).toUpperCase() + name.slice(1))"
        return value="true"
      let name=lower value="name.toLowerCase()"
      each name=h in="this.tools.values()"
        if cond="h.definition.name.toLowerCase() === lower"
          return value="true"
      return value="false"

  method name=names returns="string[]"
    handler lang="kern"
      return value="Array.from(this.tools.keys())"

// ── Executor Pipeline ─────────────────────────────────────────────

fn name=executeToolCall async=true params="call:ToolCall, ctx:ToolContext, registry:ToolRegistry, onPermissionAsk?:(tool:string,message:string)=>Promise<boolean|string>" returns="Promise<ToolCallResult>"
  doc "Three-phase pipeline: validate → permission → execute"
  handler <<<
    const start = Date.now();
    const handler = registry.get(call.name);

    if (!handler) {
      return {
        toolCallId: call.id,
        toolName: call.name,
        result: { ok: false, content: '', error: `Unknown tool: ${call.name}`, terminalReason: 'failed' },
        durationMs: Date.now() - start,
      };
    }

    if (ctx.abortSignal?.aborted) {
      return {
        toolCallId: call.id,
        toolName: call.name,
        result: { ok: false, content: '', error: 'Tool call cancelled', terminalReason: 'cancelled' },
        durationMs: Date.now() - start,
      };
    }

    const blockedTools = Array.isArray((ctx as any).blockedTools) ? (ctx as any).blockedTools as string[] : [];
    if (blockedTools.includes(call.name)) {
      return {
        toolCallId: call.id,
        toolName: call.name,
        result: { ok: false, content: '', error: String((ctx as any).blockedToolMessage ?? `Tool blocked: ${call.name}`), terminalReason: 'skipped_policy' },
        durationMs: Date.now() - start,
      };
    }

    // Phase 0: Read-only gate — block mutating tools during investigation
    // Bash handles readOnlyMode in its own checkPermission (allows safe commands like ls, git diff)
    if (ctx.readOnlyMode && !handler.definition.isReadOnly && call.name !== 'Bash') {
      return {
        toolCallId: call.id,
        toolName: call.name,
        result: { ok: false, content: '', error: `[Investigation phase] ${call.name} skipped — Cesar is still investigating. Mutating tools available after confidence check.`, terminalReason: 'skipped_policy' },
        durationMs: Date.now() - start,
      };
    }

    // Phase 1: Validate input
    const validationError = handler.validate(call.input, ctx);
    if (validationError) {
      return {
        toolCallId: call.id,
        toolName: call.name,
        result: { ok: false, content: '', error: validationError, terminalReason: 'failed' },
        durationMs: Date.now() - start,
      };
    }

    // Authority gate above tool-specific permission rules. Some handlers
    // intentionally auto-allow in AUTO mode or for in-workspace writes; the
    // caller's task/session lease must still get the final say before any
    // authority-bearing execution reaches those fast paths.
    if (ctx.authorizeToolCall) {
      try {
        const authorized = await ctx.authorizeToolCall(call.name, call.input);
        if (authorized !== true) {
          return {
            toolCallId: call.id,
            toolName: call.name,
            result: {
              ok: false,
              content: '',
              error: typeof authorized === 'string' ? authorized : PERMISSION_DENIED_MESSAGE,
              terminalReason: 'denied',
            },
            durationMs: Date.now() - start,
          };
        }
      } catch (err) {
        return {
          toolCallId: call.id,
          toolName: call.name,
          result: {
            ok: false,
            content: '',
            error: `Tool authorization failed: ${err instanceof Error ? err.message : String(err)}`,
            terminalReason: 'denied',
          },
          durationMs: Date.now() - start,
        };
      }
    }

    // Phase 2: Permission check
    const permission = handler.checkPermission(call.input, ctx);
    if (permission.behavior === 'deny') {
      const terminalReason = permission.reason === 'read-only-mode' ? 'skipped_policy' : 'denied';
      return {
        toolCallId: call.id,
        toolName: call.name,
        result: { ok: false, content: '', error: permission.message ?? 'Permission denied', terminalReason },
        durationMs: Date.now() - start,
      };
    }
    if (permission.behavior === 'ask') {
      if (onPermissionAsk) {
        const allowed = await onPermissionAsk(call.name, permission.message ?? `Allow ${call.name}?`);
        if (typeof allowed === 'string') {
          return {
            toolCallId: call.id,
            toolName: call.name,
            result: { ok: false, content: '', error: allowed, terminalReason: 'denied' },
            durationMs: Date.now() - start,
          };
        }
        if (!allowed) {
          return {
            toolCallId: call.id,
            toolName: call.name,
            result: { ok: false, content: '', error: PERMISSION_DENIED_MESSAGE, terminalReason: 'denied' },
            durationMs: Date.now() - start,
          };
        }
      } else {
        // No ask handler — deny by default
        return {
          toolCallId: call.id,
          toolName: call.name,
          result: { ok: false, content: '', error: 'Permission required but no handler available', terminalReason: 'denied' },
          durationMs: Date.now() - start,
        };
      }
    }

    // Phase 2.5: PreToolUse hooks (.agon.json hooks.preToolUse) — fail-safe.
    // Runs AFTER the permission gate, BEFORE execution, for EVERY path that
    // reaches executeToolCall (API native, XML loop, eager). Exit 2 blocks
    // with stderr as the engine-visible refusal; timeout / spawn failure /
    // any other non-0 exit fails OPEN (proceeds) with one warning line. A
    // zero-overhead guard skips all of this when no tool hooks are configured.
    const toolHooks = (ctx as any).toolHooks;
    const hooksActive = hasToolHooks(toolHooks);
    if (hooksActive) {
      const pre = await runPreToolUseHooks(call.name, call.input, toolHooks, ctx.cwd);
      if (pre.warning && typeof ctx.onProgress === 'function') {
        try { ctx.onProgress(pre.warning); } catch { /* never let a status line break a tool call */ }
      }
      if (pre.block) {
        return {
          toolCallId: call.id,
          toolName: call.name,
          result: { ok: false, content: '', error: pre.reason ?? `PreToolUse hook blocked ${call.name}`, terminalReason: 'denied' },
          durationMs: Date.now() - start,
        };
      }
    }

    // Phase 3: Execute
    try {
      const result = await handler.execute(call.input, ctx);
      if (!result.terminalReason) result.terminalReason = result.ok ? 'succeeded' : 'failed';

      // Truncate if over maxResultSizeChars
      if (result.content.length > handler.definition.maxResultSizeChars) {
        result.content = result.content.slice(0, handler.definition.maxResultSizeChars) + `\n\n[Truncated: ${result.content.length - handler.definition.maxResultSizeChars} chars omitted]`;
      }

      // Phase 4: PostToolUse hooks — never block, result ignored except logging.
      if (hooksActive) {
        const responsePayload = result.ok ? result.content : { error: result.error ?? '' };
        await runPostToolUseHooks(call.name, call.input, responsePayload, toolHooks, ctx.cwd);
      }

      return {
        toolCallId: call.id,
        toolName: call.name,
        result,
        durationMs: Date.now() - start,
      };
    } catch (err) {
      const cancelled = ctx.abortSignal?.aborted || (err instanceof Error && err.name === 'AbortError');
      return {
        toolCallId: call.id,
        toolName: call.name,
        result: { ok: false, content: '', error: err instanceof Error ? err.message : String(err), terminalReason: cancelled ? 'cancelled' : 'failed' },
        durationMs: Date.now() - start,
      };
    }
  >>>

fn name=executeToolCalls async=true params="calls:ToolCall[], ctx:ToolContext, registry:ToolRegistry, onPermissionAsk?:(tool:string,message:string)=>Promise<boolean|string>, onProgress?:(result:ToolCallResult)=>void" returns="Promise<ToolCallResult[]>"
  doc "Execute multiple tool calls, partitioned into concurrent/serial batches."
  handler <<<
    const results: ToolCallResult[] = [];

    // Partition into batches with metadata: consecutive concurrency-safe tools run in parallel
    const batchMeta: { calls: ToolCall[]; concurrent: boolean }[] = [];
    let currentBatch: ToolCall[] = [];
    let currentBatchConcurrent = false;

    for (const call of calls) {
      const handler = registry.get(call.name);
      const isSafe = handler?.definition.isConcurrencySafe ?? false;

      if (currentBatch.length === 0) {
        currentBatch.push(call);
        currentBatchConcurrent = isSafe;
      } else if (isSafe && currentBatchConcurrent) {
        currentBatch.push(call);
      } else {
        batchMeta.push({ calls: currentBatch, concurrent: currentBatchConcurrent });
        currentBatch = [call];
        currentBatchConcurrent = isSafe;
      }
    }
    if (currentBatch.length > 0) batchMeta.push({ calls: currentBatch, concurrent: currentBatchConcurrent });

    // Execute batches
    for (const { calls: batch, concurrent } of batchMeta) {
      if (batch.length === 1 || !concurrent) {
        // Serial
        for (const call of batch) {
          if (ctx.abortSignal?.aborted) break;
          const result = await executeToolCall(call, ctx, registry, onPermissionAsk);
          results.push(result);
          if (onProgress) onProgress(result);
        }
      } else {
        // Parallel (capped at 10)
        const MAX_CONCURRENT = 10;
        for (let i = 0; i < batch.length; i += MAX_CONCURRENT) {
          if (ctx.abortSignal?.aborted) break;
          const chunk = batch.slice(i, i + MAX_CONCURRENT);
          const chunkResults = await Promise.all(
            chunk.map(call => executeToolCall(call, ctx, registry, onPermissionAsk))
          );
          results.push(...chunkResults);
          for (const r of chunkResults) {
            if (onProgress) onProgress(r);
          }
        }
      }
    }

    return results;
  >>>
