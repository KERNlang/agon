// ── Tool Call Parser ─────────────────────────────────────────────────
// Extracts tool invocations from any engine's text output.
// Format: <tool name="X">{json}</tool>
// Works with Claude, Codex, Gemini, OpenCode — any LLM that can follow instructions.

import from="./tool-types.js" names="ToolCall" types=true

interface name=ParsedToolCall
  field name=name type=string
  field name=input type="Record<string,unknown>"
  field name=startIndex type=number
  field name=endIndex type=number

interface name=ParseResult
  field name=textBefore type=string
  field name=toolCalls type="ParsedToolCall[]"
  field name=textAfter type=string
  field name=hasToolCalls type=boolean

const name=TOOL_OPEN_PATTERN type=RegExp
  handler <<<
    /<tool\s+name="([^"]+)">\s*/g
  >>>

const name=TOOL_CLOSE type=string
  handler <<<
    '</tool>'
  >>>

fn name=parseToolCalls params="text:string" returns=ParseResult
  doc "Parse tool call markers from engine output text."
  handler <<<
    const toolCalls: ParsedToolCall[] = [];
    const pattern = new RegExp(TOOL_OPEN_PATTERN.source, 'g');
    let lastEnd = 0;
    let textBefore = '';
    let match;

    while ((match = pattern.exec(text)) !== null) {
      const toolName = match[1];
      const jsonStart = match.index + match[0].length;

      // Find closing </tool> tag
      const closeIdx = text.indexOf(TOOL_CLOSE, jsonStart);
      if (closeIdx === -1) break; // Unclosed tag — stop parsing

      // Capture text before this tool call
      if (toolCalls.length === 0) {
        textBefore = text.slice(0, match.index).trim();
      }

      const jsonStr = text.slice(jsonStart, closeIdx).trim();
      let input: Record<string, unknown> = {};

      try {
        input = JSON.parse(jsonStr);
      } catch {
        // Try to be lenient — handle common LLM mistakes
        try {
          // Sometimes LLMs wrap in markdown code blocks
          const cleaned = jsonStr.replace(/^```json?\s*\n?/, '').replace(/\n?```\s*$/, '').trim();
          input = JSON.parse(cleaned);
        } catch {
          // Give up parsing this tool call, include as text
          continue;
        }
      }

      toolCalls.push({
        name: toolName,
        input,
        startIndex: match.index,
        endIndex: closeIdx + TOOL_CLOSE.length,
      });

      lastEnd = closeIdx + TOOL_CLOSE.length;
      // Advance regex past the close tag
      pattern.lastIndex = lastEnd;
    }

    const textAfter = lastEnd > 0 ? text.slice(lastEnd).trim() : '';

    if (toolCalls.length === 0) {
      return { textBefore: text, toolCalls: [], textAfter: '', hasToolCalls: false };
    }

    return { textBefore, toolCalls, textAfter, hasToolCalls: true };
  >>>

fn name=toolCallsToApiFormat params="parsed:ParsedToolCall[]" returns="ToolCall[]"
  doc "Convert parsed text-based tool calls to ToolCall format for the executor."
  handler <<<
    return parsed.map((tc, i) => ({
      id: `tc_${Date.now()}_${i}`,
      name: tc.name,
      input: tc.input,
    }));
  >>>

fn name=formatToolResult params="toolName:string, result:string, isError?:boolean" returns=string
  doc "Format a tool result to inject back into the conversation."
  handler <<<
    if (isError) {
      return `<tool_result name="${toolName}" error="true">\n${result}\n</tool_result>`;
    }
    return `<tool_result name="${toolName}">\n${result}\n</tool_result>`;
  >>>

fn name=formatToolResults params="results:{name:string,content:string,error?:string}[]" returns=string
  doc "Format multiple tool results for injection."
  handler <<<
    return results.map(r => {
      if (r.error) {
        return formatToolResult(r.name, r.error, true);
      }
      return formatToolResult(r.name, r.content);
    }).join('\n\n');
  >>>
