// ── Tool Permission System ───────────────────────────────────────────
// Deny > Ask > Allow layering. Filesystem checks. Dangerous command detection.

import from="node:path" names="resolve,relative,isAbsolute"
import from="node:fs" names="realpathSync"
import from="node:child_process" names="execSync"
import from="../models/tool-types.js" names="PermissionDecision,ToolContext,ParsedPermissionRule,PermissionRuleSet" types=true
import from="../signals/tool-registry.js" names="PERMISSION_DENIED_MESSAGE"

interface name=PermissionRule
  field name=tool type=string
  field name=behavior type="'allow'|'ask'|'deny'"
  field name=pattern type=string optional=true
  field name=reason type=string optional=true

// ── Dangerous Bash Patterns ──────────────────────────────────────

const name=DANGEROUS_COMMANDS type="string[]" value={{ ['rm -rf /', 'rm -rf ~', 'rm -rf *', 'dd if' + String.fromCharCode(61), 'mkfs.', '> /dev/sd', '> /dev/nv', 'chmod 777 /', ':(){:|:&}\\x3b:'] }}

const name=DANGEROUS_PREFIXES type="string[]" value={{ ['sudo ', 'su ', 'doas '] }}

const name=SAFE_SHELL_WRAPPERS type="string[]" value={{ ['timeout', 'time', 'nice', 'nohup', 'env', 'command'] }}

const name=READONLY_COMMANDS type="Set<string>" value={{ new Set(['ls', 'cat', 'head', 'tail', 'less', 'more', 'wc', 'file', 'stat', 'pwd', 'echo', 'printf', 'date', 'which', 'whereis', 'type', 'find', 'grep', 'rg', 'ag', 'fd', 'fzf', 'git status', 'git log', 'git diff', 'git branch', 'git show', 'git blame', 'npm test', 'npm run test', 'npx vitest', 'npx tsc', 'node --version', 'npm --version', 'python --version', 'agon --help', 'agon config --help', 'agon config list', 'agon config get', 'tree', 'du', 'df']) }}

// ── Core Permission Functions ─────────────────────────────────

module name=ShellParsing
  fn name=stripShellWrappers params="command:string" returns=string
    handler lang="kern"
      return value="command.trim().replace(/^(?:(?:timeout|time|nice|nohup|env|command)(?:\\s+-\\S+)*)\\s+/, '')"

  fn name=extractBaseCommand params="command:string" returns=string
    handler lang="kern"
      return value="stripShellWrappers(command).split(/\\s+/)[0] ?? ''"

  fn name=stripShellRedirections params="command:string" returns=string
    handler lang="kern"
      return value="command .replace(/\\s+\\d*(?:>>?|<<?)\\s*\\S+/g, '') .replace(/\\s+\\d*(?:>&|<&)\\s*\\S+/g, '') .trim()"

  fn name=isDangerousCommand params="command:string" returns=boolean
    handler lang="kern"
      return value="((lower) => DANGEROUS_COMMANDS.some((dangerous: string) => lower.includes(dangerous)) || DANGEROUS_PREFIXES.some((prefix: string) => lower.startsWith(prefix)))(command.toLowerCase().trim())"

  fn name=isReadOnlyCommand params="command:string" returns=boolean
    handler lang="kern"
      return value="((readonlyCommand, commandSeparator) => ((readonlyCommand.includes('&&') || readonlyCommand.includes('||') || readonlyCommand.includes(commandSeparator) || /&(?!&)/.test(readonlyCommand)) && !/^\\|/.test(readonlyCommand)) ? readonlyCommand.replace(/&&|\\|\\||&(?!&)/g, commandSeparator).split(commandSeparator).every((p: string) => p.trim() && isReadOnlyCommand(p.trim())) : readonlyCommand.includes('|') ? readonlyCommand.split('|').map((p: string) => p.trim()).every((p: string) => p && isReadOnlyCommand(p)) : [...READONLY_COMMANDS].some((safe: string) => readonlyCommand === safe || readonlyCommand.startsWith(safe + ' ')))(stripShellRedirections(stripShellWrappers(command)).trim(), String.fromCharCode(59))"

// ── Git-Dirty File Cache (for smart mode) ─────────────────────────

const name=_gitDirtyCache type="{files:Set<string>|null,cwd:string|null,expiry:number}" value={{ { files: null, cwd: null, expiry: 0 } }}

const name=GIT_DIRTY_CACHE_TTL type=number value={{ 2000  // 2 seconds }}

module name=GitDirtyCache
  fn name=getGitDirtyFiles params="cwd:string" returns="Set<string>" export=true
    handler <<<
      const now = Date.now();
      if (_gitDirtyCache.files && _gitDirtyCache.cwd === cwd && now < _gitDirtyCache.expiry) {
        return _gitDirtyCache.files;
      }
      try {
        const raw = execSync('git diff --name-only HEAD 2>/dev/null && git diff --cached --name-only 2>/dev/null', {
          cwd,
          encoding: 'utf-8',
          timeout: 2000,
        });
        _gitDirtyCache.files = new Set(raw.split('\n').filter(Boolean));
        _gitDirtyCache.cwd = cwd;
        _gitDirtyCache.expiry = now + GIT_DIRTY_CACHE_TTL;
      } catch {
        _gitDirtyCache.files = new Set();
        _gitDirtyCache.cwd = cwd;
        _gitDirtyCache.expiry = now + GIT_DIRTY_CACHE_TTL;
      }
      return _gitDirtyCache.files;
    >>>

  fn name=invalidateGitDirtyCache export=true
    handler lang="kern"
      assign target="_gitDirtyCache.files" value="null"
      assign target="_gitDirtyCache.cwd" value="null"
      assign target="_gitDirtyCache.expiry" value="0"

  fn name=isGitDirtyFile params="filePath:string, cwd:string" returns=boolean
    handler lang="kern"
      return value="((dirty, fileName) => [...dirty].some((dirtyPath: string) => filePath.endsWith(dirtyPath) || dirtyPath.endsWith(fileName)))(getGitDirtyFiles(cwd), filePath.split('/').pop() ?? filePath)"

module name=PermissionChecks
  fn name=isPathUnderCwd params="filePath:string, cwd:string" returns=boolean
    handler <<<
      const resolved = isAbsolute(filePath) ? filePath : resolve(cwd, filePath);
      // Resolve symlinks to prevent traversal via symlinks
      let realPath: string;
      let realCwd: string;
      try {
        realPath = realpathSync(resolved);
      } catch {
        // File doesn't exist yet — use unresolved path (safe for new files)
        realPath = resolved;
      }
      try {
        realCwd = realpathSync(cwd);
      } catch {
        realCwd = cwd;
      }
      const rel = relative(realCwd, realPath);
      return !rel.startsWith('..');
    >>>

// ── CC-parity allow/deny rule engine (.agon.json permissions) ─────────
// Mirrors Claude Code settings.json semantics: rules are strings like
// `Bash(npm test:*)`, `Bash(git diff:*)`, `Edit`, `Write`, `Read`.
// `deny` ALWAYS wins over `allow`. An allow rule auto-approves the matching
// ask; a deny rule refuses without prompting; everything else falls through
// to the normal ask flow. Bash uses prefix matching with an optional `:*`
// suffix on the command. Malformed rules are ignored (warned once), never
// crash or block. This is the ONE seam consulted by the approval gate.

const name=_warnedMalformedRules type="Set<string>" value={{ new Set() }}

module name=PermissionRules
  fn name=parsePermissionRule params="raw:unknown" returns="ParsedPermissionRule|null" export=true
    doc "Parse a single Claude-Code-style rule string into {tool, command?, prefix}. Returns null for malformed input. e.g. 'Bash(npm test:*)' → {tool:'Bash', command:'npm test', prefix:true}; 'Edit' → {tool:'Edit', prefix:false}."
    handler <<<
      if (typeof raw !== 'string') return null;
      const trimmed = raw.trim();
      if (trimmed.length === 0) return null;
      // Tool(arg) form
      const paren = trimmed.match(/^([A-Za-z][A-Za-z0-9_-]*)\((.*)\)$/);
      if (paren) {
        const tool = paren[1];
        let arg = paren[2].trim();
        if (arg.length === 0) {
          // Tool() — empty arg, treat as tool-level
          return { tool, prefix: false };
        }
        const prefix = arg.endsWith(':*');
        if (prefix) arg = arg.slice(0, -2).trim();
        if (arg.length === 0) {
          // 'Bash(:*)' — degenerate; ignore
          return null;
        }
        return { tool, command: arg, prefix };
      }
      // Bare tool form: 'Edit', 'Write', 'Read'
      if (/^[A-Za-z][A-Za-z0-9_-]*$/.test(trimmed)) {
        return { tool: trimmed, prefix: false };
      }
      return null;
    >>>

  fn name=parsePermissionRuleSet params="raw:unknown" returns="PermissionRuleSet" export=true
    doc "Normalize a raw permissions object into parsed allow/deny rule sets. Fail-safe: any malformed entry is skipped (warned once); a non-object input yields empty sets. Never throws."
    handler <<<
      const empty: PermissionRuleSet = { allow: [], deny: [] };
      if (!raw || typeof raw !== 'object' || Array.isArray(raw)) return empty;
      const r = raw as Record<string, unknown>;
      const parseList = (list: unknown, kind: string): ParsedPermissionRule[] => {
        if (!Array.isArray(list)) {
          if (list !== undefined) {
            const key = `list:${kind}`;
            if (!_warnedMalformedRules.has(key)) {
              _warnedMalformedRules.add(key);
              console.warn(`[agon] warning: permissions.${kind} is not an array — ignoring`);
            }
          }
          return [];
        }
        const out: ParsedPermissionRule[] = [];
        for (const entry of list) {
          const parsed = parsePermissionRule(entry);
          if (parsed) {
            out.push(parsed);
          } else {
            const key = `rule:${String(entry)}`;
            if (!_warnedMalformedRules.has(key)) {
              _warnedMalformedRules.add(key);
              console.warn(`[agon] warning: ignoring malformed permission rule: ${JSON.stringify(entry)}`);
            }
          }
        }
        return out;
      };
      return { allow: parseList(r.allow, 'allow'), deny: parseList(r.deny, 'deny') };
    >>>

  fn name=ruleMatches params="rule:ParsedPermissionRule, tool:string, command:string" returns=boolean export=true
    doc "Does a parsed rule match a (tool, command) pair? Tool name match is case-sensitive (CC uses exact tool names). A rule with no command is tool-level (matches any invocation of that tool). A prefix rule (':*' suffix) matches when the command starts with the rule command on a word boundary; a non-prefix command rule matches exactly. Bash prefix 'npm test' matches 'npm test -- --filter x' but NOT 'npm testify'."
    handler <<<
      if (rule.tool !== tool) return false;
      // Tool-level rule (no command) matches any invocation of the tool.
      if (rule.command === undefined) return true;
      const cmd = command.trim();
      const ruleCmd = rule.command.trim();
      if (ruleCmd.length === 0) return false;
      if (rule.prefix) {
        // Prefix match on a word boundary: 'npm test' matches 'npm test'
        // and 'npm test -- x' but not 'npm testify'.
        return cmd === ruleCmd || cmd.startsWith(ruleCmd + ' ');
      }
      return cmd === ruleCmd;
    >>>

  fn name=evaluatePermissionRules params="tool:string, command:string, rules:PermissionRuleSet" returns="'allow'|'deny'|null" export=true
    doc "Evaluate parsed allow/deny rule sets against a (tool, command). Returns 'deny' if ANY deny rule matches (deny always wins), else 'allow' if any allow rule matches, else null (fall through to normal ask flow). NOTE: this is the simple single-token matcher; for the security-correct gate use evaluateToolRules, which adds Bash compound-segment splitting (F2) and file-path resolution (F3)."
    handler <<<
      for (const rule of rules.deny) {
        if (ruleMatches(rule, tool, command)) return 'deny';
      }
      for (const rule of rules.allow) {
        if (ruleMatches(rule, tool, command)) return 'allow';
      }
      return null;
    >>>

  // ── F2: compound-command splitting ────────────────────────────────
  // A prefix allow rule like `Bash(npm test:*)` must NOT auto-approve a
  // compound such as `npm test && rm -rf /`. Detect shell control/substitution
  // and split into segments; ALL segments must be allowed for allow, ANY
  // segment denied → deny. Redirection (>/>>) cannot be allowed via a prefix
  // rule (the target is not in the command token) → never returns 'allow'.

  fn name=hasShellControl params="command:string" returns=boolean export=true
    doc "True if the command contains shell control operators or substitution that make single-token prefix matching unsafe: && || ; | & (background) $( ` > >> and newlines/CR. Single & and newline ARE separators — omitting them let `npm test & rm -rf /` ride a prefix allow rule (security re-review of 7090dff8). Used to decide whether Bash rule evaluation must split into segments."
    handler <<<
      return /&&|\|\||;|\||\$\(|`|>>?|&|[\n\r]/.test(command);
    >>>

  fn name=hasRedirection params="command:string" returns=boolean export=true
    doc "True if the command contains an output redirection operator (> or >>). A redirection target lives outside the command token a prefix rule matches, so a redirecting command can never be auto-allowed by a prefix rule — it falls through to ask."
    handler <<<
      return />>?/.test(command);
    >>>

  fn name=hasSubstitution params="command:string" returns=boolean export=true
    doc "True if the command contains command substitution: $(...) or backticks. The substituted command is opaque to segment-splitting (it does not appear as a top-level segment), so a substituting command can never be auto-allowed by a prefix rule — it falls through to ask. e.g. `npm test $(curl evil)` must not ride a `Bash(npm test:*)` allow."
    handler <<<
      return /\$\(|`/.test(command);
    >>>

  fn name=splitShellSegments params="command:string" returns="string[]" export=true
    doc "Split a compound shell command into its executable segments on &&, ||, ; , | (pipe), single & (background), and newlines/CR. Command-substitution bodies $(...) / backticks are NOT executed-as-segments here; their PRESENCE alone forces ask via hasShellControl, so segment-level allow can never fire on a substituting command. Empty segments are dropped."
    handler <<<
      const sep = String.fromCharCode(59); // ';'
      return command
        .replace(/&&|\|\||&(?!&)|[\n\r]+/g, sep)
        .split(new RegExp('\\|' + '|' + sep))
        .map((s: string) => s.trim())
        .filter((s: string) => s.length > 0);
    >>>

  fn name=evaluateBashRules params="command:string, rules:PermissionRuleSet" returns="'allow'|'deny'|null" export=true
    doc "F2-hardened Bash rule evaluation. For a simple (no control-op) command, behaves like evaluatePermissionRules. For a compound command: deny if ANY segment matches a deny rule; allow ONLY if EVERY segment matches an allow rule (and there is no redirection); otherwise null (ask). Command substitution / backticks force ask. This closes the `npm test && rm -rf /` auto-approve hole."
    handler <<<
      const cmd = command.trim();
      // Deny always wins — check the whole command AND every segment.
      const segments = hasShellControl(cmd) ? splitShellSegments(cmd) : [cmd];
      for (const seg of segments) {
        for (const rule of rules.deny) {
          if (ruleMatches(rule, 'Bash', seg)) return 'deny';
        }
      }
      // Also honor a deny rule that matches the full compound string verbatim.
      for (const rule of rules.deny) {
        if (ruleMatches(rule, 'Bash', cmd)) return 'deny';
      }
      // Allow only when the command is simple (or every segment is allowed) AND
      // there is no redirection (the redirect target is unguarded by a prefix).
      if (!hasShellControl(cmd)) {
        for (const rule of rules.allow) {
          if (ruleMatches(rule, 'Bash', cmd)) return 'allow';
        }
        return null;
      }
      // Redirection target and substitution body are unguarded by a prefix
      // rule — never auto-allow them; fall through to ask.
      if (hasRedirection(cmd) || hasSubstitution(cmd) || segments.length === 0) return null;
      const everyAllowed = segments.every((seg: string) =>
        rules.allow.some((rule) => ruleMatches(rule, 'Bash', seg)));
      return everyAllowed ? 'allow' : null;
    >>>

  // ── F3: real file-path matching ───────────────────────────────────
  // `Edit(/etc:*)` must block `/etc/passwd`, and `../` / symlink escapes must
  // be resolved before matching. Resolve the path to absolute against the tool
  // cwd, realpath it (parent realpath when the file does not exist yet), then
  // match on a '/'-segment boundary.

  fn name=resolveRulePath params="filePath:string, cwd:string" returns=string export=true
    doc "Resolve a tool file_path to an absolute, symlink-canonical path for rule matching. Absolute paths are kept; relative paths resolve against cwd. realpathSync canonicalizes existing paths; when the file does not exist yet, the longest existing ancestor is realpath'd and the remaining tail re-appended (so ../ escapes and symlinked parents are still resolved). Never throws."
    handler <<<
      try {
        const abs = isAbsolute(filePath) ? filePath : resolve(cwd, filePath);
        try {
          return realpathSync(abs);
        } catch {
          // File doesn't exist — realpath the longest existing ancestor, using
          // path.relative to split off the non-existent tail (robust at root,
          // where there is no extra '/' separator between parent and basename).
          let dir = abs;
          for (let i = 0; i < 4096; i++) {
            const parent = resolve(dir, '..');
            if (parent === dir) break; // reached root and root is unreadable
            try {
              const realParent = realpathSync(parent);
              const tail = relative(parent, abs);
              return tail ? resolve(realParent, tail) : realParent;
            } catch {
              dir = parent;
            }
          }
          return abs;
        }
      } catch {
        return filePath;
      }
    >>>

  fn name=pathRuleMatches params="rule:ParsedPermissionRule, tool:string, resolvedPath:string, cwd:string" returns=boolean export=true
    doc "Does a parsed file-tool rule match a resolved absolute path? Tool name must match. A command-less rule (bare `Edit`) is tool-level → matches any path. The rule path is itself resolved against cwd AND symlink-canonicalized the same way as the target (so `Edit(/etc:*)` matches `/etc/passwd` even though /etc → /private/etc on macOS). A match is exact equality or, for a ':*' prefix rule, the target sitting under the rule path on a '/'-segment boundary (so `Edit(/etc:*)` matches `/etc/passwd` but not `/etcother`). An exact (non-prefix) path rule matches only that exact file."
    handler <<<
      if (rule.tool !== tool) return false;
      if (rule.command === undefined) return true;
      const rulePathRaw = rule.command.trim();
      if (rulePathRaw.length === 0) return false;
      // Canonicalize the rule path the SAME way as the target path so symlinked
      // ancestors (e.g. /etc → /private/etc) compare equal on both sides.
      const ruleAbs = resolveRulePath(rulePathRaw, cwd);
      if (resolvedPath === ruleAbs) return true;
      if (rule.prefix) {
        return resolvedPath.startsWith(ruleAbs.endsWith('/') ? ruleAbs : ruleAbs + '/');
      }
      return false;
    >>>

  fn name=evaluateFilePathRules params="tool:string, filePath:string, cwd:string, rules:PermissionRuleSet" returns="'allow'|'deny'|null" export=true
    doc "F3-hardened evaluation for file tools (Edit/Write/Read). Resolves the path (absolute + realpath, ../ and symlink safe) then matches on '/'-segment boundaries. deny wins. A bare tool rule (Edit/Write/Read) still matches any invocation."
    handler <<<
      const resolved = resolveRulePath(filePath, cwd);
      for (const rule of rules.deny) {
        if (pathRuleMatches(rule, tool, resolved, cwd)) return 'deny';
      }
      for (const rule of rules.allow) {
        if (pathRuleMatches(rule, tool, resolved, cwd)) return 'allow';
      }
      return null;
    >>>

  fn name=evaluateToolRules params="tool:string, arg:string, cwd:string, rules:PermissionRuleSet" returns="'allow'|'deny'|null" export=true
    doc "The security-correct gate consulted by every approval seam. Dispatches Bash (arg = the command) to evaluateBashRules (F2 compound splitting) and the file tools Edit/Write/Read (arg = the file_path) to evaluateFilePathRules (F3 path resolution). Any other tool uses the simple single-token matcher. deny ALWAYS wins; allow auto-approves; null falls through to the normal ask flow."
    handler <<<
      if (tool === 'Bash') return evaluateBashRules(arg, rules);
      if (tool === 'Edit' || tool === 'Write' || tool === 'Read') {
        return evaluateFilePathRules(tool, arg, cwd, rules);
      }
      return evaluatePermissionRules(tool, arg, rules);
    >>>
