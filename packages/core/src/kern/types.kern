type name=EngineMode values="exec|review|agent"
type name=TaskClass values="algorithm|refactor|bugfix|test|docs|feature|other"

interface name=EngineModeConfig
  field name=args type="string[]"
  field name=stdin type=boolean optional=true

interface name=ImageAttachment
  field name=path type=string
  field name=filename type=string
  field name=mimeType type=string

interface name=EngineModelConfig
  field name=configKey type=string optional=true
  field name=flag type=string optional=true
  field name=default type="string|null" optional=true

interface name=EngineEnvVar
  field name=required type=boolean optional=true
  field name=default type=string optional=true

interface name=EngineDefinition
  field name=schemaVersion type="1|2|3"
  field name=id type=string
  field name=displayName type=string
  field name=binary type=string
  field name=searchPaths type="string[]"
  field name=versionCmd type="string[]"
  field name=isLocal type=boolean
  field name=tier type="'builtin'|'user'"
  field name=installHint type=string optional=true
  field name=timeout type=number
  field name=exec type=EngineModeConfig optional=true
  field name=review type=EngineModeConfig optional=true
  field name=model type=EngineModelConfig optional=true
  field name=env type="Record<string,EngineEnvVar>" optional=true
  field name=test type="{args:string[]}" optional=true
  field name=modes type="EngineMode[]" optional=true
  field name=modelConfigKey type=string optional=true
  field name=adapterType type=string optional=true
  field name=capabilities type="string[]" optional=true
  field name=imageFlag type=string optional=true
  field name=agent type=EngineModeConfig optional=true
  field name=api type="{baseUrl:string, apiKeyEnv:string, model:string, maxTokens?:number}" optional=true

interface name=DispatchOptions
  field name=engine type=EngineDefinition
  field name=prompt type=string
  field name=cwd type=string
  field name=mode type=EngineMode
  field name=timeout type=number
  field name=outputDir type=string
  field name=signal type=AbortSignal optional=true
  field name=images type="ImageAttachment[]" optional=true

interface name=DispatchResult
  field name=exitCode type=number
  field name=stdout type=string
  field name=stderr type=string
  field name=durationMs type=number
  field name=timedOut type=boolean

interface name=AgentDispatchResult extends=DispatchResult
  field name=diff type=string
  field name=diffLines type=number
  field name=filesChanged type=number

interface name=EngineAdapter
  field name=dispatch type="(options:DispatchOptions)=>Promise<DispatchResult>"
  field name=dispatchStream type="(options:DispatchOptions)=>AsyncGenerator<string, DispatchResult, void>" optional=true
  field name=dispatchAgent type="(options:DispatchOptions)=>Promise<AgentDispatchResult>" optional=true
  field name=dispatchAgentStream type="(options:DispatchOptions)=>AsyncGenerator<string, AgentDispatchResult, void>" optional=true
  field name=isAvailable type="(engine:EngineDefinition)=>Promise<boolean>"
  field name=getVersion type="(engine:EngineDefinition)=>Promise<string|null>"

interface name=FitnessResult
  field name=pass type=boolean
  field name=diffLines type=number
  field name=filesChanged type=number
  field name=durationSec type=number
  field name=lintWarnings type=number
  field name=styleScore type=number
  field name=compositeScore type=number

interface name=ScoreWeights
  field name=pass type=number
  field name=quality type=number
  field name=diff type=number
  field name=files type=number
  field name=duration type=number

interface name=ScoreComponents
  field name=passScore type=number
  field name=qualityScore type=number
  field name=diffScore type=number
  field name=filesScore type=number
  field name=durationScore type=number
  field name=composite type=number

interface name=EloRating
  field name=rating type=number
  field name=wins type=number
  field name=losses type=number
  field name=draws type=number

interface name=EloRecord
  field name=global type="Record<string,EloRating>"
  field name=byTaskClass type="Record<string,Record<string,EloRating>>"
  field name=lastUpdated type=string

config name=AgonConfig
  field name=debug type=boolean default=false
  field name=timeout type=number default=360
  field name=forgeTimeout type=number default=600
  field name=forgeAutoAcceptScore type=number default=88
  field name=forgeClearWinnerSpread type=number default=8
  field name=forgeEnableSynthesis type=boolean default=true
  field name=forgeMaxCritiques type=number default=3
  field name=forgeStarterStrategy type="'fixed'|'rotate'" default="'fixed'"
  field name=forgeFixedStarter type=string default=claude
  field name=forgeRequireBaselineCheck type=boolean default=true
  field name=forgeEnabledEngines type="string[]" default="['claude','codex','gemini']"
  field name=forgeFitnessTimeout type=number default=120
  field name=forgeSynthesisTimeout type=number default=300
  field name=eloEnabled type=boolean default=true
  field name=eloKFactor type=number default=32
  field name=contextSummary type=boolean default=true
  field name=onboarded type=boolean default=false
  field name=projectContext type=string default=""
  field name=contextFormat type="'plain'|'kern'" default=plain
  field name=approvalLevel type="'auto'|'plan'|'step'" default=plan
  field name=agentTimeout type=number default=600
  field name=agentPermissionLevel type="'full'|'plan'|'read-only'" default=full
  field name=cesarEnabled type=boolean default=true
  field name=cesarScoutCount type=number default=2
  field name=cesarDirectThreshold type=number default=85
  field name=cesarDisagreementSpread type=number default=20
  field name=campfireObserverStrategy type="'lead-first'|'all-respond'" default=lead-first

interface name=ScoutBid
  field name=engineId type=string
  field name=confidence type=number
  field name=approach type=string
  field name=steps type="string[]"
  field name=keyFiles type="string[]"
  field name=risk type="'low'|'medium'|'high'"
  field name=needsCompetition type=boolean

interface name=RoutingDecision
  field name=action type="'chat'|'build'|'pipeline'|'campfire'|'forge'"
  field name=leadEngine type=string
  field name=confidence type=number
  field name=reasoning type=string
  field name=seedPlan type=string optional=true
  field name=observerEngines type="string[]"
  field name=forgeEngines type="string[]" optional=true
  field name=bids type="ScoutBid[]"

interface name=CampfireMessage
  field name=engineId type=string
  field name=content type=string
  field name=isLead type=boolean

interface name=ForgeOptions
  field name=task type=string
  field name=fitnessCmd type=string
  field name=cwd type=string
  field name=forgeDir type=string
  field name=context type=string optional=true
  field name=seedPlan type=string optional=true
  field name=timeout type=number optional=true
  field name=fitnessTimeout type=number optional=true
  field name=starter type=string optional=true
  field name=engines type="string[]" optional=true
  field name=dryRun type=boolean optional=true
  field name=signal type=AbortSignal optional=true

interface name=EngineResult
  field name=engineId type=string
  field name=pass type=boolean
  field name=score type=number
  field name=diffLines type=number
  field name=filesChanged type=number
  field name=durationSec type=number
  field name=lintWarnings type=number
  field name=styleScore type=number
  field name=patchPath type=string optional=true
  field name=worktreePath type=string optional=true

interface name=ForgeManifest
  field name=forgeId type=string
  field name=forgeDir type=string
  field name=task type=string
  field name=fitnessCmd type=string
  field name=timestamp type=string
  field name=engines type="string[]"
  field name=results type="Record<string,EngineResult>"
  field name=patches type="Record<string,string>"
  field name=winner type="string|null"
  field name=closeCall type=boolean
  field name=stage1Accepted type=boolean
  field name=baselinePasses type=boolean
  field name=starter type=string
  field name=enginesDispatched type=number
  field name=synthesis type="{pass:boolean,score:number,wins:boolean,patchPath:string,originalWinnerScore:number}" optional=true

event name=ForgeEvent
  type name="baseline:start"
  type name="baseline:done" data="{ passes: boolean }"
  type name="stage1:start"
  type name="stage1:dispatch" data="{ engineId: string }"
  type name="stage1:score" data="{ engineId: string }"
  type name="stage1:accepted" data="{ engineId: string, score: number }"
  type name="stage2:start"
  type name="stage2:dispatch" data="{ engineId: string }"
  type name="stage2:score" data="{ engineId: string }"
  type name="stage2:done"
  type name="winner:determined" data="{ winner: string, bestScore: number }"
  type name="synthesis:start"
  type name="synthesis:critique" data="{ engineId: string }"
  type name="synthesis:refine"
  type name="synthesis:score" data="{ score: number }"
  type name="synthesis:done"
  type name="elo:update"
  type name="forge:done"

interface name=BrainstormBid
  field name=engineId type=string
  field name=confidence type=number
  field name=reasoning type=string
  field name=approach type=string

interface name=BrainstormResult
  field name=question type=string
  field name=bids type="BrainstormBid[]"
  field name=winner type=string
  field name=response type=string

interface name=Critique
  field name=file type=string
  field name=lines type=string
  field name=problem type=string
  field name=minimalFix type=string

const name=DEFAULT_CONFIG type="Required<AgonConfig>" value=DEFAULT_AGON_CONFIG
