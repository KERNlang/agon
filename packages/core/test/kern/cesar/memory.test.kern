test name="Cesar memory — project memory block" target="../../../src/kern/cesar/memory.kern"
  it name="memory source stays valid KERN"
    expect no=schemaViolations
    expect no=semanticViolations
    expect no=codegenErrors

  it name="project-memory helpers keep their shape (behavior pinned in tests/unit/save-memory-tool.test.ts)"
    expect node=fn name=extractProjectMemorySections prop=returns is=string
    expect node=fn name=stripProjectMemorySections prop=returns is=string
    expect node=fn name=buildProjectMemoryBlock prop=returns is=string
    expect node=const name=PROJECT_MEMORY_SECTIONS prop=type is="string[]"
