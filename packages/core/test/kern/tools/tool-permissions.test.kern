test name="Core tool permissions" target="../../../src/kern/tools/tool-permissions.kern"
  it name="permission source stays valid KERN"
    expect no=schemaViolations
    expect no=semanticViolations
    expect no=codegenErrors

  it name="command classifiers keep safety boundaries"
    expect node=const name=DANGEROUS_COMMANDS prop=type is="string[]"
    expect node=const name=DANGEROUS_PREFIXES prop=type is="string[]"
    expect node=fn name=isDangerousCommand prop=returns is=boolean
    expect node=fn name=isReadOnlyCommand prop=returns is=boolean
    expect fn=isDangerousCommand args={{["rm -rf /"]}} equals=true
    expect fn=isDangerousCommand args={{["sudo rm file"]}} equals=true
    expect fn=isDangerousCommand args={{["ls -la"]}} equals=false
    expect fn=isDangerousCommand args={{["npm test"]}} equals=false
    expect fn=isReadOnlyCommand args={{["ls -la"]}} equals=true
    expect fn=isReadOnlyCommand args={{["git status"]}} equals=true
    expect fn=isReadOnlyCommand args={{["npm test"]}} equals=true
    expect fn=isReadOnlyCommand args={{["npm install"]}} equals=false
    expect fn=isReadOnlyCommand args={{["rm file.txt"]}} equals=false
    expect fn=isReadOnlyCommand args={{["cat file.txt | grep pattern"]}} equals=true
    expect fn=isReadOnlyCommand args={{['agon config --help 2>/dev/null && echo "---" && agon config list 2>/dev/null']}} equals=true
    expect fn=isReadOnlyCommand args={{["npm install express"]}} equals=false

  it name="shell cleanup helpers normalize command text"
    expect fn=stripShellRedirections args={{["cat file.txt > out.txt"]}} equals="cat file.txt"
    expect fn=stripShellWrappers args={{["timeout --preserve-status npm test"]}} equals="npm test"
    expect fn=extractBaseCommand args={{["timeout --preserve-status npm test"]}} equals="npm"
    expect node=fn name=stripShellWrappers prop=returns is=string
    expect node=fn name=extractBaseCommand prop=returns is=string

  // The standalone checkBashPermission / checkFileReadPermission /
  // checkFileWritePermission were proven dead (no execution path called them —
  // executeToolCall uses each tool's inline checkPermission) and were deleted.
  // The inline tool factories live in tool-bash/tool-read/tool-write.kern and
  // are not in this file's expr scope, so equivalent deny/allow/ask coverage
  // now lives in tests/unit/permission-rules.test.ts (inline-gate chokepoint
  // tests via createBashTool()/createReadTool()/createWriteTool()).

  it name="path-under-cwd gate stays declared in KERN"
    expect node=fn name=isPathUnderCwd prop=returns is=boolean

  it name="CC-parity rule engine functions stay declared in KERN"
    expect node=fn name=parsePermissionRule prop=returns is="ParsedPermissionRule|null"
    expect node=fn name=parsePermissionRuleSet prop=returns is=PermissionRuleSet
    expect node=fn name=ruleMatches prop=returns is=boolean
    expect node=fn name=evaluatePermissionRules prop=returns is="'allow'|'deny'|null"

  it name="rule parsing splits tool, command and prefix flag"
    expect expr={{parsePermissionRule("Bash(npm test:*)")?.tool}} equals="Bash"
    expect expr={{parsePermissionRule("Bash(npm test:*)")?.command}} equals="npm test"
    expect expr={{parsePermissionRule("Bash(npm test:*)")?.prefix}} equals=true
    expect expr={{parsePermissionRule("Bash(git diff)")?.command}} equals="git diff"
    expect expr={{parsePermissionRule("Bash(git diff)")?.prefix}} equals=false
    expect expr={{parsePermissionRule("Edit")?.tool}} equals="Edit"
    expect expr={{parsePermissionRule("Edit")?.command}} equals={{undefined}}
    expect expr={{parsePermissionRule("Edit")?.prefix}} equals=false
    expect expr={{parsePermissionRule("Write")?.tool}} equals="Write"

  it name="malformed rule strings are ignored, not crashed"
    expect expr={{parsePermissionRule("")}} equals={{null}}
    expect expr={{parsePermissionRule("   ")}} equals={{null}}
    expect expr={{parsePermissionRule(42)}} equals={{null}}
    expect expr={{parsePermissionRule(null)}} equals={{null}}
    expect expr={{parsePermissionRule("Bash(:*)")}} equals={{null}}
    expect expr={{parsePermissionRule("two words here")}} equals={{null}}

  it name="bash prefix matching respects word boundaries"
    fixture name=npmTestRule value={{({ tool: "Bash", command: "npm test", prefix: true })}}
    expect expr={{ruleMatches(npmTestRule, "Bash", "npm test")}} equals=true
    expect expr={{ruleMatches(npmTestRule, "Bash", "npm test -- --filter x")}} equals=true
    expect expr={{ruleMatches(npmTestRule, "Bash", "npm testify")}} equals=false
    expect expr={{ruleMatches(npmTestRule, "Bash", "npm tes")}} equals=false
    expect expr={{ruleMatches(npmTestRule, "Edit", "npm test")}} equals=false

  it name="tool-level rules match any invocation"
    fixture name=editRule value={{({ tool: "Edit", prefix: false })}}
    expect expr={{ruleMatches(editRule, "Edit", "/any/path.ts")}} equals=true
    expect expr={{ruleMatches(editRule, "Edit", "")}} equals=true
    expect expr={{ruleMatches(editRule, "Write", "/any/path.ts")}} equals=false

  it name="precedence: deny beats allow, both beat ask-fallthrough"
    fixture name=ruleSet value={{({ allow: [{ tool: "Bash", command: "npm test", prefix: true }, { tool: "Edit", prefix: false }], deny: [{ tool: "Bash", command: "npm test", prefix: true }, { tool: "Write", prefix: false }, { tool: "Bash", command: "rm", prefix: true }] })}}
    expect expr={{evaluatePermissionRules("Bash", "npm test -- x", ruleSet)}} equals="deny"
    expect expr={{evaluatePermissionRules("Bash", "rm -rf node_modules", ruleSet)}} equals="deny"
    expect expr={{evaluatePermissionRules("Write", "/x/y.ts", ruleSet)}} equals="deny"
    expect expr={{evaluatePermissionRules("Edit", "/x/y.ts", ruleSet)}} equals="allow"
    expect expr={{evaluatePermissionRules("Bash", "git status", ruleSet)}} equals={{null}}
    expect expr={{evaluatePermissionRules("Read", "/x/y.ts", ruleSet)}} equals={{null}}
