{
  "name": "@kernlang/agon-forge",
  "version": "0.2.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "kern:compile": "node ../../scripts/run-kern-compile.mjs src/kern/ src/generated/ --target=auto --recursive",
    "prebuild": "npm run kern:compile",
    "build": "tsup && tsc -b tsconfig.json --force",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@kernlang/agon-core": "*",
    "@kernlang/protocol": "~4.0.0"
  },
  "optionalDependencies": {}
}
