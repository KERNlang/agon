import from="@kernlang/agon-core" names="EngineRegistry,EngineAdapter,DispatchResult" types=true
import from="@kernlang/agon-core" names="resolveWorkingDir"

interface name=DelegateResult export=true
  field name=engineId type=string
  field name=response type=string
  field name=usage type="DispatchResult['usage']" optional=true

fn name=runDelegate async=true params="opts:{engineId:string,task:string,mode?:string,cwd?:string,registry:EngineRegistry,adapter:EngineAdapter,timeout:number,outputDir:string,signal?:AbortSignal}" returns="Promise<DelegateResult>" export=true
  handler lang="kern"
    let name=engine value="opts.registry.get(opts.engineId)"
    comment raw="// cwd pins the dispatch directory. Callers inside a goal worktree (judge adjudication, route escalation) MUST pass opts.cwd=<worktree> so the engine never runs in — or writes to — the parent repo; defaults to resolveWorkingDir() for top-level callers."
    let name=result value="await opts.adapter.dispatch({ engine, prompt: opts.task, cwd: opts.cwd ?? resolveWorkingDir(), mode: (opts.mode ?? 'exec') as any, timeout: opts.timeout, outputDir: opts.outputDir, signal: opts.signal, })"
    if cond="!result.stdout.trim()"
      return value="{ engineId: opts.engineId, response: '', usage: result.usage }"
    comment raw="// Strip <think> blocks"
    let name=cleaned value="result.stdout.trim().replace(/<think>[\\s\\S]*?<\\/think>\\s*/gi, '').trim()"
    return value="{ engineId: opts.engineId, response: cleaned, usage: result.usage }"
