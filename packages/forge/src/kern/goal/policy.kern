// ── agon goal — controller policy (pure decision logic) ────────────────
// The risky judgement calls — when to park a task, when to abort the whole
// run, whether budget/time is blown, and how to fingerprint a gate failure
// for oscillation detection — are pulled out of the orchestration shell so
// they can be unit-tested without spinning real git worktrees. The
// controller is a thin loop around these; these are where the bugs hide.
// See AGON-GOAL-DESIGN.md rails 5 (park, don't grind) and 6 (budgets).

import from="node:crypto" names="createHash"
import from="./types.js" names="JournalState,GoalTask" types=true

fn name=gateFailureSignature params="output:string" returns=string export=true
  doc "Stable, volatility-stripped fingerprint of a gate failure. Normalizes away hex shas, durations, line:col numbers and absolute paths so the SAME logical failure hashes identically across runs — that identity is what the oscillation breaker keys on. Hashes the tail (where the real error usually is)."
  handler <<<
    const norm = (output || '')
      .replace(/\x1b\[[0-9;]*m/g, '')
      .replace(/\b[0-9a-f]{7,40}\b/gi, '<hex>')
      .replace(/\b\d+(?:\.\d+)?\s*(?:ms|s|m|h)\b/g, '<dur>')
      .replace(/:\d+:\d+/g, ':<n>:<n>')
      .replace(/\/[^\s:'"]+/g, '<path>')
      .replace(/\d+/g, '<n>')
      .replace(/\s+/g, ' ')
      .trim();
    const tail = norm.slice(-2000);
    return createHash('sha256').update(tail).digest('hex').slice(0, 16);
  >>>

fn name=taskParkDecision params="task:GoalTask, maxAttempts:number" returns="{park:boolean, reason:string}" export=true
  doc "Park a task when it has burned its attempts OR is oscillating — the same gate-failure signature recurring means the agent keeps producing the same broken fix, so more attempts only waste budget."
  handler <<<
    // Guard against a NaN / non-positive cap (which would make every >= compare
    // false and grind a task forever) by collapsing it to 1.
    const cap = Number.isFinite(maxAttempts) && maxAttempts >= 1 ? Math.floor(maxAttempts) : 1;
    if (task.attempts >= cap) {
      return { park: true, reason: `max-attempts (${cap})` };
    }
    const seen = new Set<string>();
    for (const a of task.attemptLog) {
      const sig = a.gateFailureSignature;
      if (!sig) continue;
      if (seen.has(sig)) return { park: true, reason: 'oscillation: repeated gate-failure signature' };
      seen.add(sig);
    }
    return { park: false, reason: '' };
  >>>

fn name=pushRecentOutcome params="recent:string[], outcome:string, cap:number" returns="string[]" export=true
  doc "Append a TERMINAL task outcome ('done' | 'parked') to the bounded ring that fuels the sliding-window breaker, dropping the oldest entries beyond `cap` (cap <= 0 = unbounded). Pure: the controller calls this once per task that reaches a terminal state."
  handler <<<
    const next = [...recent, outcome];
    if (cap > 0 && next.length > cap) {
      return next.slice(-cap);
    }
    return next;
  >>>

fn name=globalBreaker params="state:JournalState, maxParkStreak:number, maxNoProgress:number, window?:{size:number, minSuccessRate:number}" returns="{stop:boolean, reason:string}" export=true
  doc "Abort the whole run only when it is genuinely thrashing — NOT when it merely hit a cluster of hard tasks. The PRIMARY long-run signal is the sliding-window success rate (`window`): over the last `window.size` terminal outcomes, if the fraction that are 'done' is below `window.minSuccessRate`, the gate/env is likely broken or the queue is uniformly too hard, so stop. The legacy consecutive park-streak (`maxParkStreak`) is kept only as an opt-in hard cap (0 = off, the new default) because a park DECREASES remaining work, so it never trips the no-progress breaker on its own. `maxNoProgress` still catches retry-thrash with no net progress."
  handler <<<
    const recent = state.recentOutcomes ?? [];
    if (window && window.size > 0 && recent.length >= window.size) {
      const windowEntries = recent.slice(-window.size);
      const successRate = windowEntries.filter(o => o === 'done').length / window.size;
      if (successRate < window.minSuccessRate) {
        return { stop: true, reason: `success-rate ${(successRate * 100).toFixed(0)}% < ${(window.minSuccessRate * 100).toFixed(0)}% over last ${window.size} tasks` };
      }
    }
    if (maxParkStreak > 0 && state.parkedStreak >= maxParkStreak) {
      return { stop: true, reason: `park-streak >= ${maxParkStreak}` };
    }
    if (maxNoProgress > 0 && state.noProgressStreak >= maxNoProgress) {
      return { stop: true, reason: `no-progress-streak >= ${maxNoProgress}` };
    }
    return { stop: false, reason: '' };
  >>>

fn name=pickImplementWinner params="forgeWinner:string, candidates:Array<{engine:string,pass:boolean,score:number,addsTest:boolean}>, requireTests:boolean, isFix:boolean" returns=string export=true
  doc "Constraint-aware winner pick for the goal loop. Forge scores by fitness alone, so it can crown a higher-scoring patch that adds NO test while lower-scoring PASSING patches include one — the witness then parks it and the whole panel is wasted. When requireTests is on and this is not a fix pass, if the forge winner adds no test, return the highest-scoring PASSING candidate that DOES add a test; otherwise keep forge's winner (the witness will park it, correctly). Pure: the caller resolves each candidate's addsTest by inspecting its patch."
  handler <<<
    if (isFix || !requireTests) return forgeWinner;
    const w = candidates.find((c) => c.engine === forgeWinner);
    if (w && w.addsTest) return forgeWinner;
    const withTest = candidates
      .filter((c) => c.pass && c.addsTest)
      .slice()
      .sort((a, b) => b.score - a.score);
    return withTest.length > 0 ? withTest[0].engine : forgeWinner;
  >>>

fn name=chooseImplementRoster params="params:{flow:string, forgeScope:string, escalationHint:string, estimatedCostUsd:number, allEngines:string[], soloEngine:string, escalateThresholdUsd:number}" returns="{engines:string[], solo:boolean, escalate:boolean, reason:string}" export=true
  doc "Cesar-style per-task implement roster: route a trivial gap to a single engine (cheap/fast) and a real feature to the full competitive panel. Pure mapping of Cesar's routing hints. solo when forgeScope is 'none' or the flow is quick-fix/answer/bug-fix or the escalationHint is self/delegate (and a soloEngine exists); otherwise compete with allEngines. escalate flags big/expensive tasks (forgeScope 'full', flow 'forge-full', or estimatedCostUsd over a positive threshold) so the caller can ask an LLM to confirm/adjust the roster. The all-engine REVIEW is unaffected — this only shapes IMPLEMENT."
  handler <<<
    const { flow, forgeScope, escalationHint, estimatedCostUsd, allEngines, soloEngine, escalateThresholdUsd } = params;
    const roster = allEngines.length > 0 ? allEngines : (soloEngine ? [soloEngine] : []);
    const soloFlows = ['quick-fix', 'answer', 'bug-fix'];
    const wantSolo = forgeScope === 'none' || soloFlows.includes(flow) || escalationHint === 'self' || escalationHint === 'delegate';
    const solo = wantSolo && !!soloEngine;
    const engines = solo ? [soloEngine] : roster;
    const escalate = forgeScope === 'full' || flow === 'forge-full' || (escalateThresholdUsd > 0 && estimatedCostUsd >= escalateThresholdUsd);
    const reason = solo
      ? `solo ${soloEngine} (${flow}/${forgeScope})`
      : `compete ${engines.length} engines (${flow}/${forgeScope})${escalate ? ' — escalate' : ''}`;
    return { engines, solo, escalate, reason };
  >>>

fn name=budgetExceeded params="state:JournalState" returns=boolean export=true
  doc "True once cumulative spend reaches the goal's USD ceiling (0 = unlimited)."
  handler <<<
    const cap = state.spec.budgetUsd;
    return cap > 0 && state.spentUsd >= cap;
  >>>

fn name=timeExceeded params="state:JournalState, now:number" returns=boolean export=true
  doc "True once wall-clock since startedAt reaches the goal's hour ceiling (0 = unlimited)."
  handler <<<
    if (!state.startedAt) return false;
    const cap = state.spec.maxHours;
    return cap > 0 && (now - state.startedAt) >= cap * 3_600_000;
  >>>
