// ── Seat dispatch with one auto-retry + loud panel health ──────────────
// Field failure this fixes: "I dispatch 6 engines, codex times out in round 1,
// zai parse-fails — and the run quietly completes as 3/4." One retry per failed
// seat (shorter timeout) fixes most transient flake; whatever still fails must
// be REPORTED, not silently folded into a smaller committee. Every panel mode
// (brainstorm/tribunal/council) dispatches seats through here.

import from="@kernlang/agon-core" names="EngineAdapter,DispatchResult" types=true
import from="@kernlang/agon-core" names="authFailureHint"

interface name=SeatOutcome export=true
  field name=engineId type=string
  field name=ok type=boolean
  field name=text type=string
  field name=attempts type=number
  field name=failure type="'timeout' | 'empty' | 'error' | null"
  field name=note type="string | null"
  field name=detail type="string | null"

const name=RETRY_MIN_TIMEOUT_SEC type=number value=30

fn name=classifySeatFailure params="result:DispatchResult" returns="'timeout' | 'empty' | 'error' | null" export=true
  doc "null = usable response. timeout/empty/error are the transient-shaped failures worth one retry."
  handler <<<
    if (result.timedOut) return 'timeout';
    if (result.exitCode !== 0) return 'error';
    if (!String(result.stdout ?? '').trim()) return 'empty';
    return null;
  >>>

fn name=dispatchSeatWithRetry async=true params="adapter:EngineAdapter, opts:{engineId:string, engine:any, prompt:string, systemPrompt?:string, cwd:string, mode:string, timeout:number, outputDir:string, signal?:AbortSignal, extract?:(result:DispatchResult)=>string}" returns="Promise<SeatOutcome>" export=true
  doc "Dispatch one panel seat; on a transient failure (timeout/empty/error) retry ONCE with ~half the timeout (never longer than the first attempt). Never retries a user abort. opts.extract lets a mode keep its own text-extraction (e.g. tribunal's <think> salvage) — an extract throw counts as an 'empty' failure. The outcome note feeds the panel-health banner; detail preserves the underlying stderr/message so diagnosability survives the categorization."
  handler <<<
    const attemptOnce = async (timeoutSec: number): Promise<{ failure: 'timeout' | 'empty' | 'error' | null; text: string; detail: string; auth: boolean }> => {
      try {
        const result = await adapter.dispatch({
          engine: opts.engine,
          prompt: opts.prompt,
          systemPrompt: opts.systemPrompt,
          cwd: opts.cwd,
          mode: opts.mode,
          timeout: timeoutSec,
          outputDir: opts.outputDir,
          signal: opts.signal,
        } as any);
        const failure = classifySeatFailure(result);
        if (failure) {
          // A 401 seat carries the exact recovery command (e.g. `agon login codex --force`) in its
          // panel-health note instead of raw stderr — so `agon review`/brainstorm/tribunal no longer
          // print an unexplained "API Error: 401". Non-auth failures keep their own detail (null hint).
          const authHint = authFailureHint(opts.engine, { stderr: result.stderr, exitCode: result.exitCode, timedOut: result.timedOut });
          const detail = result.timedOut
            ? `timed out after ${timeoutSec}s`
            : (authHint ?? (String(result.stderr ?? '').trim().slice(0, 240) || (failure === 'empty' ? 'empty response (no visible output)' : `exit ${result.exitCode}`)));
          return { failure, text: '', detail, auth: !!authHint };
        }
        if (!opts.extract) return { failure: null, text: String(result.stdout ?? ''), detail: '', auth: false };
        try {
          return { failure: null, text: opts.extract(result), detail: '', auth: false };
        } catch (err) {
          return { failure: 'empty', text: '', detail: err instanceof Error ? err.message : String(err), auth: false };
        }
      } catch (err) {
        const msg = err instanceof Error ? err.message : String(err);
        const authHint = authFailureHint(opts.engine, { errorMessage: msg });
        return { failure: 'error', text: '', detail: authHint ?? msg, auth: !!authHint };
      }
    };

    // Already aborted? Don't burn a dispatch at all.
    if (opts.signal?.aborted) {
      return { engineId: opts.engineId, ok: false, text: '', attempts: 0, failure: 'error', note: `${opts.engineId} aborted`, detail: 'aborted before dispatch' };
    }

    const first = await attemptOnce(opts.timeout);
    if (!first.failure) {
      return { engineId: opts.engineId, ok: true, text: first.text, attempts: 1, failure: null, note: null, detail: null };
    }
    // A user abort is a decision, not flake — respect it immediately.
    if (opts.signal?.aborted) {
      return { engineId: opts.engineId, ok: false, text: '', attempts: 1, failure: first.failure, note: `${opts.engineId} aborted`, detail: first.detail };
    }
    // An AUTH failure (401 / invalid key / expired token) can NOT recover by retrying — surface the
    // exact credential fix on the first attempt instead of burning a second doomed dispatch (~30s+).
    if (first.auth) {
      return { engineId: opts.engineId, ok: false, text: '', attempts: 1, failure: first.failure, note: `${opts.engineId} auth failed — ${first.detail}`, detail: first.detail };
    }
    // Half the original wall clock, floored at 30s, but NEVER longer than the
    // first attempt — for sub-60s callers a "retry" must not raise the budget.
    const retryTimeout = Math.min(opts.timeout, Math.max(RETRY_MIN_TIMEOUT_SEC, Math.floor(opts.timeout / 2)));
    const second = await attemptOnce(retryTimeout);
    if (!second.failure) {
      return { engineId: opts.engineId, ok: true, text: second.text, attempts: 2, failure: null, note: `${opts.engineId} ${first.failure} → retried OK`, detail: first.detail };
    }
    return { engineId: opts.engineId, ok: false, text: '', attempts: 2, failure: second.failure, note: `${opts.engineId} ${first.failure} → retry ${second.failure}, dropped`, detail: `${first.detail}${second.detail && second.detail !== first.detail ? ` | retry: ${second.detail}` : ''}` };
  >>>

fn name=buildPanelHealth params="outcomes:SeatOutcome[]" returns="{ requested: number; responded: number; degraded: boolean; notes: string[]; banner: string | null }" export=true
  doc "Fold seat outcomes into the structured panel-health record + the one-line banner every surface must print when degraded ('panel degraded: codex timeout → retried OK; zai empty → dropped (5/6 responded)')."
  handler <<<
    const requested = outcomes.length;
    const responded = outcomes.filter((o) => o.ok).length;
    const notes = outcomes.map((o) => o.note).filter((n): n is string => !!n);
    const degraded = responded < requested;
    const banner = notes.length === 0
      ? null
      : `panel ${degraded ? 'degraded' : 'recovered'}: ${notes.join('; ')} (${responded}/${requested} responded)`;
    return { requested, responded, degraded, notes, banner };
  >>>
