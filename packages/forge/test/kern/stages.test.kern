test name="Forge stage contracts" target="../../src/kern/stages.kern"
  it name="stage source stays valid KERN"
    expect no=schemaViolations
    expect no=semanticViolations
    expect no=codegenErrors

  it name="dispatch failure results stay deterministic"
    expect fn=makeFailedResult args={{["codex", "dispatch failed", 1250]}} equals={{ { engineId: "codex", pass: false, score: 0, diffLines: 0, filesChanged: 0, durationSec: 1, lintWarnings: 0, styleScore: 0, dispatchStdout: "ERROR: dispatch failed" } }}

  it name="stage orchestration keeps typed public shape"
    expect node=fn name=formatDispatchError prop=returns is=string
    expect node=fn name=runStage1 prop=returns is="Promise<StageResult>"
    expect node=fn name=runStage2 prop=returns is="Promise<StageResult>"
