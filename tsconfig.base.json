{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@agon/core": ["packages/core/src/index.ts"],
      "@agon/forge": ["packages/forge/src/index.ts"],
      "@agon/adapter-cli": ["packages/adapter-cli/src/index.ts"],
      "@agon/mcp": ["packages/mcp/src/index.ts"],
      "@agon/kern-engines": ["kern_engines/index.ts"],
      "@agon/kern-engines/cli/claude": ["kern_engines/cli/claude.ts"]
    },
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "outDir": "dist",
    "rootDir": "src"
  }
}
