{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@kernlang/agon-core": ["packages/core/src/index.ts"],
      "@kernlang/agon-forge": ["packages/forge/src/index.ts"],
      "@kernlang/agon-adapter-cli": ["packages/adapter-cli/src/index.ts"],
      "@kernlang/agon-mcp": ["packages/mcp/src/index.ts"]
    },
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "outDir": "dist",
    "rootDir": "src"
  }
}
